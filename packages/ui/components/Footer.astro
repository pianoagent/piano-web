---
/**
 * Footer — Piano (tmavý, vícesloupcový). Prop-driven, per-web data.
 * Bez props se chová jako dřív (Piano default z config/nav).
 */
import Icon from './Icon.astro';
import { companyNav, legalNav, socialLinks, contact as defaultContact, products } from '../config/nav';
import type { NavLink } from '../config/nav';

interface ContactItem { label?: string; value: string; href?: string; }
interface FooterColumn { heading: string; links: NavLink[]; }
interface Social { label: string; href: string; icon: string; }

interface Props {
  brand?: string;
  logoSrc?: string;
  logoAlt?: string;                        // alt textu loga (default = brand); pro "by Piano" lockup
  homeHref?: string;
  mark?: boolean;                          // zobrazit piano-mark ikonu (default true)
  tagline?: string;
  parentNote?: { text: string; href: string };  // "<produkt> je součástí skupiny Piano"
  columns?: FooterColumn[];
  offices?: { heading?: string; items: ContactItem[] };  // textový sloupec s adresami poboček
  contact?: { heading?: string; items: ContactItem[] };
  social?: Social[];
  legal?: NavLink[];
  copyright?: string;
}

const year = new Date().getFullYear();

const defaultColumns: FooterColumn[] = [
  { heading: 'Produkty', links: products },
  { heading: 'Společnost', links: companyNav },
];
const defaultContactBlock = {
  heading: 'Kontakt',
  items: [
    { value: defaultContact.company },
    { value: defaultContact.address },
    { value: defaultContact.phone, href: `tel:${defaultContact.phone.replace(/\s/g, '')}` },
    { value: defaultContact.email, href: `mailto:${defaultContact.email}` },
    { label: 'IČ', value: defaultContact.ic },
    { label: 'DIČ', value: defaultContact.dic },
  ] as ContactItem[],
};

const {
  brand = 'Piano',
  logoSrc,
  logoAlt,
  homeHref = '/',
  mark = true,
  tagline = 'Technologie pro restaurace a hotely — pokladny, rezervace, platby a analytika na jednom místě.',
  parentNote,
  columns = defaultColumns,
  offices,
  contact = defaultContactBlock,
  social = socialLinks,
  legal = legalNav,
  copyright = `© ${year} Piano Solutions s.r.o.`,
} = Astro.props;

const hasOffices = !!(offices && offices.items.length > 0);

// Mřížka: brand + N sloupců odkazů + kontakt (přes proměnnou, ať média dotazy přebijí)
const topStyle = `--footer-cols: ${columns.length + (hasOffices ? 1 : 0) + 1};`;
---

<footer class="footer">
  <div class="footer__inner">
    <div class="footer__top" style={topStyle}>
      <!-- Brand -->
      <div class="footer__brand">
        <a href={homeHref} class="footer__logo" aria-label={`${brand} — domů`}>
          {logoSrc ? (
            <img class="footer__logo-img" src={logoSrc} alt={logoAlt ?? brand} />
          ) : (
            <>
              {mark && <Icon name="piano-mark" size="md" />}
              <span class="footer__wordmark">{brand}</span>
            </>
          )}
        </a>
        {tagline && <p class="footer__tagline">{tagline}</p>}
        {parentNote && (
          <p class="footer__parent">
            <a href={parentNote.href} class="footer__parent-link" target="_blank" rel="noopener">{parentNote.text} →</a>
          </p>
        )}
        {social.length > 0 && (
          <ul class="footer__social" aria-label="Sociální sítě">
            {social.map((s) => (
              <li>
                <a href={s.href} class="footer__social-link" aria-label={s.label} target="_blank" rel="noopener">
                  <Icon name={s.icon} size="sm" />
                </a>
              </li>
            ))}
          </ul>
        )}
      </div>

      <!-- Sloupce odkazů -->
      {columns.map((col) => (
        <nav class="footer__col" aria-label={col.heading}>
          <h2 class="footer__heading">{col.heading}</h2>
          <ul class="footer__list">
            {col.links.map((l) => (
              <li><a href={l.href} class="footer__link" target={l.external ? '_blank' : undefined} rel={l.external ? 'noopener noreferrer' : undefined}>{l.label}</a></li>
            ))}
          </ul>
        </nav>
      ))}

      <!-- Pobočky (textový sloupec) -->
      {hasOffices && (
        <div class="footer__col">
          <h2 class="footer__heading">{offices!.heading ?? 'Pobočky'}</h2>
          <ul class="footer__list">
            {offices!.items.map((o) => (
              <li><span class="footer__muted">{o.label ? `${o.label}: ` : ''}{o.value}</span></li>
            ))}
          </ul>
        </div>
      )}

      <!-- Kontakt -->
      <div class="footer__col">
        <h2 class="footer__heading">{contact.heading ?? 'Kontakt'}</h2>
        <ul class="footer__list">
          {contact.items.map((it) => (
            <li>
              {it.href
                ? <a href={it.href} class="footer__link">{it.label ? `${it.label}: ` : ''}{it.value}</a>
                : <span class="footer__muted">{it.label ? `${it.label}: ` : ''}{it.value}</span>}
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Spodní lišta -->
    <div class="footer__bottom">
      <p class="footer__copy">{copyright}</p>
      <ul class="footer__legal">
        {legal.map((l) => (
          <li><a href={l.href} class="footer__link footer__link--small">{l.label}</a></li>
        ))}
      </ul>
    </div>
  </div>
</footer>

<style>
  .footer { background: var(--color-neutral-900); color: var(--color-text-on-dark); }
  .footer__inner { max-width: var(--container-max); margin: 0 auto; padding: var(--space-8) var(--container-pad) var(--space-5); }

  .footer__top {
    display: grid;
    grid-template-columns: 2fr repeat(var(--footer-cols, 3), minmax(0, 1fr));
    gap: var(--space-7);
    padding-bottom: var(--space-7);
    border-bottom: 1px solid var(--color-border-on-dark);
  }

  /* Brand */
  .footer__logo { display: inline-flex; align-items: center; gap: var(--space-2); color: var(--color-text-on-dark); text-decoration: none; }
  .footer__logo-img { height: 42px; width: auto; display: block; filter: brightness(0) invert(1); }
  .footer__wordmark { font-family: var(--font-sans); font-weight: var(--font-weight-semibold); font-size: 22px; letter-spacing: var(--letter-spacing-tight); }
  .footer__tagline { margin-top: var(--space-3); max-width: 320px; font-size: var(--font-size-small); line-height: var(--line-height-body); color: var(--color-text-on-dark-muted); }
  .footer__parent { margin-top: var(--space-3); }
  .footer__parent-link { color: var(--color-primary); font-size: var(--font-size-small); font-weight: var(--font-weight-medium); text-decoration: none; }
  .footer__parent-link:hover { text-decoration: underline; }
  .footer__social { display: flex; gap: var(--space-2); list-style: none; margin-top: var(--space-5); }
  .footer__social-link { display: inline-flex; align-items: center; justify-content: center; width: 36px; height: 36px; color: var(--color-text-on-dark); border: 1px solid var(--color-border-on-dark); border-radius: var(--radius-sm); transition: var(--transition); }
  .footer__social-link:hover { background: var(--color-primary); border-color: var(--color-primary); }

  /* Sloupce */
  .footer__heading { font-family: var(--font-sans); font-size: var(--font-size-label); font-weight: var(--font-weight-semibold); text-transform: uppercase; letter-spacing: var(--letter-spacing-wide); color: var(--color-text-on-dark-muted); margin-bottom: var(--space-4); }
  .footer__list { list-style: none; display: flex; flex-direction: column; gap: var(--space-3); }
  .footer__link { color: var(--color-text-on-dark); text-decoration: none; font-size: var(--font-size-body); transition: var(--transition); }
  .footer__link:hover { color: var(--color-primary); }
  .footer__link--small { font-size: var(--font-size-small); }
  .footer__muted { color: var(--color-text-on-dark-muted); font-size: var(--font-size-body); }

  /* Spodní lišta */
  .footer__bottom { display: flex; align-items: center; justify-content: space-between; gap: var(--space-4); padding-top: var(--space-5); flex-wrap: wrap; }
  .footer__copy { font-size: var(--font-size-small); color: var(--color-text-on-dark-muted); }
  .footer__legal { display: flex; gap: var(--space-5); list-style: none; flex-wrap: wrap; }

  @media (max-width: 880px) {
    .footer__top { grid-template-columns: 1fr 1fr; gap: var(--space-6); }
    .footer__brand { grid-column: 1 / -1; }
  }
  @media (max-width: 520px) {
    .footer__top { grid-template-columns: 1fr; }
    .footer__bottom { flex-direction: column; align-items: flex-start; }
  }
</style>
