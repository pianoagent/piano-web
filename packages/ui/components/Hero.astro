---
/**
 * Hero — Piano sekční blok (úvodní sekce stránky)
 *
 * Props:
 *   eyebrow?:    string  → malý verzálkový popisek nad nadpisem
 *   title?:      string  → nadpis (pro akcent PP Eiko použij slot "title")
 *   lead?:       string  → perex pod nadpisem
 *   align?:      "left" | "center"   (default "left"; ignorováno u split layoutu)
 *   background?: "default" | "alt" | "invert" | "primary"
 *   space?:      "sm" | "md" | "lg"  (default "lg")
 *
 * Sloty:
 *   "title"   → vlastní nadpis (např. <Heading> s <em> akcentem)
 *   "actions" → CTA tlačítka
 *   "media"   → obrázek/grafika vpravo (zapne split layout)
 */
import Section from './Section.astro';
import Heading from './Heading.astro';
import Text from './Text.astro';
import Icon from './Icon.astro';

interface HeroSlide {
  eyebrow?: string;
  title: string;       // může obsahovat <em> pro PP Eiko akcent
  lead?: string;
  image?: string;
  imageAlt?: string;
}

interface Props {
  eyebrow?: string;
  title?: string;
  lead?: string;
  align?: 'left' | 'center';
  background?: 'default' | 'alt' | 'warm' | 'invert' | 'primary' | 'gradient';
  space?: 'sm' | 'md' | 'lg';
  usp?: (string | { text: string; icon?: string })[];   // klíčové body → proužek uvnitř hero; ikonu lze určit per bod
  slides?: HeroSlide[];  // rotující eyebrow+nadpis+lead+obrázek; actions a usp zůstávají fixní
}

const { eyebrow, title, lead, align = 'left', background = 'default', space = 'lg', usp = [], slides = [] } = Astro.props;
const uspItems = usp.map((u) => (typeof u === 'string' ? { text: u, icon: 'lucide:check' } : { text: u.text, icon: u.icon ?? 'lucide:check' }));

const useSlides = slides.length > 0;
const isCarousel = slides.length > 1;
const hasTitle = Astro.slots.has('title');
const hasActions = Astro.slots.has('actions');
const hasMedia = useSlides ? slides.some((s) => s.image) : Astro.slots.has('media');
const onDark = background === 'invert' || background === 'primary' || background === 'gradient';

const innerClasses = [
  'hero__inner',
  hasMedia ? 'hero__inner--split' : 'hero__inner--single',
  !hasMedia && `hero__inner--align-${align}`,
  onDark && 'hero__inner--on-dark',
]
  .filter(Boolean)
  .join(' ');
---

<Section background={background} space={space}>
  <div class={innerClasses} data-hero-carousel={isCarousel ? '' : undefined}>
    <div class="hero__text">
      {useSlides ? (
        <div class="hero__rot">
          {slides.map((s, i) => (
            <div class={`hero__slide${i === 0 ? ' is-active' : ''}`} data-hero-slide={i}>
              {s.eyebrow && <p class="hero__eyebrow">{s.eyebrow}</p>}
              <Heading as="h1" size="display" color={onDark ? 'on-dark' : 'default'}><Fragment set:html={s.title} /></Heading>
              {s.lead && <Text size="lead" color={onDark ? 'on-dark-muted' : 'muted'} class="hero__lead">{s.lead}</Text>}
            </div>
          ))}
        </div>
      ) : (
        <>
          {eyebrow && <p class="hero__eyebrow">{eyebrow}</p>}
          {hasTitle ? (
            <slot name="title" />
          ) : (
            title && <Heading as="h1" size="display" color={onDark ? 'on-dark' : 'default'}>{title}</Heading>
          )}
          {lead && (
            <Text size="lead" color={onDark ? 'on-dark-muted' : 'muted'} class="hero__lead">{lead}</Text>
          )}
        </>
      )}

      {hasActions && (
        <div class="hero__actions"><slot name="actions" /></div>
      )}

      {uspItems.length > 0 && (
        <ul class="hero__usp">
          {uspItems.map((u) => (
            <li class="hero__usp-item">
              <span class="hero__usp-check"><Icon name={u.icon} size="sm" /></span>
              {u.text}
            </li>
          ))}
        </ul>
      )}

      {isCarousel && (
        <div class="hero__dots" role="tablist" aria-label="Přepnout sdělení">
          {slides.map((_, i) => (
            <button type="button" class={`hero__dot${i === 0 ? ' is-active' : ''}`} data-hero-dot={i} aria-label={`Sdělení ${i + 1}`}></button>
          ))}
        </div>
      )}
    </div>

    {hasMedia && (
      <div class="hero__media">
        {useSlides ? (
          <div class="hero__rot hero__media-rot">
            {slides.map((s, i) => s.image && (
              <img class={`hero__slide${i === 0 ? ' is-active' : ''}`} data-hero-mslide={i}
                   src={s.image} alt={s.imageAlt ?? ''} width="1100" height="733" loading={i === 0 ? 'eager' : 'lazy'} />
            ))}
          </div>
        ) : (
          <slot name="media" />
        )}
      </div>
    )}
  </div>
</Section>

{isCarousel && (
  <script>
    function initHero(root: HTMLElement) {
      const texts = Array.from(root.querySelectorAll<HTMLElement>('[data-hero-slide]'));
      const medias = Array.from(root.querySelectorAll<HTMLElement>('[data-hero-mslide]'));
      const dots = Array.from(root.querySelectorAll<HTMLElement>('[data-hero-dot]'));
      const n = texts.length;
      if (n < 2) return;
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      let i = 0;
      let timer: ReturnType<typeof setInterval> | undefined;
      const go = (k: number) => {
        i = (k + n) % n;
        texts.forEach((el, idx) => el.classList.toggle('is-active', idx === i));
        medias.forEach((el) => el.classList.toggle('is-active', Number(el.dataset.heroMslide) === i));
        dots.forEach((el, idx) => el.classList.toggle('is-active', idx === i));
      };
      const stop = () => { if (timer) clearInterval(timer); timer = undefined; };
      const start = () => { if (reduce) return; stop(); timer = setInterval(() => go(i + 1), 4000); };
      dots.forEach((d, idx) => d.addEventListener('click', () => { go(idx); start(); }));
      root.addEventListener('mouseenter', stop);
      root.addEventListener('mouseleave', start);
      root.addEventListener('focusin', stop);
      root.addEventListener('focusout', start);
      let x0: number | null = null;
      root.addEventListener('touchstart', (e) => { x0 = e.touches[0].clientX; }, { passive: true });
      root.addEventListener('touchend', (e) => {
        if (x0 === null) return;
        const dx = e.changedTouches[0].clientX - x0;
        if (Math.abs(dx) > 40) { go(dx < 0 ? i + 1 : i - 1); start(); }
        x0 = null;
      });
      start();
    }
    document.querySelectorAll<HTMLElement>('[data-hero-carousel]').forEach(initHero);
  </script>
)}

<style>
  .hero__inner { display: flex; flex-direction: column; }

  /* Split — text vlevo, média vpravo */
  .hero__inner--split {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: var(--space-8);
    align-items: center;
  }

  /* Single — sloupec, volitelně vycentrovaný */
  .hero__inner--single .hero__text { max-width: 720px; }
  .hero__inner--align-center {
    align-items: center;
    text-align: center;
  }
  .hero__inner--align-center .hero__text { margin-inline: auto; }
  .hero__inner--align-center .hero__actions { justify-content: center; }

  /* Rotace (carousel) — slidy se stackují přes sebe a prolínají */
  .hero__rot { display: grid; }
  .hero__rot > .hero__slide { grid-area: 1 / 1; }
  .hero__slide {
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.5s ease;
  }
  .hero__slide.is-active { opacity: 1; visibility: visible; }
  .hero__media-rot > img { width: 100%; height: auto; }

  /* Tečky */
  .hero__dots { display: flex; gap: var(--space-2); margin-top: var(--space-7); }
  .hero__dot {
    width: 10px; height: 10px; padding: 0; border: none; cursor: pointer;
    border-radius: var(--radius-full); background: var(--color-border);
    transition: var(--transition);
  }
  .hero__dot.is-active { width: 26px; background: var(--color-primary); }
  .hero__inner--on-dark .hero__dot { background: var(--color-border-on-dark); }
  .hero__inner--on-dark .hero__dot.is-active { background: var(--color-secondary-gold); }
  @media (prefers-reduced-motion: reduce) { .hero__slide { transition: none; } }

  /* Eyebrow */
  .hero__eyebrow {
    font-family: var(--font-sans);
    font-size: var(--font-size-label);
    font-weight: var(--font-weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wide);
    color: var(--color-text-accent);
    margin-bottom: var(--space-4);
  }
  .hero__inner--on-dark .hero__eyebrow { color: var(--color-secondary-gold); }

  /* Lead + akce */
  .hero__lead { margin-top: var(--space-5); max-width: 620px; }
  .hero__inner--align-center .hero__lead { margin-inline: auto; }
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-top: var(--space-7);
  }

  /* USP proužek — klíčové body uvnitř hero */
  .hero__usp {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3) var(--space-6);
    margin-top: var(--space-7);
    padding-top: var(--space-5);
    border-top: 1px solid var(--color-border);
  }
  .hero__usp-item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--font-size-small);
    font-weight: var(--font-weight-medium);
    color: var(--color-text);
  }
  .hero__usp-check { display: inline-flex; color: var(--color-primary); flex-shrink: 0; }
  .hero__inner--align-center .hero__usp { justify-content: center; }
  .hero__inner--on-dark .hero__usp { border-top-color: var(--color-border-on-dark); }
  .hero__inner--on-dark .hero__usp-item { color: var(--color-text-on-dark); }
  .hero__inner--on-dark .hero__usp-check { color: var(--color-secondary-gold); }

  /* Média (obrázek nebo video) */
  .hero__media { display: block; }
  .hero__media :global(img),
  .hero__media :global(video) {
    display: block;
    width: 100%;
    height: auto;
  }
  /* Video v poměru 16:9 vyplní rámeček (cover) */
  .hero__media :global(video) {
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  /* Responsive — split se skládá pod sebe */
  @media (max-width: 880px) {
    .hero__inner--split {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
    .hero__inner--split .hero__media { order: -1; }
  }
</style>
