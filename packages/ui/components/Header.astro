---
/**
 * Header — Piano (sticky navigace + mobilní drawer)
 *
 *   transparent: boolean → overlay přes hero (světlý text), po scrollu zpevní na bílou
 *
 * Navigace se čte z src/config/nav.ts (obsah oddělen od vzhledu).
 * Logo je prozatím textový wordmark + piano-mark ikona — výměna za reálné SVG
 * je triviální (nahradit obsah .header__logo).
 */
import Icon from './Icon.astro';
import Button from './Button.astro';
import Badge from './Badge.astro';
import { mainNav, headerCta, megaToLinks } from '../config/nav';
import type { NavItem, NavLink } from '../config/nav';

interface Props {
  transparent?: boolean;
  brand?: string;       // název pro aria-label / wordmark (default "Piano")
  logoSrc?: string;     // cesta k obrázku loga; bez něj piano-mark + wordmark
  logoHeight?: string;  // výška loga v liště (default 38px); brandové weby ~26px
  homeHref?: string;    // odkaz loga (default "/")
  nav?: NavItem[];      // per-web navigace (default sdílená mainNav)
  cta?: NavLink;        // per-web hlavní CTA (default sdílená headerCta)
}
const {
  transparent = false,
  brand = 'Piano',
  logoSrc,
  logoHeight = '38px',
  homeHref = '/',
  nav = mainNav,
  cta = headerCta,
} = Astro.props;

const classes = ['header', transparent && 'header--transparent'].filter(Boolean).join(' ');
---

<header class={classes} data-header style={`--logo-h: ${logoHeight};`}>
  <div class="header__inner">
    <!-- Logo -->
    <a href={homeHref} class="header__logo" aria-label={`${brand} — domů`}>
      {logoSrc ? (
        <img class="header__logo-img" src={logoSrc} alt={brand} />
      ) : (
        <>
          <Icon name="piano-mark" size="md" />
          <span class="header__wordmark">{brand}</span>
        </>
      )}
    </a>

    <!-- Desktop navigace -->
    <nav class="header__nav" aria-label="Hlavní navigace">
      <ul class="header__menu">
        {nav.map((item) => (
          item.mega ? (
            <li class="header__item header__item--mega">
              <button class="header__link header__link--toggle" aria-expanded="false" aria-haspopup="true">
                {item.label}
                <Icon name="lucide:chevron-down" size="xs" class="header__chevron" />
              </button>

              <div class="header__mega">
                <div class:list={['header__mega-inner', !item.mega.featured && 'header__mega-inner--no-featured']}>
                  {item.mega.featured && (
                    <div class="mega__featured">
                      {item.mega.featured.label && <p class="mega__label">{item.mega.featured.label}</p>}
                      {item.mega.featured.items.map((f) => (
                        <a href={f.href} class="mega__feat">
                          {f.icon && <span class="mega__feat-icon"><Icon name={f.icon} size="md" /></span>}
                          <span class="mega__feat-body">
                            <span class="mega__feat-title">
                              {f.label}
                              {f.badge && <Badge variant="primary" size="sm">{f.badge}</Badge>}
                            </span>
                            {f.description && <span class="mega__feat-desc">{f.description}</span>}
                          </span>
                        </a>
                      ))}
                    </div>
                  )}

                  <div class:list={['mega__cols', item.mega.columns.length === 1 && 'mega__cols--single']}>
                    {item.mega.columns.map((col) => (
                      <div class="mega__col">
                        {col.label && <p class="mega__label">{col.label}</p>}
                        <ul class="mega__list">
                          {col.links.map((l) => (
                            <li>
                              <a href={l.href} class="mega__row">
                                {l.icon && <span class="mega__row-icon"><Icon name={l.icon} size="sm" /></span>}
                                <span class="mega__row-body">
                                  <span class="mega__row-name">{l.label}</span>
                                  {l.description && <span class="mega__row-desc">{l.description}</span>}
                                </span>
                              </a>
                            </li>
                          ))}
                        </ul>
                      </div>
                    ))}
                  </div>
                </div>

                {item.mega.footer && (
                  <a href={item.mega.footer.href} class="mega__footer">{item.mega.footer.label} →</a>
                )}
              </div>
            </li>
          ) : item.children ? (
            <li class="header__item header__item--dropdown">
              <a href={item.href} class="header__link header__link--toggle" aria-haspopup="true">
                {item.label}
                <Icon name="lucide:chevron-down" size="xs" class="header__chevron" />
              </a>
              <div class="header__dropdown">
                <ul class="header__dropdown-list">
                  {item.children.map((c) => (
                    <li>
                      <a href={c.href} class="header__dropdown-link">
                        {c.icon && <span class="header__dropdown-icon"><Icon name={c.icon} size="sm" /></span>}
                        <span class="header__dropdown-body">
                          <span class="header__dropdown-name">{c.label}</span>
                          {c.description && <span class="header__dropdown-desc">{c.description}</span>}
                        </span>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            </li>
          ) : (
            <li class="header__item">
              <a href={item.href} class="header__link">{item.label}</a>
            </li>
          )
        ))}
      </ul>
    </nav>

    <!-- CTA + hamburger -->
    <div class="header__actions">
      <Button href={cta.href} variant="primary" size="sm" class="header__cta">{cta.label}</Button>
      <button class="header__burger" aria-label="Otevřít menu" aria-expanded="false" aria-controls="mobile-drawer" data-burger>
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <!-- Mobilní drawer -->
  <div class="drawer" id="mobile-drawer" data-drawer hidden>
    <div class="drawer__overlay" data-drawer-overlay></div>
    <div class="drawer__panel" role="dialog" aria-modal="true" aria-label="Menu">
      <div class="drawer__head">
        {logoSrc ? <img class="header__logo-img" src={logoSrc} alt={brand} /> : <span class="header__wordmark">{brand}</span>}
        <button class="drawer__close" aria-label="Zavřít menu" data-drawer-close>
          <Icon name="lucide:x" size="md" />
        </button>
      </div>
      <nav class="drawer__nav" aria-label="Mobilní navigace">
        <ul class="drawer__menu">
          {nav.map((item) => {
            const sub = megaToLinks(item);
            return sub.length > 0 ? (
              <li class="drawer__item">
                <button class="drawer__link drawer__link--toggle" aria-expanded="false" data-accordion>
                  {item.label}
                  <Icon name="lucide:chevron-down" size="sm" class="drawer__chevron" />
                </button>
                <ul class="drawer__sublist" hidden>
                  {sub.map((child) => (
                    <li><a href={child.href} class="drawer__sublink">{child.label}</a></li>
                  ))}
                </ul>
              </li>
            ) : (
              <li class="drawer__item">
                <a href={item.href} class="drawer__link">{item.label}</a>
              </li>
            );
          })}
        </ul>
        <Button href={cta.href} variant="primary" full class="drawer__cta">{cta.label}</Button>
      </nav>
    </div>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    transition: background var(--duration-base) var(--easing), border-color var(--duration-base) var(--easing);
  }

  .header__inner {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    max-width: var(--container-max);
    margin: 0 auto;
    padding: var(--space-3) var(--container-pad);
  }

  /* Logo */
  .header__logo {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-text);
    text-decoration: none;
    flex-shrink: 0;
  }
  .header__wordmark {
    font-family: var(--font-sans);
    font-weight: var(--font-weight-semibold);
    font-size: 22px;
    letter-spacing: var(--letter-spacing-tight);
  }
  .header__logo-img { height: var(--logo-h, 38px); width: auto; display: block; }

  /* Desktop navigace */
  .header__nav { margin-left: auto; }
  .header__menu {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    list-style: none;
  }
  .header__item { position: relative; }
  .header__item--mega { position: static; }

  .header__link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-2) var(--space-3);
    font-family: var(--font-sans);
    font-size: var(--font-size-body);
    color: var(--color-text);
    text-decoration: none;
    background: none;
    border: none;
    cursor: pointer;
    border-radius: var(--radius-sm);
    transition: var(--transition);
  }
  .header__link:hover { color: var(--color-text-accent); }
  .header__chevron { transition: transform var(--duration-fast) var(--easing); }

  /* ---- Mega menu ---- */
  .header__mega {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(-6px);
    width: min(880px, calc(100vw - 48px));
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-lg);
    opacity: 0;
    visibility: hidden;
    transition: var(--transition);
    z-index: 300;
  }
  /* Neviditelný „most" přes mezeru pod lištou — udrží hover při přejezdu kurzoru */
  .header__mega::before {
    content: "";
    position: absolute;
    top: -16px;
    left: 0;
    right: 0;
    height: 16px;
  }
  .header__item--mega:hover .header__mega,
  .header__item--mega:focus-within .header__mega {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }
  .header__item--mega:hover .header__chevron,
  .header__item--mega:focus-within .header__chevron { transform: rotate(180deg); }

  .header__mega-inner { display: grid; grid-template-columns: 280px 1fr; }
  .header__mega-inner--no-featured { grid-template-columns: 1fr; }

  .mega__label {
    font-size: var(--font-size-caption);
    font-weight: var(--font-weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wide);
    color: var(--color-text-muted);
    margin-bottom: var(--space-3);
  }

  /* Featured sloupec (na bílé, oddělený dělící čárou) */
  .mega__featured {
    background: var(--color-bg);
    border-right: 1px solid var(--color-border);
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .mega__feat {
    display: flex;
    gap: var(--space-3);
    align-items: flex-start;
    padding: var(--space-3);
    text-decoration: none;
    color: inherit;
    transition: var(--transition);
  }
  .mega__feat:hover { background: var(--color-bg-hover); }
  .mega__feat-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    flex-shrink: 0;
    color: var(--color-text-accent);
    background: var(--color-bg-hover);
    border: 1px solid var(--color-border);
  }
  .mega__feat-body { display: flex; flex-direction: column; gap: 2px; }
  .mega__feat-title { display: flex; align-items: center; gap: var(--space-2); font-weight: var(--font-weight-medium); color: var(--color-text); }
  .mega__feat-desc { font-size: var(--font-size-small); color: var(--color-text-muted); }

  /* Sloupce odkazů */
  .mega__cols { padding: var(--space-5); display: flex; gap: var(--space-6); }
  .mega__col { flex: 1; }
  /* Více sloupců vedle sebe → každý seznam jednosloupcový (pod sebe).
     Jediný sloupec → rozdělit do dvou, ať není vytáhlý a úzký. */
  .mega__list { list-style: none; display: grid; grid-template-columns: 1fr; gap: var(--space-1); align-content: start; }
  .mega__cols--single .mega__list { grid-template-columns: 1fr 1fr; }
  .mega__row {
    display: flex;
    gap: var(--space-3);
    align-items: flex-start;
    padding: var(--space-3);
    text-decoration: none;
    color: inherit;
    transition: var(--transition);
  }
  .mega__row:hover { background: var(--color-bg-hover); }
  .mega__row-icon { display: inline-flex; color: var(--color-text-accent); flex-shrink: 0; margin-top: 1px; }
  .mega__row-body { display: flex; flex-direction: column; gap: 2px; }
  .mega__row-name { font-weight: var(--font-weight-medium); color: var(--color-text); font-size: var(--font-size-small); }
  .mega__row-desc { font-size: var(--font-size-caption); color: var(--color-text-muted); }

  /* Footer mega panelu */
  .mega__footer {
    display: block;
    padding: var(--space-3) var(--space-5);
    border-top: 1px solid var(--color-border);
    font-size: var(--font-size-small);
    font-weight: var(--font-weight-medium);
    color: var(--color-text-accent);
    text-decoration: none;
  }
  .mega__footer:hover { background: var(--color-bg-hover); }

  /* ---- Jednoduchý dropdown (item.children) ---- */
  .header__item--dropdown { position: relative; }
  .header__dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 260px;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lg);
    padding: var(--space-2);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-6px);
    transition: var(--transition);
    z-index: 300;
  }
  .header__dropdown::before { content: ""; position: absolute; top: -16px; left: 0; right: 0; height: 16px; }
  .header__item--dropdown:hover .header__dropdown,
  .header__item--dropdown:focus-within .header__dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .header__item--dropdown:hover .header__chevron,
  .header__item--dropdown:focus-within .header__chevron { transform: rotate(180deg); }
  .header__dropdown-list { list-style: none; display: flex; flex-direction: column; }
  .header__dropdown-link {
    display: flex;
    gap: var(--space-3);
    align-items: flex-start;
    padding: var(--space-3);
    border-radius: var(--radius-sm);
    text-decoration: none;
    color: inherit;
    transition: var(--transition);
  }
  .header__dropdown-link:hover { background: var(--color-bg-hover); }
  .header__dropdown-icon { display: inline-flex; color: var(--color-text-accent); flex-shrink: 0; margin-top: 1px; }
  .header__dropdown-body { display: flex; flex-direction: column; gap: 2px; }
  .header__dropdown-name { font-weight: var(--font-weight-medium); color: var(--color-text); font-size: var(--font-size-small); }
  .header__dropdown-desc { font-size: var(--font-size-caption); color: var(--color-text-muted); }

  /* Actions */
  .header__actions { display: flex; align-items: center; gap: var(--space-3); }

  /* Hamburger */
  .header__burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    padding: 0 8px;
    background: none;
    border: none;
    cursor: pointer;
  }
  .header__burger span {
    display: block;
    height: 2px;
    width: 100%;
    background: var(--color-text);
    transition: var(--transition);
  }

  /* ---- Transparent varianta (overlay přes hero) ---- */
  .header--transparent:not(.is-scrolled) {
    background: transparent;
    border-bottom-color: transparent;
  }
  .header--transparent:not(.is-scrolled) .header__logo,
  .header--transparent:not(.is-scrolled) .header__link,
  .header--transparent:not(.is-scrolled) .header__wordmark { color: var(--color-text-on-dark); }
  .header--transparent:not(.is-scrolled) .header__link:hover { color: var(--color-text-on-dark); opacity: 0.8; }
  .header--transparent:not(.is-scrolled) .header__burger span { background: var(--color-text-on-dark); }

  /* ---- Mobilní drawer ---- */
  .drawer { position: fixed; inset: 0; z-index: 200; }
  .drawer__overlay {
    position: absolute;
    inset: 0;
    background: rgba(38, 38, 38, 0.5);
    opacity: 0;
    transition: opacity var(--duration-base) var(--easing);
  }
  .drawer__panel {
    position: absolute;
    top: 0;
    right: 0;
    height: 100%;
    width: min(360px, 86vw);
    background: var(--color-bg);
    box-shadow: var(--shadow-lg);
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform var(--duration-base) var(--easing);
    overflow-y: auto;
  }
  .drawer.is-open .drawer__overlay { opacity: 1; }
  .drawer.is-open .drawer__panel { transform: translateX(0); }

  .drawer__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-5);
  }
  .drawer__close {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text);
    display: inline-flex;
    padding: var(--space-1);
  }
  .drawer__menu { list-style: none; display: flex; flex-direction: column; }
  .drawer__item { border-bottom: 1px solid var(--color-border); }
  .drawer__link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: var(--space-4) 0;
    font-family: var(--font-sans);
    font-size: var(--font-size-lead);
    color: var(--color-text);
    text-decoration: none;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
  }
  .drawer__chevron { transition: transform var(--duration-fast) var(--easing); }
  .drawer__link--toggle[aria-expanded="true"] .drawer__chevron { transform: rotate(180deg); }
  .drawer__sublist { list-style: none; padding: 0 0 var(--space-3) var(--space-3); }
  .drawer__sublink {
    display: block;
    padding: var(--space-2) 0;
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: var(--font-size-body);
  }
  .drawer__sublink:hover { color: var(--color-text-accent); }
  .drawer__cta { margin-top: var(--space-6); }

  /* ---- Responsive přepínač ---- */
  @media (max-width: 880px) {
    .header__nav, .header__cta { display: none; }
    .header__burger { display: flex; }
    /* hamburger zarovnat doprava (nav je skrytá, tak ji nahradí actions) */
    .header__actions { margin-left: auto; }
  }
</style>

<script>
  const header = document.querySelector('[data-header]');
  const burger = document.querySelector('[data-burger]');
  const drawer = document.querySelector('[data-drawer]') as HTMLElement | null;
  const overlay = document.querySelector('[data-drawer-overlay]');
  const closeBtn = document.querySelector('[data-drawer-close]');

  function openDrawer() {
    if (!drawer) return;
    drawer.hidden = false;
    // vynutit reflow, pak animovat
    requestAnimationFrame(() => drawer.classList.add('is-open'));
    burger?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }
  function closeDrawer() {
    if (!drawer) return;
    drawer.classList.remove('is-open');
    burger?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
    setTimeout(() => { if (drawer && !drawer.classList.contains('is-open')) drawer.hidden = true; }, 200);
  }

  burger?.addEventListener('click', openDrawer);
  overlay?.addEventListener('click', closeDrawer);
  closeBtn?.addEventListener('click', closeDrawer);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeDrawer(); });

  // Accordion produktů v draweru
  document.querySelectorAll('[data-accordion]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      const sublist = btn.nextElementSibling as HTMLElement | null;
      if (sublist) sublist.hidden = expanded;
    });
  });

  // Transparent header → zpevnění po scrollu
  if (header?.classList.contains('header--transparent')) {
    const onScroll = () => header.classList.toggle('is-scrolled', window.scrollY > 20);
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }
</script>
