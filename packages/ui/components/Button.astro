---
/**
 * Button — Piano primitivní komponenta
 *
 * Varianty:
 *   variant: "primary" | "secondary" | "ghost"
 *   size:    "sm" | "md" | "lg"
 *   href:    string  → renderuje jako <a>, jinak <button>
 *   full:    boolean → 100% šířka
 *
 * Primary nese signature zkosený roh. Secondary a ghost mají ostré rohy (0px),
 * žádné zaoblení.
 */

interface Props {
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  full?: boolean;
  type?: 'button' | 'submit' | 'reset';
  class?: string;
  [key: string]: any;
}

const {
  variant = 'primary',
  size = 'md',
  href,
  full = false,
  type = 'button',
  class: className,
  ...rest
} = Astro.props;

const tag = href ? 'a' : 'button';
const classes = ['btn', `btn--${variant}`, `btn--${size}`, full && 'btn--full', className]
  .filter(Boolean)
  .join(' ');
---

{tag === 'a' ? (
  <a href={href} class={classes} {...rest}>
    <slot />
  </a>
) : (
  <button type={type} class={classes} {...rest}>
    <slot />
  </button>
)}

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    font: var(--text-label);
    font-family: var(--font-sans);
    letter-spacing: var(--letter-spacing-wide);
    text-transform: uppercase;
    text-decoration: none;
    border: 1px solid transparent;
    border-radius: var(--btn-radius);
    cursor: pointer;
    transition: var(--transition);
    white-space: nowrap;
  }

  .btn:focus-visible {
    outline: none;
    box-shadow: var(--shadow-focus);
  }

  /* Sizes */
  .btn--sm {
    padding: var(--space-2) var(--space-4);
    font-size: 12px;
  }

  .btn--md {
    padding: var(--space-3) var(--space-5);
  }

  .btn--lg {
    padding: var(--space-4) var(--space-7);
    font-size: 14px;
  }

  /* Full width */
  .btn--full {
    width: 100%;
  }

  /* Primary — karmínová CTA se signature zkosením */
  .btn--primary {
    background: var(--color-primary);
    color: var(--color-text-on-dark);
    border-color: var(--color-primary);
    clip-path: var(--btn-clip);
  }
  .btn--primary:hover {
    background: var(--color-primary-hover);
    border-color: var(--color-primary-hover);
  }
  .btn--primary:active {
    background: var(--color-primary-active);
    border-color: var(--color-primary-active);
  }

  /* Secondary — obyčejný obdélník s rámečkem (normální rohy) */
  .btn--secondary {
    background: transparent;
    color: var(--color-text);
    border-color: var(--color-border-strong);
  }
  .btn--secondary:hover {
    border-color: var(--color-neutral-900);
    color: var(--color-neutral-900);
  }
  .btn--secondary:active {
    background: var(--color-neutral-50);
  }

  /* Ghost — jen text */
  .btn--ghost {
    background: transparent;
    color: var(--color-text-accent);
    border-color: transparent;
    padding-left: 0;
    padding-right: 0;
  }
  .btn--ghost:hover {
    color: var(--color-primary-hover);
  }
</style>
