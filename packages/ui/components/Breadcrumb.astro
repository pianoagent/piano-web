---
/**
 * Breadcrumb — Piano (drobečková navigace).
 * Vizuální drobečky pro orientaci v hloubce stránek. JSON-LD (BreadcrumbList)
 * se předává zvlášť přes `schema` prop v Base layoutu (zůstává v <head>).
 *
 * Props:
 *   items: { label: string; href?: string }[]
 *     — poslední položka = aktuální stránka (bez odkazu).
 *   background?: "default" | "alt"   (default "default")
 *
 * Tenký pruh; obvykle se vkládá jako první prvek <main> nad hero.
 */
import Container from './Container.astro';
import Icon from './Icon.astro';

interface Crumb { label: string; href?: string; }
interface Props { items: Crumb[]; background?: 'default' | 'alt'; }

const { items = [], background = 'default' } = Astro.props;
---

<nav class:list={['crumbs', `crumbs--${background}`]} aria-label="Drobečková navigace">
  <Container>
    <ol class="crumbs__list">
      {items.map((c, i) => {
        const isLast = i === items.length - 1;
        return (
          <li class="crumbs__item">
            {!isLast && c.href ? (
              <a class="crumbs__link" href={c.href}>{c.label}</a>
            ) : (
              <span class="crumbs__current" aria-current="page">{c.label}</span>
            )}
            {!isLast && <Icon name="lucide:chevron-right" size="xs" class="crumbs__sep" />}
          </li>
        );
      })}
    </ol>
  </Container>
</nav>

<style>
  .crumbs { border-bottom: 1px solid var(--color-border); }
  .crumbs--default { background: var(--color-bg); }
  .crumbs--alt { background: var(--color-bg-alt); }
  .crumbs__list {
    list-style: none; display: flex; flex-wrap: wrap; align-items: center; gap: var(--space-2);
    padding-block: var(--space-3);
    font-size: var(--font-size-small);
  }
  .crumbs__item { display: inline-flex; align-items: center; gap: var(--space-2); }
  .crumbs__link { color: var(--color-text-accent); text-decoration: none; }
  .crumbs__link:hover { text-decoration: underline; }
  .crumbs__current { color: var(--color-text-muted); }
  .crumbs__sep { color: var(--color-border-strong); }
</style>
