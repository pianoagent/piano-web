---
/**
 * LeadForm — Piano sekční blok (poptávkový formulář → CRM)
 *
 * Dvě varianty pro A/B testování (lze je v sekci jednoduše prohodit):
 *   variant="full"     → jméno, e-mail, telefon, název podniku, město (+ souhlas)
 *   variant="callback" → jen telefon ("zavolejte mi")
 *
 * Layout: formulář je úzký, vedle něj sloupec s „proofs" (důvody důvěry).
 * Telefon je bez předvolby — přijme i SK a jiná zahraniční čísla.
 *
 * Props:
 *   variant?:     "full" | "callback"     (default "full")
 *   title?:       string
 *   lead?:        string
 *   proofs?:      Proof[]  → body důvěry vedle formuláře (icon? / title / text?)
 *   action?:      string  → endpoint pro odeslání; default "/api/lead.php" (PHP hosting → e-mail)
 *   submitLabel?: string
 *   background?:  "default" | "alt" | "invert" | "primary"   (default "alt")
 *   space?:       "sm" | "md" | "lg"
 *   id?:          string
 *
 * Odesílá se přes fetch (progressive enhancement) — skryté pole `form_variant`
 * rozliší zdroj v CRM, honeypot `website` filtruje boty.
 */
import Section from './Section.astro';
import Heading from './Heading.astro';
import Text from './Text.astro';
import Button from './Button.astro';
import Field from './Field.astro';
import Icon from './Icon.astro';

interface Proof { icon?: string; title: string; text?: string; }

interface Props {
  variant?: 'full' | 'callback';
  title?: string;
  lead?: string;
  proofs?: Proof[];
  action?: string;
  successUrl?: string;   // přesměrování po úspěšném odeslání (analytika); default "/dekujeme"
  submitLabel?: string;
  background?: 'default' | 'alt' | 'invert' | 'primary';
  space?: 'sm' | 'md' | 'lg';
  id?: string;
  locale?: 'cs' | 'en';
}

const LEAD_I18N = {
  cs: {
    name: 'Jméno', email: 'E-mail', phone: 'Telefon', company: 'Název podniku', city: 'Město',
    phoneHelper: 'Zavoláme vám zpět, jakmile to půjde.',
    consentPre: 'Souhlasím se zpracováním osobních údajů dle ', consentLink: 'zásad ochrany údajů', consentPost: '.',
    submitFull: 'Odeslat poptávku', submitCallback: 'Zavolejte mi',
    statusOk: 'Děkujeme! Ozveme se vám co nejdříve.',
    statusErr: 'Něco se nepovedlo. Zkuste to prosím znovu, nebo nám zavolejte.',
    consentHref: '/gdpr',
    proofs: [
      { icon: 'lucide:headset', title: 'Podpora 24/7', text: 'Česká podpora každý den v roce.' },
      { icon: 'lucide:store', title: '6 000+ provozů', text: 'Důvěřují nám restaurace i hotely v celé ČR.' },
      { icon: 'lucide:calendar-check', title: '30 let na trhu', text: 'Zkušenosti s gastro a hotelovým provozem.' },
      { icon: 'lucide:gift', title: 'Konzultace zdarma', text: 'Nezávazně a bez rizika.' },
    ] as Proof[],
  },
  en: {
    name: 'Name', email: 'Email', phone: 'Phone', company: 'Business name', city: 'City',
    phoneHelper: 'We will call you back as soon as we can.',
    consentPre: 'I agree to the processing of personal data under the ', consentLink: 'privacy policy', consentPost: '.',
    submitFull: 'Send inquiry', submitCallback: 'Call me back',
    statusOk: 'Thank you! We will get back to you shortly.',
    statusErr: 'Something went wrong. Please try again, or give us a call.',
    consentHref: '/gdpr',
    proofs: [
      { icon: 'lucide:headset', title: '24/7 support', text: 'Support every day of the year.' },
      { icon: 'lucide:store', title: '6,000+ venues', text: 'Trusted by restaurants and hotels across Czechia.' },
      { icon: 'lucide:calendar-check', title: '30 years on the market', text: 'Deep experience in hospitality operations.' },
      { icon: 'lucide:gift', title: 'Free consultation', text: 'No commitment, no risk.' },
    ] as Proof[],
  },
} as const;

const {
  variant = 'full',
  title,
  lead,
  proofs,
  action = '/api/lead.php',
  successUrl = '/dekujeme',
  submitLabel,
  background = 'alt',
  space = 'md',
  id,
  locale = 'cs',
} = Astro.props;

const L = LEAD_I18N[locale];
const proofsList: Proof[] = proofs ?? L.proofs;
const isCallback = variant === 'callback';
const onDark = background === 'invert' || background === 'primary';
const submitText = submitLabel ?? (isCallback ? L.submitCallback : L.submitFull);
---

<Section background={background} space={space} id={id}>
  <div class:list={['leadform__layout', isCallback && 'leadform__layout--callback']}>

    <!-- Levý sloupec: nadpis + proofs -->
    <div class="leadform__intro">
      {title && <Heading as="h2" size="h2" color={onDark ? 'on-dark' : 'default'}>{title}</Heading>}
      {lead && <Text size="lead" color={onDark ? 'on-dark-muted' : 'muted'} class="leadform__lead">{lead}</Text>}

      {proofsList.length > 0 && (
        <ul class:list={['leadform__proofs', onDark && 'leadform__proofs--on-dark']}>
          {proofsList.map((p) => (
            <li class="leadform__proof">
              {p.icon && <span class="leadform__proof-icon"><Icon name={p.icon} size="md" /></span>}
              <span class="leadform__proof-body">
                <span class="leadform__proof-title">{p.title}</span>
                {p.text && <span class="leadform__proof-text">{p.text}</span>}
              </span>
            </li>
          ))}
        </ul>
      )}
    </div>

    <!-- Pravý sloupec: úzký formulář -->
    <form
      class:list={['leadform', `leadform--${variant}`]}
      action={action}
      method="POST"
      data-leadform
      data-success-url={successUrl}
      novalidate
    >
      <input type="hidden" name="form_variant" value={variant} />
      <input type="hidden" name="page" data-page />
      <div class="leadform__hp" aria-hidden="true">
        <label>Web<input type="text" name="website" tabindex="-1" autocomplete="off" /></label>
      </div>

      <div class="leadform__fields">
        {isCallback ? (
          <Field
            label={L.phone}
            name="phone"
            type="tel"
            placeholder="+420 123 456 789"
            helper={L.phoneHelper}
            autocomplete="tel"
            inputmode="tel"
            required
          />
        ) : (
          <>
            <Field label={L.name} name="name" placeholder="John Doe" autocomplete="name" required />
            <Field label={L.email} name="email" type="email" placeholder="info@podnik.cz" autocomplete="email" required />
            <Field label={L.phone} name="phone" type="tel" placeholder="+420 123 456 789" autocomplete="tel" inputmode="tel" />
            <Field label={L.company} name="company" placeholder="Restaurace U Lva" autocomplete="organization" />
            <Field label={L.city} name="city" placeholder="Praha" autocomplete="address-level2" />

            <label class="leadform__consent">
              <input type="checkbox" name="consent" required />
              <span class="leadform__check" aria-hidden="true"></span>
              <span class="leadform__consent-text">
                {L.consentPre}<a href={L.consentHref}>{L.consentLink}</a>{L.consentPost}
              </span>
            </label>
          </>
        )}
      </div>

      <div class="leadform__footer">
        <Button type="submit" variant="primary" full data-submit>{submitText}</Button>
      </div>

      <p class="leadform__status leadform__status--ok" data-success hidden>
        {L.statusOk}
      </p>
      <p class="leadform__status leadform__status--err" data-error hidden>
        {L.statusErr}
      </p>
    </form>
  </div>
</Section>

<style>
  /* Layout — proofs vlevo, úzký formulář vpravo */
  .leadform__layout {
    display: grid;
    grid-template-columns: 1fr minmax(0, 420px);
    gap: var(--space-8);
    align-items: start;
  }
  .leadform__layout--callback {
    grid-template-columns: 1fr minmax(0, 360px);
  }

  .leadform__lead { margin-top: var(--space-3); max-width: 460px; }

  /* Proofs */
  .leadform__proofs {
    list-style: none;
    display: grid;
    gap: var(--space-5);
    margin-top: var(--space-6);
    max-width: 460px;
  }
  .leadform__proof { display: flex; align-items: flex-start; gap: var(--space-3); }
  .leadform__proof-icon { display: inline-flex; color: var(--color-text-accent); flex-shrink: 0; }
  .leadform__proofs--on-dark .leadform__proof-icon { color: var(--color-secondary-gold); }
  .leadform__proof-body { display: flex; flex-direction: column; gap: 2px; }
  .leadform__proof-title { font-family: var(--font-sans); font-weight: var(--font-weight-medium); }
  .leadform__proof-text { font-size: var(--font-size-small); color: var(--color-text-muted); }
  .leadform__proofs--on-dark .leadform__proof-text { color: var(--color-text-on-dark-muted); }

  /* Formulář */
  .leadform__fields { display: flex; flex-direction: column; gap: var(--space-4); }
  .leadform__footer { margin-top: var(--space-5); }

  /* Honeypot */
  .leadform__hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  /* Souhlas — vlastní checkbox (ostré rohy) */
  .leadform__consent {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    cursor: pointer;
    margin-top: var(--space-1);
  }
  .leadform__consent input { position: absolute; opacity: 0; width: 0; height: 0; }
  .leadform__check {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    margin-top: 1px;
    background: var(--color-bg);
    border: 1.5px solid var(--color-border-strong);
    border-radius: 0;
    transition: var(--transition);
    position: relative;
  }
  .leadform__consent input:checked ~ .leadform__check {
    background: var(--color-neutral-900);
    border-color: var(--color-neutral-900);
  }
  .leadform__consent input:checked ~ .leadform__check::after {
    content: "";
    position: absolute;
    left: 6px;
    top: 2px;
    width: 5px;
    height: 10px;
    border: solid var(--color-text-on-dark);
    border-width: 0 2px 2px 0;
    transform: rotate(45deg);
  }
  .leadform__consent input:focus-visible ~ .leadform__check { box-shadow: var(--shadow-focus); }
  .leadform__consent-text {
    font-family: var(--font-sans);
    font-size: var(--font-size-small);
    color: var(--color-text-muted);
    line-height: var(--line-height-body);
  }
  .leadform__consent-text a { color: var(--color-text-accent); }

  /* Stavové hlášky */
  .leadform__status {
    margin-top: var(--space-4);
    font-family: var(--font-sans);
    font-size: var(--font-size-body);
    font-weight: var(--font-weight-medium);
  }
  .leadform__status--ok { color: var(--color-success); }
  .leadform__status--err { color: var(--color-error); }

  /* Responsive — sloupce pod sebe */
  @media (max-width: 880px) {
    .leadform__layout,
    .leadform__layout--callback { grid-template-columns: 1fr; gap: var(--space-6); }
  }
</style>

<script>
  document.querySelectorAll<HTMLFormElement>('[data-leadform]').forEach((form) => {
    const submit = form.querySelector<HTMLButtonElement>('[data-submit]');
    const ok = form.querySelector<HTMLElement>('[data-success]');
    const err = form.querySelector<HTMLElement>('[data-error]');
    const successUrl = form.getAttribute('data-success-url') || '';

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      ok && (ok.hidden = true);
      err && (err.hidden = true);

      if (!form.checkValidity()) { form.reportValidity(); return; }

      // URL stránky, odkud poptávka přišla (kvůli určení produktu v mailu)
      const pageField = form.querySelector<HTMLInputElement>('input[name="page"]');
      if (pageField) pageField.value = window.location.href;

      const hp = form.querySelector<HTMLInputElement>('input[name="website"]');
      if (hp && hp.value) { form.reset(); if (ok) ok.hidden = false; return; }

      const original = submit?.textContent;
      if (submit) { submit.disabled = true; submit.textContent = 'Odesílám…'; }

      try {
        const res = await fetch(form.action, {
          method: 'POST',
          headers: { Accept: 'application/json' },
          body: new FormData(form),
        });
        if (!res.ok) throw new Error(String(res.status));
        form.reset();
        if (successUrl) { window.location.assign(successUrl); return; }
        if (ok) ok.hidden = false;
      } catch {
        if (err) err.hidden = false;
      } finally {
        if (submit) { submit.disabled = false; submit.textContent = original ?? ''; }
      }
    });
  });
</script>
