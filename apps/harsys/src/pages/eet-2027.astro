---
/**
 * ABX HARSYS — EET od roku 2027.
 * Obsah z obsah/eet-pro-restaurace-od-roku-2027.md. Komponenty z @piano/ui.
 */
import Base from '../layouts/Base.astro';
import Header from '@piano/ui/components/Header.astro';
import Footer from '@piano/ui/components/Footer.astro';
import Section from '@piano/ui/components/Section.astro';
import Hero from '@piano/ui/components/Hero.astro';
import Heading from '@piano/ui/components/Heading.astro';
import Text from '@piano/ui/components/Text.astro';
import Button from '@piano/ui/components/Button.astro';
import Icon from '@piano/ui/components/Icon.astro';
import USPGrid from '@piano/ui/components/USPGrid.astro';
import LeadForm from '@piano/ui/components/LeadForm.astro';
import { harsysNav, harsysCta } from '../config/nav';

const ready = [
  { icon: 'lucide:history', title: 'Zvládli jsme EET 2016', text: 'EET jsme bezproblémově zvládli už v roce 2016 — technologicky jsme připraveni.' },
  { icon: 'lucide:refresh-cw', title: 'Úpravy včas', text: 'Nezbytné úpravy programu provedeme s dostatečným předstihem.' },
  { icon: 'lucide:settings', title: 'Konfigurace s podporou', text: 'Naše podpora pomůže s konfigurací, certifikátem i spuštěním.' },
  { icon: 'lucide:wallet-cards', title: 'Všechny typy plateb', text: 'EET podporujeme pro hotovost, kartu i platby přes QR kód.' },
];

const uctenka = [
  'Obchodní jméno, označení provozovny a číslo pokladny.',
  'Fiskální kód FIK, nebo bezpečnostní kód BKP.',
  'U právnických osob DIČ.',
  'Eviduje se jen celková částka, pravděpodobně dle sazeb DPH.',
  'Obsah účtenky (položky) se do EET neodesílá.',
];

const faqs = [
  { q: 'Budu si kvůli EET 2027 muset kupovat novou pokladnu?', a: 'Ne. Pokud vám Harsys funguje a máte pokladnu připojenou k internetu, hardware vyhoví i pro EET 2.0. Bude potřeba aktualizace softwaru a konfigurace (pravděpodobně i instalace certifikátu) — s tím vám ráda pomůže naše podpora.' },
  { q: 'Platí se za EET nějaké poplatky?', a: 'Za EET modul u nás neplatíte žádné měsíční poplatky. Úprava programu pro EET 2.0 bude zahrnuta v ceně aktualizace, kterou máte v rámci podpory zdarma.' },
  { q: 'Má stát díky EET přehled o tom, co prodávám?', a: 'Ne. Součástí datové zprávy nejsou jednotlivé položky — stát ani nikdo jiný se tak nedozví, kolik prodáte piv nebo gulášů.' },
  { q: 'Nemůže někdo EET data zneužít?', a: 'Datové zprávy jsou zašifrované vaším osobním EET certifikátem chráněným heslem. Tak tomu bylo u předchozí verze a dá se předpokládat, že stejně bude zabezpečená i nová EET.' },
];

const leadProofs = [
  { icon: 'lucide:calendar-clock', title: 'Spuštění od 1. 1. 2027', text: 'Podle aktuálních informací.' },
  { icon: 'lucide:gift', title: 'Modul bez měsíčních poplatků', text: 'Úprava v ceně aktualizace.' },
  { icon: 'lucide:shield-check', title: 'Data v bezpečí', text: 'Položky se do EET neodesílají.' },
];
---

<Base title="EET pro restaurace od roku 2027 | ABX HARSYS"
      description="Na znovuzavedení EET od 1. 1. 2027 je Harsys připraven. EET jsme zvládli už v roce 2016 — úpravy programu provedeme včas a podpora pomůže s konfigurací.">
  <Header brand="ABX HARSYS" logoSrc="/logos/abx_logo.svg" logoHeight="26px" homeHref="/" nav={harsysNav} cta={harsysCta} />

  <main>
  <Hero eyebrow="EET od roku 2027" background="gradient"
        lead="Podle aktuálních informací se chystá znovuzavedení EET od 1. 1. 2027. Technicky by se mělo vycházet z předchozí EET 1.0, povinné pro restaurace v letech 2016–2022. Na EET 2.0 jsme připraveni.">
    <Heading slot="title" as="h1" size="display" color="on-dark">Na EET 2.0 jsme <span class="accent">připraveni</span></Heading>
    <Fragment slot="actions">
      <Button href="#poptavka">Nezávazná konzultace</Button>
    </Fragment>
  </Hero>

  <USPGrid eyebrow="Aktuální stav" title="Připraveni technologicky i podporou"
           items={ready} columns={4} minItemWidth="230px" background="default" space="lg" />

  <!-- ÚČTENKY -->
  <Section background="alt" space="lg">
    <div class="split">
      <figure class="split__media"><img src="/images/eet-uctenka.webp" alt="Povinné náležitosti účtenky v EET" loading="lazy" /></figure>
      <div class="split__text">
        <Text size="label" color="accent">Účtenky a data</Text>
        <Heading as="h2" size="h2">Co bude účtenka <span class="accent">obsahovat</span></Heading>
        <Text size="lead" color="muted" balance>V rámci EET 2.0 budou stanoveny povinné náležitosti účtenek. Tisk účtenky ale nemá být povinný.</Text>
        <ul class="checks">
          {uctenka.map((u) => (<li><Icon name="lucide:check" size="sm" class="check" />{u}</li>))}
        </ul>
      </div>
    </div>
  </Section>

  <!-- FAQ -->
  <Section background="default" space="lg">
    <div class="head"><Heading as="h2" size="h2" align="center">Časté otázky k EET</Heading></div>
    <div class="faq">
      {faqs.map((f) => (
        <details class="faq__item">
          <summary>{f.q}<Icon name="lucide:chevron-down" size="sm" class="faq__chev" /></summary>
          <div class="faq__a"><Text color="muted">{f.a}</Text></div>
        </details>
      ))}
    </div>
  </Section>

  <LeadForm id="poptavka" variant="callback" background="primary"
            title="Máte zájem o nezávaznou konzultaci?"
            lead="Zanechte číslo a my se vám ozveme. Poradíme, jak být na EET 2.0 připraveni."
            proofs={leadProofs} successUrl="/dekujeme" />

  </main>
  <Footer legal={[{ label: 'Ochrana osobních údajů', href: '/ochrana-udaju' }]} />
</Base>

<style>
  .head { max-width: 760px; margin-inline: auto; margin-bottom: var(--space-6); text-align: center; }
  .split { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-8); align-items: center; }
  .split__text > * + * { margin-top: var(--space-4); }
  .split__media { margin: 0; line-height: 0; }
  .split__media img { width: 100%; height: auto; display: block; border-radius: var(--radius-lg); box-shadow: var(--shadow-md); }
  .checks { list-style: none; display: flex; flex-direction: column; gap: var(--space-3); }
  .checks li { display: flex; align-items: flex-start; gap: var(--space-2); color: var(--color-text); }
  .checks :global(.check) { color: var(--color-secondary-azure); flex-shrink: 0; margin-top: 3px; }
  @media (max-width: 880px) { .split { grid-template-columns: 1fr; gap: var(--space-6); } .split__media { order: -1; } }
  .faq { max-width: 800px; margin-inline: auto; display: flex; flex-direction: column; gap: var(--space-3); }
  .faq__item { border: 1px solid var(--color-border); border-radius: var(--radius-md); background: var(--color-bg); padding: 0 var(--space-5); }
  .faq__item summary { display: flex; align-items: center; justify-content: space-between; gap: var(--space-4); padding: var(--space-4) 0; cursor: pointer; font-weight: var(--font-weight-semibold); list-style: none; }
  .faq__item summary::-webkit-details-marker { display: none; }
  .faq__chev { transition: transform var(--duration-base) var(--easing); color: var(--color-text-muted); }
  .faq__item[open] .faq__chev { transform: rotate(180deg); }
  .faq__a { padding-bottom: var(--space-5); }
</style>
