---
/**
 * ABX HARSYS — Kontakt / O nás.
 * Obsah z obsah/kontakty-abx-software.md + obsah/o-abx-software.md. Komponenty z @piano/ui.
 */
import Base from '../layouts/Base.astro';
import Header from '@piano/ui/components/Header.astro';
import Footer from '@piano/ui/components/Footer.astro';
import Section from '@piano/ui/components/Section.astro';
import Hero from '@piano/ui/components/Hero.astro';
import Heading from '@piano/ui/components/Heading.astro';
import Text from '@piano/ui/components/Text.astro';
import Icon from '@piano/ui/components/Icon.astro';
import USPGrid from '@piano/ui/components/USPGrid.astro';
import LeadForm from '@piano/ui/components/LeadForm.astro';
import { harsysNav, harsysCta } from '../config/nav';

const offices = [
  { city: 'Karlovy Vary — centrála', phone: '774 719 494', phoneHref: 'tel:+420774719494', email: 'office@ab-x.cz', note: 'Závodu míru 739/9a, 360 17 Karlovy Vary' },
  { city: 'Praha', phone: '734 230 090', phoneHref: 'tel:+420734230090', email: 'praha@ab-x.cz', note: 'Obchodní zastoupení' },
  { city: 'Ostrava', phone: '774 719 494', phoneHref: 'tel:+420774719494', email: 'office@ab-x.cz', note: 'Obchodní zastoupení' },
  { city: 'Technická podpora a servis', phone: '353 034 111', phoneHref: 'tel:+420353034111', email: 'podpora@ab-x.cz', note: 'Po–Pá 8:00–16:00, Podpora PLUS na vyžádání' },
];

const company = [
  { icon: 'lucide:award', title: '25+ let zkušeností', text: 'Patříme mezi přední dodavatele spolehlivých pokladních systémů v České republice.' },
  { icon: 'lucide:users', title: 'Stabilní tým', text: 'Na vývoji, instalacích i podpoře se podílí zkušení programátoři, technici a obchodní zástupci.' },
  { icon: 'lucide:map', title: 'Po celé ČR', text: 'Sídlo v Karlových Varech, stálé zastoupení v Praze a Ostravě, prodejci i v dalších městech.' },
  { icon: 'lucide:wrench', title: 'Předvedení a servis', text: 'Předvedení, instalaci i servis zajišťujeme po celé České republice.' },
];

const leadProofs = [
  { icon: 'lucide:clock', title: 'Reagujeme rychle', text: 'Požadavek začneme řešit nejpozději další pracovní den.' },
  { icon: 'lucide:wrench', title: 'Zakázky neodmítáme', text: 'I velmi specifické požadavky doprogramujeme.' },
  { icon: 'lucide:headset', title: 'Nejlepší podpora', text: 'K nám se dovoláte snadno.' },
];
---

<Base title="Kontakty ABX software | ABX HARSYS"
      description="Kontakty na ABX software s.r.o. — centrála Karlovy Vary, obchodní zastoupení Praha a Ostrava, technická podpora a servis. Napište nám nebo zavolejte.">
  <Header brand="ABX HARSYS" logoSrc="/logos/abx_logo.svg" logoHeight="26px" homeHref="/" nav={harsysNav} cta={harsysCta} />

  <Hero eyebrow="Kontakty" background="gradient"
        lead="Naši lidé čekají na vaše zavolání. Ozvěte se nám — poradíme s výběrem, předvedením i instalací pokladního systému Harsys.">
    <Heading slot="title" as="h1" size="display" color="on-dark">Spojte se s <span class="accent">ABX software</span></Heading>
  </Hero>

  <!-- KONTAKTY -->
  <Section background="default" space="lg">
    <div class="offices">
      {offices.map((o) => (
        <article class="office">
          <Heading as="h2" size="h3">{o.city}</Heading>
          <Text size="small" color="muted">{o.note}</Text>
          <a class="office__row" href={o.phoneHref}><Icon name="lucide:phone" size="sm" />{o.phone}</a>
          <a class="office__row" href={`mailto:${o.email}`}><Icon name="lucide:mail" size="sm" />{o.email}</a>
        </article>
      ))}
    </div>
    <div class="ico"><Text size="small" color="muted" align="center">ABX software s.r.o. · IČ: 27968588 · DIČ: CZ27968588 · provozní doba Po–Pá 8:00–15:00</Text></div>
  </Section>

  <!-- O FIRMĚ -->
  <USPGrid eyebrow="O ABX software" title="Dodavatel spolehlivých pokladních systémů"
           lead="Vyvinuli jsme profesionální pokladní software, který ulehčuje práci podnikatelům v gastronomii i obchodě."
           items={company} columns={4} minItemWidth="230px" background="alt" space="lg" />

  <!-- FORMULÁŘ -->
  <LeadForm id="poptavka" variant="full" background="default"
            title="Napište nám"
            lead="Nechte nám kontakt — ozveme se co nejdříve a poradíme s výběrem řešení pro váš provoz."
            proofs={leadProofs} successUrl="/dekujeme" />

  <Footer logoSrc="/logos/abx_by_piano.svg" logoAlt="ABX HARSYS by Piano" />
</Base>

<style>
  .offices { display: grid; gap: var(--space-5); grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); }
  .office { background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: var(--space-6); box-shadow: var(--shadow-sm); display: flex; flex-direction: column; gap: var(--space-2); }
  .office__row { display: inline-flex; align-items: center; gap: var(--space-2); color: var(--color-primary); text-decoration: none; font-weight: var(--font-weight-medium); margin-top: var(--space-1); }
  .office__row:hover { color: var(--color-primary-hover); }
  .ico { margin-top: var(--space-6); }
</style>
