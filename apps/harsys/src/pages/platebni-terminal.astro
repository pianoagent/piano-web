---
/**
 * ABX HARSYS — Platební terminál.
 * Obsah z obsah/platebni-terminal-pro-restaurace.md. Komponenty z @piano/ui.
 */
import Base from '../layouts/Base.astro';
import Header from '@piano/ui/components/Header.astro';
import Footer from '@piano/ui/components/Footer.astro';
import Section from '@piano/ui/components/Section.astro';
import Hero from '@piano/ui/components/Hero.astro';
import Heading from '@piano/ui/components/Heading.astro';
import Text from '@piano/ui/components/Text.astro';
import Button from '@piano/ui/components/Button.astro';
import Icon from '@piano/ui/components/Icon.astro';
import USPGrid from '@piano/ui/components/USPGrid.astro';
import LeadForm from '@piano/ui/components/LeadForm.astro';
import { harsysNav, harsysCta } from '../config/nav';

const benefits = [
  { icon: 'lucide:link', title: 'Propojení s pokladnou', text: 'Částka se z pokladny přenese automaticky — odpadají chyby z ručního zadávání.' },
  { icon: 'lucide:list-checks', title: 'Nabídka od více poskytovatelů', text: 'Zprostředkujeme nabídky a vy si vyberete tu nejvýhodnější.' },
  { icon: 'lucide:layers', title: 'Klidně více terminálů', text: 'Podle potřeby můžete provozovat i více terminálů zároveň.' },
  { icon: 'lucide:coins', title: 'Poradíme se spropitným', text: 'Poradíme, jak naložit se spropitným z plateb kartou.' },
];

const providers = ['pay-global-payments', 'pay-teya', 'pay-csob', 'pay-moneta'];

const faqs = [
  { q: 'Mám účet v jiné bance, její terminály nemáte. Jak postupovat?', a: 'Pro propojení s pokladnou potřebujete terminál od některého z našich poskytovatelů. Banku ale měnit nemusíte — poskytovatelé posílají peníze do jakékoli banky.' },
  { q: 'Jaké jsou poplatky a kolik stojí napojení na pokladnu?', a: 'Pokud smlouvu zprostředkujeme my, je napojení zdarma. Poplatky jsou individuální dle počtu a objemu transakcí. Rádi zajistíme nabídku od více poskytovatelů.' },
];

const leadProofs = [
  { icon: 'lucide:gift', title: 'Napojení zdarma', text: 'Při zprostředkování smlouvy od nás.' },
  { icon: 'lucide:credit-card', title: 'NFC i z mobilního číšníka', text: 'Dle typu terminálu a poskytovatele.' },
  { icon: 'lucide:handshake', title: 'Vyberete nejlepší nabídku', text: 'Porovnáme poskytovatele za vás.' },
];
---

<Base title="Platební terminál pro restaurace | ABX HARSYS"
      description="Platební terminál propojený s pokladnou Harsys — částka se přenese automaticky. Zprostředkujeme nabídku od více poskytovatelů (Global Payments, Teya, ČSOB, EVO/Moneta), napojení zdarma.">
  <Header brand="ABX HARSYS" logoSrc="/logos/abx_logo.svg" logoHeight="26px" homeHref="/" nav={harsysNav} cta={harsysCta} />

  <main>
  <Hero eyebrow="Platební terminál" background="gradient"
        lead="Bezhotovostní platby ve vaší restauraci za nejlepších podmínek. Terminál provozujete samostatně nebo propojený s pokladnou — částka se přenese automaticky, bez chyb z ručního zadávání.">
    <Heading slot="title" as="h1" size="display" color="on-dark">Platby kartou <span class="accent">bez chyb</span></Heading>
    <Fragment slot="actions">
      <Button href="#poptavka">Chci nabídku</Button>
      <Button href="/integrace" variant="secondary" onDark>Další integrace</Button>
    </Fragment>
  </Hero>

  <USPGrid eyebrow="Proč terminál od nás" title="Nejlepší podmínky pro bezhotovostní platby"
           items={benefits} columns={4} minItemWidth="230px" background="default" space="lg" />

  <!-- POSKYTOVATELÉ -->
  <Section background="alt" space="lg">
    <div class="head">
      <Text size="label" color="accent" align="center">Naši poskytovatelé</Text>
      <Heading as="h2" size="h2" align="center">Vyberete si tu <span class="accent">nejlepší nabídku</span></Heading>
      <Text size="lead" color="muted" align="center" balance>Spolupracujeme s Global Payments (Česká spořitelna), Teya, ČSOB a EVO (Moneta). Na vyžádání zajistíme nabídku od více poskytovatelů — při zprostředkování od nás je napojení zdarma.</Text>
    </div>
    <div class="providers">
      {providers.map((p) => (<img src={`/logos/${p}.svg`} alt={p.replace('pay-', '').replace(/-/g, ' ')} loading="lazy" />))}
    </div>
    <ul class="checks checks--center">
      <li><Icon name="lucide:check" size="sm" class="check" />Uzávěrky terminálu lze vyvolat z kasy*</li>
      <li><Icon name="lucide:check" size="sm" class="check" />NFC platby i z mobilního číšníka*</li>
    </ul>
    <Text size="small" color="muted" align="center" class="note">* dle typu terminálu a poskytovatele, info na vyžádání</Text>
  </Section>

  <!-- FAQ -->
  <Section background="default" space="lg">
    <div class="head"><Heading as="h2" size="h2" align="center">Časté otázky</Heading></div>
    <div class="faq">
      {faqs.map((f) => (
        <details class="faq__item">
          <summary>{f.q}<Icon name="lucide:chevron-down" size="sm" class="faq__chev" /></summary>
          <div class="faq__a"><Text color="muted">{f.a}</Text></div>
        </details>
      ))}
    </div>
  </Section>

  <LeadForm id="poptavka" variant="callback" background="primary"
            title="Máte zájem o nabídku platebního terminálu?"
            lead="Zanechte číslo a my se vám ozveme. Zajistíme nabídky od více poskytovatelů a pomůžeme vybrat."
            proofs={leadProofs} successUrl="/dekujeme" />

  </main>
  <Footer legal={[{ label: 'Ochrana osobních údajů', href: '/ochrana-udaju' }]} />
</Base>

<style>
  .head { max-width: 760px; margin-inline: auto; margin-bottom: var(--space-6); text-align: center; }
  .head > * + * { margin-top: var(--space-3); }
  .providers { display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: var(--space-7); margin-bottom: var(--space-6); }
  .providers img { height: 40px; width: auto; opacity: 0.8; }
  .checks { list-style: none; display: flex; flex-direction: column; gap: var(--space-3); }
  .checks--center { align-items: center; }
  .checks li { display: flex; align-items: flex-start; gap: var(--space-2); color: var(--color-text); }
  .checks :global(.check) { color: var(--color-secondary-azure); flex-shrink: 0; margin-top: 3px; }
  .note { margin-top: var(--space-3); }
  .faq { max-width: 800px; margin-inline: auto; display: flex; flex-direction: column; gap: var(--space-3); }
  .faq__item { border: 1px solid var(--color-border); border-radius: var(--radius-md); background: var(--color-bg); padding: 0 var(--space-5); }
  .faq__item summary { display: flex; align-items: center; justify-content: space-between; gap: var(--space-4); padding: var(--space-4) 0; cursor: pointer; font-weight: var(--font-weight-semibold); list-style: none; }
  .faq__item summary::-webkit-details-marker { display: none; }
  .faq__chev { transition: transform var(--duration-base) var(--easing); color: var(--color-text-muted); }
  .faq__item[open] .faq__chev { transform: rotate(180deg); }
  .faq__a { padding-bottom: var(--space-5); }
</style>
