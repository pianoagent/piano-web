---
/**
 * ABX HARSYS — homepage.
 * Obsah z podklady starých webů/Harsys/obsah/index.md (+ srovnani, funkce, cenik,
 * reference), layout ověřen proti screenshots/index.png.
 * Vše ze SDÍLENÝCH komponent @piano/ui; téma řeší src/styles/theme.css.
 * Sekce bez vlastní komponenty (Varianty, Pilíře, Stats, Hardware, Reference, FAQ)
 * jsou složené z primitivů — komponenty se NEFORKUJÍ.
 */
import Base from '../layouts/Base.astro';
import Header from '@piano/ui/components/Header.astro';
import Footer from '@piano/ui/components/Footer.astro';
import Section from '@piano/ui/components/Section.astro';
import Hero from '@piano/ui/components/Hero.astro';
import Heading from '@piano/ui/components/Heading.astro';
import Text from '@piano/ui/components/Text.astro';
import Button from '@piano/ui/components/Button.astro';
import Icon from '@piano/ui/components/Icon.astro';
import USPGrid from '@piano/ui/components/USPGrid.astro';
import LeadForm from '@piano/ui/components/LeadForm.astro';
import LogoWall from '@piano/ui/components/LogoWall.astro';
import { harsysNav, harsysCta } from '../config/nav';

const PHONE = '774 719 494';
const PHONE_HREF = 'tel:+420774719494';

/* Varianty programu — 8 klíčových funkcí + bitmaska dostupnosti (z obsah/index.md) */
const variantFeatures = [
  'Adresář, skupiny, ceník',
  'Uzávěrky a sumáře',
  'Skladové hospodářství',
  'Happy Hours',
  'Vzdálený přístup',
  'Denní nabídka',
  'Bonus a kredit systém',
  'Provizní systém pro obsluhu',
];
const variants = [
  { name: 'Lite', desc: 'Pro malý provoz, kde stačí základní funkce a stručný přehled o tržbách', bits: [1,1,0,0,0,0,0,0], buy: '5 900', rent: '390', popular: false },
  { name: 'Gold', desc: 'Pro ty, kteří chtějí vést sklady a mít podrobnější přehled o své restauraci', bits: [1,1,1,1,0,0,0,0], buy: '10 900', rent: '690', popular: true },
  { name: 'Gold+NET', desc: 'Profi varianta s vyspělými funkcemi a možností přístupu přes internet', bits: [1,1,1,1,1,1,0,0], buy: '16 900', rent: '890', popular: false },
  { name: 'Premium', desc: 'Komplexní profi řešení pro střední a větší provozy s maximem funkcí', bits: [1,1,1,1,1,1,1,1], buy: '22 900', rent: '1 290', popular: false },
];

const prednosti = [
  { icon: 'lucide:headset', title: 'Nejlepší podpora na trhu', text: 'O své klienty se staráme. Od školení a vzdálené podpory až po následný servis — dostupná i o svátcích a víkendech.' },
  { icon: 'lucide:line-chart', title: 'Manažerské nástroje', text: 'Umožňují efektivní chod podniku a plnou kontrolu nad tržbou, skladem i ceníkem.' },
  { icon: 'lucide:mouse-pointer-click', title: 'Snadná a rychlá obsluha', text: 'Promyšlené rozhraní s potřebnými funkcemi, snadnou obsluhou a přizpůsobitelným designem.' },
  { icon: 'lucide:shield-check', title: 'Data mimo cloud', text: 'Vaše data jsou ve vaší správě v bezpečí, nikoli v cloudu. Nikdo další je nezpracovává ani neprodává dál.' },
];

const moduly = [
  { img: '/images/mod-mobilni-cisnik.webp', title: 'Mobilní číšník', text: 'Rychlá obsluha zákazníka přímo u stolu. NFC bezkontaktní platby, pro Android zařízení.', href: '/mobilni-cisnik' },
  { img: '/images/mod-viewer.webp', title: 'Viewer', text: 'Náhled do vašeho pokladního systému z mobilu. Data k dispozici i offline — pro Android i iPhone.', href: '/rozsireni' },
  { img: '/images/mod-rozvoz.webp', title: 'Aplikace pro rozvoz', text: 'Vytvoření objednávky v kase na základě telefonního hovoru, propojení s adresářem Harsys.', href: '/rozsireni' },
  { img: '/images/mod-vazena-inventura.webp', title: 'Vážená inventura', text: 'Snadné vážení nápojů namísto pracného odměřování. Váží se při uzávěrce kasy a snižuje ztráty.', href: '/rozsireni' },
];

const stats = [
  { num: '27+', lbl: 'let zkušeností s vývojem' },
  { num: '11 535', lbl: 'registrovaných licencí' },
  { num: '4 108', lbl: 'spokojených zákazníků' },
  { num: '7', lbl: 'dní v týdnu podpora' },
];

const reference = [
  { img: '/images/ref/jan-poloch.webp', name: 'Ing. Jan Poloch', role: 'Startronic Gastro Ostrava, 27+ provozoven', quote: 'Pokladní systém pro restaurace Harsys mi pomáhá úplně se vším. Mám ho rád! Je přehledný a spolehlivý.' },
  { img: '/images/ref/long-story-short.webp', name: 'Petr Heneš', role: 'Long story short, Olomouc', quote: 'S firmou ABX spolupracujeme již celých 6 let. V celém našem podniku vždy maximálně využíváme všechny vychytávky, které jejich pokladní systém nabízí.' },
  { img: '/images/ref/hana-ztratilova.webp', name: 'Hana Ztratilová', role: 'Restaurace Na Špici, Radošov', quote: 'Harsys používáme od roku 2009 a opravdu nám vyhovuje. Nabízí spoustu užitečných funkcí a oceňujeme i podporu, která je vždy připravena pomoci.' },
];

const faqs = [
  { q: 'Jaký je rozdíl mezi Harsysem a jinými pokladnami?', a: 'Rozdíl je v detailu. Harsys vznikl z osobních zkušeností s provozem restaurace — umíme se vžít do vaší situace a máme pochopení pro vaše problémy. Víme, kde v hospodách utíkají peníze, a pomůžeme vám je ohlídat.' },
  { q: 'Všichni říkají, že nejlepší je mít data v cloudu. Opravdu?', a: 'Harsys ukládá data na vašem vlastním počítači, takže k nim nikdo jiný (ani my) nemá přístup. Jsou jen vaše. Zálohu si uložíte kamkoliv chcete — na USB, Google Drive, NAS či vlastní server — a kdykoli ji obnovíte.' },
  { q: 'Můžu později přejít na vyšší variantu?', a: 'Ano. Při upgradu (např. z Lite na Gold) doplácíte jen rozdíl cen dle aktuálního ceníku, ne celou cenu znovu.' },
  { q: 'Když si Harsys nejdřív pronajmu, můžu licenci později koupit?', a: 'Můžete. Na dodatečný nákup doživotní licence vám nabídneme slevu s ohledem na dobu pronájmu.' },
  { q: 'Jak rychle můžu systém mít?', a: 'Váš nový systém můžete mít už za pár dnů — možná i zítra, nejpozději do týdne. Instalaci zvládnete sami, nebo vám asistujeme přes vzdálenou správu.' },
];

const leadProofs = [
  { icon: 'lucide:headset', title: 'Nejlepší podpora na trhu', text: 'Dostupná i o víkendech a svátcích.' },
  { icon: 'lucide:server', title: 'Data ve vašich rukou', text: 'Bez cloudu — jen vy máte přístup.' },
  { icon: 'lucide:calendar-check', title: '27+ let zkušeností', text: '11 535 licencí, 4 108 zákazníků.' },
  { icon: 'lucide:zap', title: 'Rychlý start', text: 'Nový systém klidně už zítra.' },
];
---

<Base title="Spolehlivý pokladní systém pro restaurace | ABX HARSYS"
      description="Spolehlivý pokladní systém Harsys s jednoduchou a rychlou obsluhou a spoustou vychytávek, který usnadní provoz vaší restaurace. Vyzkoušejte zdarma.">
  <Header brand="ABX HARSYS" logoSrc="/logos/abx_logo.svg" logoHeight="26px" homeHref="/" nav={harsysNav} cta={harsysCta} />

  <main>
  <!-- HERO — split: text vlevo, foto pokladny vpravo -->
  <Hero eyebrow="Pokladní systém pro restaurace" background="gradient"
        lead="Spolehlivý pokladní systém s jednoduchou a rychlou obsluhou, nejlepší podporou a spoustou vychytávek, který usnadní provoz vaší restaurace."
        usp={[{ text: '27+ let zkušeností', icon: 'lucide:calendar-check' }, { text: '4 108 zákazníků', icon: 'lucide:users' }, { text: 'Podpora 7 dní v týdnu', icon: 'lucide:headset' }]}>
    <Heading slot="title" as="h1" size="display" color="on-dark">Profesionální pokladní systém pro restaurace</Heading>
    <Fragment slot="actions">
      <Button href="#poptavka">Konzultace zdarma</Button>
      <Button href="/srovnani-variant" variant="secondary" onDark>Srovnání variant</Button>
    </Fragment>
    <figure slot="media" class="hero-figure">
      <img src="/images/hero-pokladna.webp" alt="Dotyková pokladna Harsys v restauračním provozu" width="720" height="540" loading="eager" />
    </figure>
  </Hero>

  <!-- LOGA KLIENTŮ -->
  <LogoWall background="default" label="Důvěřují nám restaurace a provozy po celé ČR"
    logos={['ref-field-michelin-restaurant', 'ref-cafe-savoy', 'ref-kolkovna', 'ref-sasazu', 'ref-O2-arena', 'ref-clarion-hotel', 'ref-zatisi-group', 'ref-420-restaurant', 'ref-pizza-coloseum', 'ref-entree', 'ref-100-chuti-brna', 'ref-sisters-bistro']} />

  <!-- VARIANTY PROGRAMU -->
  <Section id="varianty" background="default" space="lg">
    <div class="head head--center">
      <Text size="label" color="accent" align="center">Varianty programu</Text>
      <Heading as="h2" size="h2" align="center">Čtyři varianty — od <span class="accent">Lite</span> po <span class="accent">Premium</span></Heading>
      <Text size="lead" color="muted" align="center" balance>
        Varianty se liší výbavou. Z nižší na vyšší lze kdykoli přejít, dokupujete jen rozdíl. Ceny jsou uvedeny bez DPH.
      </Text>
    </div>
    <div class="variants">
      {variants.map((v) => (
        <article class={`variant${v.popular ? ' variant--popular' : ''}`}>
          {v.popular && <span class="variant__badge">Nejoblíbenější</span>}
          <span class="variant__name">Harsys {v.name}</span>
          <Text size="small" color="muted" class="variant__desc">{v.desc}</Text>
          <div class="variant__price">
            <span class="variant__price-buy">{v.buy} Kč</span>
            <span class="variant__price-note">doživotní licence</span>
            <span class="variant__price-or">nebo {v.rent} Kč / měsíc</span>
          </div>
          <ul class="variant__feats">
            {variantFeatures.map((f, i) => (
              <li class={v.bits[i] ? 'is-on' : 'is-off'}>
                <Icon name={v.bits[i] ? 'lucide:check' : 'lucide:minus'} size="sm" />{f}
              </li>
            ))}
          </ul>
          <Button href="#poptavka" full variant={v.popular ? 'primary' : 'secondary'}>Mám zájem o {v.name}</Button>
        </article>
      ))}
    </div>
    <div class="variants__cta">
      <Button href="/srovnani-variant" variant="secondary">Podrobné srovnání variant</Button>
      <Button href="/cenik" variant="ghost">Kompletní ceník</Button>
    </div>
  </Section>

  <!-- PŘEDNOSTI -->
  <USPGrid eyebrow="Přednosti systému Harsys" title="Proč si vybrat Harsys"
           lead="Spolehlivý systém, který vznikl z reálných zkušeností s provozem restaurace."
           items={prednosti} columns={4} minItemWidth="240px" background="alt" space="lg" />

  <!-- VOLITELNÁ ROZŠÍŘENÍ -->
  <Section background="default" space="lg">
    <div class="head head--center">
      <Text size="label" color="accent" align="center">Volitelná rozšíření</Text>
      <Heading as="h2" size="h2" align="center">Doplňkové moduly <span class="accent">na míru provozu</span></Heading>
      <Text size="lead" color="muted" align="center" balance>
        Harsys rozšíříte přesně podle potřeb vaší restaurace — od mobilního číšníka po vážené inventury.
      </Text>
    </div>
    <div class="pillars">
      {moduly.map((m) => (
        <a class="pillar" href={m.href}>
          <div class="pillar__media"><img src={m.img} alt={m.title} loading="lazy" /></div>
          <div class="pillar__body">
            <Heading as="h3" size="h3">{m.title}</Heading>
            <Text size="small" color="muted">{m.text}</Text>
          </div>
        </a>
      ))}
    </div>
    <div class="variants__cta">
      <Button href="/funkce" variant="secondary">Všechny funkce programu</Button>
    </div>
  </Section>

  <!-- FUNKCE SPLIT — stolová mapa -->
  <Section background="default" space="lg">
    <div class="split">
      <div class="split__text">
        <Text size="label" color="accent">Restkasa &amp; stolová mapa</Text>
        <Heading as="h2" size="h2">Středobod celého <span class="accent">provozu</span></Heading>
        <Text size="lead" color="muted" balance>
          Účty na stoly, objednávky, bony, rozdělení i sloučení účtů, placení dohromady nebo zvlášť. Vlastní mapu stolů si navrhnete sami a účet přesunete jednoduše prstem.
        </Text>
        <ul class="checks">
          <li><Icon name="lucide:check" size="sm" class="check" />Neomezený počet stolů, židlí i účtů</li>
          <li><Icon name="lucide:check" size="sm" class="check" />Skladové hospodářství a receptury s food cost</li>
          <li><Icon name="lucide:check" size="sm" class="check" />Přehledy prodejů, statistiky a online monitoring</li>
        </ul>
        <div class="split__cta"><Button href="/funkce">Prozkoumat funkce</Button></div>
      </div>
      <figure class="split__media">
        <img src="/images/funkce-stolova-mapa.webp" alt="Markování ve stolové mapě pokladny Harsys" loading="lazy" />
      </figure>
    </div>
  </Section>

  <!-- HARDWARE -->
  <Section id="hardware" background="alt" space="lg">
    <div class="split split--reverse">
      <figure class="split__media">
        <img src="/images/nas-hardware.webp" alt="Pokladní hardware ABX vhodný do gastro provozu" loading="lazy" />
      </figure>
      <div class="split__text">
        <Text size="label" color="accent">Pokladní hardware</Text>
        <Heading as="h2" size="h2">Vyzkoušený hardware <span class="accent">do gastra</span></Heading>
        <Text size="lead" color="muted" balance>
          Nabízíme hardware, který známe a umíme s ním pomoci — opravdu vhodný do náročného restauračního provozu. S instalací a nastavením vám pomůžeme v rámci podpory.
        </Text>
        <ul class="checks">
          <li><Icon name="lucide:check" size="sm" class="check" />Dotykové pokladny, tiskárny a příslušenství</li>
          <li><Icon name="lucide:check" size="sm" class="check" />Ukázkové pokladní sestavy na míru</li>
          <li><Icon name="lucide:check" size="sm" class="check" />Zápůjčka náhradní pokladny po dobu opravy</li>
        </ul>
        <div class="split__cta"><Button href="#poptavka" variant="secondary">Poradíme s hardwarem</Button></div>
      </div>
    </div>
  </Section>

  <!-- REFERENCE -->
  <Section background="default" space="lg">
    <div class="head head--center">
      <Text size="label" color="accent" align="center">Reference</Text>
      <Heading as="h2" size="h2" align="center">Spokojené uživatele najdete <span class="accent">po celé ČR</span></Heading>
    </div>
    <div class="quotes">
      {reference.map((t) => (
        <figure class="quote">
          <span class="quote__mark"><Icon name="lucide:quote" size="md" /></span>
          <blockquote class="quote__text">{t.quote}</blockquote>
          <figcaption class="quote__foot">
            <img class="quote__photo" src={t.img} alt={t.name} loading="lazy" />
            <span class="quote__id">
              <strong class="quote__name">{t.name}</strong>
              <span class="quote__role">{t.role}</span>
            </span>
          </figcaption>
        </figure>
      ))}
    </div>
    <div class="variants__cta">
      <Button href="/reference" variant="secondary">Všechny reference</Button>
    </div>
  </Section>

  <!-- FAQ -->
  <Section id="faq" background="alt" space="lg">
    <div class="head head--center">
      <Heading as="h2" size="h2" align="center">Často kladené otázky</Heading>
      <Text size="lead" color="muted" align="center">Nenašli jste odpověď? Zavolejte nebo nám napište, rádi poradíme.</Text>
    </div>
    <div class="faq">
      {faqs.map((f) => (
        <details class="faq__item">
          <summary>{f.q}<Icon name="lucide:chevron-down" size="sm" class="faq__chev" /></summary>
          <div class="faq__a"><Text color="muted">{f.a}</Text></div>
        </details>
      ))}
    </div>
  </Section>

  <!-- POPTÁVKA -->
  <LeadForm id="poptavka" variant="callback" background="primary"
            title="Zaujal vás pokladní systém Harsys?"
            lead="Zanechte číslo a my se vám ozveme. Nezávazně vám poradíme s výběrem varianty i hardwaru."
            proofs={leadProofs} successUrl="/dekujeme" />
  </main>

  <Footer legal={[{ label: 'Ochrana osobních údajů', href: '/ochrana-udaju' }]} logoSrc="/logos/abx_by_piano.svg" logoAlt="ABX HARSYS by Piano" parentNote={{ text: 'Harsys je součástí skupiny Piano', href: 'https://piano.cz' }} />
</Base>

<style>
  /* Hero foto */
  .hero-figure { margin: 0; width: 100%; line-height: 0; }
  .hero-figure img { width: 100%; height: auto; display: block; border-radius: var(--radius-lg); box-shadow: var(--shadow-lg); }

  /* Sdílená hlavička sekce */
  .head { max-width: 760px; margin-inline: auto; margin-bottom: var(--space-7); }
  .head--center { text-align: center; }
  .head > * + * { margin-top: var(--space-3); }

  /* Varianty */
  .variants { display: grid; gap: var(--space-5); grid-template-columns: repeat(4, 1fr); align-items: stretch; }
  .variant {
    position: relative; display: flex; flex-direction: column; gap: var(--space-3);
    background: var(--color-bg); border: 1px solid var(--color-border);
    border-radius: var(--radius-lg); padding: var(--space-6) var(--space-5);
    box-shadow: var(--shadow-sm); transition: var(--transition);
  }
  .variant:hover { border-color: var(--color-primary); box-shadow: var(--shadow-md); }
  .variant--popular { border-color: var(--color-primary); box-shadow: var(--shadow-md); }
  .variant__badge {
    position: absolute; top: 0; right: var(--space-5); transform: translateY(-50%);
    background: var(--color-secondary-terracotta); color: #fff;
    font-size: var(--font-size-caption); font-weight: var(--font-weight-semibold);
    text-transform: uppercase; letter-spacing: var(--letter-spacing-wide);
    padding: var(--space-1) var(--space-3); border-radius: var(--radius-full);
  }
  .variant__name { font-size: var(--font-size-h3); font-weight: var(--font-weight-bold); color: var(--color-primary); }
  .variant__desc { min-height: 3.4em; }
  .variant__price { display: flex; flex-direction: column; gap: 2px; padding: var(--space-3) 0; border-block: 1px solid var(--color-border); }
  .variant__price-buy { font-size: var(--font-size-h2); font-weight: var(--font-weight-bold); color: var(--color-text); line-height: 1; }
  .variant__price-note { font-size: var(--font-size-caption); color: var(--color-text-muted); text-transform: uppercase; letter-spacing: var(--letter-spacing-wide); }
  .variant__price-or { font-size: var(--font-size-small); color: var(--color-secondary); font-weight: var(--font-weight-medium); margin-top: var(--space-1); }
  .variant__feats { list-style: none; display: flex; flex-direction: column; gap: var(--space-2); flex: 1; }
  .variant__feats li { display: flex; align-items: flex-start; gap: var(--space-2); font-size: var(--font-size-small); }
  .variant__feats li.is-on { color: var(--color-text); }
  .variant__feats li.is-on :global(svg) { color: var(--color-secondary-azure); flex-shrink: 0; margin-top: 2px; }
  .variant__feats li.is-off { color: var(--color-neutral-400); }
  .variant__feats li.is-off :global(svg) { color: var(--color-neutral-300); flex-shrink: 0; margin-top: 2px; }
  .variants__cta { display: flex; gap: var(--space-3); justify-content: center; flex-wrap: wrap; margin-top: var(--space-7); }
  @media (max-width: 980px) { .variants { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .variants { grid-template-columns: 1fr; } }

  /* Pilíře (moduly) */
  .pillars { display: grid; gap: var(--space-6); grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); }
  .pillar {
    display: flex; flex-direction: column;
    background: var(--color-bg); border: 1px solid var(--color-border);
    border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-sm);
    transition: var(--transition); text-decoration: none; color: inherit;
  }
  .pillar:hover { border-color: var(--color-primary); box-shadow: var(--shadow-md); }
  .pillar__media { background: var(--color-bg-alt); line-height: 0; }
  .pillar__media img { width: 100%; height: 180px; object-fit: cover; display: block; }
  .pillar__body { padding: var(--space-5); display: flex; flex-direction: column; gap: var(--space-2); }

  /* Stats band */
  .stats { list-style: none; display: grid; gap: var(--space-5); grid-template-columns: repeat(4, 1fr); text-align: center; }
  .stats__item { display: flex; flex-direction: column; gap: var(--space-1); }
  .stats__num { font-size: var(--font-size-h1); font-weight: var(--font-weight-bold); line-height: 1; color: #fff; }
  .stats__lbl { font-size: var(--font-size-small); color: var(--color-text-on-dark-muted); }
  @media (max-width: 720px) { .stats { grid-template-columns: repeat(2, 1fr); gap: var(--space-6); } }

  /* Split (funkce / hardware) */
  .split { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-8); align-items: center; }
  .split__text > * + * { margin-top: var(--space-4); }
  .split__media { margin: 0; line-height: 0; }
