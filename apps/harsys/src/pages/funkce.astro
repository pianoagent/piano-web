---
/**
 * ABX HARSYS — Funkce programu.
 * Obsah z obsah/funkce-program-system-pro-restaurace-harsys.md. Komponenty z @piano/ui.
 */
import Base from '../layouts/Base.astro';
import Header from '@piano/ui/components/Header.astro';
import Footer from '@piano/ui/components/Footer.astro';
import Section from '@piano/ui/components/Section.astro';
import Hero from '@piano/ui/components/Hero.astro';
import Heading from '@piano/ui/components/Heading.astro';
import Text from '@piano/ui/components/Text.astro';
import Button from '@piano/ui/components/Button.astro';
import Icon from '@piano/ui/components/Icon.astro';
import USPGrid from '@piano/ui/components/USPGrid.astro';
import LeadForm from '@piano/ui/components/LeadForm.astro';
import { harsysNav, harsysCta } from '../config/nav';

const groups = [
  {
    eyebrow: 'Restkasa',
    title: 'Pokladna — středobod celého systému',
    text: 'Účty na stoly, objednávky, bony, rozdělení účtu, přesuny, placení dohromady i zvlášť. Pokladna Harsys toho umí opravdu hodně.',
    items: [
      { icon: 'lucide:layout-dashboard', title: 'Mapa stolů', text: 'Vlastní mapa stolů pro snadnou orientaci v účtech. Účet přesunete ze stolu na stůl jednoduše prstem. Návrhář mapy je součástí programu.' },
      { icon: 'lucide:smartphone', title: 'Mobilní číšník', text: 'K pokladně připojíte jednoho i více mobilních číšníků. Přímo od stolu zapíšete objednávku i vytisknete účtenku.' },
      { icon: 'lucide:receipt', title: 'Uzávěrky', text: 'Denně, týdně nebo při střídání směny. Součástí je rychlá inventura a výčetka hotovosti, stravenek i dalších náležitostí směny.' },
      { icon: 'lucide:wallet', title: 'Vnitřní účty', text: 'Vše projde přes kasu — personální konzumace, firemní stravování „na fakturu", repre i škody. Neomezený počet vnitřních účtů.' },
    ],
  },
  {
    eyebrow: 'Ceník a sklady',
    title: 'Sortiment a skladové hospodářství',
    text: 'Přehledná správa prodejního sortimentu a spolehlivá evidence pohybů a stavů surovin.',
    items: [
      { icon: 'lucide:folder-tree', title: 'Skupiny a sortiment', text: 'Zboží, suroviny i pokrmy přehledně ve skupinách. Prodejní ceník, receptury, food cost i alergeny na jednom místě. Neomezený počet položek.' },
      { icon: 'lucide:package', title: 'Skladové karty a příjemky', text: 'Hned po namarkování uvidíte pohyb ve skladové kartě. Příjem, převod, výdej i odpis — i automaticky přes napojení na AUTSET.' },
      { icon: 'lucide:clipboard-check', title: 'Inventury', text: 'Zboží na baru i v kuchyni zkontrolujete v intervalech dle uvážení. Zápisem skutečných stavů zjistíte přebytek nebo manko.' },
      { icon: 'lucide:grid-2x2', title: 'Dotykový rastr', text: 'Rozložení, velikost i barvy tlačítek si jednoduše nataháte myší přesně podle svého provozu.' },
    ],
  },
  {
    eyebrow: 'Zákazníci',
    title: 'Věrnost, slevy a kredit',
    text: 'Skupinová i individuální správa zákazníků s bonusy, kredity a slevovými programy.',
    items: [
      { icon: 'lucide:contact', title: 'Adresář', text: 'Evidence zákazníků s mnoha možnostmi vyhledávání, archiv účtenek a nastavení kreditního či bonusového systému na jednom místě.' },
      { icon: 'lucide:ticket-percent', title: 'Slevové programy', text: 'Procentní slevy na nápoje a jídlo i komplexní slevové plány zohledňující dosažený obrat. Každý druh položek může mít jinou slevu.' },
      { icon: 'lucide:gift', title: 'Bonusy a kredit', text: 'Registrovaný zákazník sbírá body, které se převádějí na kredit. Slevový poukaz s platností vystavíte i běžnému hostu.' },
      { icon: 'lucide:building', title: 'ARES a e-mailing', text: 'Firemní zákazníky dohledáte podle IČ, data se přenesou automaticky. Kasa odešle účtenku e-mailem i hromadný mailing.' },
    ],
  },
  {
    eyebrow: 'Statistiky a online',
    title: 'Přehledy a sledování provozu',
    text: 'Detailní data s filtry a náhled do systému online — i při vypnuté pokladně.',
    items: [
      { icon: 'lucide:bar-chart-3', title: 'Přehledy prodejů', text: 'Co se jak prodává, na čem nejvíc vyděláváte, co přináší zisk. Dnes, tento týden, měsíc či loni — čím vyšší varianta, tím víc přehledů.' },
      { icon: 'lucide:monitor-dot', title: 'Monitor', text: 'V manažerské části sledujete v reálném čase dění na pokladně — otevřené účty i výši tržby.' },
      { icon: 'lucide:smartphone-nfc', title: 'ABX Viewer', text: 'Restaurace ve vašem mobilu — účty, uzávěrky, stavy zboží i docházka. Pro Android i iPhone, vždy po ruce.' },
      { icon: 'lucide:mail-check', title: 'E-mail a SMS report', text: 'Podrobné zprávy o uzávěrkách a sumáře prodejů do schránky, krátké info o denní tržbě jako SMS — ať jste kdekoli.' },
    ],
  },
];

const leadProofs = [
  { icon: 'lucide:search-x', title: 'Nevidíte funkci?', text: 'Na web se nevejde vše — zeptejte se.' },
  { icon: 'lucide:lightbulb', title: 'Nápady vítáme', text: 'Zajímavé funkce doprogramujeme zdarma.' },
  { icon: 'lucide:headset', title: 'Nejlepší podpora', text: 'K nám se dovoláte snadno.' },
];
---

<Base title="Funkce programu Harsys | ABX HARSYS"
      description="Přehled funkcí pokladního systému Harsys: pokladna, stolová mapa, sklady, zákazníci, statistiky, kuchyně, online sledování i interní logy.">
  <Header brand="ABX HARSYS" logoSrc="/logos/abx_logo.svg" logoHeight="26px" homeHref="/" nav={harsysNav} cta={harsysCta} />

  <main>

  <Hero eyebrow="Funkce programu" background="gradient"
        lead="Harsys vznikl z osobních zkušeností s provozem restaurace. Pokrývá celý provoz — od markování přes sklady a zákazníky až po statistiky a online sledování.">
    <Heading slot="title" as="h1" size="display" color="on-dark">Co všechno <span class="accent">Harsys umí</span></Heading>
    <Fragment slot="actions">
      <Button href="/srovnani-variant">Srovnání variant</Button>
      <Button href="#poptavka" variant="secondary" onDark>Konzultace zdarma</Button>
    </Fragment>
  </Hero>

  {groups.map((g, i) => (
    <USPGrid eyebrow={g.eyebrow} title={g.title} lead={g.text}
             items={g.items} columns={4} minItemWidth="230px"
             background={i % 2 === 0 ? 'default' : 'alt'} space="lg" />
  ))}

  <LeadForm id="poptavka" variant="callback" background="primary"
            title="Chcete se na něco zeptat?"
            lead="Zanechte číslo a my se vám ozveme. Na tento web se nevejde vše, co Harsys umí — rádi vám funkce předvedeme."
            proofs={leadProofs} successUrl="/dekujeme" />

  </main>

  <Footer logoSrc="/logos/abx_by_piano.svg" logoAlt="ABX HARSYS by Piano" parentNote={{ text: 'Harsys je součástí skupiny Piano', href: 'https://piano.cz' }} />
</Base>
