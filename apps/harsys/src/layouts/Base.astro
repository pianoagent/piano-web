---
/**
 * Base — layout webu ABX HARSYS.
 * Načte téma Harsys + sdílenou SEO hlavičku. Definuje Organization schema.
 */
import '../styles/theme.css';
import BaseHead from '@piano/ui/layouts/BaseHead.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  schema?: object;
}

const SITE_NAME = 'ABX HARSYS';
const SITE_URL = 'https://abxharsys.cz';

const {
  title,
  description = 'Harsys — spolehlivý pokladní systém pro restaurace. Snadná obsluha, manažerské nástroje, data mimo cloud a nejlepší podpora na trhu. Vyzkoušejte zdarma.',
  image = '/og-default.jpg',
  type = 'website',
  noindex = false,
  schema,
} = Astro.props;

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'ABX HARSYS',
  legalName: 'ABX software s.r.o.',
  url: SITE_URL,
  logo: `${SITE_URL}/logos/abx_logo.svg`,
  email: 'office@ab-x.cz',
  telephone: '+420774719494',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Závodu míru 739/9a',
    addressLocality: 'Karlovy Vary',
    postalCode: '360 17',
    addressCountry: 'CZ',
  },
  parentOrganization: { '@type': 'Organization', name: 'Piano Solutions', url: 'https://piano.cz' },
};

const schemas = [organizationSchema, ...(schema ? [schema] : [])];
---

<!doctype html>
<html lang="cs">
  <head>
    <BaseHead
      title={title}
      description={description}
      image={image}
      type={type}
      noindex={noindex}
      siteName={SITE_NAME}
      siteUrl={SITE_URL}
      schemas={schemas}
    />
  </head>
  <body>
    <slot />
  </body>
</html>
