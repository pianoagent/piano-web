---
/**
 * SiteHeader — Hugo wrapper nad sdíleným @piano/ui Header.
 * Drží na jednom místě brand, logo a Hugo navigaci (per-web data z config/nav).
 */
import Header from '@piano/ui/components/Header.astro';
import { hugoNav, hugoCta } from '../config/nav';

interface Props { transparent?: boolean; }
const { transparent = false } = Astro.props;
---
<Header brand="Hugo" logoSrc="/logos/hugo_logo.svg" logoHeight="38px" homeHref="/"
        nav={hugoNav} cta={hugoCta} transparent={transparent} />
