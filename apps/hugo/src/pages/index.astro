---
/**
 * Hugo — homepage (one-pager).
 * Obsah vytěžen z mirroru starého webu (podklady-migrace/hugo-website-mirror/
 * _obsah-strukturovany.md). Vše ze SDÍLENÝCH komponent @piano/ui; téma řeší
 * src/styles/theme.css. Sekce bez vlastní komponenty jsou složené z primitivů
 * (Section/Heading/Text/Button) — komponenty se NEFORKUJÍ.
 */
import Base from '../layouts/Base.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import Section from '@piano/ui/components/Section.astro';
import Hero from '@piano/ui/components/Hero.astro';
import Heading from '@piano/ui/components/Heading.astro';
import Text from '@piano/ui/components/Text.astro';
import Button from '@piano/ui/components/Button.astro';
import Icon from '@piano/ui/components/Icon.astro';
import USPGrid from '@piano/ui/components/USPGrid.astro';
import LeadForm from '@piano/ui/components/LeadForm.astro';
import LogoWall from '@piano/ui/components/LogoWall.astro';

const heroStats = [
  { num: '5 min', lbl: 'od stažení k první tržbě' },
  { num: '+19 %', lbl: 'vyšší spropitné, když appka sama nabídne dýško' },
  { num: '−4 h/týd', lbl: 'méně administrativy (DPH, účtenky, foodcost)' },
  { num: '0 Kč', lbl: 'appka, když platby bereš přes Hugo' },
];

const devices = [
  { icon: 'lucide:smartphone', title: 'iOS / iPhone', text: 'Tap to Pay na iPhonu. Žádná čtečka, žádný dongle. Přijmeš jakoukoli bezkontaktní kartu i peněženku.' },
  { icon: 'lucide:tablet-smartphone', title: 'Android', text: 'NFC platby na jakémkoli moderním Androidu. Stejná appka, stejná rychlost, stejný Brain.' },
  { icon: 'lucide:monitor-smartphone', title: '+ všechno ostatní', text: 'Tablet na pultu, web v zázemí, terminál na baru, kuchyně na displeji. Všechno se synchronizuje v reálném čase.' },
];

const trust = [
  'Bez smlouvy, zrušíš kdykoli',
  'Peníze máš další pracovní den',
  'Připraveni na EET 2027',
  'Česká podpora 7 dní v týdnu',
];

const steps = [
  { icon: 'lucide:notebook-pen', tag: 'Objednávka', title: 'Objednávka u stolu', text: 'Ťukni položky, přidej poznámku a pošli do kuchyně, bez odcházení od hosta a čmárání na blok.' },
  { icon: 'lucide:cooking-pot', tag: 'Kuchyně', title: 'Rovnou do kuchyně', text: 'Objednávka je na výdeji ve chvíli, kdy ji potvrdíš. Žádné křičení přes linku, žádné ztracené bonky.' },
  { icon: 'lucide:hand-coins', tag: 'Platba', title: 'Rozděl, spropitné, zaplať', text: 'Rozděl podle položek nebo hostů a pak přijmi kartu, bezkontakt nebo QR jedním ťuknutím. Výzva na spropitné je v ceně.' },
];

const reliability = [
  { icon: 'lucide:wifi-off', title: 'Funguje offline', text: 'Vypadne wifi ve špičce? Markuj dál objednávky i hotovost. Hugo se sesynchronizuje, až budeš zpátky, a účtenky se po návratu EET v roce 2027 zařadí a samy odešlou.' },
  { icon: 'lucide:printer', title: 'Použij, co máš', text: 'Připoj svou tiskárnu účtenek a pokladní zásuvku, nebo jeď úplně bez papíru. Žádná proprietární krabička ke koupi ani pronájmu.' },
  { icon: 'lucide:battery-charging', title: 'Žádná čtečka k nabíjení', text: 'Tap to Pay na iPhonu, NFC na Androidu. Platební terminál žije v telefonu, nic navíc, co bys ztrácel nebo měnil.' },
  { icon: 'lucide:download', title: 'Data jsou tvoje', text: 'Cokoli kdykoli vyexportuješ. Žádné vázání, odejdeš, kdy chceš, a čísla si vezmeš s sebou.' },
];

const brain = [
  { icon: 'lucide:package-search', title: 'Přestaň docházet i přeobjednávat', text: 'Hugo upozorní, co dnes nejspíš dojde a co připravit, takže míň plýtváš a nikdy nevyprodáš hit uprostřed služby.' },
  { icon: 'lucide:calendar-clock', title: 'Naplánuj správné směny', text: 'Uvidíš příští týden po hodinách rušno i klid dřív, než napíšeš rozpis. Míň prostojů, žádná podcezená špička.' },
  { icon: 'lucide:message-circle-question', title: 'Zeptej se vlastními slovy', text: '„Proč bylo v pátek mrtvo?" Dostaneš přímou odpověď s čísly za ní, česky i anglicky.' },
];

const setup = [
  { num: '01', icon: 'lucide:camera', title: 'Ťukni', text: 'Vyfoť svoje tištěné menu. Hugo z něj během vteřin vytáhne položky, ceny i doplňky.', demo: 'Pivo Plzeň 0,5 l, 79 Kč · Smažený sýr, 189 Kč' },
  { num: '02', icon: 'lucide:mic', title: 'Řekni', text: 'Řekni Hugovi, co se změnilo. „Přidej víno Albariño za 89 Kč, u řízku půlporci." Hotovo.', demo: '„Přidáno pod Víno bílé. Chceš i lahev 0,75 l?"' },
  { num: '03', icon: 'lucide:sparkles', title: 'Automaticky', text: 'Hugo se postará o daně, DPH, účtenky, spropitné, dělení účtů i foodcost. Potichu, na pozadí, napořád.', demo: 'DPH a EET 2027 nastaveno · Foodcost z účtenek 34 %' },
];

const migrace = [
  { icon: 'lucide:file-input', title: 'Menu přeneseme za tebe', text: 'Pošli fotku nebo export ze starého systému. Položky, ceny i doplňky složíme my a ty je jen zkontroluješ.' },
  { icon: 'lucide:git-compare-arrows', title: 'Běh paralelně, bez výpadku', text: 'Nech stávající pokladnu běžet, dokud Hugo zkoušíš. Žádný stresující den spuštění, žádné ztracené tržby ve špičce.' },
  { icon: 'lucide:graduation-cap', title: 'Personál zaškolíš za jednu směnu', text: 'Když tvůj tým umí ovládat telefon, zvládne i Hugo. Většině podniků stačí jedna služba.' },
];

const pricing = [
  { icon: 'lucide:gift', title: 'Appka: 0 Kč', text: 'Celá pokladna (objednávky, menu, DPH, reporty) je zdarma, když platby kartou bereš přes Hugo.' },
  { icon: 'lucide:percent', title: 'Jen poplatek z karty', text: 'Malé % z platby kartou, jaké platíš i dnes. Klesá, jak roste obrat.' },
  { icon: 'lucide:credit-card', title: 'Máš vlastní terminál?', text: 'Nech si ho a plať místo toho jeden pevný měsíční paušál. Žádná překvapení.' },
];

const presets = [
  { name: 'Food truck', rev: '~30k Kč / měs' },
  { name: 'Malá kavárna', rev: '~80k Kč / měs' },
  { name: 'Rušné bistro', rev: '~350k Kč / měs' },
  { name: 'Zavedená restaurace', rev: '~1,2M Kč / měs' },
];

const onboarding = [
  'Menu naimportujeme, z fotky nebo ze starého systému',
  '15minutový videohovor, česky, kdy se ti to hodí',
  'Stávající terminál může běžet, dokud přecházíš',
  'Zdarma na start, platíš, až když bereš platby',
];

const faqs = [
  { q: 'Je Hugo opravdu zdarma? V čem je háček?', a: 'Appka je 0 Kč, když platby kartou bereš přes nás. Platíš jen malé % z platby, které klesá, jak rosteš. Máš vlastní terminál? Plať místo toho jeden paušál. Žádný háček, žádná smlouva.' },
  { q: 'Musím podepsat smlouvu?', a: 'Ne. Hugo běží bez smlouvy a zrušíš ho kdykoli. Data si vezmeš s sebou.' },
  { q: 'Jsem na Dotykačce nebo Storyous, bude přechod peklo?', a: 'Nebude. Menu přeneseme za tebe, Hugo rozjedeme vedle stávajícího systému a přepneš, až budeš připravený.' },
  { q: 'Musím kupovat hardware?', a: 'Ne. Tap to Pay na iPhonu nebo NFC na Androidu, který už máš. Vlastní tiskárnu a zásuvku můžeš připojit, ale nemusíš.' },
  { q: 'Kdy dostanu peníze z karet?', a: 'Peníze z plateb kartou máš zpravidla další pracovní den.' },
  { q: 'Co DPH a EET?', a: 'Hugo řeší DPH, účtenky i spropitné automaticky a je připravený na návrat EET v roce 2027. Offline účtenky se po obnovení spojení samy odešlou.' },
];

const leadProofs = [
  { icon: 'lucide:timer', title: 'Spustíš za 5 minut', text: 'Od stažení k první tržbě.' },
  { icon: 'lucide:credit-card', title: 'Bez karty na start', text: 'Platíš, až když bereš platby.' },
  { icon: 'lucide:repeat', title: 'Menu přeneseme zdarma', text: 'Z fotky nebo ze starého systému.' },
  { icon: 'lucide:headset', title: 'Skuteční lidé, česky', text: 'Podpora 7 dní v týdnu.' },
];

const refLogos = [
  'ref-field-michelin-restaurant', 'ref-cafe-savoy', 'ref-kolkovna', 'ref-sasazu',
  'ref-O2-arena', 'ref-clarion-hotel', 'ref-zatisi-group', 'ref-420-restaurant',
  'ref-pizza-coloseum', 'ref-entree', 'ref-100-chuti-brna', 'ref-sisters-bistro',
];
---

<Base title="Pokladna, která se zaplatí za 5 minut | Hugo"
      description="Hugo je moderní pokladna pro kavárny, bary a restaurace. Objednávky, platby kartou, spropitné i účtenky v jedné appce na telefonu, co už máš. Připraveno na EET 2027.">
  <SiteHeader />

  <main>

  <!-- HERO -->
  <Hero eyebrow="Pro české kavárny, bary a restaurace · připraveno na EET 2027" background="gradient"
        lead="Hugo je moderní pokladna pro kavárny, bary a restaurace. Objednávky, menu, platby kartou, spropitné i účtenky v jedné appce na iPhonu nebo Androidu, který už máš. Žádný terminál k pronájmu, žádná týdenní instalace."
        usp={[{ text: 'Spustíš za 5 minut', icon: 'lucide:timer' }, { text: 'Bez karty na start', icon: 'lucide:credit-card' }, { text: 'Zrušíš kdykoli', icon: 'lucide:circle-check' }]}>
    <Heading slot="title" as="h1" size="display" color="on-dark">Jedna appka řídí celý podnik. <em>Na telefonu, co máš.</em></Heading>
    <Fragment slot="actions">
      <Button href="#zacit">Začít zdarma</Button>
      <Button href="#spusteni" variant="secondary" onDark>Podívat se, jak funguje</Button>
    </Fragment>
    <div slot="media" class="hero-card">
      <span class="hero-card__dot" aria-hidden="true"></span>
      <div class="hero-card__body">
        <strong class="hero-card__amount">+30 Kč tip</strong>
        <span class="hero-card__meta">Stůl 14 · právě teď</span>
      </div>
      <Icon name="lucide:bell" size="md" class="hero-card__ico" />
    </div>
  </Hero>

  <!-- STATISTIKY -->
  <Section background="default" space="md">
    <ul class="stats">
      {heroStats.map((s) => (
        <li class="stats__item">
          <span class="stats__num">{s.num}</span>
          <span class="stats__lbl">{s.lbl}</span>
        </li>
      ))}
    </ul>
  </Section>

  <!-- REFERENCE / LOGA -->
  <LogoWall id="reference" logos={refLogos} background="alt"
            label="Pokladnu Piano si vybírají kavárny, bistra i restaurace po celé ČR" />

  <!-- PRODUKT: zařízení -->
  <Section id="produkt" background="default" space="lg">
    <div class="head head--center">
      <Text size="label" color="accent" align="center">Jakékoli zařízení, jedna pokladna</Text>
      <Heading as="h2" size="h2" align="center">Jeden Hugo. <em>iPhone, Android, tablet, terminál.</em></Heading>
      <Text size="lead" color="muted" align="center" balance>
        Žádný proprietární hardware, žádná béžová krabice, co práší u kasy. Podej telefon číšníkovi, opři tablet o bar, na špičku připoj terminál. Všechno se synchronizuje v reálném čase.
      </Text>
    </div>
    <div class="tiles">
      {devices.map((d) => (
        <article class="tile">
          <span class="tile__icon"><Icon name={d.icon} size="md" /></span>
          <Heading as="h3" size="h3">{d.title}</Heading>
          <Text size="small" color="muted">{d.text}</Text>
        </article>
      ))}
    </div>
    <ul class="trust">
      {trust.map((t) => (
        <li class="trust__item"><Icon name="lucide:check" size="sm" />{t}</li>
      ))}
    </ul>
  </Section>

  <!-- NA PLACE: rychlost provozu -->
  <Section background="alt" space="lg">
    <div class="head head--center">
      <Text size="label" color="accent" align="center">Na place</Text>
      <Heading as="h2" size="h2" align="center">Dost rychlé i na <em>páteční nával.</em></Heading>
      <Text size="lead" color="muted" align="center" balance>
        Tvoji lidi nečtou manuály a s Hugem nemusí. Od první objednávky po zaplacený účet je to pár ťuknutí, takže fronta plyne a stoly se točí rychleji.
      </Text>
    </div>
    <ol class="steps">
      {steps.map((s, i) => (
        <li class="step">
          <span class="step__num">{`0${i + 1}`}</span>
          <span class="step__icon"><Icon name={s.icon} size="md" /></span>
          <span class="step__tag">{s.tag}</span>
          <Heading as="h3" size="h3">{s.title}</Heading>
          <Text size="small" color="muted">{s.text}</Text>
        </li>
      ))}
    </ol>
  </Section>

  <!-- SPOLEHLIVOST -->
  <USPGrid id="spolehlivost" eyebrow="Postaveno na spolehlivost"
           title="Pokladna v telefonu, která nezakolísá"
           lead="Vypadne wifi, dojde papír, vybije se hardware? Hugo s tím počítá."
           items={reliability} columns={2} minItemWidth="280px" background="default" space="lg" />

  <!-- CTA proužek -->
  <Section background="primary" space="md">
    <div class="band">
      <div>
        <Heading as="h2" size="h3" color="on-dark">Připravený ještě před polední špičkou.</Heading>
        <Text size="small" color="on-dark-muted">Zdarma s našimi platbami · spustíš za 5 minut · bez karty, bez smlouvy.</Text>
      </div>
      <div class="band__actions">
        <Button href="#zacit">Začít zdarma</Button>
        <Button href="tel:800331122" variant="secondary" onDark>800 331 122</Button>
      </div>
    </div>
  </Section>

  <!-- PIANO BRAIN -->
  <Section id="brain" background="invert" space="lg">
    <div class="head head--center">
      <Text size="label" color="accent" align="center">Vestavěná inteligence · pohání Piano</Text>
      <Heading as="h2" size="h2" align="center" color="on-dark">Řekne ti, <em>co vařit, kdy koho a co naskladnit.</em></Heading>
      <Text size="lead" color="on-dark-muted" align="center" balance>
        Každá objednávka, každá směna, každá změna menu se potichu sčítá. Hugo z toho udělá srozumitelnou radu. Žádné tabulky, žádný analytik, žádný domácí úkol.
      </Text>
    </div>
    <div class="brain">
      {brain.map((b) => (
        <article class="brain__card">
          <span class="brain__icon"><Icon name={b.icon} size="md" /></span>
          <Heading as="h3" size="h3" color="on-dark">{b.title}</Heading>
          <Text size="small" color="on-dark-muted">{b.text}</Text>
        </article>
      ))}
    </div>
    <p class="brain__ask"><Icon name="lucide:sparkles" size="sm" /> „Jak zvednout tržby ve slabých dnech?"</p>
  </Section>

  <!-- SPUŠTĚNÍ: 5 minut -->
  <Section id="spusteni" background="default" space="lg">
    <div class="head head--center">
      <Text size="label" color="accent" align="center">Od krabice k první tržbě za 5 minut</Text>
      <Heading as="h2" size="h2" align="center">Ťukni, řekni, hotovo.</Heading>
      <Text size="lead" color="muted" align="center" balance>
        Hugo se naučí, co prodáváš, jak to prodáváš a kam patří doplňky. Z fotky menu, z tvého hlasu nebo z účtenek z minulého týdne. Žádný technik v polokošili, žádný týden zaškolování.
      </Text>
    </div>
    <ol class="setup">
      {setup.map((s) => (
        <li class="setup__item">
          <span class="setup__num">{s.num}</span>
          <span class="setup__icon"><Icon name={s.icon} size="md" /></span>
          <Heading as="h3" size="h3">{s.title}</Heading>
          <Text size="small" color="muted">{s.text}</Text>
          <span class="setup__demo">{s.demo}</span>
        </li>
      ))}
    </ol>
  </Section>

  <!-- MIGRACE -->
  <USPGrid eyebrow="Přecházíš odjinud"
           title="Už jsi na Dotykačce nebo Storyous? Těžkou práci uděláme my."
           lead="Šest let stará pokladna se 140 položkami není práce na pět minut a my to nepředstíráme. Přeneseme menu, rozjedeme Hugo vedle stávajícího systému a přepneme, až budeš připravený."
           items={migrace} columns={3} background="alt" space="lg" />

  <!-- CENÍK -->
  <Section id="cenik" background="default" space="lg">
    <div class="head head--center">
      <Text size="label" color="accent" align="center">Ceník</Text>
      <Heading as="h2" size="h2" align="center">Hugo je zdarma, <em>když platby bereš s námi.</em></Heading>
      <Text size="lead" color="muted" align="center" balance>
        Žádné fixní smlouvy, žádné skryté řádky. Platíš jen malé % z platby kartou, které klesá, jak roste tvůj obrat.
      </Text>
    </div>
    <div class="price">
      {pricing.map((p) => (
        <article class="price__card">
          <span class="price__icon"><Icon name={p.icon} size="md" /></span>
          <Heading as="h3" size="h3">{p.title}</Heading>
          <Text size="small" color="muted">{p.text}</Text>
        </article>
      ))}
    </div>
    <div class="presets">
      <Text size="label" color="muted" align="center">Začni od typického provozu</Text>
      <ul class="presets__list">
        {presets.map((p) => (
          <li class="preset"><strong>{p.name}</strong><span>{p.rev}</span></li>
        ))}
      </ul>
    </div>
  </Section>

  <!-- MANIFEST -->
  <Section background="primary" space="lg">
    <div class="head head--center">
      <Heading as="h2" size="h2" align="center" color="on-dark">Skutečná síla. <em>Nula tření.</em></Heading>
      <Text size="lead" color="on-dark-muted" align="center" balance>
        Žádné telefonáty. Žádné papírování. Hugo je pro provozovatele, kteří byznys řídí daty, ne pocity. Pokud jsi to ty, můžeš jet ještě před polední špičkou. Dnes.
      </Text>
    </div>
  </Section>

  <!-- ONBOARDING -->
  <Section background="alt" space="lg">
    <div class="onb">
      <div class="onb__text">
        <Text size="label" color="accent">Onboarding zdarma · bez závazku</Text>
        <Heading as="h2" size="h2">Přejdi za den. <em>Nastavíme to s tebou.</em></Heading>
        <Text size="lead" color="muted">
          Založ si účet a bereš platby během pár minut. Chceš pomoct? Domluv si bezplatný 15minutový hovor, naimportujeme tvoje menu a rozjedeš to před další špičkou.
        </Text>
        <Button href="#zacit">Domluvit migraci zdarma</Button>
      </div>
      <ul class="onb__list">
        {onboarding.map((o) => (
          <li class="onb__item"><Icon name="lucide:check" size="sm" />{o}</li>
        ))}
      </ul>
    </div>
  </Section>

  <!-- FAQ -->
  <Section background="default" space="lg">
    <div class="head head--center">
      <Text size="label" color="accent" align="center">Než se rozhodneš</Text>
      <Heading as="h2" size="h2" align="center">Otázky, co padají nejčastěji.</Heading>
    </div>
    <div class="faq">
      {faqs.map((f) => (
        <details class="faq__item">
          <summary>{f.q}<Icon name="lucide:chevron-down" size="sm" class="faq__chev" /></summary>
          <div class="faq__a"><Text color="muted">{f.a}</Text></div>
        </details>
      ))}
    </div>
  </Section>

  <!-- ZAČNI / REGISTRACE -->
  <LeadForm id="zacit" variant="full" background="alt"
            title="Začni s Hugem."
            lead="Založ si účet hned, nebo nech kontakt a do 24 hodin zavoláme a nastavíme to s tebou. Bez karty, bez závazku. Radši zavoláš? 800 331 122, zdarma, 7 dní v týdnu."
            proofs={leadProofs} />

  </main>

  <SiteFooter />
</Base>

<style>
  /* Hero — plovoucí notifikační karta */
  .hero-card {
    display: flex; align-items: center; gap: var(--space-4);
    background: rgba(255, 253, 245, 0.08);
    border: 1px solid var(--color-border-on-dark);
    border-radius: var(--radius-lg);
    padding: var(--space-5) var(--space-6);
    box-shadow: var(--shadow-lg);
    backdrop-filter: blur(6px);
    max-width: 360px;
  }
  .hero-card__dot { width: 12px; height: 12px; border-radius: 50%; background: var(--color-secondary-yellow); flex-shrink: 0; box-shadow: 0 0 0 6px rgba(255, 223, 44, 0.18); }
  .hero-card__body { display: flex; flex-direction: column; gap: 2px; margin-right: auto; }
  .hero-card__amount { font-size: var(--font-size-lead); font-weight: var(--font-weight-bold); color: var(--color-text-on-dark); }
  .hero-card__meta { font-size: var(--font-size-small); color: var(--color-text-on-dark-muted); }
  .hero-card__ico { color: var(--color-secondary-yellow); }

  /* Sdílená hlavička sekce */
