---
/**
 * Base — layout webu piano.cz.
 * Globálně: téma, SEO hlavička, Header + <main> + Footer.
 * Stránky dodávají JEN vnitřní obsah (do <slot/>). Hlavička/patička se tak
 * nastavují na jednom místě.
 */
import '../styles/theme.css';
import BaseHead from '@piano/ui/layouts/BaseHead.astro';
import Header from '@piano/ui/components/Header.astro';
import Footer from '@piano/ui/components/Footer.astro';
import { companyNav, contact } from '@piano/ui/config/nav';

// Patička piano.cz: sloupce Společnost / Pobočky / Kontakt (telefon + e-mail na konci).
const footerColumns = [{ heading: 'Společnost', links: companyNav }];
const footerOffices = { heading: 'Pobočky', items: contact.offices };
const footerContact = {
  heading: 'Kontakt',
  items: [
    { value: contact.company },
    { label: 'IČ', value: contact.ic },
    { label: 'DIČ', value: contact.dic },
    { value: contact.phone, href: `tel:${contact.phone.replace(/\s/g, '')}` },
    { value: contact.email, href: `mailto:${contact.email}` },
  ],
};

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  schema?: object;             // JSON-LD per stránka
  headerTransparent?: boolean; // overlay header přes hero (per stránka)
  contactBand?: boolean;       // globální pruh „Spojte se s námi" nad patičkou (default true)
}

const SITE_NAME = 'Piano';
const SITE_URL = 'https://piano.cz';
const LOGO = '/logos/piano_color.svg';

const {
  title,
  description = 'Piano, technologie pro restaurace a hotely. Pokladní systémy, rezervace, online platby a analytika na jednom místě.',
  image = '/og-default.jpg',
  type = 'website',
  noindex = false,
  schema,
  headerTransparent = false,
  contactBand = true,
} = Astro.props;

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Piano Solutions',
  url: SITE_URL,
  logo: `${SITE_URL}${LOGO}`,
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'sales',
    telephone: '+420770320248',
    email: 'info@piano.cz',
    areaServed: 'CZ',
    availableLanguage: ['Czech', 'English'],
  },
  sameAs: ['https://www.linkedin.com/company/piano-solutions'],
};

const schemas = [organizationSchema, ...(schema ? [schema] : [])];
---

<!doctype html>
<html lang="cs">
  <head>
    <BaseHead
      title={title}
      description={description}
      image={image}
      type={type}
      noindex={noindex}
      siteName={SITE_NAME}
      siteUrl={SITE_URL}
      schemas={schemas}
    />
  </head>
  <body>
    <Header logoSrc={LOGO} transparent={headerTransparent} />
    <main>
      <slot />
    </main>

    <!-- Globální kontaktní pruh nad patičkou (cíl odkazu „Kontakt" v menu) -->
    {contactBand && (
    <section id="kontakt" class="contactband">
      <div class="contactband__inner">
        <p class="contactband__eyebrow">Konzultace zdarma</p>
        <h2 class="contactband__title">Spojte se s námi</h2>
        <p class="contactband__lead">Zavolejte nebo napište, společně projdeme, co vás zajímá, a najdeme nejlepší řešení přesně pro váš podnik.</p>
        <div class="contactband__links">
          <a href="tel:+420773798758" class="contactband__link"><span>Zavolejte</span>+420 773 798 758</a>
          <a href="mailto:info@piano.cz" class="contactband__link"><span>Napište</span>info@piano.cz</a>
        </div>
      </div>
    </section>
    )}

    <Footer logoSrc={LOGO} logoAlt="Piano" columns={footerColumns} offices={footerOffices} contact={footerContact} />
  </body>
</html>

<style>
  .contactband { background: var(--color-bg-warm, #FFF5E8); border-top: 1px solid var(--color-border); }
  .contactband__inner { max-width: var(--container-max); margin: 0 auto; padding: var(--space-8) var(--container-pad); text-align: center; }
  .contactband__eyebrow { font-size: var(--font-size-label); font-weight: var(--font-weight-semibold); text-transform: uppercase; letter-spacing: var(--letter-spacing-wide); color: var(--color-text-accent); }
  .contactband__title { font-size: var(--font-size-h2); margin-top: var(--space-2); }
  .contactband__lead { max-width: 560px; margin: var(--space-3) auto 0; color: var(--color-text-muted); }
  .contactband__links { display: flex; flex-wrap: wrap; gap: var(--space-5); justify-content: center; margin-top: var(--space-6); }
  .contactband__link {
    display: inline-flex; flex-direction: column; align-items: center; gap: 2px;
    padding: var(--space-4) var(--space-7); background: var(--color-bg);
    border: 1px solid var(--color-border); border-radius: var(--radius-md);
    text-decoration: none; color: var(--color-text);
    font-size: var(--font-size-lead); font-weight: var(--font-weight-semibold); transition: var(--transition);
  }
  .contactband__link span { font-size: var(--font-size-caption); font-weight: var(--font-weight-medium); text-transform: uppercase; letter-spacing: var(--letter-spacing-wide); color: var(--color-text-muted); }
  .contactband__link:hover { border-color: var(--color-primary); color: var(--color-primary); transform: translateY(-2px); }
</style>
