---
/**
 * Base — layout webu piano.cz.
 * Globálně: téma, SEO hlavička, Header + <main> + Footer.
 * Stránky dodávají JEN vnitřní obsah (do <slot/>). Hlavička/patička se tak
 * nastavují na jednom místě.
 */
import '../styles/theme.css';
import BaseHead from '@piano/ui/layouts/BaseHead.astro';
import Header from '@piano/ui/components/Header.astro';
import Footer from '@piano/ui/components/Footer.astro';
import {
  getNav, getCompanyNav, getLegalNav, getHeaderCta,
  contactInfo, ui, switchHref, stripLocale, EN_READY, localeFromPath,
  type Locale,
} from '../i18n';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  schema?: object;             // JSON-LD per stránka
  headerTransparent?: boolean; // overlay header přes hero (per stránka)
  contactBand?: boolean;       // globální pruh „Spojte se s námi" nad patičkou (default true)
  locale?: Locale;             // jazyk stránky (default dle URL: /en/ → en, jinak cs)
}

const SITE_NAME = 'Piano';
const SITE_URL = 'https://piano.cz';
const LOGO = '/logos/piano_color.svg';

const {
  title,
  description = 'Piano, technologie pro restaurace a hotely. Pokladní systémy, rezervace, online platby a analytika na jednom místě.',
  image = '/og-default.png',
  type = 'website',
  noindex = false,
  schema,
  headerTransparent = false,
  contactBand = true,
  locale = localeFromPath(Astro.url.pathname),
} = Astro.props;

const t = ui[locale];
const homeHref = locale === 'en' ? '/en/' : '/';

// Navigace + patička v jazyce stránky
const nav = getNav(locale);
const headerCta = getHeaderCta(locale);
const footerColumns = [{ heading: t.footerCompany, links: getCompanyNav(locale) }];
const footerOffices = { heading: t.footerOffices, items: contactInfo.offices };
const footerContact = {
  heading: t.footerContact,
  items: [
    { value: contactInfo.company },
    { label: 'IČ', value: contactInfo.ic },
    { label: 'DIČ', value: contactInfo.dic },
    { value: contactInfo.phone, href: `tel:${contactInfo.phone.replace(/\s/g, '')}` },
    { value: contactInfo.email, href: `mailto:${contactInfo.email}` },
  ],
};

// Přepínač jazyků + hreflang (jen když existuje EN protějšek)
const langSwitch = { href: switchHref(Astro.url.pathname, locale), label: t.switchTo, title: t.switchLabel };
const canonicalPath = stripLocale(Astro.url.pathname);
const hasAlt = EN_READY.has(canonicalPath);
const alternates = hasAlt
  ? [
      { lang: 'cs', href: new URL(canonicalPath, SITE_URL).href },
      { lang: 'en', href: new URL(canonicalPath === '/' ? '/en/' : '/en' + canonicalPath, SITE_URL).href },
      { lang: 'x-default', href: new URL(canonicalPath, SITE_URL).href },
    ]
  : [];

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Piano Solutions',
  url: SITE_URL,
  logo: `${SITE_URL}${LOGO}`,
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'sales',
    telephone: '+420770320248',
    email: 'info@piano.cz',
    areaServed: 'CZ',
    availableLanguage: ['Czech', 'English'],
  },
  sameAs: ['https://www.linkedin.com/company/piano-solutions'],
};

const schemas = [organizationSchema, ...(schema ? [schema] : [])];
---

<!doctype html>
<html lang={locale}>
  <head>
    <!-- Google Search Console — ověření přes HTML tag (DNS na hostingu blokované) -->
    <meta name="google-site-verification" content="KgZuNpYxxMSjYosWLt0mC_2B8zkvHz-DUCYw_HbbtKw" />
    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-NC3PW2KC');</script>
    <!-- End Google Tag Manager -->
    <BaseHead
      title={title}
      description={description}
      image={image}
      type={type}
      noindex={noindex}
      siteName={SITE_NAME}
      siteUrl={SITE_URL}
      locale={locale === 'en' ? 'en_US' : 'cs_CZ'}
      alternates={alternates}
      schemas={schemas}
    />
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-NC3PW2KC"
      height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <Header logoSrc={LOGO} transparent={headerTransparent} homeHref={homeHref} nav={nav} cta={headerCta} localeSwitch={langSwitch} />
    <main>
      <slot />
    </main>

    <!-- Globální kontaktní pruh nad patičkou (cíl odkazu „Kontakt" v menu) -->
    {contactBand && (
    <section id="kontakt" class="contactband">
      <div class="contactband__inner">
        <p class="contactband__eyebrow">{t.contactEyebrow}</p>
        <h2 class="contactband__title">{t.contactTitle}</h2>
        <p class="contactband__lead">{t.contactLead}</p>
        <div class="contactband__links">
          <a href="tel:+420773798758" class="contactband__link"><span>{t.contactCall}</span>+420 773 798 758</a>
          <a href="mailto:info@piano.cz" class="contactband__link"><span>{t.contactWrite}</span>info@piano.cz</a>
        </div>
      </div>
    </section>
    )}

    <Footer logoSrc={LOGO} logoAlt="Piano" homeHref={homeHref} tagline={t.footerTagline}
            columns={footerColumns} offices={footerOffices} contact={footerContact} legal={getLegalNav(locale)} />
  </body>
</html>

<style>
  .contactband { background: var(--color-bg-warm, #FFF5E8); border-top: 1px solid var(--color-border); }
  .contactband__inner { max-width: var(--container-max); margin: 0 auto; padding: var(--space-8) var(--container-pad); text-align: center; }
  .contactband__eyebrow { font-size: var(--font-size-label); font-weight: var(--font-weight-semibold); text-transform: uppercase; letter-spacing: var(--letter-spacing-wide); color: var(--color-text-accent); }
  .contactband__title { font-size: var(--font-size-h2); margin-top: var(--space-2); }
  .contactband__lead { max-width: 560px; margin: var(--space-3) auto 0; color: var(--color-text-muted); }
  .contactband__links { display: flex; flex-wrap: wrap; gap: var(--space-5); justify-content: center; margin-top: var(--space-6); }
  .contactband__link {
    display: inline-flex; flex-direction: column; align-items: center; gap: 2px;
    padding: var(--space-4) var(--space-7); background: var(--color-bg);
    border: 1px solid var(--color-border); border-radius: var(--radius-md);
    text-decoration: none; color: var(--color-text);
    font-size: var(--font-size-lead); font-weight: var(--font-weight-semibold); transition: var(--transition);
  }
  .contactband__link span { font-size: var(--font-size-caption); font-weight: var(--font-weight-medium); text-transform: uppercase; letter-spacing: var(--letter-spacing-wide); color: var(--color-text-muted); }
  .contactband__link:hover { border-color: var(--color-primary); color: var(--color-primary); transform: translateY(-2px); }
</style>
