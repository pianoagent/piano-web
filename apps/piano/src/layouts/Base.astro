---
/**
 * Base — layout webu piano.cz.
 * Globálně: téma, SEO hlavička, Header + <main> + Footer.
 * Stránky dodávají JEN vnitřní obsah (do <slot/>). Hlavička/patička se tak
 * nastavují na jednom místě.
 */
import '../styles/theme.css';
import BaseHead from '@piano/ui/layouts/BaseHead.astro';
import Header from '@piano/ui/components/Header.astro';
import Footer from '@piano/ui/components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  schema?: object;             // JSON-LD per stránka
  headerTransparent?: boolean; // overlay header přes hero (per stránka)
}

const SITE_NAME = 'Piano';
const SITE_URL = 'https://piano.cz';
const LOGO = '/logos/piano_color.svg';

const {
  title,
  description = 'Piano — technologie pro restaurace a hotely. Pokladní systémy, rezervace, online platby a analytika na jednom místě.',
  image = '/og-default.jpg',
  type = 'website',
  noindex = false,
  schema,
  headerTransparent = false,
} = Astro.props;

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Piano Solutions',
  url: SITE_URL,
  logo: `${SITE_URL}${LOGO}`,
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'sales',
    telephone: '+420770320248',
    email: 'info@piano.cz',
    areaServed: 'CZ',
    availableLanguage: ['Czech', 'English'],
  },
  sameAs: ['https://www.linkedin.com/company/piano-solutions'],
};

const schemas = [organizationSchema, ...(schema ? [schema] : [])];
---

<!doctype html>
<html lang="cs">
  <head>
    <BaseHead
      title={title}
      description={description}
      image={image}
      type={type}
      noindex={noindex}
      siteName={SITE_NAME}
      siteUrl={SITE_URL}
      schemas={schemas}
    />
  </head>
  <body>
    <Header logoSrc={LOGO} transparent={headerTransparent} />
    <main>
      <slot />
    </main>
    <Footer logoSrc={LOGO} logoAlt="Piano" />
  </body>
</html>
