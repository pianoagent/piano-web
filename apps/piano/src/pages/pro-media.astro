---
/**
 * Pro média — piano.cz/pro-media (tiskové centrum).
 * Vzhled dle předlohy: tiskové zprávy, videorozhovory, napsali o nás, media kit.
 */
import Base from '../layouts/Base.astro';
import Section from '@piano/ui/components/Section.astro';
import Heading from '@piano/ui/components/Heading.astro';
import Text from '@piano/ui/components/Text.astro';
import Button from '@piano/ui/components/Button.astro';
import Icon from '@piano/ui/components/Icon.astro';

const releases = [
  { date: '20. 5. 2026', title: 'Češi konzumují jinak. Preferují nealko, platí bezhotovostně a v zimě chodí do restaurací méně.', pdf: '/press/tz-trendy-spotreba-platby.pdf' },
  { date: '21. 4. 2026', title: 'Čtyři značky, jedna rodina. Piano spouští první kampaň v tempu gastro světa.', pdf: '/press/tz-prvni-kampan-gastro.pdf' },
  { date: '9. 2. 2026', title: 'Piano Group a.s., budovaná investiční skupinou Miton, dokončila akvizici sedmi technologických firem a jejich systémů.', pdf: '/press/tz-akvizice.pdf' },
];

const videos = [
  { publisher: 'Reflex', date: '5. 2. 2026', title: 'Gastropodnik 2025: Vaše oblíbená hospoda si zaslouží být vidět, říká Tomáš Mráz z holdingu Piano', href: 'https://www.reflex.cz/clanek/byznys-x/134019/gastropodnik-2025-vase-oblibena-hospoda-si-zaslouzi-byt-videt-rika-tomas-mraz-z-holdingu-piano.html' },
  { publisher: 'iDNES.cz', date: '5. 3. 2026', title: 'Berou jen hotovost a pak se diví prázdné hospodě? Trendem je QR kód', href: 'https://www.idnes.cz/ekonomika/domaci/idnes-lounge-digitalizace-pohostinstvi-restaurace-qerko.A260302_130547_eko-doprava_vov' },
  { publisher: 'e15', date: '2. 4. 2026', title: 'Pod Lupou: České gastro sbírá uznání, zároveň bojuje o lidi. Bez změn bude tlak jen sílit', href: 'https://www.e15.cz/podcasty/pod-lupou-ceske-gastro-sbira-uznani-zaroven-bojuje-o-lidi-bez-zmen-bude-tlak-jen-silit-1431865' },
];

const articles = [
  { publisher: 'Euro', title: 'Jak ušetřit až čtvrtinu nákladů a zvýšit tržby. Kostelný z Piana popisuje problémy současné české gastronomie', href: 'https://www.euro.cz/clanky/jak-usetrit-az-ctvrtinu-nakladu-a-zvysit-trzby-restaurace-kostelny-z-piana-popisuje-problemy-soucasne-ceske-gastronomie/' },
  { publisher: 'Ekonom', title: 'EET měla narovnat trh, ale víc změnila chování podniků. Teď se vrací s jednodušší verzí a novými riziky', href: 'https://ekonom.cz/c1-67873800-eet-mela-narovnat-trh-ale-vic-zmenila-chovani-podniku-ted-se-vraci-s-jednodussi-verzi-a-novymi-riziky' },
  { publisher: 'MediaGuru', title: 'Piano Group zahajuje první kampaň, propojuje své značky', href: 'https://www.mediaguru.cz/piano-group-zahajuje-prvni-kampan-propojuje-sve-znacky' },
  { publisher: 'CzechCrunch', title: 'Při placení obědů ji miluje statisíce lidí. Teď mění majitele českou aplikaci, kterou poháněli i investoři Alzy', href: 'https://cc.cz/pri-placeni-obedu-ji-miluji-statisice-lidi-ted-meni-majitele-ceskou-aplikaci-pohaneli-i-investori-alzy/' },
  { publisher: 'CzechCrunch', title: 'Miton spojuje svých osm gastroprojektů pod novou značku. Letos cílí na čtvrtmiliardové tržby', href: 'https://cc.cz/miton-spojuje-svych-osm-gastroprojektu-pod-novou-znacku-letos-cili-na-ctvrtmiliardove-trzby/' },
];

const mediaKit = 'https://drive.google.com/drive/folders/1-W3kD79LVz5aMy6kSGHNwJgnJflyGvcr?usp=sharing';
---

<Base title="Pro média — Piano v médiích"
      description="Tiskové centrum Piano: tiskové zprávy, videorozhovory, články a media kit ke stažení i kontakt pro novináře.">

  <section class="pm-hero">
    <div class="pm-hero__overlay"></div>
    <div class="pm-hero__inner">
      <p class="pm-hero__eyebrow">Pro média</p>
      <h1 class="pm-hero__title">Piano <em>v médiích</em></h1>
      <p class="pm-hero__lead">Zde najdete tiskové zprávy, rozhovory, videa a veškeré podklady pro novináře.</p>
    </div>
  </section>

  <!-- Tiskové zprávy -->
  <Section background="default" space="lg">
    <Heading as="h2" size="h2" align="center" class="pm-h">Tiskové zprávy Piano</Heading>
    <div class="pm-grid">
      {releases.map((r) => (
        <article class="pm-release">
          <Text size="caption" color="muted">{r.date}</Text>
          <p class="pm-release__title">{r.title}</p>
          <a class="pm-link" href={r.pdf} target="_blank" rel="noopener"><Icon name="lucide:download" size="xs" /> Stáhnout PDF</a>
        </article>
      ))}
    </div>
  </Section>

  <!-- Videorozhovory -->
  <Section background="warm" space="lg">
    <Heading as="h2" size="h2" align="center" class="pm-h">Videorozhovory</Heading>
    <div class="pm-grid">
      {videos.map((v) => (
        <article class="pm-video">
          <span class="pm-video__pub">{v.publisher}</span>
          <a class="pm-video__thumb" href={v.href} target="_blank" rel="noopener" aria-label={v.title}>
            <span class="pm-video__play"><Icon name="lucide:play" size="md" /></span>
          </a>
          <p class="pm-card__title">{v.title}</p>
          <Text size="caption" color="muted">{v.date}</Text>
          <Button href={v.href} variant="secondary" size="sm" target="_blank" rel="noopener noreferrer">Přehrát</Button>
        </article>
      ))}
    </div>
  </Section>

  <!-- Napsali o nás -->
  <Section background="default" space="lg">
    <Heading as="h2" size="h2" align="center" class="pm-h">Napsali o nás</Heading>
    <div class="pm-grid pm-grid--articles">
      {articles.map((a) => (
        <article class="pm-article">
          <span class="pm-article__pub">{a.publisher}</span>
          <p class="pm-card__title">{a.title}</p>
          <Button href={a.href} variant="secondary" size="sm" target="_blank" rel="noopener noreferrer">Přečíst článek</Button>
        </article>
      ))}
    </div>
  </Section>

  <!-- Media kit -->
  <Section id="media-kit" background="warm" space="lg" container="narrow">
    <div class="pm-kit">
      <Text size="label" color="accent" align="center">Media kit</Text>
      <Heading as="h2" size="h2" align="center" class="pm-h">Loga a brand podklady ke stažení</Heading>
      <Text color="muted" align="center" class="pm-kit__sub">Stáhněte si kompletní mediální balíček Piana a jednotlivých firem jako Qerko, Septim či Pecosta. Obsahuje loga ve všech formátech a jejich brand guidelines.</Text>
      <Button href={mediaKit} target="_blank" rel="noopener noreferrer">Stáhnout media kit</Button>
    </div>
  </Section>

  <!-- Kontakt pro novináře -->
  <Section id="kontakt-media" background="invert" space="lg" container="narrow">
    <div class="pm-contact">
      <Text size="label" color="on-dark-muted" align="center">Kontakt pro novináře</Text>
      <Heading as="h2" size="h2" color="on-dark" align="center" class="pm-h">Mluvčí Piana</Heading>
      <Text color="on-dark-muted" align="center" class="pm-kit__sub">Pro tiskové dotazy, rozhovory a domluvení návštěvy v provozech našich zákazníků se obracejte přímo na nás. Odpovídáme do dvou pracovních hodin.</Text>
      <div class="pm-contact__links">
        <a href="mailto:media@piano.cz"><Icon name="lucide:mail" size="sm" /> media@piano.cz</a>
        <a href="tel:+420774722222"><Icon name="lucide:phone" size="sm" /> +420 774 722 222</a>
      </div>
    </div>
  </Section>

</Base>

<style>
  /* Hero s obrázkovým pozadím + vycentrovaný text */
  .pm-hero { position: relative; background: var(--color-neutral-900) url('/images/promedia-hero.webp') center / cover no-repeat; }
  .pm-hero__overlay { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(0,0,0,.35), rgba(0,0,0,.6)); }
  .pm-hero__inner { position: relative; max-width: 760px; margin: 0 auto; padding: var(--space-9) var(--container-pad); text-align: center; display: flex; flex-direction: column; align-items: center; }
  .pm-hero__eyebrow { font-family: var(--font-sans); font-size: var(--font-size-label); font-weight: var(--font-weight-semibold); text-transform: uppercase; letter-spacing: var(--letter-spacing-wide); color: var(--color-secondary-gold); margin: 0; }
  .pm-hero__title { color: #fff; font-size: var(--font-size-display); line-height: var(--line-height-tight); margin: var(--space-3) 0 0; }
  .pm-hero__title em { font-family: var(--font-serif); font-style: normal; }
  .pm-hero__lead { color: rgba(255,255,255,.85); font-size: var(--font-size-lead); max-width: 520px; margin: var(--space-4) auto 0; }

  .pm-h { margin-bottom: var(--space-7); }
  .pm-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: var(--space-6); }
  .pm-grid--articles { grid-template-columns: repeat(3, minmax(0, 1fr)); }

  /* Tiskové zprávy — vycentrované */
  .pm-release { display: flex; flex-direction: column; align-items: center; gap: var(--space-2); text-align: center; padding: 0 var(--space-3); }
  .pm-release__title { font-family: var(--font-sans); font-weight: var(--font-weight-semibold); font-size: var(--font-size-lead); line-height: var(--line-height-tight); margin: 0; }
  .pm-link { display: inline-flex; align-items: center; gap: var(--space-1); margin-top: var(--space-1); color: var(--color-text-accent); text-decoration: none; font-weight: var(--font-weight-medium); font-size: var(--font-size-small); text-transform: uppercase; letter-spacing: var(--letter-spacing-wide); }

  /* Karty — společné */
  .pm-card__title { font-family: var(--font-sans); font-weight: var(--font-weight-semibold); font-size: var(--font-size-body); line-height: var(--line-height-tight); margin: 0; }

  /* Videorozhovory */
  .pm-video { display: flex; flex-direction: column; align-items: center; gap: var(--space-2); text-align: center; }
  .pm-video__pub { font-weight: var(--font-weight-bold); font-size: var(--font-size-lead); letter-spacing: var(--letter-spacing-tight); }
  .pm-video__thumb { display: grid; place-items: center; width: 100%; aspect-ratio: 16/9; background: var(--color-neutral-900); border-radius: var(--radius-md); margin: var(--space-1) 0 var(--space-2); }
  .pm-video__play { display: grid; place-items: center; width: 52px; height: 52px; border-radius: var(--radius-full); background: rgba(255,255,255,.16); color: #fff; transition: var(--transition); }
  .pm-video__thumb:hover .pm-video__play { background: var(--color-primary); }
  .pm-video :global(.btn) { margin-top: var(--space-2); }

  /* Napsali o nás */
  .pm-article { display: flex; flex-direction: column; align-items: center; gap: var(--space-3); text-align: center; padding: var(--space-6); background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-md); }
  .pm-article__pub { font-weight: var(--font-weight-bold); font-size: var(--font-size-lead); color: var(--color-text-accent); }
  .pm-article :global(.btn) { margin-top: auto; }

  /* Media kit */
  .pm-kit { display: flex; flex-direction: column; align-items: center; text-align: center; }
  .pm-kit :global(h2) { margin-top: var(--space-2); }
  .pm-kit__sub { max-width: 560px; margin: var(--space-3) auto var(--space-6); }

  /* Kontakt pro novináře */
  .pm-contact { display: flex; flex-direction: column; align-items: center; text-align: center; }
  .pm-contact :global(h2) { margin-top: var(--space-2); }
  .pm-contact__links { display: flex; flex-wrap: wrap; gap: var(--space-5); justify-content: center; margin-top: var(--space-5); }
  .pm-contact__links a { display: inline-flex; align-items: center; gap: var(--space-2); color: var(--color-text-on-dark); text-decoration: none; font-weight: var(--font-weight-medium); }
  .pm-contact__links a:hover { color: var(--color-secondary-gold); }

  @media (max-width: 880px) {
    .pm-grid, .pm-grid--articles { grid-template-columns: 1fr; max-width: 460px; margin: 0 auto; }
  }
</style>
