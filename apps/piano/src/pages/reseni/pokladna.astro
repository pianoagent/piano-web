---
/**
 * Řešení — Pokladní a hotelové systémy (piano.cz/reseni/pokladna).
 * Obsah dle stávajícího webu piano.cz/pokladni-a-hotelove-systemy.
 */
import Base from '../../layouts/Base.astro';
import Hero from '@piano/ui/components/Hero.astro';
import Heading from '@piano/ui/components/Heading.astro';
import Button from '@piano/ui/components/Button.astro';
import USPGrid from '@piano/ui/components/USPGrid.astro';
import LeadForm from '@piano/ui/components/LeadForm.astro';

const benefits = [
  { icon: 'lucide:bar-chart-3', title: 'Přehled až na prvním místě', text: 'Kompletní přehled o tržbách, nákladech a skladech je základním stavebním kamenem úspěchu. Zefektivněte podnikání a zjednodušte si život díky spolehlivému systému s pravidelným servisem a zákaznickou podporou.' },
  { icon: 'lucide:monitor-smartphone', title: 'Kvalitní pracovní prostředí', text: 'Najít uživatelsky přívětivý a intuitivní pokladní systém, se kterým budou zaměstnanci rádi pracovat, je jako hledat jehlu v kupce sena. Stejně jako majitel potřebuje přehled o celém podniku, potřebuje i obsluha absolutní přehled nad tím, co se děje na place, a tím zvyšovat hodnoty objednávek.' },
];
---

<Base title="Pokladní a hotelové systémy, řešení | Piano"
      description="Dostáváme provoz vašeho podniku pod kontrolu. Přehled o tržbách, nákladech a skladech na jednom místě, se servisem a podporou.">

  <Hero eyebrow="Řešení" background="warm"
        lead="Získejte přehled o tom, co se ve vašem podniku děje a kde utrácíte víc, než byste měli."
        usp={[{ text: 'Vše pod jednou střechou', icon: 'lucide:layers' }, { text: '6 000+ podniků', icon: 'lucide:store' }, { text: '10+ nástrojů', icon: 'lucide:grid-2x2' }]}>
    <Heading slot="title" as="h1" size="display">Dostáváme provoz vašeho podniku pod kontrolu</Heading>
    <Fragment slot="actions">
      <Button href="#poptavka">Domluvit konzultaci zdarma</Button>
      <Button href="/produkty" variant="secondary">Prozkoumat nástroje</Button>
    </Fragment>
    <img slot="media" src="/images/cat-pokladna.webp" alt="Pokladní a hotelové systémy, Piano" width="1100" height="733" />
  </Hero>

  <USPGrid eyebrow="Jak to řešíme" title="Provoz pod kontrolou"
           items={benefits} columns={2} background="default" minItemWidth="320px" />

  <LeadForm id="poptavka" variant="full"
            title="Získejte pokladní systém přímo pro vás"
            lead="Kontaktujte nás pro konzultaci zdarma, navrhneme řešení šité na míru vašemu provozu." />
</Base>
