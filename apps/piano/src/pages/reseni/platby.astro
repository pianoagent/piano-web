---
/**
 * Řešení — Platby a komunikace s hosty (piano.cz/reseni/platby).
 * Obsah dle stávajícího webu piano.cz/platby-a-komunikace-s-hosty.
 */
import Base from '../../layouts/Base.astro';
import Hero from '@piano/ui/components/Hero.astro';
import Heading from '@piano/ui/components/Heading.astro';
import Button from '@piano/ui/components/Button.astro';
import USPGrid from '@piano/ui/components/USPGrid.astro';
import LeadForm from '@piano/ui/components/LeadForm.astro';

const benefits = [
  { icon: 'lucide:utensils', title: 'Více obsloužených stolů', text: 'Platba hostům i obsluze zabírá zbytečně moc času. Ve špičce hosté čekající na zaplacení zabírají místo nově příchozím a obsluha řeší platby místo objednávek. Nechte hosty zaplatit samostatně — obsloužíte jich víc a výrazně zvýšíte tržby.' },
  { icon: 'lucide:message-circle-heart', title: 'Lepší komunikace s hosty', text: 'Poznejte lépe své zákazníky, objevte štamgasty a odměňte je za věrnost. Získejte víc pozitivních recenzí, sledujících na sociálních sítích i neveřejnou konstruktivní zpětnou vazbu.' },
];
---

<Base title="Platby a komunikace s hosty — řešení | Piano"
      description="Zrychlujeme platby a zvyšujeme obrátkovost stolů. Obslužte více stolů, zvyšte tržby o statisíce a dýška až o 40 %.">

  <Hero eyebrow="Řešení" background="warm"
        lead="Obslužte více stolů, zvyšte tržby o statisíce a dýška až o 40 %."
        usp={[{ text: 'Vše pod jednou střechou', icon: 'lucide:layers' }, { text: '6 000+ podniků', icon: 'lucide:store' }, { text: '10+ nástrojů', icon: 'lucide:grid-2x2' }]}>
    <Heading slot="title" as="h1" size="display">Zrychlujeme platby a zvyšujeme obrátkovost stolů</Heading>
    <Fragment slot="actions">
      <Button href="#poptavka">Domluvit konzultaci zdarma</Button>
      <Button href="/produkty" variant="secondary">Prozkoumat nástroje</Button>
    </Fragment>
    <img slot="media" src="/images/cat-platby.webp" alt="Platby a komunikace s hosty — Piano" width="1100" height="733" />
  </Hero>

  <USPGrid eyebrow="Jak to řešíme" title="Rychlejší platby, spokojenější hosté"
           items={benefits} columns={2} background="default" minItemWidth="320px" />

  <LeadForm id="poptavka" variant="full"
            title="Vyřešte rychlejší platby a komunikaci s hosty ještě dnes"
            lead="Kontaktujte nás pro konzultaci zdarma — navrhneme řešení šité na míru vašemu provozu." />
</Base>
