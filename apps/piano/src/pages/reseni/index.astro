---
/**
 * Řešení — rozcestník (piano.cz/reseni).
 * Řešení podle problému + odkaz na All-in-One platformu.
 */
import Base from '../../layouts/Base.astro';
import Section from '@piano/ui/components/Section.astro';
import Hero from '@piano/ui/components/Hero.astro';
import Heading from '@piano/ui/components/Heading.astro';
import Text from '@piano/ui/components/Text.astro';
import Button from '@piano/ui/components/Button.astro';
import Icon from '@piano/ui/components/Icon.astro';
import LeadForm from '@piano/ui/components/LeadForm.astro';

const areas = [
  { icon: 'lucide:monitor', title: 'Pokladní a hotelové systémy', problem: 'Chaos v objednávkách a skladu', href: '/reseni/pokladna' },
  { icon: 'lucide:credit-card', title: 'Platby a komunikace s hosty', problem: 'Fronty, nízká dýška, nulové recenze', href: '/reseni/platby' },
  { icon: 'lucide:shopping-cart', title: 'Nákupy a sklady', problem: 'Předražené suroviny, ruční přepisování', href: '/reseni/nakupy' },
  { icon: 'lucide:users', title: 'Lidé a personál', problem: 'Chybějící brigádníci, chaos ve směnách', href: '/reseni/personal' },
];
---

<Base title="Řešení pro váš provoz | Piano"
      description="Řešení šitá na míru vašemu provozu — od pokladen a plateb po nákupy, sklady a personál. Jeden ekosystém, jeden poplatek z obratu, jedna faktura.">

  <Hero eyebrow="Řešení" background="warm"
        lead="Ať vás trápí cokoliv — fronty u placení, předražené nákupy nebo věčné shánění lidí — máme propojené nástroje, které to vyřeší.">
    <Heading slot="title" as="h1" size="display">Řešení šitá na míru vašemu provozu</Heading>
    <Fragment slot="actions">
      <Button href="#poptavka">Domluvit konzultaci zdarma</Button>
      <Button href="/produkty" variant="secondary">Prozkoumat nástroje</Button>
    </Fragment>
  </Hero>

  <Section background="default" space="lg">
    <div class="res-head">
      <Text size="label" color="accent" align="center">Řešení podle problému</Text>
      <Heading as="h2" size="h2" align="center">Co dnes řešíte?</Heading>
    </div>
    <div class="res-grid">
      {areas.map((a) => (
        <a class="res-card" href={a.href}>
          <span class="res-card__icon"><Icon name={a.icon} size="md" /></span>
          <Heading as="h3" size="h3">{a.title}</Heading>
          <Text size="small" color="muted">{a.problem}</Text>
          <span class="res-card__link">Zobrazit řešení <Icon name="lucide:arrow-right" size="xs" /></span>
        </a>
      ))}
    </div>
  </Section>

  <Section background="primary" space="lg" container="narrow">
    <div class="res-allin">
      <Text size="label" color="on-dark-muted" align="center">All-in-One platforma</Text>
      <Heading as="h2" size="h2" color="on-dark" align="center">Jeden ekosystém, jeden poplatek z obratu, jedna faktura</Heading>
      <Text color="on-dark-muted" align="center" class="res-allin__sub">Nemusíte řešit každý problém zvlášť. Piano propojuje pokladny, platby, nákupy, sklady i personál do jednoho celku — bez integrací a dvojího zadávání.</Text>
      <div class="res-allin__cta"><Button href="/produkty" variant="secondary" onDark>Prozkoumat ekosystém</Button></div>
    </div>
  </Section>

  <LeadForm id="poptavka" variant="full"
            title="Kontaktujte nás ještě dnes pro konzultaci zdarma"
            lead="Ozvěte se a navrhneme řešení šité na míru vašemu provozu." />
</Base>

<style>
  .res-head { max-width: 640px; margin: 0 auto var(--space-7); }
  .res-head :global(h2) { margin-top: var(--space-2); }
  .res-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: var(--space-5); max-width: 900px; margin: 0 auto; }
  .res-card {
    display: flex; flex-direction: column; gap: var(--space-2);
    padding: var(--space-6); background: var(--color-bg); border: 1px solid var(--color-border);
    border-radius: var(--radius-md); text-decoration: none; color: var(--color-text); transition: var(--transition);
  }
  .res-card:hover { border-color: var(--color-primary); transform: translateY(-4px); box-shadow: var(--shadow-lg, 0 18px 40px rgba(0,0,0,.12)); }
  .res-card__icon { display: grid; place-items: center; width: 48px; height: 48px; border-radius: var(--radius-sm); background: var(--color-bg-accent-soft, rgba(190,30,45,.08)); color: var(--color-primary); margin-bottom: var(--space-2); }
  .res-card__link { display: inline-flex; align-items: center; gap: var(--space-1); margin-top: var(--space-2); color: var(--color-text-accent); font-weight: var(--font-weight-medium); font-size: var(--font-size-small); }

  .res-allin { text-align: center; }
  .res-allin :global(h2) { margin-top: var(--space-2); }
  .res-allin__sub { margin-top: var(--space-3); }
  .res-allin__cta { margin-top: var(--space-6); }

  @media (max-width: 720px) { .res-grid { grid-template-columns: 1fr; } }
</style>
