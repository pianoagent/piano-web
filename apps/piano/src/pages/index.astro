---
/**
 * Piano — homepage piano.cz
 * Spojení nejlepšího z původního WP webu (obsah: pain pointy, kategorie,
 * ekosystém, reference, FAQ) a referenčního webu (silný hero, stats, logo wall).
 * Vše ze sdílených komponent @piano/ui; produkty žijící na piano.cz odkazují
 * dovnitř, ostatní na demo <produkt>-web.pages.dev.
 */
import Base from '../layouts/Base.astro';
import Section from '@piano/ui/components/Section.astro';
import Hero from '@piano/ui/components/Hero.astro';
import Heading from '@piano/ui/components/Heading.astro';
import Text from '@piano/ui/components/Text.astro';
import Button from '@piano/ui/components/Button.astro';
import Icon from '@piano/ui/components/Icon.astro';
import USPGrid from '@piano/ui/components/USPGrid.astro';
import LeadForm from '@piano/ui/components/LeadForm.astro';
import LogoWall from '@piano/ui/components/LogoWall.astro';

const stats = [
  { num: '6 000+', lbl: 'podniků v ČR nám důvěřuje' },
  { num: '36 mld Kč', lbl: 'proteče přes naše nástroje ročně' },
  { num: '30 let', lbl: 'inovací v gastronomii' },
  { num: '10+', lbl: 'propojených nástrojů' },
];

// Novinky od Piana — vlastní vlajkové produkty (spotlight hned pod hero)
const novinky = [
  { suffix: 'PILOT', image: '/images/hero-pilot.webp', text: 'Celý provoz v jedné mobilní aplikaci — tržby, sklad i AI doporučení v reálném čase.', href: '/pilot' },
  { suffix: 'TERMINÁL', image: '/images/hero-terminal.webp', text: 'Platební Terminál, který platbou kartou teprve začíná — data o hostech a platby dodavatelům.', href: '/terminal' },
];

// Hero — rotující sdělení (mění se nadpis + lead + obrázek; CTA a USP zůstávají)
const heroSlides = [
  {
    eyebrow: 'Technologie pro gastronomii a hotely',
    title: 'Všechny klíčové nástroje pro pohostinství pod&nbsp;jednou střechou',
    lead: 'Piano představuje sehraný orchestr nástrojů, který vyladí váš provoz, ušetří vám čas a zvýší zisk. Ať už provozujete restauraci, kavárnu, bistro, jídelnu či hotel, máme pro vás řešení.',
    image: '/images/home-hero-dark.webp',
    imageAlt: 'Piano — pokladna, terminál a mobilní aplikace',
  },
  {
    eyebrow: 'Novinka — Piano Pilot',
    title: 'Celý provoz v jedné mobilní aplikaci',
    lead: 'Tržby, sklad i AI doporučení v reálném čase. S Pilotem máte přehled o podniku odkudkoliv — přímo z telefonu.',
    image: '/images/hero-pilot.webp',
    imageAlt: 'Piano Pilot — mobilní aplikace pro provoz',
  },
  {
    eyebrow: 'Novinka — Piano Terminál',
    title: 'Terminál, který platbou teprve začíná',
    lead: 'Data o hostech a automatické platby dodavatelům. Z obyčejného platebního terminálu děláme chytrý nástroj pro celý provoz.',
    image: '/images/hero-terminal.webp',
    imageAlt: 'Piano Terminál — platební terminál',
  },
];

const pains = [
  { icon: 'lucide:user-x', title: 'Nedostatek personálu', text: 'Neustálé hledání nových lidí je drahé a únavné. Kvalitních lidí je čím dál méně.' },
  { icon: 'lucide:clock', title: 'Úbytek zákazníků', text: 'Dlouhé čekání na objednání nebo platbu znamená ztrátu tržeb.' },
  { icon: 'lucide:file-stack', title: 'Zdlouhavé papírování', text: 'Nástroje a systémy nespolupracují, nebo neumí to, co potřebujete.' },
  { icon: 'lucide:trending-up', title: 'Rostoucí ceny', text: 'Marže se zmenšují, ceny se špatně kontrolují, dodavatelé zdražují.' },
];

const categories = [
  { img: '/images/cat-nakupy.webp', title: 'Nákupy a sklady', headline: 'Nakupujte chytře, skladujte přesně', text: 'Skladové hospodářství, automatické naskladňování z dodacích listů a lepší ceny u dodavatelů — vše propojené.', items: ['Skladové hospodářství', 'Automatické naskladňování', 'Lepší ceny u dodavatelů'] },
  { img: '/images/cat-personal.webp', title: 'Lidé a personál', headline: 'Personál, který nechybí', text: 'Více obsloužených hostů, plánování směn i nábor brigádníků na pár kliknutí.', items: ['Více obsloužených hostů', 'Plánování směn', 'Nábor personálu'] },
  { img: '/images/cat-pokladna.webp', title: 'Pokladní a manažerské systémy', headline: 'Provoz pod kontrolou', text: 'Pokladní systémy, reporting dat a management hotelů — přehled o všem na jednom místě.', items: ['Reporting dat', 'Pokladní systémy', 'Management hotelů'] },
  { img: '/images/cat-platby.webp', title: 'Platby a komunikace s hosty', headline: 'Hosté, kteří se vracejí', text: 'Rychlé platby, rezervace, věrnostní program a komunikace se zákazníkem.', items: ['Komunikace se zákazníkem', 'Rezervační systém', 'Věrnostní program'] },
];

// Ekosystém — odkazy: piano-hosté dovnitř (/), ostatní na ostré produkční domény
const ecosystem = [
  { name: 'Piano Pilot', logo: '/brand/pilot_logo.svg', desc: 'Celý provoz v mobilní aplikaci s daty a AI.', href: '/pilot', badge: 'Novinka' },
  { name: 'Piano Terminál', logo: '/brand/terminal_logo.svg', desc: 'Terminál, který platbou teprve začíná — data o hostech i platby dodavatelům.', href: '/terminal', badge: 'Novinka' },
  { name: 'Septim', logo: '/brand/septim_logo.svg', desc: 'Nejrespektovanější pokladní a provozní systém na trhu.', href: 'https://www.septim.cz' },
  { name: 'Qerko', logo: '/brand/qerko_logo.svg', desc: 'Nejpohodlnější platba u stolu a komunikace s hosty.', href: 'https://www.qerko.com' },
  { name: 'Pecosta', logo: '/brand/pecosta_logo.svg', desc: 'Aukční nákupy surovin — levněji až o 16 %.', href: 'https://www.pecosta.cz' },
  { name: 'Grason', logo: '/brand/grason_logo.svg', desc: 'Brigádníci, plánování směn a papírování v jedné appce.', href: 'https://www.grason.cz' },
  { name: 'Autset', logo: '/brand/autset_logo.svg', desc: 'Automatické naskladňování z dodacích listů.', href: 'https://autset.com' },
  { name: 'ABX Harsys', logo: '/brand/abx_logo.svg', desc: 'Multifunkční pokladní systémy a pokladny.', href: 'https://www.abxharsys.cz' },
  { name: 'Savarin', logo: '/brand/savarin_logo.svg', desc: 'Komplexní řešení pro stravovací a ubytovací provozy.', href: 'https://cominn.cz' },
  { name: 'Protel', logo: '/brand/protel_logo.svg', desc: 'Software pro efektivní řízení hotelů.', href: 'https://www.protelsystems.cz' },
];

const benefits = [
  { icon: 'lucide:lightbulb', title: 'Více času na kreativitu', text: 'Soustřeďte se na nové nápady a cashflow, zatímco tým se věnuje hostům.' },
  { icon: 'lucide:line-chart', title: 'Rychlejší finanční rozhodování', text: 'Přehled cen a nákladů. S námi ušetříte v průměru 16 %.' },
  { icon: 'lucide:users-round', title: 'Spokojenější personál', text: 'Přístup k široké databázi profesí, když vám někdo vypadne — i nastálo.' },
];

const testimonials = [
  { quote: 'Provozní systém Septim je zásadní součástí restaurace FIELD. Díky němu mám jistotu, že celý provoz běží stabilně a efektivně.', author: 'Radek Kašpárek', role: 'Šéfkuchař a zakladatel FIELD' },
  { quote: 'Na Septimu mi nejvíce vyhovuje, že si mohu nadefinovat jakoukoli sestavu a okamžitě dostanu vyhodnocení. Mám pak naprostý přehled.', author: 'Václav Vojíř', role: "Majitel Bugsy's baru" },
  { quote: 'Když dokážeme proces automatizovat — vše na jednom portálu, porovnání cen od konkurence — je to úspora času a ve finále i peněz.', author: 'Lukáš Pytloun', role: 'CEO Pytloun Hotels' },
];

const refLogos = [
  'ref-field-michelin-restaurant', 'ref-cafe-savoy', 'ref-kolkovna', 'ref-sasazu',
  'ref-O2-arena', 'ref-clarion-hotel', 'ref-zatisi-group', 'ref-420-restaurant',
  'ref-pizza-coloseum', 'ref-entree', 'ref-100-chuti-brna', 'ref-sisters-bistro',
];

const faqs = [
  { q: 'Co tvoří skupinu Piano?', a: 'Uskupení chytrých nástrojů, které společně digitalizují a zefektivňují podnikání v gastronomii, hotelnictví a maloobchodu — Septim, Qerko, Grason, POS Experts, Savarin, Harsys, Protel a Pecosta. Každý funguje samostatně, společně tvoří nejkomplexnější řešení pro pohostinství v Česku.' },
  { q: 'Proč bych si měl vybrat zrovna vaše produkty?', a: 'Naše produkty používá přes 6 000 podniků a ročně přes ně proteče 36 miliard Kč. Od pokladen přes platby a řízení personálu po sklady a marketing — šetří čas, minimalizují chyby a zvyšují zisk, ať máte kavárnu, síť restaurací nebo hotel.' },
  { q: 'Kolik budu mít smluv a kontaktů?', a: 'Zatím se pro vás nic nemění — stejný obchodní zástupce i podmínky. Smlouvy a kontakty budeme postupně sjednocovat, vždy s vaším souhlasem a ve váš prospěch.' },
  { q: 'Co mám dělat, když chci další produkty?', a: 'Ozvěte se na +420 773 798 758 nebo info@piano.cz — společně projdeme, co vás zajímá, a najdeme nejlepší řešení pro váš podnik.' },
];

const faqSchema = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
};
---

<Base title="Všechny klíčové nástroje pro pohostinství pod jednou střechou | Piano"
      description="Piano nabízí technologie pro restaurace a hotely od pokladních systémů po personál a marketing vašeho podniku."
      schema={faqSchema}>

  <Hero background="warm" slides={heroSlides}
        usp={[{ text: '6 000+ podniků', icon: 'lucide:store' }, { text: '36 mld Kč ročně', icon: 'lucide:banknote' }, { text: '30 let inovací', icon: 'lucide:calendar-check' }]}>
    <Fragment slot="actions">
      <Button href="#poptavka">Domluvit konzultaci</Button>
      <Button href="#ekosystem" variant="secondary">Prozkoumat ekosystém</Button>
    </Fragment>
  </Hero>

  <!-- NOVINKY OD PIANA — spotlight vlastních produktů -->
  <Section background="primary" space="lg">
    <div class="novinky__head">
      <Text size="label" color="on-dark-muted" align="center">Novinky od Piana</Text>
      <Heading as="h2" size="h2" color="on-dark" align="center">Co jsme postavili sami</Heading>
      <Text color="on-dark-muted" align="center" class="novinky__sub">Vlastní produkty Piana, které posouvají provoz dál — vyvinuté přímo pro české pohostinství.</Text>
    </div>
    <div class="novinky__grid">
      {novinky.map((n) => (
        <a class="nov__card" href={n.href}>
          <div class="nov__media"><img src={n.image} alt={`Piano ${n.suffix}`} loading="lazy" /></div>
          <div class="nov__body">
            <span class="nov__logo"><img src="/logos/piano_color.svg" alt="Piano" /><span>{n.suffix}</span></span>
            <Text size="small" color="muted">{n.text}</Text>
            <span class="nov__link">Zjistit víc <Icon name="lucide:arrow-right" size="xs" /></span>
          </div>
        </a>
      ))}
    </div>
  </Section>

  <!-- PAIN POINTS -->
  <USPGrid eyebrow="Znáte to?" title="Co dnes brzdí váš provoz"
           items={pains} columns={4} background="default" minItemWidth="220px" />

  <!-- KATEGORIE NÁSTROJŮ — sticky scroll -->
  <section class="solscroll" data-solscroll>
    <div class="solscroll__pin" style={`height: ${(categories.length + 1) * 100}vh;`}>
      <div class="solscroll__inner">
        <div class="solscroll__content">

          <!-- Levý sloupec: VEŠKERÝ text (přepínač + rozbalený detail) -->
          <div class="solscroll__text-col">
            <Text size="label" color="accent">Každý provoz je jedinečný</Text>
            <Heading as="h2" size="h3" class="solscroll__title">Široká paleta nástrojů, která se přizpůsobí vám</Heading>

            <nav class="solscroll__acc">
              {categories.map((c, i) => (
                <div class:list={['solscroll__item', i === 0 && 'is-active']} data-item>
                  <button class="solscroll__head" data-navitem data-idx={i} type="button">{c.title}</button>
                  <div class="solscroll__body">
                    <div class="solscroll__body-inner">
                      <Text color="muted" class="solscroll__lead">{c.text}</Text>
                      <ul class="solscroll__list">{c.items.map((it) => <li>{it}</li>)}</ul>
                    </div>
                  </div>
                </div>
              ))}
            </nav>

            <div class="solscroll__dots">
              {categories.map((_, i) => (<span class:list={['solscroll__dot', i === 0 && 'is-active']} data-dot></span>))}
            </div>
          </div>

          <!-- Pravý sloupec: jen velká fotka -->
          <div class="solscroll__media">
            {categories.map((c, i) => (
              <img class:list={['solscroll__photo', i === 0 && 'is-active']} data-photo src={c.img} alt={c.title} loading="lazy" width="900" height="675" />
            ))}
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- EKOSYSTÉM -->
  <Section id="ekosystem" background="default" space="lg">
    <div class="head-center">
      <Text size="label" color="accent" align="center">30 let inovací</Text>
      <Heading as="h2" size="h2" align="center">Sehraný orchestr pro snadný provoz</Heading>
      <Text size="lead" color="muted" align="center" class="head-sub">Každý nástroj funguje samostatně. Společně jsou mnohem silnější.</Text>
    </div>
    <div class="eco">
      {ecosystem.map((p) => (
        <a class="eco__card" href={p.href}>
          {p.badge && <span class="eco__badge">{p.badge}</span>}
          <img class="eco__logo" src={p.logo} alt={p.name} loading="lazy" />
          <span class="eco__desc">{p.desc}</span>
          <span class="eco__more">Zjistit víc <Icon name="lucide:arrow-right" size="xs" /></span>
        </a>
      ))}
    </div>
  </Section>

  <!-- LOGO WALL -->
  <LogoWall background="alt" label="Víc jak 6 000 podniků spoléhá na nástroje od Piana" logos={refLogos} />

  <!-- TESTIMONIALY -->
  <Section background="invert" space="lg">
    <Heading as="h2" size="h2" align="center" color="on-dark">Věří nám ti nejlepší v oboru</Heading>
    <div class="quotes">
      {testimonials.map((t) => (
        <figure class="quote">
          <Text color="on-dark" class="quote__text">„{t.quote}“</Text>
          <figcaption class="quote__by">
            <span class="quote__author">{t.author}</span>
            <span class="quote__role">{t.role}</span>
          </figcaption>
        </figure>
      ))}
    </div>
  </Section>

  <!-- BENEFITY -->
  <USPGrid eyebrow="Co tím získáte" title="Posuňte své podnikání na vyšší úroveň"
           items={benefits} columns={3} background="default" />

  <!-- FAQ -->
  <Section background="alt" space="lg" container="narrow">
    <Heading as="h2" size="h2" align="center">Často kladené dotazy</Heading>
    <div class="faq">
      {faqs.map((f) => (
        <details class="faq__item">
          <summary class="faq__q">{f.q}</summary>
          <div class="faq__a"><Text color="muted">{f.a}</Text></div>
        </details>
      ))}
    </div>
  </Section>

  <!-- LEADFORM -->
  <LeadForm id="poptavka" variant="full"
            title="Kontaktujte nás pro konzultaci zdarma"
            lead="Ozvěte se a uděláme vám nabídku šitou na míru vašemu provozu." />

</Base>

<style>
  /* Novinky od Piana — spotlight */
  .novinky__head { max-width: 720px; margin: 0 auto var(--space-7); text-align: center; }
  .novinky__head :global(h2) { margin-top: var(--space-2); }
  .novinky__sub { margin-top: var(--space-3); }
  .novinky__grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: var(--space-6); max-width: 880px; margin: 0 auto; }

  .nov__card {
    display: flex; flex-direction: column; overflow: hidden;
    background: var(--color-bg); border-radius: var(--radius-lg, 16px);
    text-decoration: none; color: var(--color-text); transition: var(--transition);
  }
  .nov__card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg, 0 18px 40px rgba(0,0,0,.18)); }
  .nov__media {
    display: grid; place-items: center; padding: var(--space-6) var(--space-6) 0;
    background: linear-gradient(180deg, #fff 0%, var(--color-bg-warm, #FFF5E8) 100%);
  }
  .nov__media img { width: 76%; max-width: 240px; height: auto; }
  .nov__body { display: flex; flex-direction: column; gap: var(--space-3); padding: var(--space-5) var(--space-6) var(--space-6); }
  .nov__logo { display: inline-flex; align-items: center; gap: 7px; }
  .nov__logo img { height: 22px; width: auto; }
  .nov__logo span { font-family: var(--font-sans); font-weight: var(--font-weight-bold); font-size: 1.35rem; letter-spacing: .005em; color: var(--color-text); }
  .nov__link { display: inline-flex; align-items: center; gap: var(--space-1); margin-top: var(--space-1); color: var(--color-text-accent); font-weight: var(--font-weight-medium); font-size: var(--font-size-small); }
  @media (max-width: 880px) { .novinky__grid { grid-template-columns: 1fr; max-width: 420px; } }

  .head-center { text-align: center; max-width: 720px; margin: 0 auto var(--space-7); }
  .head-center :global(.head-sub) { margin-top: var(--space-3); }

  /* Stats band */
  .stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-5); text-align: center; }
  .stat { display: flex; flex-direction: column; gap: var(--space-1); }
  .stat__num { font-family: var(--font-sans); font-weight: var(--font-weight-semibold); font-size: clamp(28px, 4vw, 44px); color: var(--color-text-accent); letter-spacing: var(--letter-spacing-tight); }
  .stat__lbl { font-size: var(--font-size-small); color: var(--color-text-muted); }

  /* Kategorie — sticky scroll: VEŠKERÝ text vlevo, velká fotka vpravo */
  .solscroll { background: var(--color-bg-alt); }
  .solscroll__pin { position: relative; }
  .solscroll__inner { position: sticky; top: 0; height: 100vh; display: flex; align-items: center; overflow: hidden; }
  .solscroll__content {
    display: grid; grid-template-columns: 0.82fr 1.18fr; gap: var(--space-8); align-items: center;
    width: 100%; max-width: var(--container-max); margin: 0 auto; padding-inline: var(--container-pad);
  }

  /* Levý sloupec — všechen text */
  .solscroll__title { margin: var(--space-3) 0 var(--space-6); }

  /* Accordion kategorií (přepínač + rozbalený detail aktivní) */
  .solscroll__acc { display: flex; flex-direction: column; gap: var(--space-2); }
  .solscroll__item { border-left: 2px solid var(--color-border); padding-left: var(--space-5); transition: border-color var(--duration-base) var(--easing); }
  .solscroll__item.is-active { border-left-color: var(--color-primary); }
  .solscroll__head {
    text-align: left; background: none; border: none; cursor: pointer; width: 100%;
    font-family: var(--font-sans); font-size: var(--font-size-lead); font-weight: var(--font-weight-medium);
    color: var(--color-text-muted); padding: var(--space-2) 0; transition: var(--transition);
  }
  .solscroll__head:hover { color: var(--color-text); }
  .solscroll__item.is-active .solscroll__head { color: var(--color-text-accent); font-weight: var(--font-weight-semibold); }
  /* tělo — rozbalí se jen u aktivní (grid-rows trik, plynule) */
  .solscroll__body { display: grid; grid-template-rows: 0fr; opacity: 0; transition: grid-template-rows var(--duration-base) var(--easing), opacity var(--duration-base) var(--easing); }
  .solscroll__body > * { overflow: hidden; min-height: 0; }
  .solscroll__item.is-active .solscroll__body { grid-template-rows: 1fr; opacity: 1; padding-bottom: var(--space-3); }
  .solscroll__lead { margin-bottom: var(--space-3); }
  .solscroll__list { list-style: none; display: flex; flex-direction: column; gap: var(--space-2); }
  .solscroll__list li { position: relative; padding-left: var(--space-5); color: var(--color-text-muted); font-size: var(--font-size-small); }
  .solscroll__list li::before { content: "✓"; position: absolute; left: 0; color: var(--color-text-accent); font-weight: 700; }

  .solscroll__dots { display: flex; gap: var(--space-2); margin-top: var(--space-6); }
  .solscroll__dot { width: 7px; height: 7px; border-radius: var(--radius-full); background: var(--color-border-strong); transition: var(--transition); }
  .solscroll__dot.is-active { background: var(--color-primary); transform: scale(1.4); }

  /* Pravý sloupec — velká fotka (cross-fade) */
  .solscroll__media { position: relative; aspect-ratio: 4 / 3; border-radius: var(--radius-md); overflow: hidden; box-shadow: var(--shadow-lg); }
  .solscroll__photo { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0; transition: opacity var(--duration-base) var(--easing); }
  .solscroll__photo.is-active { opacity: 1; }

  /* Mobil / tablet — pin se vypne, všechny kategorie rozbalené, fotky skryté */
  @media (max-width: 880px) {
    .solscroll__pin { height: auto !important; }
    .solscroll__inner { position: static; height: auto; padding-block: var(--space-8); }
    .solscroll__content { grid-template-columns: 1fr; gap: var(--space-5); }
    .solscroll__dots { display: none; }
    .solscroll__head { cursor: default; }
    .solscroll__body, .solscroll__item.is-active .solscroll__body { grid-template-rows: 1fr; opacity: 1; padding-bottom: var(--space-3); }
    .solscroll__media { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .solscroll__photo, .solscroll__body { transition: none; }
  }

  /* Ekosystém */
  .eco { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: var(--space-5); }
  .eco__card { position: relative; display: flex; flex-direction: column; gap: var(--space-2); padding: var(--space-6); background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-md); text-decoration: none; transition: var(--transition); }
  .eco__badge { position: absolute; top: var(--space-4); right: var(--space-4); font-size: var(--font-size-caption); font-weight: var(--font-weight-medium); color: var(--color-primary); background: var(--color-bg-accent-soft, rgba(190,30,45,.08)); padding: 2px var(--space-2); border-radius: var(--radius-full); }
  .eco__card:hover { border-color: var(--color-primary); box-shadow: var(--shadow-md); transform: translateY(-2px); }
  .eco__logo { height: 32px; width: auto; max-width: 72%; object-fit: contain; object-position: left center; align-self: flex-start; margin-bottom: var(--space-3); }
  .eco__desc { font-size: var(--font-size-small); color: var(--color-text-muted); flex: 1; }
  .eco__more { display: inline-flex; align-items: center; gap: var(--space-1); font-size: var(--font-size-small); font-weight: var(--font-weight-medium); color: var(--color-text-accent); margin-top: var(--space-2); }

  /* Logo wall */
  .lw__label { margin-bottom: var(--space-5); }
  .lw { display: flex; flex-wrap: wrap; justify-content: center; align-items: center; gap: var(--space-6) var(--space-7); max-width: var(--container-max); margin: 0 auto; padding-inline: var(--container-pad); }
  .lw img { height: 32px; width: auto; opacity: 0.62; filter: grayscale(1); transition: var(--transition); }
  .lw img:hover { opacity: 1; filter: none; }

  /* Testimonialy */
  .quotes { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: var(--space-5); margin-top: var(--space-6); }
  .quote { display: flex; flex-direction: column; gap: var(--space-4); padding: var(--space-6); border: 1px solid var(--color-border-on-dark); border-radius: var(--radius-md); }
  .quote__text { font-size: var(--font-size-lead); line-height: var(--line-height-lead); }
  .quote__by { display: flex; flex-direction: column; gap: 2px; }
  .quote__author { font-weight: var(--font-weight-semibold); color: var(--color-text-on-dark); }
  .quote__role { font-size: var(--font-size-small); color: var(--color-text-on-dark-muted); }

  /* FAQ */
  .faq { margin-top: var(--space-6); display: flex; flex-direction: column; gap: var(--space-3); }
  .faq__item { background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: var(--space-4) var(--space-5); }
  .faq__q { cursor: pointer; font-family: var(--font-sans); font-weight: var(--font-weight-semibold); color: var(--color-text); list-style: none; display: flex; justify-content: space-between; align-items: center; gap: var(--space-4); }
  .faq__q::-webkit-details-marker { display: none; }
  .faq__q::after { content: "+"; color: var(--color-text-accent); font-size: 1.4em; line-height: 1; flex-shrink: 0; }
  .faq__item[open] .faq__q::after { content: "−"; }
  .faq__a { margin-top: var(--space-3); }

  @media (max-width: 720px) {
    .stats { grid-template-columns: repeat(2, 1fr); gap: var(--space-6) var(--space-4); }
  }
</style>

<script>
  const root = document.querySelector('[data-solscroll]') as HTMLElement | null;
  if (root) {
    const pin = root.querySelector('.solscroll__pin') as HTMLElement;
    const items = Array.from(root.querySelectorAll('[data-item]'));
    const photos = Array.from(root.querySelectorAll('[data-photo]'));
    const navs = Array.from(root.querySelectorAll('[data-navitem]'));
    const dots = Array.from(root.querySelectorAll('[data-dot]'));
    const N = items.length;
    const desktop = window.matchMedia('(min-width: 881px)');
    let current = -1;

    const setActive = (i: number) => {
      if (i === current) return;
      current = i;
      items.forEach((s, n) => s.classList.toggle('is-active', n === i));
      photos.forEach((s, n) => s.classList.toggle('is-active', n === i));
      dots.forEach((s, n) => s.classList.toggle('is-active', n === i));
    };

    const onScroll = () => {
      if (!desktop.matches) return;
      const seg = (pin.offsetHeight - window.innerHeight) / N;
      const scrolled = -pin.getBoundingClientRect().top;
      setActive(Math.max(0, Math.min(N - 1, Math.floor(scrolled / seg))));
    };

    navs.forEach((btn, i) => btn.addEventListener('click', () => {
      const seg = (pin.offsetHeight - window.innerHeight) / N;
      window.scrollTo({ top: pin.offsetTop + i * seg + seg * 0.5, behavior: 'smooth' });
    }));

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll);
    setActive(0);
    onScroll();
  }
</script>
