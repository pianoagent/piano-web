---
/**
 * EET 2.0 — English page piano.cz/en/eet
 * Mirrors the CS page (eet.astro) with the same layout/CSS, translated content.
 * The blog collection stays in Czech (not translated).
 */
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Section from '@piano/ui/components/Section.astro';
import Hero from '@piano/ui/components/Hero.astro';
import Heading from '@piano/ui/components/Heading.astro';
import Text from '@piano/ui/components/Text.astro';
import Button from '@piano/ui/components/Button.astro';
import USPGrid from '@piano/ui/components/USPGrid.astro';
import LeadForm from '@piano/ui/components/LeadForm.astro';
import Icon from '@piano/ui/components/Icon.astro';
import { locPath } from '../../i18n';

const novinky = [
  { icon: 'lucide:hand-coins', title: 'Tax relief on tips', text: 'Voluntary tips of up to 7% of revenue will now be exempt from taxes and levies.' },
  { icon: 'lucide:percent', title: 'Lower VAT on soft drinks', text: 'VAT on non-alcoholic drinks drops from 21% to 12%.' },
  { icon: 'lucide:receipt', title: 'Modernized sales', text: 'No more mandatory receipt printing and simpler record-keeping without needless paperwork.' },
];

// EET vs. EET 2.0 — 5 key differences (per source)
const compare = [
  { icon: 'lucide:receipt', cat: 'Receipt', old: 'Mandatory printing', neu: 'Only on request' },
  { icon: 'lucide:credit-card', cat: 'What is recorded', old: 'Cash and cards', neu: 'In-person payments only' },
  { icon: 'lucide:cpu', cat: 'Hardware', old: 'New equipment', neu: 'Your POS is enough' },
  { icon: 'lucide:file-text', cat: 'Data', old: 'Extensive report', neu: 'Minimal details' },
  { icon: 'lucide:search', cat: 'Inspections', old: 'Blanket inspections', neu: 'Targeted analytics' },
];

// EET 2.0 timeline — legislative milestones
const timeline = [
  { date: 'February 2026', title: 'Start of the comment procedure', state: 'done' },
  { date: 'April 2026', title: 'Resolution of comments', state: 'done' },
  { date: 'May 2026', title: 'Bill passed its first reading', state: 'done' },
  { date: 'June 2026', title: 'Publication of the technical specification', state: 'current' },
  { date: 'July 2026', title: 'Test environment made available', state: 'future' },
  { date: 'November 2026', title: 'Certificate generation in the DIS+ environment', state: 'future' },
  { date: 'December 2026', title: 'Launch of the MOJE EET application', state: 'future' },
  { date: '1 January 2027', title: 'Start of regular EET 2.0 operation', state: 'future' },
  { date: 'January 2027', title: 'Project trial mode', state: 'future' },
];

const faqs = [
  { q: 'When does EET 2.0 take effect and do I have to deal with it now?', a: 'From 1 January 2027. By then every business must have a working POS system ready for the new rules, including installation, setup and staff training.' },
  { q: 'Who does EET 2.0 apply to?', a: 'Practically every restaurant, café, bar or hotel. You will record all payments received in person from the customer: cash, card, QR code and meal vouchers. The only exception is self-employed people in the first band of the flat-rate scheme with income up to CZK 1 million per year.' },
  { q: 'Do I have to buy a new POS system?', a: 'It depends on what you use now. Modern systems can handle EET 2.0 with a software update. An outdated or unsuitable system, however, can prove costly, and time to switch is running out.' },
  { q: 'What happens if I do not keep records?', a: 'A fine of up to CZK 500,000. On top of that, the tax authority will actively compare the revenues of businesses in the same field and region, so anomalies will automatically draw inspectors’ attention.' },
  { q: 'Is EET 2.0 more complicated than the first one?', a: 'No, quite the opposite. It works only in online mode with no exceptions or variants, you issue a receipt only on request and digitally, and the state asks for less data than before. If you have the right system, you will hardly notice most of it.' },
  { q: 'Why not just solve EET 2.0 the cheapest way possible?', a: 'Because a POS system is not just a legal obligation. The right solution gives you an overview of revenue, inventory and staff in one place, automates admin and helps increase margins. Our clients raise their margins by 7% on average.' },
  { q: 'What is changing with tips?', a: 'Voluntary tips will be exempt from tax and levies up to 7% of monthly revenue. The detailed rules for recording them in the POS system are still being clarified; as soon as they are clear, we will write up the exact procedure.' },
];

// Blog articles on the topic of EET (by slug / category)
const eetPosts = (await getCollection('blog'))
  .filter((p) => /eet/i.test(p.id) || (p.data.categories ?? []).some((c) => /eet/i.test(c)))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);
const fmtDate = (d: Date) => d.toLocaleDateString('cs-CZ', { day: 'numeric', month: 'long', year: 'numeric' });

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<Base locale="en"
      title="EET 2.0, with Piano you will handle it smoothly"
      description="EET 2.0 launches in 2027. As your technology partner we take care of everything you need: a POS system ready for the new rules, installation and training. Free consultation."
      schema={faqSchema}>


  <Hero eyebrow="EET 2.0" background="primary"
        lead="The announced launch of EET 2.0 in 2027 does not have to worry you. As your technology partner we will take care of everything you need, just like years ago. Get ahead and settle your revenue records once and for all.">
    <Heading slot="title" as="h1" size="display" color="on-dark">EET is back. With Piano you will handle it <em>smoothly</em></Heading>
    <Fragment slot="actions">
      <Button href="#poptavka">Free consultation</Button>
    </Fragment>
    <img slot="media" src="/images/eet-hero.webp" alt="EET 2.0 with Piano" width="612" height="408" />
  </Hero>

  <USPGrid eyebrow="What's new" title="Key updates in EET 2.0"
           lead="Changes that make running your business easier."
           items={novinky} columns={3} background="default" />

  <!-- EET vs. EET 2.0 -->
  <Section background="alt" space="lg">
    <div class="head-center">
      <Text size="label" color="accent" align="center">5 key differences</Text>
      <Heading as="h2" size="h2" align="center">EET vs. EET 2.0, what really <em>changes</em>?</Heading>
    </div>
    <div class="cmp">
      <div class="cmp__col">
        <p class="cmp__head"><strong>EET</strong><span>how it was</span></p>
        {compare.map((c) => (
          <div class="cmp__row">
            <span class="cmp__ico"><Icon name={c.icon} size="sm" /></span>
            <span class="cmp__txt"><span class="cmp__cat">{c.cat}</span><span class="cmp__val">{c.old}</span></span>
          </div>
        ))}
      </div>
      <div class="cmp__col cmp__col--new">
        <p class="cmp__head"><strong>EET 2.0</strong><span>how it will be</span></p>
        {compare.map((c) => (
          <div class="cmp__row">
            <span class="cmp__ico"><Icon name={c.icon} size="sm" /></span>
            <span class="cmp__txt"><span class="cmp__cat">{c.cat}</span><span class="cmp__val">{c.neu}</span></span>
          </div>
        ))}
      </div>
    </div>
  </Section>

  <!-- Timeline -->
  <Section background="default" space="lg">
    <div class="head-center">
      <Text size="label" color="accent" align="center">Timeline</Text>
      <Heading as="h2" size="h2" align="center">EET 2.0 schedule</Heading>
    </div>
    <div class="tl">
      <span class="tl__line" aria-hidden="true"></span>
      {timeline.map((m) => (
        <div class:list={['tl__item', `tl__item--${m.state}`]}>
          <span class="tl__dot" aria-hidden="true"></span>
          <div class="tl__card">
            <span class="tl__date">{m.date}</span>
            <p class="tl__title">{m.title}</p>
            {m.state === 'current' && <span class="tl__badge">Current</span>}
          </div>
        </div>
      ))}
    </div>
  </Section>

  <!-- From the blog -->
  {eetPosts.length > 0 && (
    <Section background="alt" space="lg">
      <div class="head-center">
        <Text size="label" color="accent" align="center">From the blog</Text>
        <Heading as="h2" size="h2" align="center">Read more about EET 2.0</Heading>
      </div>
      <div class="eetblog">
        {eetPosts.map((p) => (
          <a class="eetblog__card" href={locPath(`/blog/${p.id}`, 'en')}>
            <span class="eetblog__date">{fmtDate(p.data.pubDate)}</span>
            <p class="eetblog__title">{p.data.title}</p>
            {p.data.description && <span class="eetblog__desc">{p.data.description}</span>}
            <span class="eetblog__more">Read article <Icon name="lucide:arrow-right" size="xs" /></span>
          </a>
        ))}
      </div>
    </Section>
  )}

  <!-- FAQ -->
  <Section background="default" space="lg" container="narrow">
    <Heading as="h2" size="h2" align="center">Frequently asked questions</Heading>
    <div class="faq">
      {faqs.map((f) => (
        <details class="faq__item">
          <summary class="faq__q">{f.q}</summary>
          <div class="faq__a"><Text color="muted">{f.a}</Text></div>
        </details>
      ))}
    </div>
  </Section>

  <LeadForm id="poptavka" variant="callback" locale="en"
            title="Is the regulation making your head spin?"
            lead="Leave us your contact details and we will solve it together, a free, no-obligation consultation." />


</Base>

<style>
  .head-center { max-width: 720px; margin: 0 auto var(--space-7); text-align: center; }
  .head-center :global(h2) { margin-top: var(--space-2); }

  /* EET vs. EET 2.0 */
  .cmp { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-5); max-width: 880px; margin: 0 auto; }
  .cmp__col { background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: var(--space-6); display: flex; flex-direction: column; gap: var(--space-4); }
  .cmp__col--new { background: var(--color-primary); border-color: var(--color-primary); color: #fff; }
  .cmp__head { margin: 0 0 var(--space-2); display: flex; flex-direction: column; }
  .cmp__head strong { font-family: var(--font-sans); font-size: var(--font-size-h3); font-weight: var(--font-weight-bold); }
  .cmp__head span { font-size: var(--font-size-small); color: var(--color-text-muted); }
  .cmp__col--new .cmp__head span { color: rgba(255,255,255,.7); }
  .cmp__row { display: flex; align-items: center; gap: var(--space-3); }
  .cmp__ico { display: inline-flex; color: var(--color-text-accent); flex-shrink: 0; }
  .cmp__col--new .cmp__ico { color: var(--color-secondary-gold); }
  .cmp__txt { display: flex; flex-direction: column; }
  .cmp__cat { font-size: var(--font-size-caption); text-transform: uppercase; letter-spacing: var(--letter-spacing-wide); color: var(--color-text-muted); }
  .cmp__col--new .cmp__cat { color: rgba(255,255,255,.65); }
  .cmp__val { font-weight: var(--font-weight-semibold); font-size: var(--font-size-body); }

  /* Timeline — vertical list */
  .tl { position: relative; max-width: 620px; margin: 0 auto; display: flex; flex-direction: column; gap: var(--space-4); padding-left: var(--space-1); }
  .tl__line { position: absolute; left: 8px; top: 10px; bottom: 10px; width: 2px; background: var(--color-border); }
  .tl__item { position: relative; display: grid; grid-template-columns: auto 1fr; column-gap: var(--space-4); align-items: start; }
  .tl__dot { width: 18px; height: 18px; border-radius: var(--radius-full); background: var(--color-bg); border: 2px solid var(--color-border); margin-top: 2px; position: relative; z-index: 1; }
  .tl__item--done .tl__dot { background: var(--color-primary); border-color: var(--color-primary); }
  .tl__item--current .tl__dot { border-color: var(--color-primary); box-shadow: 0 0 0 4px var(--color-bg), 0 0 0 6px var(--color-primary); }
  .tl__item--current .tl__dot::after { content: ''; position: absolute; inset: 3px; border-radius: var(--radius-full); background: var(--color-primary); }
  .tl__card { padding: var(--space-4) var(--space-5); background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-md); }
  .tl__item--current .tl__card { border-color: var(--color-primary); box-shadow: 0 8px 24px rgba(190,30,45,.12); }
  .tl__item--future .tl__card { background: transparent; border-style: dashed; }
  .tl__date { font-size: var(--font-size-caption); font-weight: var(--font-weight-semibold); text-transform: uppercase; letter-spacing: var(--letter-spacing-wide); color: var(--color-text-accent); }
  .tl__item--future .tl__date { color: var(--color-text-muted); }
  .tl__title { margin: var(--space-1) 0 0; font-size: var(--font-size-body); font-weight: var(--font-weight-semibold); line-height: var(--line-height-tight); }
  .tl__badge { display: inline-block; margin-top: var(--space-2); font-size: var(--font-size-caption); font-weight: var(--font-weight-medium); text-transform: uppercase; letter-spacing: var(--letter-spacing-wide); color: #fff; background: var(--color-primary); padding: 1px var(--space-2); border-radius: var(--radius-sm); }

  @media (max-width: 768px) {
    .cmp { grid-template-columns: 1fr; max-width: 460px; }
  }

  /* From the blog */
  .eetblog { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: var(--space-5); }
  .eetblog__card { display: flex; flex-direction: column; gap: var(--space-2); padding: var(--space-6); background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-md); text-decoration: none; color: var(--color-text); transition: var(--transition); }
  .eetblog__card:hover { border-color: var(--color-primary); transform: translateY(-4px); box-shadow: var(--shadow-lg, 0 18px 40px rgba(0,0,0,.10)); }
  .eetblog__date { font-size: var(--font-size-caption); color: var(--color-text-muted); }
  .eetblog__title { margin: 0; font-family: var(--font-sans); font-weight: var(--font-weight-semibold); font-size: var(--font-size-lead); line-height: var(--line-height-tight); }
  .eetblog__desc { font-size: var(--font-size-small); color: var(--color-text-muted); display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  .eetblog__more { display: inline-flex; align-items: center; gap: var(--space-1); margin-top: auto; padding-top: var(--space-2); color: var(--color-text-accent); font-weight: var(--font-weight-medium); font-size: var(--font-size-small); }
  @media (max-width: 860px) { .eetblog { grid-template-columns: 1fr; max-width: 460px; margin: 0 auto; } }

  .faq { margin-top: var(--space-6); display: flex; flex-direction: column; gap: var(--space-3); }
  .faq__item {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-4) var(--space-5);
  }
  .faq__q {
    cursor: pointer;
    font-family: var(--font-sans);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text);
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
  }
  .faq__q::-webkit-details-marker { display: none; }
  .faq__q::after { content: "+"; color: var(--color-text-accent); font-size: 1.4em; line-height: 1; flex-shrink: 0; }
  .faq__item[open] .faq__q::after { content: "−"; }
  .faq__a { margin-top: var(--space-3); }
</style>
