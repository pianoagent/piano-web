---
/**
 * For media — piano.cz/en/pro-media (press centre).
 * Mirrors CS pro-media.astro with the same layout/CSS, translated content.
 */
import Base from '../../layouts/Base.astro';
import Section from '@piano/ui/components/Section.astro';
import Heading from '@piano/ui/components/Heading.astro';
import Text from '@piano/ui/components/Text.astro';
import Button from '@piano/ui/components/Button.astro';
import Icon from '@piano/ui/components/Icon.astro';
import { locPath } from '../../i18n';

const L = 'en' as const;

const releases = [
  { date: '20. 5. 2026', title: 'Češi konzumují jinak. Preferují nealko, platí bezhotovostně a v zimě chodí do restaurací méně.', pdf: '/press/tz-trendy-spotreba-platby.pdf' },
  { date: '21. 4. 2026', title: 'Čtyři značky, jedna rodina. Piano spouští první kampaň v tempu gastro světa.', pdf: '/press/tz-prvni-kampan-gastro.pdf' },
  { date: '9. 2. 2026', title: 'Piano Group a.s., budovaná investiční skupinou Miton, dokončila akvizici sedmi technologických firem a jejich systémů.', pdf: '/press/tz-akvizice.pdf' },
];

// Video interviews — newest first
const videos = [
  { publisher: 'e15', date: '2. 4. 2026', image: '/images/press/e15.webp', title: 'Pod Lupou: České gastro sbírá uznání, zároveň bojuje o lidi. Bez změn bude tlak jen sílit', href: 'https://www.e15.cz/podcasty/pod-lupou-ceske-gastro-sbira-uznani-zaroven-bojuje-o-lidi-bez-zmen-bude-tlak-jen-silit-1431865' },
  { publisher: 'iDNES.cz', date: '5. 3. 2026', image: '/images/press/idnes.webp', title: 'Berou jen hotovost a pak se diví prázdné hospodě? Trendem je QR kód', href: 'https://www.idnes.cz/ekonomika/domaci/idnes-lounge-digitalizace-pohostinstvi-restaurace-qerko.A260302_130547_eko-doprava_vov' },
  { publisher: 'Reflex', date: '5. 2. 2026', image: '/images/press/reflex.webp', title: 'Gastropodnik 2025: Vaše oblíbená hospoda si zaslouží být vidět, říká Tomáš Mráz z holdingu Piano', href: 'https://www.reflex.cz/clanek/byznys-x/134019/gastropodnik-2025-vase-oblibena-hospoda-si-zaslouzi-byt-videt-rika-tomas-mraz-z-holdingu-piano.html' },
];

const articles = [
  { publisher: 'Euro', image: '/images/press/euro.webp', title: 'Jak ušetřit až čtvrtinu nákladů a zvýšit tržby. Kostelný z Piana popisuje problémy současné české gastronomie', href: 'https://www.euro.cz/clanky/jak-usetrit-az-ctvrtinu-nakladu-a-zvysit-trzby-restaurace-kostelny-z-piana-popisuje-problemy-soucasne-ceske-gastronomie/' },
  { publisher: 'Ekonom', image: '/images/press/ekonom.webp', title: 'EET měla narovnat trh, ale víc změnila chování podniků. Teď se vrací s jednodušší verzí a novými riziky', href: 'https://ekonom.cz/c1-67873800-eet-mela-narovnat-trh-ale-vic-zmenila-chovani-podniku-ted-se-vraci-s-jednodussi-verzi-a-novymi-riziky' },
  { publisher: 'MediaGuru', image: '/images/press/mediaguru.webp', title: 'Piano Group zahajuje první kampaň, propojuje své značky', href: 'https://www.mediaguru.cz/piano-group-zahajuje-prvni-kampan-propojuje-sve-znacky' },
  { publisher: 'CzechCrunch', image: '/images/press/cc-alza.webp', title: 'Při placení obědů ji miluje statisíce lidí. Teď mění majitele českou aplikaci, kterou poháněli i investoři Alzy', href: 'https://cc.cz/pri-placeni-obedu-ji-miluji-statisice-lidi-ted-meni-majitele-ceskou-aplikaci-pohaneli-i-investori-alzy/' },
  { publisher: 'CzechCrunch', image: '/images/press/cc-miton.webp', title: 'Miton spojuje svých osm gastroprojektů pod novou značku. Letos cílí na čtvrtmiliardové tržby', href: 'https://cc.cz/miton-spojuje-svych-osm-gastroprojektu-pod-novou-znacku-letos-cili-na-ctvrtmiliardove-trzby/' },
];

const mediaKit = 'https://drive.google.com/drive/folders/1-W3kD79LVz5aMy6kSGHNwJgnJflyGvcr?usp=sharing';
---

<Base locale="en"
      title="For media, Piano in the media"
      description="Piano press centre: video interviews, articles, press releases and a downloadable media kit, plus a contact for journalists."
      contactBand={false}>

  <section class="pm-hero">
    <div class="pm-hero__overlay"></div>
    <div class="pm-hero__inner">
      <p class="pm-hero__eyebrow">For media</p>
      <h1 class="pm-hero__title">Piano <em>in the media</em></h1>
      <p class="pm-hero__lead">Here you will find press releases, interviews, videos and all materials for journalists.</p>
    </div>
  </section>

  <!-- Video interviews -->
  <Section background="default" space="lg">
    <Heading as="h2" size="h2" align="center" class="pm-h">Video interviews</Heading>
    <div class="pm-grid">
      {videos.map((v) => (
        <article class="pm-video">
          <a class="pm-video__thumb" href={v.href} target="_blank" rel="noopener" aria-label={v.title}>
            <img src={v.image} alt={v.title} loading="lazy" />
            <span class="pm-video__play"><Icon name="lucide:play" size="md" /></span>
          </a>
          <span class="pm-pub">{v.publisher} · {v.date}</span>
          <p class="pm-card__title">{v.title}</p>
          <Button href={v.href} variant="secondary" size="sm" target="_blank" rel="noopener noreferrer">Play</Button>
        </article>
      ))}
    </div>
  </Section>

  <!-- Press coverage -->
  <Section background="warm" space="lg">
    <Heading as="h2" size="h2" align="center" class="pm-h">Press coverage</Heading>
    <div class="pm-grid pm-grid--articles">
      {articles.map((a) => (
        <a class="pm-article" href={a.href} target="_blank" rel="noopener noreferrer">
          <div class="pm-article__media"><img src={a.image} alt={a.title} loading="lazy" /></div>
          <span class="pm-pub pm-pub--accent">{a.publisher}</span>
          <p class="pm-card__title">{a.title}</p>
          <span class="pm-more">Read the article <Icon name="lucide:arrow-right" size="xs" /></span>
        </a>
      ))}
    </div>
  </Section>

  <!-- Press releases -->
  <Section background="default" space="lg">
    <Heading as="h2" size="h2" align="center" class="pm-h">Piano press releases</Heading>
    <div class="pm-grid">
      {releases.map((r) => (
        <article class="pm-release">
          <Text size="caption" color="muted">{r.date}</Text>
          <p class="pm-release__title">{r.title}</p>
          <a class="pm-link" href={r.pdf} target="_blank" rel="noopener"><Icon name="lucide:download" size="xs" /> Download PDF</a>
        </article>
      ))}
    </div>
  </Section>

  <!-- Media kit -->
  <Section id="media-kit" background="warm" space="lg" container="narrow">
    <div class="pm-kit">
      <Text size="label" color="accent" align="center">Media kit</Text>
      <Heading as="h2" size="h2" align="center" class="pm-h">Logos and brand assets to download</Heading>
      <Text color="muted" align="center" class="pm-kit__sub">Download the complete media kit for Piano and its individual companies such as Qerko, Septim or Pecosta. It includes logos in all formats along with their brand guidelines.</Text>
      <Button href={mediaKit} target="_blank" rel="noopener noreferrer">Download media kit</Button>
    </div>
  </Section>

  <!-- Contact for journalists -->
  <Section id="kontakt-media" background="invert" space="lg" container="narrow">
    <div class="pm-contact">
      <Heading as="h2" size="h2" color="on-dark" align="center" class="pm-h">Contact for journalists</Heading>
      <Text color="on-dark-muted" align="center" class="pm-kit__sub">For press enquiries, interviews and to arrange a visit to our customers' venues, get in touch with us directly. We respond within two business hours.</Text>
      <div class="pm-contact__links">
        <a href="mailto:media@piano.cz"><Icon name="lucide:mail" size="sm" /> media@piano.cz</a>
        <a href="tel:+420774722222"><Icon name="lucide:phone" size="sm" /> +420 774 722 222</a>
      </div>
    </div>
  </Section>

</Base>

<style>
  /* Hero s obrázkovým pozadím + vycentrovaný text */
  .pm-hero { position: relative; background: var(--color-neutral-900) url('/images/promedia-hero.webp') center / cover no-repeat; }
  .pm-hero__overlay { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(0,0,0,.35), rgba(0,0,0,.6)); }
  .pm-hero__inner { position: relative; max-width: 760px; margin: 0 auto; padding: var(--space-9) var(--container-pad); text-align: center; display: flex; flex-direction: column; align-items: center; }
  .pm-hero__eyebrow { font-family: var(--font-sans); font-size: var(--font-size-label); font-weight: var(--font-weight-semibold); text-transform: uppercase; letter-spacing: var(--letter-spacing-wide); color: var(--color-secondary-gold); margin: 0; }
  .pm-hero__title { color: #fff; font-size: var(--font-size-display); line-height: var(--line-height-tight); margin: var(--space-3) 0 0; }
  .pm-hero__title em { font-family: var(--font-serif); font-style: normal; }
  .pm-hero__lead { color: rgba(255,255,255,.85); font-size: var(--font-size-lead); max-width: 520px; margin: var(--space-4) auto 0; }

  .pm-h { margin-bottom: var(--space-7); }
  .pm-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: var(--space-6); }
  .pm-grid--articles { grid-template-columns: repeat(3, minmax(0, 1fr)); }

  .pm-pub { font-size: var(--font-size-caption); text-transform: uppercase; letter-spacing: var(--letter-spacing-wide); font-weight: var(--font-weight-semibold); color: var(--color-text-muted); }
  .pm-pub--accent { color: var(--color-text-accent); }
  .pm-card__title { font-family: var(--font-sans); font-weight: var(--font-weight-semibold); font-size: var(--font-size-body); line-height: var(--line-height-tight); margin: 0; }
  .pm-more { display: inline-flex; align-items: center; gap: var(--space-1); color: var(--color-text-accent); font-weight: var(--font-weight-medium); font-size: var(--font-size-small); }

  /* Videorozhovory */
  .pm-video { display: flex; flex-direction: column; align-items: center; gap: var(--space-2); text-align: center; }
  .pm-video__thumb { position: relative; display: block; width: 100%; aspect-ratio: 16/9; border-radius: var(--radius-md); overflow: hidden; margin-bottom: var(--space-1); }
  .pm-video__thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .pm-video__play { position: absolute; inset: 0; margin: auto; width: 54px; height: 54px; display: grid; place-items: center; border-radius: var(--radius-full); background: rgba(0,0,0,.55); color: #fff; transition: var(--transition); }
  .pm-video__thumb:hover .pm-video__play { background: var(--color-primary); }
  .pm-video :global(.btn) { margin-top: var(--space-2); }

  /* Napsali o nás — celá karta je odkaz */
  .pm-article { display: flex; flex-direction: column; gap: var(--space-2); text-align: left; padding: 0 0 var(--space-5); background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-md); overflow: hidden; text-decoration: none; color: var(--color-text); transition: var(--transition); }
  .pm-article:hover { border-color: var(--color-primary); transform: translateY(-4px); box-shadow: var(--shadow-lg, 0 18px 40px rgba(0,0,0,.10)); }
  .pm-article__media { aspect-ratio: 16/9; overflow: hidden; background: var(--color-bg-alt); }
  .pm-article__media img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .pm-article .pm-pub, .pm-article .pm-card__title, .pm-article .pm-more { padding: 0 var(--space-5); }
  .pm-article .pm-pub { margin-top: var(--space-4); }
  .pm-article .pm-more { margin-top: var(--space-2); }

  /* Tiskové zprávy — vycentrované */
  .pm-release { display: flex; flex-direction: column; align-items: center; gap: var(--space-2); text-align: center; padding: 0 var(--space-3); }
  .pm-release__title { font-family: var(--font-sans); font-weight: var(--font-weight-semibold); font-size: var(--font-size-lead); line-height: var(--line-height-tight); margin: 0; }
  .pm-link { display: inline-flex; align-items: center; gap: var(--space-1); margin-top: var(--space-1); color: var(--color-text-accent); text-decoration: none; font-weight: var(--font-weight-medium); font-size: var(--font-size-small); text-transform: uppercase; letter-spacing: var(--letter-spacing-wide); }

  /* Media kit */
  .pm-kit { display: flex; flex-direction: column; align-items: center; text-align: center; }
  .pm-kit :global(h2) { margin-top: var(--space-2); }
  .pm-kit__sub { max-width: 560px; margin: var(--space-3) auto var(--space-6); }

  /* Kontakt pro novináře */
  .pm-contact { display: flex; flex-direction: column; align-items: center; text-align: center; }
  .pm-contact :global(h2) { margin-top: var(--space-2); }
  .pm-contact__links { display: flex; flex-wrap: wrap; gap: var(--space-5); justify-content: center; margin-top: var(--space-5); }
  .pm-contact__links a { display: inline-flex; align-items: center; gap: var(--space-2); color: var(--color-text-on-dark); text-decoration: none; font-weight: var(--font-weight-medium); }
  .pm-contact__links a:hover { color: var(--color-secondary-gold); }

  @media (max-width: 880px) {
    .pm-grid, .pm-grid--articles { grid-template-columns: 1fr; max-width: 460px; margin: 0 auto; }
  }
</style>
