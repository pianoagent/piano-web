---
/**
 * Piano Brain — stránka piano.cz/brain
 * Datový engine ekosystému. Obsah dle bloku #page-brain (piano-web-2026.html).
 */
import Base from '../layouts/Base.astro';
import Header from '@piano/ui/components/Header.astro';
import Footer from '@piano/ui/components/Footer.astro';
import Hero from '@piano/ui/components/Hero.astro';
import Heading from '@piano/ui/components/Heading.astro';
import Button from '@piano/ui/components/Button.astro';
import USPGrid from '@piano/ui/components/USPGrid.astro';
import LeadForm from '@piano/ui/components/LeadForm.astro';

const stats = [
  { icon: 'lucide:sliders-horizontal', title: '36', text: 'sledovaných parametrů' },
  { icon: 'lucide:layers', title: '298', text: 'kategorií jídel a nápojů' },
  { icon: 'lucide:store', title: '6 000', text: 'podniků v beta testu' },
  { icon: 'lucide:tags', title: '50 000+', text: 'sledovaných položek' },
];

const co = [
  { icon: 'lucide:brain', title: 'AI asistent v Pilotu', text: 'Pohání doporučení pro majitele restaurací přímo v aplikaci Piano Pilot.' },
  { icon: 'lucide:map-pin', title: 'Data na úrovni ulice', text: 'Dodavatelům do gastra dává přehled o trhu — položky, ceny, poptávka v okolí.' },
  { icon: 'lucide:database', title: 'Desítky zdrojů, jedno místo', text: 'Tržní data, která dřív neexistovala, sjednocená do jednoho datového enginu.' },
];
---

<Base title="Piano Brain — datový engine Piano ekosystému"
      description="Piano Brain je datový engine ekosystému Piano. Tržní data na úrovni ulice, položky a ceny — pohání AI asistenta v Piano Pilotu a dává přehled dodavatelům do gastra.">
  <Header logoSrc="/logos/piano_color.svg" />

  <main>
  <Hero eyebrow="Datový engine Piano ekosystému" background="primary"
        lead="Piano Brain pohání AI asistenta v Piano Pilotu pro majitele restaurací a zároveň dává dodavatelům do gastra přehled o trhu na úrovni ulice, položky a ceny. Jedno místo, desítky zdrojů.">
    <Heading slot="title" as="h1" size="display" color="on-dark">Tržní data, která dřív <em>neexistovala</em></Heading>
    <Fragment slot="actions">
      <Button href="#poptavka">Chci demo</Button>
    </Fragment>
  </Hero>

  <USPGrid eyebrow="Hloubka dat" title="Co Piano Brain sleduje"
           items={stats} columns={4} background="default" minItemWidth="200px" />

  <USPGrid eyebrow="K čemu to je" title="Jeden engine, dvě strany trhu"
           items={co} columns={3} background="alt" />

  <LeadForm id="poptavka" variant="callback"
            title="Chcete vidět Piano Brain v akci?"
            lead="Nechte nám číslo a ukážeme vám data o vašem trhu." />
  </main>

  <Footer />
</Base>
