---
/**
 * EET 2.0 — stránka piano.cz/eet
 * Obsah: wordpress-export/pages/eet.md. Sdílené komponenty @piano/ui.
 */
import Base from '../layouts/Base.astro';
import Section from '@piano/ui/components/Section.astro';
import Hero from '@piano/ui/components/Hero.astro';
import Heading from '@piano/ui/components/Heading.astro';
import Text from '@piano/ui/components/Text.astro';
import Button from '@piano/ui/components/Button.astro';
import USPGrid from '@piano/ui/components/USPGrid.astro';
import LeadForm from '@piano/ui/components/LeadForm.astro';
import Icon from '@piano/ui/components/Icon.astro';

const novinky = [
  { icon: 'lucide:hand-coins', title: 'Daňové zvýhodnění spropitného', text: 'Dobrovolné spropitné do 7 % tržeb bude nově osvobozeno od daní i odvodů.' },
  { icon: 'lucide:percent', title: 'Nižší DPH na nealko', text: 'Daň u nealkoholických nápojů klesá z 21 % na 12 %.' },
  { icon: 'lucide:receipt', title: 'Modernizace prodeje', text: 'Konec povinného tisku účtenek a jednodušší evidence bez zbytečného papírování.' },
];

// EET vs. EET 2.0 — 5 klíčových rozdílů (dle podkladu)
const compare = [
  { icon: 'lucide:receipt', cat: 'Účtenka', old: 'Povinný tisk', neu: 'Jen na vyžádání' },
  { icon: 'lucide:credit-card', cat: 'Co se eviduje', old: 'Hotovost i karty', neu: 'Jen kontaktní platby' },
  { icon: 'lucide:cpu', cat: 'Hardware', old: 'Nové vybavení', neu: 'Pokladna stačí' },
  { icon: 'lucide:file-text', cat: 'Data', old: 'Rozsáhlý výkaz', neu: 'Minimum údajů' },
  { icon: 'lucide:search', cat: 'Kontroly', old: 'Plošné kontroly', neu: 'Cílená analytika' },
];

// Harmonogram EET 2.0 — legislativní milníky
const timeline = [
  { date: 'Únor 2026', title: 'Zahájení připomínkového řízení', state: 'done' },
  { date: 'Duben 2026', title: 'Vypořádání připomínek', state: 'done' },
  { date: 'Květen 2026', title: 'Návrh prošel prvním čtením', state: 'done' },
  { date: 'Červen 2026', title: 'Zveřejnění technické specifikace', state: 'current' },
  { date: 'Červenec 2026', title: 'Zpřístupnění testovacího prostředí', state: 'future' },
  { date: 'Listopad 2026', title: 'Generování certifikátů v prostředí DIS+', state: 'future' },
  { date: 'Prosinec 2026', title: 'Spuštění aplikace MOJE EET', state: 'future' },
  { date: '1. ledna 2027', title: 'Zahájení běžného provozu EET 2.0', state: 'future' },
  { date: 'Leden 2027', title: 'Zkušební režim projektu', state: 'future' },
];
// podíl „hotové" části osy (po aktuální milník)
const tlProgress = `${((timeline.findIndex((m) => m.state === 'current') + 0.5) / timeline.length * 100).toFixed(1)}%`;

const faqs = [
  { q: 'Kdy začne platit EET 2.0 a musím to řešit už teď?', a: 'Od 1. ledna 2027. Do té doby musí mít každý podnik funkční pokladní systém připravený na nová pravidla, včetně instalace, nastavení a zaškolení obsluhy.' },
  { q: 'Koho se EET 2.0 týká?', a: 'Prakticky každé restaurace, kavárny, baru nebo hotelu. Evidovat budete všechny platby přijaté při osobním kontaktu se zákazníkem — hotovost, kartu, QR kód i stravenky. Výjimku mají pouze OSVČ v prvním pásmu paušálního režimu s příjmy do 1 milionu Kč ročně.' },
  { q: 'Musím si pořizovat nový pokladní systém?', a: 'Záleží na tom, co teď používáte. Moderní systémy zvládnou EET 2.0 softwarovým updatem. Zastaralý nebo nevhodný systém vás ale může přijít draho a čas na přechod se krátí.' },
  { q: 'Co mi hrozí, když nebudu evidovat?', a: 'Pokuta až 500 000 Kč. Finanční správa navíc bude aktivně porovnávat tržby podnikatelů ve stejném oboru a regionu, takže anomálie automaticky přitáhnou pozornost kontrolorů.' },
  { q: 'Je EET 2.0 složitější než to první?', a: 'Ne, naopak. Funguje pouze v online režimu bez výjimek a variant, účtenku vydáváte jen na vyžádání i digitálně a stát po vás chce méně dat než dřív. Pokud máte správný systém, většinu věcí nepoznáte.' },
  { q: 'Proč nevyřešit EET 2.0 jen tou nejlevnější cestou?', a: 'Protože pokladní systém není jen zákonná povinnost. Správné řešení vám dá přehled o tržbách, zásobách i personálu na jednom místě, automatizuje administrativu a pomůže zvýšit marže. Naši klienti průměrně zvyšují marže o 7 %.' },
  { q: 'Co se změní u spropitného?', a: 'Dobrovolné spropitné bude osvobozeno od daně i odvodů až do výše 7 % měsíčních tržeb. Detailní pravidla pro evidenci v pokladním systému se ještě upřesňují — jakmile budou jasná, sepíšeme přesný postup.' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<Base title="EET 2.0 — s Pianem to zvládnete hladce"
      description="EET 2.0 startuje v roce 2027. Jako technologický partner zajistíme vše potřebné — pokladní systém připravený na nová pravidla, instalaci i zaškolení. Konzultace zdarma."
      schema={faqSchema}>


  <Hero eyebrow="EET 2.0" background="primary"
        lead="Ohlášený start EET 2.0 v roce 2027 vás nemusí trápit. Jako technologický partner zajistíme vše potřebné, stejně jako před lety. Získejte náskok a vyřešte evidenci tržeb jednou provždy.">
    <Heading slot="title" as="h1" size="display" color="on-dark">EET se vrací. S Pianem to zvládnete <em>hladce</em></Heading>
    <Fragment slot="actions">
      <Button href="#poptavka">Konzultace zdarma</Button>
    </Fragment>
    <img slot="media" src="/images/eet-hero.webp" alt="EET 2.0 s Pianem" width="612" height="408" />
  </Hero>

  <USPGrid eyebrow="Co je nového" title="Klíčové novinky EET 2.0"
           lead="Změny, které vám zjednoduší podnikání."
           items={novinky} columns={3} background="default" />

  <!-- EET vs. EET 2.0 -->
  <Section background="alt" space="lg">
    <div class="head-center">
      <Text size="label" color="accent" align="center">5 klíčových rozdílů</Text>
      <Heading as="h2" size="h2" align="center">EET vs. EET 2.0 — co se opravdu <em>mění</em>?</Heading>
    </div>
    <div class="cmp">
      <div class="cmp__col">
        <p class="cmp__head"><strong>EET</strong><span>jak to bylo</span></p>
        {compare.map((c) => (
          <div class="cmp__row">
            <span class="cmp__ico"><Icon name={c.icon} size="sm" /></span>
            <span class="cmp__txt"><span class="cmp__cat">{c.cat}</span><span class="cmp__val">{c.old}</span></span>
          </div>
        ))}
      </div>
      <div class="cmp__col cmp__col--new">
        <p class="cmp__head"><strong>EET 2.0</strong><span>jak to bude</span></p>
        {compare.map((c) => (
          <div class="cmp__row">
            <span class="cmp__ico"><Icon name={c.icon} size="sm" /></span>
            <span class="cmp__txt"><span class="cmp__cat">{c.cat}</span><span class="cmp__val">{c.neu}</span></span>
          </div>
        ))}
      </div>
    </div>
  </Section>

  <!-- Harmonogram -->
  <Section background="default" space="lg">
    <div class="head-center">
      <Text size="label" color="accent" align="center">Časová osa</Text>
      <Heading as="h2" size="h2" align="center">Harmonogram EET 2.0</Heading>
    </div>
    <div class="tl">
      <span class="tl__line" aria-hidden="true"></span>
      <span class="tl__line tl__line--done" style={`--tl-progress:${tlProgress}`} aria-hidden="true"></span>
      {timeline.map((m, i) => (
        <div class:list={['tl__item', `tl__item--${m.state}`, i % 2 === 0 ? 'tl__item--up' : 'tl__item--down']}>
          <div class="tl__card">
            <span class="tl__date">{m.date}</span>
            <p class="tl__title">{m.title}</p>
            {m.state === 'current' && <span class="tl__badge">Aktuálně</span>}
          </div>
          <span class="tl__dot" aria-hidden="true"></span>
        </div>
      ))}
    </div>
  </Section>

  <!-- FAQ -->
  <Section background="alt" space="lg" container="narrow">
    <Heading as="h2" size="h2" align="center">Často kladené dotazy</Heading>
    <div class="faq">
      {faqs.map((f) => (
        <details class="faq__item">
          <summary class="faq__q">{f.q}</summary>
          <div class="faq__a"><Text color="muted">{f.a}</Text></div>
        </details>
      ))}
    </div>
  </Section>

  <LeadForm id="poptavka" variant="callback"
            title="Jde vám hlava kolem z nařízení?"
            lead="Nechte nám kontakt a společně to vyřešíme — konzultace zdarma a nezávazně." />


</Base>

<style>
  .head-center { max-width: 720px; margin: 0 auto var(--space-7); text-align: center; }
  .head-center :global(h2) { margin-top: var(--space-2); }

  /* EET vs. EET 2.0 */
  .cmp { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-5); max-width: 880px; margin: 0 auto; }
  .cmp__col { background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: var(--space-6); display: flex; flex-direction: column; gap: var(--space-4); }
  .cmp__col--new { background: var(--color-primary); border-color: var(--color-primary); color: #fff; }
  .cmp__head { margin: 0 0 var(--space-2); display: flex; flex-direction: column; }
  .cmp__head strong { font-family: var(--font-sans); font-size: var(--font-size-h3); font-weight: var(--font-weight-bold); }
  .cmp__head span { font-size: var(--font-size-small); color: var(--color-text-muted); }
  .cmp__col--new .cmp__head span { color: rgba(255,255,255,.7); }
  .cmp__row { display: flex; align-items: center; gap: var(--space-3); }
  .cmp__ico { display: inline-flex; color: var(--color-text-accent); flex-shrink: 0; }
  .cmp__col--new .cmp__ico { color: var(--color-secondary-gold); }
  .cmp__txt { display: flex; flex-direction: column; }
  .cmp__cat { font-size: var(--font-size-caption); text-transform: uppercase; letter-spacing: var(--letter-spacing-wide); color: var(--color-text-muted); }
  .cmp__col--new .cmp__cat { color: rgba(255,255,255,.65); }
  .cmp__val { font-weight: var(--font-weight-semibold); font-size: var(--font-size-body); }

  /* Harmonogram — vodorovná osa s kartami nad/pod, vlevo „hotovo" */
  .tl { position: relative; display: flex; overflow-x: auto; padding: var(--space-3) var(--space-1) var(--space-5); }
  .tl__line { position: absolute; left: 0; right: 0; top: 50%; height: 2px; background: var(--color-border); transform: translateY(-50%); }
  .tl__line--done { right: auto; width: var(--tl-progress, 0%); background: var(--color-primary); }
  .tl__item { flex: 1 0 130px; min-width: 130px; display: grid; grid-template-rows: 1fr auto 1fr; align-items: center; justify-items: center; }
  .tl__dot { grid-row: 2; width: 14px; height: 14px; border-radius: var(--radius-full); background: var(--color-bg); border: 2px solid var(--color-border); position: relative; z-index: 1; }
  .tl__item--done .tl__dot { background: var(--color-primary); border-color: var(--color-primary); }
  .tl__item--current .tl__dot { background: var(--color-primary); border-color: var(--color-primary); box-shadow: 0 0 0 4px var(--color-bg), 0 0 0 6px var(--color-primary); }
  .tl__card { width: 92%; max-width: 170px; padding: var(--space-3) var(--space-4); background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-md); text-align: left; }
  .tl__item--up .tl__card { grid-row: 1; margin-bottom: var(--space-4); }
  .tl__item--down .tl__card { grid-row: 3; margin-top: var(--space-4); }
  .tl__item--current .tl__card { border-color: var(--color-primary); box-shadow: 0 8px 24px rgba(190,30,45,.14); }
  .tl__date { font-size: var(--font-size-caption); font-weight: var(--font-weight-semibold); text-transform: uppercase; letter-spacing: var(--letter-spacing-wide); color: var(--color-text-accent); }
  .tl__title { margin: var(--space-1) 0 0; font-size: var(--font-size-small); font-weight: var(--font-weight-semibold); line-height: var(--line-height-tight); }
  .tl__badge { display: inline-block; margin-top: var(--space-2); font-size: var(--font-size-caption); font-weight: var(--font-weight-medium); text-transform: uppercase; letter-spacing: var(--letter-spacing-wide); color: #fff; background: var(--color-primary); padding: 1px var(--space-2); border-radius: var(--radius-sm); }

  @media (max-width: 768px) {
    .cmp { grid-template-columns: 1fr; max-width: 460px; }
    /* osa svisle */
    .tl { flex-direction: column; overflow-x: visible; padding-left: var(--space-2); gap: var(--space-4); }
    .tl__line { left: 6px; right: auto; top: 0; bottom: 0; width: 2px; height: auto; transform: none; }
    .tl__line--done { display: none; }
    .tl__item { grid-template-rows: none; grid-template-columns: auto 1fr; justify-items: start; align-items: start; min-width: 0; column-gap: var(--space-4); }
    .tl__dot { grid-row: 1; grid-column: 1; margin-top: 4px; }
    .tl__item--up .tl__card, .tl__item--down .tl__card { grid-row: 1; grid-column: 2; margin: 0; width: 100%; max-width: none; }
  }

  .faq { margin-top: var(--space-6); display: flex; flex-direction: column; gap: var(--space-3); }
  .faq__item {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-4) var(--space-5);
  }
  .faq__q {
    cursor: pointer;
    font-family: var(--font-sans);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text);
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
  }
  .faq__q::-webkit-details-marker { display: none; }
  .faq__q::after { content: "+"; color: var(--color-text-accent); font-size: 1.4em; line-height: 1; flex-shrink: 0; }
  .faq__item[open] .faq__q::after { content: "−"; }
  .faq__a { margin-top: var(--space-3); }
</style>
