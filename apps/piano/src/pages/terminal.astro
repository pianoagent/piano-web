---
/**
 * Terminál — produktová stránka piano.cz/terminal (1:1 dle piano.cz).
 * Obrázky z mirroru převedené na webp. Sdílené komponenty @piano/ui.
 */
import Base from '../layouts/Base.astro';
import Section from '@piano/ui/components/Section.astro';
import Hero from '@piano/ui/components/Hero.astro';
import Heading from '@piano/ui/components/Heading.astro';
import Text from '@piano/ui/components/Text.astro';
import Button from '@piano/ui/components/Button.astro';
import Icon from '@piano/ui/components/Icon.astro';
import USPGrid from '@piano/ui/components/USPGrid.astro';
import LeadForm from '@piano/ui/components/LeadForm.astro';

const benefits = [
  { icon: 'lucide:credit-card', title: 'Bezstarostné platby', text: 'Zapomeňte na hotovost pro závozníky a hlídání splatnosti faktur. Zaplatíte za zboží online na jedno kliknutí.' },
  { icon: 'lucide:users', title: 'Data, která vydělávají', text: 'Zjistěte, jak často se k vám hosté vrací a kdo u vás utrácí nejvíc. Vidíte loajalitu zákazníků v čase.' },
  { icon: 'lucide:headset', title: 'Česká podpora 24/7', text: 'Připojíme se na dálku a dotaz vyřešíme obratem. S námi na to nejste sami.' },
  { icon: 'lucide:wallet', title: 'Vyplácíme každý pracovní den', text: 'Vaše peníze jsou v bezpečí — máme celoevropskou licenci ČNB a posíláme je každý pracovní den.' },
];

const data = [
  { title: 'Konec dohadů', text: 'Poznejte své štamgasty a včas zjistěte, když k vám někdo přestane chodit, abyste mohli reagovat.' },
  { title: 'Jasné trendy', text: 'Vidíte černé na bílém, které dny táhnou nové tváře a kdy podnik drží stálá parta.' },
  { title: 'Klíčoví zákazníci', text: 'Systém sám vytipuje nejvěrnější hosty, kteří u vás nechávají nejvíc peněz.' },
  { title: 'Zdraví podniku', text: 'Identifikujte, že se něco děje dřív, než to uvidíte v tržbách. Buďte napřed a předvídejte růst i pokles.' },
];

const supplier = [
  { icon: 'lucide:hand-coins', title: 'Platíte z toho, co vyděláte', text: 'Žádné návštěvy bankomatů ani hotovost za dodávky — platby dodavateli probíhají bezhotovostně.' },
  { icon: 'lucide:receipt', title: 'Jedno vyúčtování', text: 'Jedno vyúčtování za všechny transakce z terminálu, Qerka i plateb dodavatelům.' },
  { icon: 'lucide:shield-check', title: 'Bez přístupu k bance', text: 'Autorizujete jen osoby, které mohou převzít a proplatit dodávku — bez přístupů k vaší kartě či bance.' },
  { icon: 'lucide:repeat', title: 'Vše automaticky', text: 'Žádné dodatečné poplatky za přímé bezhotovostní platby dodavatelům.' },
];

const steps = [
  { icon: 'lucide:truck', title: 'Dodavatel dodá zboží' },
  { icon: 'lucide:qr-code', title: 'Autorizovaná osoba zaplatí přes Qerko' },
  { icon: 'lucide:receipt', title: 'Částka se automaticky odečte z vyúčtování.' },
];

// Srovnání: Piano vždy ✓; ostatní terminály — no (nemají) / maybe (možná) / yes (mají)
const compare = [
  { label: 'Unikátní data o hostech v čase (štamgasti vs. noví)', other: 'no' },
  { label: 'Platby dodavatelům na kliknutí (bez hotovosti)', other: 'no' },
  { label: 'Expresní servis', other: 'no' },
  { label: 'Osobní Account Manažer', other: 'no' },
  { label: 'Celoevropská licence ČNB', other: 'maybe' },
  { label: 'Česká podpora 24/7', other: 'maybe' },
  { label: 'Plná integrace s pokladnou', other: 'maybe' },
  { label: 'Vše v jednom (mobilní číšník, objednávka, markování, tisk)', other: 'yes' },
  { label: 'Vyšší spropitné díky chytrému displeji', other: 'yes' },
  { label: 'Vyplácení tržeb každý pracovní den', other: 'yes' },
  { label: 'Podpora stravenkových karet', other: 'yes' },
  { label: 'Odolný hardware (výdrž až 10 hodin)', other: 'yes' },
];
---

<Base title="Piano Terminál — platby a data o hostech"
      description="Piano Terminál není jen platební terminál. Přináší unikátní data o hostech, automatické platby dodavatelům a vyplácení každý pracovní den. Česká podpora 24/7.">

  <Hero eyebrow="Piano Terminál" background="primary"
        lead="Běžné terminály končí zaplacením. Piano Terminál platbou teprve začíná.">
    <Heading slot="title" as="h1" size="display" color="on-dark">Poznejte své hosty a plaťte faktury <em>automaticky</em></Heading>
    <Fragment slot="actions">
      <Button href="#poptavka">Chci vyzkoušet</Button>
      <Button href="/proces-plateb" variant="secondary" onDark>Jak to funguje?</Button>
    </Fragment>
    <img slot="media" src="/images/term-hero.webp" alt="Piano Terminál" width="900" height="810" />
  </Hero>

  <USPGrid eyebrow="Vše v jednom zařízení" title="Co Piano Terminál umí navíc"
           items={benefits} columns={4} background="default" minItemWidth="220px" />

  <!-- Data o hostech — se screenshotem -->
  <Section background="alt" space="lg">
    <div class="td-head">
      <Text size="label" color="accent">Data o hostech</Text>
      <Heading as="h2" size="h2">Získejte unikátní data o vašich hostech</Heading>
      <Text size="lead" color="muted" class="td-lead">Sledujte v reálném čase, kolik lidí k vám přišlo poprvé a kdo se k vám pravidelně vrací.</Text>
    </div>
    <div class="td-grid">
      <figure class="td-img"><img src="/images/term-data.webp" alt="Přehled dat o hostech v Piano Terminálu" width="900" height="821" loading="lazy" /></figure>
      <ul class="td-list">
        {data.map((d) => (
          <li><strong>{d.title}</strong><span>{d.text}</span></li>
        ))}
      </ul>
    </div>
  </Section>

  <!-- Platby dodavatelům — telefon uprostřed, text po stranách -->
  <Section background="warm" space="lg">
    <Heading as="h2" size="h2" align="center">Platím dodavatele automaticky</Heading>
    <div class="sup">
      <div class="sup__col">
        {[supplier[0], supplier[1]].map((s) => (
          <div class="sup__item"><Heading as="h3" size="h3">{s.title}</Heading><Text color="muted">{s.text}</Text></div>
        ))}
      </div>
      <figure class="sup__phone"><img src="/images/term-supplier.webp" alt="Autorizace platby dodavateli v telefonu" width="322" height="656" loading="lazy" /></figure>
      <div class="sup__col">
        {[supplier[2], supplier[3]].map((s) => (
          <div class="sup__item"><Heading as="h3" size="h3">{s.title}</Heading><Text color="muted">{s.text}</Text></div>
        ))}
      </div>
    </div>
  </Section>

  <!-- Krok za krokem — timeline -->
  <Section background="warm" space="lg">
    <Heading as="h2" size="h2" align="center">Krok za krokem</Heading>
    <ol class="timeline">
      {steps.map((s) => (
        <li class="tl__step">
          <span class="tl__icon"><Icon name={s.icon} size="md" /></span>
          <span class="tl__title">{s.title}</span>
        </li>
      ))}
    </ol>
    <div class="steps-cta"><Button href="/proces-plateb" variant="secondary">Jak to funguje?</Button></div>

    <ul class="paylogos">
      {[1, 2, 3, 4, 5, 6, 7, 8].map((n) => (<li><img src={`/images/pay-${n}.webp`} alt="" height="28" loading="lazy" /></li>))}
    </ul>
  </Section>

  <!-- Srovnání -->
  <Section background="default" space="lg">
    <Heading as="h2" size="h2" align="center">V čem je Piano Terminál lepší?</Heading>
    <div class="cmp">
      <table class="cmp__table">
        <thead>
          <tr><th>Vlastnost / služba</th><th>Piano Terminál</th><th>Ostatní terminály</th></tr>
        </thead>
        <tbody>
          {compare.map((row) => (
            <tr>
              <td>{row.label}</td>
              <td class="cmp__yes"><Icon name="lucide:check" size="sm" /></td>
              <td>
                {row.other === 'yes' && <span class="cmp__yes"><Icon name="lucide:check" size="sm" /></span>}
                {row.other === 'no' && <span class="cmp__no"><Icon name="lucide:x" size="sm" /></span>}
                {row.other === 'maybe' && <span class="cmp__maybe" title="Záleží na poskytovateli">?</span>}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </Section>

  <!-- Ceník -->
  <Section background="warm" space="lg">
    <Heading as="h2" size="h2" align="center">Cenová nabídka</Heading>
    <div class="prices">
      <article class="price">
        <Text size="label" color="muted">Samostatně</Text>
        <Heading as="h3" size="h3">Terminál</Heading>
        <dl class="price__rows">
          <div><dt>Cena služby</dt><dd>Individuální nabídka</dd></div>
          <div><dt>Cena hardware</dt><dd>380 Kč/měsíc nebo zdarma*</dd></div>
          <div><dt>Závazek</dt><dd>24 měsíců</dd></div>
        </dl>
        <Button href="#poptavka" full>Chci tuto nabídku</Button>
      </article>
      <article class="price price--featured">
        <Text size="label" color="accent">Kombinace</Text>
        <Heading as="h3" size="h3">Terminál + Qerko</Heading>
        <dl class="price__rows">
          <div><dt>Cena služby</dt><dd>Individuální nabídka, sleva 15 % na první rok**</dd></div>
          <div><dt>Cena hardware</dt><dd>380 Kč/měsíc nebo zdarma*</dd></div>
          <div><dt>Závazek</dt><dd>24 měsíců</dd></div>
        </dl>
        <Button href="#poptavka" full>Chci tuto nabídku</Button>
      </article>
    </div>
    <Text size="caption" color="muted" class="price__note">
      *Na základě definovaného obratu přes Piano Terminál min. 1 ks zdarma.
      **Sleva se vztahuje na řešení Piano Terminál i na případy, kdy podnik už Qerko využívá.
    </Text>
  </Section>

  <LeadForm id="poptavka" variant="full"
            title="Posuňte své podnikání na vyšší úroveň"
            lead="Ozvěte se nám a připravíme nabídku šitou na míru vašemu provozu." />

  <!-- Technická podpora -->
  <Section background="default" space="md" container="narrow">
    <div class="tech">
      <Heading as="h2" size="h3" align="center">Technická podpora</Heading>
      <Text color="muted" align="center" class="tech__lead">Máte už naše terminály na provozovně a potřebujete s něčím pomoci? Obraťte se na naši technickou podporu — s námi na to nejste sami.</Text>
      <div class="tech__contacts">
        <a href="tel:+420228886881"><Icon name="lucide:phone" size="sm" /> +420 228 886 881</a>
        <a href="mailto:podpora@piano.cz"><Icon name="lucide:mail" size="sm" /> podpora@piano.cz</a>
      </div>
    </div>
  </Section>

</Base>

<style>
  /* Data o hostech */
  .td-head { max-width: 720px; margin: 0 auto var(--space-7); text-align: center; }
  .td-head :global(h2) { margin-top: var(--space-2); }
  .td-lead { margin-top: var(--space-3); }
  .td-grid { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: var(--space-7); align-items: center; }
  .td-img { margin: 0; border-radius: var(--radius-md); overflow: hidden; box-shadow: var(--shadow-lg); }
  .td-img img { display: block; width: 100%; height: auto; }
  .td-list { list-style: none; display: flex; flex-direction: column; gap: var(--space-5); }
  .td-list li { display: flex; flex-direction: column; gap: 4px; padding-left: var(--space-4); border-left: 2px solid var(--color-primary); }
  .td-list strong { font-weight: var(--font-weight-semibold); color: var(--color-text); }
  .td-list span { color: var(--color-text-muted); font-size: var(--font-size-small); }

  /* Platby dodavatelům — telefon uprostřed */
  .sup { display: grid; grid-template-columns: 1fr auto 1fr; gap: var(--space-7); align-items: center; margin-top: var(--space-7); }
  .sup__col { display: flex; flex-direction: column; gap: var(--space-6); }
  .sup__item :global(h3) { margin-bottom: var(--space-2); }
  .sup__phone { margin: 0; }
  .sup__phone img { display: block; width: 280px; max-width: 100%; height: auto; filter: drop-shadow(var(--shadow-lg)); }

  /* Krok za krokem — timeline */
  .timeline { list-style: none; display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-5); max-width: 880px; margin: var(--space-7) auto 0; position: relative; }
  .timeline::before { content: ""; position: absolute; top: 28px; left: 16%; right: 16%; height: 2px; background: var(--color-primary); z-index: 0; }
  .tl__step { display: flex; flex-direction: column; align-items: center; text-align: center; gap: var(--space-3); }
  .tl__icon { position: relative; z-index: 1; width: 56px; height: 56px; display: grid; place-items: center; color: var(--color-text-accent); background: var(--color-bg-warm, #FFF5E8); }
  .tl__title { color: var(--color-text-accent); font-size: var(--font-size-lead); font-weight: var(--font-weight-medium); max-width: 22ch; }

  .steps-cta { text-align: center; margin-top: var(--space-6); }

  /* Platební loga */
  .paylogos { list-style: none; display: flex; flex-wrap: wrap; justify-content: center; align-items: center; gap: var(--space-5) var(--space-7); margin-top: var(--space-8); }
  .paylogos img { height: 28px; width: auto; display: block; }

  /* Srovnání */
  .cmp { margin-top: var(--space-7); overflow-x: auto; }
  .cmp__table { width: 100%; border-collapse: collapse; max-width: 820px; margin: 0 auto; }
  .cmp__table th, .cmp__table td { padding: var(--space-3) var(--space-4); border-bottom: 1px solid var(--color-border); text-align: left; }
  .cmp__table thead th { font-family: var(--font-sans); font-size: var(--font-size-small); color: var(--color-text-muted); font-weight: var(--font-weight-semibold); }
  .cmp__table thead th:nth-child(2) { color: var(--color-text-accent); }
  .cmp__table th:nth-child(2), .cmp__table th:nth-child(3),
  .cmp__table td:nth-child(2), .cmp__table td:nth-child(3) { text-align: center; width: 130px; }
  .cmp__table td:first-child { color: var(--color-text); }
  .cmp__yes { color: var(--color-success); }
  .cmp__no { color: var(--color-error); }
  .cmp__maybe { color: var(--color-neutral-400); font-weight: var(--font-weight-semibold); }

  /* Ceník */
  .prices { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-5); margin-top: var(--space-7); }
  .price { display: flex; flex-direction: column; gap: var(--space-3); padding: var(--space-6); background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-md); }
  .price--featured { border-color: var(--color-primary); box-shadow: var(--shadow-md); }
  .price__rows { display: flex; flex-direction: column; gap: var(--space-3); margin: var(--space-2) 0 var(--space-4); }
  .price__rows div { display: flex; flex-direction: column; gap: 2px; }
  .price__rows dt { font-size: var(--font-size-small); color: var(--color-text-muted); }
  .price__rows dd { font-weight: var(--font-weight-semibold); color: var(--color-text); }
  .price :global(.btn) { margin-top: auto; }
  .price__note { display: block; margin-top: var(--space-5); text-align: center; }

  /* Technická podpora */
  .tech { text-align: center; }
  .tech__lead { margin: var(--space-3) auto var(--space-5); max-width: 540px; }
  .tech__contacts { display: flex; flex-wrap: wrap; gap: var(--space-5); justify-content: center; }
  .tech__contacts a { display: inline-flex; align-items: center; gap: var(--space-2); color: var(--color-text-accent); text-decoration: none; font-weight: var(--font-weight-medium); }

  @media (max-width: 720px) {
    .td-grid { grid-template-columns: 1fr; }
    .prices { grid-template-columns: 1fr; }
    .sup { grid-template-columns: 1fr; }
    .sup__phone { order: -1; justify-self: center; }
    .timeline { grid-template-columns: 1fr; }
    .timeline::before { display: none; }
  }
</style>
