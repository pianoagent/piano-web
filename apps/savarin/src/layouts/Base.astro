---
/**
 * Base — layout webu Savarin.
 * Načte téma Savarin + sdílenou SEO hlavičku. Definuje Organization schema.
 */
import '../styles/theme.css';
import BaseHead from '@piano/ui/layouts/BaseHead.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  schema?: object;
}

const SITE_NAME = 'Savarin';
const SITE_URL = 'https://savarin.cz';

const {
  title,
  description = 'Savarin — restaurační a hotelový systém. Pokladna, recepce, sklady a kalkulace. Modulární SW řešení pro gastro a ubytovací provozy od roku 1990.',
  image = '/og-default.jpg',
  type = 'website',
  noindex = false,
  schema,
} = Astro.props;

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Savarin',
  legalName: 'ComInn, s.r.o.',
  url: SITE_URL,
  logo: `${SITE_URL}/logos/savarin-logo.svg`,
  email: 'obchod@cominn.cz',
  telephone: '+420577925145',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Fügnerovo nábřeží 5476',
    addressLocality: 'Zlín',
    postalCode: '760 01',
    addressCountry: 'CZ',
  },
  parentOrganization: { '@type': 'Organization', name: 'Piano Solutions', url: 'https://piano.cz' },
};

const schemas = [organizationSchema, ...(schema ? [schema] : [])];
---

<!doctype html>
<html lang="cs">
  <head>
    <BaseHead
      title={title}
      description={description}
      image={image}
      type={type}
      noindex={noindex}
      siteName={SITE_NAME}
      siteUrl={SITE_URL}
      schemas={schemas}
    />
  </head>
  <body>
    <slot />
  </body>
</html>
