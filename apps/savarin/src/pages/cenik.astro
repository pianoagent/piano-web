---
/**
 * Savarin — Ceník, pronájem a slevy. Obsah z legacy stránky
 * formy-prodeje-multilicencni-slevy. Sdílené komponenty @piano/ui.
 */
import Base from '../layouts/Base.astro';
import Header from '@piano/ui/components/Header.astro';
import Footer from '@piano/ui/components/Footer.astro';
import Breadcrumb from '@piano/ui/components/Breadcrumb.astro';
import Section from '@piano/ui/components/Section.astro';
import Hero from '@piano/ui/components/Hero.astro';
import Heading from '@piano/ui/components/Heading.astro';
import Text from '@piano/ui/components/Text.astro';
import Button from '@piano/ui/components/Button.astro';
import Icon from '@piano/ui/components/Icon.astro';
import LeadForm from '@piano/ui/components/LeadForm.astro';
import { savarinNav, savarinCta } from '../config/nav';

const odkup = [
  ['V prvním roce', '1–20 %'],
  ['Ve druhém roce', '20–40 %'],
  ['Ve třetím roce', '40–60 %'],
  ['Ve čtvrtém roce', '60–80 %'],
  ['V pátém roce', '80–100 %'],
];

const multilicence = [
  ['2.–4. instalace', '25 %'],
  ['5.–10. instalace', '30 %'],
  ['10. a další instalace', '35 %'],
];

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    { '@type': 'BreadcrumbList', itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Domů', item: 'https://savarin.cz/' },
      { '@type': 'ListItem', position: 2, name: 'Ceník', item: 'https://savarin.cz/cenik' },
    ] },
  ],
};
---

<Base title="Ceník, pronájem a slevy — Savarin"
      description="Formy prodeje systému Savarin: přímý a splátkový prodej, pronájem softwaru (4 % z ceny měsíčně) s možností odkupu a multilicenční slevy. Cenová nabídka na vyžádání."
      schema={schema}>
  <Header brand="Savarin" logoSrc="/logos/savarin_logo.svg" logoHeight="36px" homeHref="/" nav={savarinNav} cta={savarinCta} />

  <main>

  <Breadcrumb items={[{ label: 'Domů', href: '/' }, { label: 'Ceník' }]} />

  <Hero eyebrow="Ceník a formy prodeje" background="gradient"
        lead="Systém je modulární, proto je cena závislá na konfiguraci (počet pokladen, pokojů, způsob komunikace s ústřednou). Cenovou nabídku zašleme na vyžádání podle vaší specifikace.">
    <Heading slot="title" as="h1" size="display" color="on-dark">Přímý prodej, splátky, nebo <span class="accent">pronájem</span></Heading>
    <Fragment slot="actions">
      <Button href="#poptavka">Chci cenovou nabídku</Button>
      <Button href="/demoverze" variant="secondary" onDark>Demoverze zdarma</Button>
    </Fragment>
  </Hero>

  <Section background="default" space="lg">
    <div class="forms">
      <article class="form-card">
        <span class="form-card__icon"><Icon name="lucide:banknote" size="md" /></span>
        <Heading as="h2" size="h3">Přímý a splátkový prodej</Heading>
        <Text size="small" color="muted">Software koupíte přímo, nebo si individuálně dohodnete splátkový prodej.</Text>
      </article>
      <article class="form-card">
        <span class="form-card__icon"><Icon name="lucide:key-round" size="md" /></span>
        <Heading as="h2" size="h3">Pronájem</Heading>
        <Text size="small" color="muted">
          Měsíční nájem činí 4 % z ceny SW (2 % nájemné + 2 % paušál za služby). Před instalací hradíte alespoň první tři nájmy.
          U provozoven v nájmu eliminujete riziko nevyužitého systému po skončení nájmu.
        </Text>
      </article>
    </div>

    <div class="tables">
      <div class="tbl">
        <h3 class="tbl__title">Odkup pronajatého SW — sleva dle doby pronájmu</h3>
        <table>
          <tbody>
            {odkup.map(([a, b]) => (<tr><td>{a}</td><td>{b}</td></tr>))}
          </tbody>
        </table>
        <p class="tbl__note">Vždy poměrným způsobem dle trvání nájmu.</p>
      </div>
      <div class="tbl">
        <h3 class="tbl__title">Multilicenční slevy — více instalací</h3>
        <table>
          <tbody>
            {multilicence.map(([a, b]) => (<tr><td>{a}</td><td>{b}</td></tr>))}
          </tbody>
        </table>
        <p class="tbl__note">Sleva z ceny programů při objednávce více instalací systému.</p>
      </div>
    </div>
  </Section>

  <LeadForm id="poptavka" variant="full" background="alt"
            title="Cenová nabídka na míru"
            lead="Popište nám svůj provoz (počet pokladen, pokojů, střediska) a způsob financování, který preferujete. Připravíme nabídku přesně na vaše podmínky."
            successUrl="/dekujeme" />

  </main>

  <Footer legal={[{ label: 'Ochrana osobních údajů', href: '/ochrana-udaju' }]} logoSrc="/logos/savarin_by_piano.svg" logoAlt="Savarin by Piano" parentNote={{ text: 'Savarin je součástí skupiny Piano', href: 'https://piano.cz' }} />
</Base>

<style>
  .forms { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: var(--space-6); max-width: 900px; margin-inline: auto; }
  .form-card { background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: var(--space-6); }
  .form-card > * + * { margin-top: var(--space-3); }
  .form-card__icon { display: inline-flex; color: var(--color-text-accent); }

  .tables { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: var(--space-6); max-width: 900px; margin: var(--space-7) auto 0; }
  .tbl__title { font-size: var(--font-size-h3); font-weight: var(--font-weight-semibold); margin-bottom: var(--space-3); }
  .tbl table { width: 100%; border-collapse: collapse; }
  .tbl td { padding: var(--space-3) var(--space-4); border-bottom: 1px solid var(--color-border); }
  .tbl tr td:last-child { text-align: right; font-weight: var(--font-weight-bold); color: var(--color-secondary); white-space: nowrap; }
  .tbl tr:nth-child(odd) td { background: var(--color-bg-alt); }
  .tbl__note { margin-top: var(--space-3); font-size: var(--font-size-small); color: var(--color-text-muted); }
</style>
