---
/**
 * Savarin — homepage.
 * Obsah z legacy webu (podklady starých webů/Savarin, stránky home / popis-programu
 * / pokladna / recepce / sklady-a-kalkulace / sluzby-servis).
 * Vše ze SDÍLENÝCH komponent @piano/ui; téma řeší src/styles/theme.css.
 * Hero vizuál je placeholder (CSS účtenka/POS) — reálné obrázky doplníme později.
 */
import Base from '../layouts/Base.astro';
import Header from '@piano/ui/components/Header.astro';
import Footer from '@piano/ui/components/Footer.astro';
import Section from '@piano/ui/components/Section.astro';
import Hero from '@piano/ui/components/Hero.astro';
import Heading from '@piano/ui/components/Heading.astro';
import Text from '@piano/ui/components/Text.astro';
import Button from '@piano/ui/components/Button.astro';
import Icon from '@piano/ui/components/Icon.astro';
import USPGrid from '@piano/ui/components/USPGrid.astro';
import LeadForm from '@piano/ui/components/LeadForm.astro';
import { savarinNav, savarinCta } from '../config/nav';

const stats = [
  { num: 'od 1990', lbl: 'na trhu' },
  { num: 'do 24 h', lbl: 'garance servisního zásahu' },
  { num: 'až 99', lbl: 'středisek v jednom systému' },
  { num: 'ČR i SK', lbl: 'certifikováno pro provoz' },
];

const moduly = [
  { icon: 'lucide:monitor', title: 'Pokladna', text: 'Pokladní systém pro PC i POS — restaurační, hotelová a samoobslužná verze. Účtování na stoly, otevřené účty, dotykové ovládání.' },
  { icon: 'lucide:smartphone', title: 'Mobilní pokladna', text: 'Mobilní číšník — objednávky, storna a úhrady přímo u stolu. Funguje i v off-line režimu mimo dosah sítě.' },
  { icon: 'lucide:bed-double', title: 'Recepce', text: 'Komplexní agenda recepce: rezervace, ubytování hostů i skupin, účty, směnárna a statistické výkazy.' },
  { icon: 'lucide:calculator', title: 'Sklady a kalkulace', text: 'HRMTZ a HRKALKUL — skladové hospodářství, evidence tržeb, receptury jídel a komunikace s pokladnami.' },
  { icon: 'lucide:keyboard', title: 'Pokladní komponenty', text: 'POS terminály, dotykové monitory, termální i jehličkové tiskárny a programovatelné klávesnice.' },
  { icon: 'lucide:headset', title: 'Služby a servis', text: 'Nepřetržitý servis do 24 hodin, školení, nové verze i poradenství — na základě servisní smlouvy.' },
];

const vyhody = [
  { icon: 'lucide:blocks', title: 'Modulární systém', text: 'Nasaďte jen to, co potřebujete, a rozšiřujte postupně po jednotlivých subsystémech.' },
  { icon: 'lucide:network', title: 'Provoz v síti', text: 'Automatické datové přenosy mezi moduly — pokladna, sklad i recepce spolu komunikují.' },
  { icon: 'lucide:badge-check', title: 'Certifikace pro SK', text: 'Provoz PC/POS s fiskálním modulem na Slovensku; připraveno i na povinné pokladní systémy v ČR.' },
  { icon: 'lucide:shield-check', title: 'Bezpečnost', text: 'Přístup chráněný heslem a oprávněními pro jednotlivé uživatele.' },
];

const leadProofs = [
  { icon: 'lucide:headset', title: 'Servis do 24 h', text: 'Smluvním zákazníkům garantujeme termín servisního zásahu.' },
  { icon: 'lucide:calendar-check', title: 'Od roku 1990', text: 'Přes 30 let zkušeností s gastro a hotelovým provozem.' },
  { icon: 'lucide:badge-check', title: 'Certifikováno pro SK', text: 'Provoz s fiskálním modulem i na Slovensku.' },
  { icon: 'lucide:gift', title: 'Demoverze zdarma', text: 'Vyzkoušejte Savarin nezávazně před nákupem.' },
];
---

<Base title="Savarin — restaurační a hotelový systém"
      description="Savarin je modulární software pro stravovací a ubytovací provozy: pokladna, mobilní pokladna, recepce, sklady a kalkulace. Vývoj, dodávka a servis od roku 1990 (ComInn s.r.o.).">
  <Header brand="Savarin" logoSrc="/logos/savarin-logo.svg" homeHref="/" nav={savarinNav} cta={savarinCta} />

  <!-- HERO — split: text vlevo, POS účtenka vpravo (placeholder) -->
  <Hero eyebrow="Restaurační a hotelový systém" background="gradient"
        lead="Savarin je modulární systém pro stravovací a ubytovací provozy — pokladna, recepce, sklady a kalkulace na jednom místě. Vyvíjíme, dodáváme a servisujeme ho od roku 1990.">
    <Heading slot="title" as="h1" size="display" color="on-dark">Kompletní software pro váš <span class="accent">gastro a hotelový</span> provoz</Heading>
    <Fragment slot="actions">
      <Button href="#poptavka">Nezávazná poptávka</Button>
      <Button href="#moduly" variant="secondary" onDark>Prohlédnout moduly</Button>
    </Fragment>
    <div slot="media" class="hero-mock" aria-hidden="true">
      <div class="pos">
        <div class="pos__bar"><span></span><span></span><span></span></div>
        <div class="pos__body">
          <div class="pos__tables">
            <span class="pos__t pos__t--busy">1</span>
            <span class="pos__t pos__t--busy">2</span>
            <span class="pos__t">3</span>
            <span class="pos__t pos__t--busy">4</span>
            <span class="pos__t">5</span>
            <span class="pos__t">6</span>
          </div>
          <div class="receipt">
            <div class="receipt__head">Stůl 4 — účet</div>
            <ul class="receipt__lines">
              <li><span>2× Svíčková</span><span>318</span></li>
              <li><span>3× Pivo 0,5</span><span>165</span></li>
              <li><span>1× Káva</span><span>49</span></li>
            </ul>
            <div class="receipt__total"><span>Celkem</span><span>532 Kč</span></div>
          </div>
        </div>
      </div>
    </div>
  </Hero>

  <!-- STATS BAND -->
  <Section background="alt" space="sm">
    <ul class="stats">
      {stats.map((s) => (
        <li class="stats__item">
          <span class="stats__num">{s.num}</span>
          <span class="stats__lbl">{s.lbl}</span>
        </li>
      ))}
    </ul>
  </Section>

  <!-- MODULY -->
  <USPGrid id="moduly" eyebrow="Moduly systému" title="Jeden systém, který pokryje celý provoz"
           lead="Restaurace, hotelová restaurace i samoobslužný provoz — moduly Savarinu spolu komunikují a sdílí data."
           items={moduly} minItemWidth="300px" background="default" space="lg" />

  <!-- JAK TO ZAPADÁ DOHROMADY (modulární systém) -->
  <Section background="alt" space="lg">
    <div class="split">
      <div class="split__text">
        <Text size="label" color="accent">Modulární architektura</Text>
        <Heading as="h2" size="h2">Nasaďte jen to, co potřebujete — a <span class="accent">rozšiřujte postupně</span></Heading>
        <Text size="lead" color="muted" balance>
          Základem je modul <strong>HRMTZ a HRKALKUL</strong> (sklady a kalkulace), na který navazuje pokladna i recepce.
          Systém běží na samostatném PC, ale v síti získáte maximální komfort a automatické datové přenosy mezi moduly.
        </Text>
        <ul class="checklist">
          <li><Icon name="lucide:check" size="sm" class="hl-check" />Hotelová pokladna připíše útratu hosta na účet v Recepci</li>
          <li><Icon name="lucide:check" size="sm" class="hl-check" />Pokladna automaticky odepisuje zboží ze skladových karet</li>
          <li><Icon name="lucide:check" size="sm" class="hl-check" />Podklady pro podvojné účetnictví (textový i databázový export)</li>
          <li><Icon name="lucide:check" size="sm" class="hl-check" />Modul SledujTU — zaúčtování telefonních hovorů hostům</li>
        </ul>
        <div class="split__cta"><Button href="/sklady-a-kalkulace" variant="secondary">Více o jádru systému</Button></div>
      </div>
      <ul class="flow">
        <li class="flow__node flow__node--core"><Icon name="lucide:calculator" size="md" /><span>HRMTZ + HRKALKUL<small>sklady a kalkulace</small></span></li>
        <li class="flow__arr"><Icon name="lucide:arrow-down" size="sm" /></li>
        <li class="flow__node"><Icon name="lucide:monitor" size="md" /><span>Pokladna<small>PC / POS</small></span></li>
        <li class="flow__node"><Icon name="lucide:bed-double" size="md" /><span>Recepce<small>ubytování a účty</small></span></li>
      </ul>
    </div>
  </Section>

  <!-- VÝHODY -->
  <Section background="default" space="lg">
    <div class="head head--center">
      <Text size="label" color="accent" align="center">Proč Savarin</Text>
      <Heading as="h2" size="h2" align="center">Prověřené řešení pro <span class="accent">gastro i hotely</span></Heading>
    </div>
    <div class="vyhody">
      {vyhody.map((v) => (
        <article class="vyhoda">
          <span class="vyhoda__icon"><Icon name={v.icon} size="md" /></span>
          <Heading as="h3" size="h3">{v.title}</Heading>
          <Text size="small" color="muted">{v.text}</Text>
        </article>
      ))}
    </div>
  </Section>

  <!-- SERVIS + FINANCOVÁNÍ TEASER -->
  <Section background="invert" space="lg">
    <div class="teasers">
      <article class="teaser">
        <span class="teaser__icon"><Icon name="lucide:wrench" size="md" /></span>
        <Heading as="h3" size="h3" color="on-dark">Servis do 24 hodin</Heading>
        <Text color="on-dark-muted">
          Nepřetržitý servis pro smluvní zákazníky, hotline 24/7, školení a nové verze programů minimálně 4× ročně.
        </Text>
        <a class="teaser__link" href="/sluzby-servis">Služby a servis →</a>
      </article>
      <article class="teaser">
        <span class="teaser__icon"><Icon name="lucide:hand-coins" size="md" /></span>
        <Heading as="h3" size="h3" color="on-dark">Financování a pronájem</Heading>
        <Text color="on-dark-muted">
          Kromě přímého a splátkového prodeje si software můžete i pronajmout — s možností pozdějšího odkupu a multilicenčními slevami.
        </Text>
        <a class="teaser__link" href="/sluzby-servis#financovani">Formy prodeje →</a>
      </article>
    </div>
  </Section>

  <!-- POPTÁVKA -->
  <LeadForm id="poptavka" variant="full" background="alt"
            title="Nezávazná poptávka"
            lead="Napište nám pár slov o svém provozu a my vám připravíme cenovou nabídku na míru. Rádi zašleme i bezplatnou demoverzi."
            proofs={leadProofs} successUrl="/dekujeme" />

  <Footer />
</Base>

<style>
  /* Hero placeholder — POS / účtenka */
  .hero-mock { width: 100%; display: flex; justify-content: center; }
  .pos {
    width: 100%; max-width: 420px; background: var(--color-bg);
    border-radius: var(--radius-lg); box-shadow: var(--shadow-lg); overflow: hidden;
  }
  .pos__bar { display: flex; gap: 6px; padding: var(--space-3) var(--space-4); background: var(--color-neutral-100); }
  .pos__bar span { width: 10px; height: 10px; border-radius: 50%; background: var(--color-border-strong); }
  .pos__body { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-4); padding: var(--space-5); }
  .pos__tables { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-3); align-content: start; }
  .pos__t {
    display: flex; align-items: center; justify-content: center;
    aspect-ratio: 1; border-radius: var(--radius-md); font-weight: var(--font-weight-bold);
    background: var(--color-bg-alt); color: var(--color-text-muted); border: 1px solid var(--color-border);
  }
  .pos__t--busy { background: var(--color-primary); color: #fff; border-color: var(--color-primary); }
  .receipt { background: var(--color-bg-alt); border-radius: var(--radius-md); padding: var(--space-4); font-size: var(--font-size-small); }
  .receipt__head { font-weight: var(--font-weight-bold); margin-bottom: var(--space-3); color: var(--color-text); }
  .receipt__lines { list-style: none; display: flex; flex-direction: column; gap: var(--space-2); }
  .receipt__lines li { display: flex; justify-content: space-between; color: var(--color-text-muted); }
  .receipt__total {
    display: flex; justify-content: space-between; margin-top: var(--space-3);
    padding-top: var(--space-3); border-top: 1px dashed var(--color-border-strong);
    font-weight: var(--font-weight-bold); color: var(--color-secondary);
  }
  @media (max-width: 480px) { .pos__body { grid-template-columns: 1fr; } }

  /* Sdílená hlavička sekce */
  .head { max-width: 760px; margin-inline: auto; margin-bottom: var(--space-7); }
  .head--center { text-align: center; }
  .head > * + * { margin-top: var(--space-3); }

  /* Stats band */
  .stats { list-style: none; display: grid; gap: var(--space-5); grid-template-columns: repeat(4, 1fr); text-align: center; }
  .stats__item { display: flex; flex-direction: column; gap: var(--space-1); }
  .stats__num { font-size: var(--font-size-h2); font-weight: var(--font-weight-bold); line-height: 1; color: var(--color-secondary); }
  .stats__lbl { font-size: var(--font-size-small); color: var(--color-text-muted); }
  @media (max-width: 720px) { .stats { grid-template-columns: repeat(2, 1fr); gap: var(--space-6); } }

  /* Split (modulární architektura) */
  .split { display: grid; grid-template-columns: 1.2fr 1fr; gap: var(--space-8); align-items: center; }
  .split__text > * + * { margin-top: var(--space-4); }
  .split__cta { margin-top: var(--space-5); }
  @media (max-width: 880px) { .split { grid-template-columns: 1fr; gap: var(--space-6); } }

  .checklist { list-style: none; display: grid; gap: var(--space-2); }
  .checklist li { display: flex; align-items: flex-start; gap: var(--space-2); color: var(--color-text); }
  .hl-check { color: var(--color-secondary-azure); flex-shrink: 0; margin-top: 2px; }

  /* Flow diagram */
  .flow { list-style: none; display: flex; flex-direction: column; gap: var(--space-3); align-items: stretch; }
  .flow__node {
    display: flex; align-items: center; gap: var(--space-4);
    background: var(--color-bg); border: 1px solid var(--color-border);
    border-radius: var(--radius-md); padding: var(--space-4) var(--space-5); box-shadow: var(--shadow-sm);
    color: var(--color-primary);
  }
  .flow__node span { display: flex; flex-direction: column; color: var(--color-text); font-weight: var(--font-weight-semibold); }
  .flow__node span small { font-weight: var(--font-weight-regular); font-size: var(--font-size-small); color: var(--color-text-muted); }
  .flow__node--core { background: var(--color-primary); border-color: var(--color-primary); color: #fff; }
  .flow__node--core span, .flow__node--core span small { color: #fff; }
  .flow__node--core span small { color: rgba(255,255,255,0.8); }
  .flow__arr { display: flex; justify-content: center; color: var(--color-border-strong); }

  /* Výhody */
  .vyhody { display: grid; gap: var(--space-5); grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); }
  .vyhoda { background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: var(--space-6) var(--space-5); transition: var(--transition); }
  .vyhoda:hover { border-color: var(--color-primary); box-shadow: var(--shadow-sm); }
  .vyhoda > * + * { margin-top: var(--space-3); }
  .vyhoda__icon { display: inline-flex; color: var(--color-text-accent); }

  /* Teasers (servis + financování) */
  .teasers { display: grid; gap: var(--space-6); grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); }
  .teaser { background: rgba(255,255,255,0.04); border: 1px solid var(--color-border-on-dark); border-radius: var(--radius-md); padding: var(--space-6); }
  .teaser > * + * { margin-top: var(--space-3); }
  .teaser__icon { display: inline-flex; color: var(--color-secondary-gold); }
  .teaser__link { display: inline-block; margin-top: var(--space-4); color: var(--color-secondary-gold); text-decoration: none; font-weight: var(--font-weight-semibold); }
  .teaser__link:hover { text-decoration: underline; }
</style>
