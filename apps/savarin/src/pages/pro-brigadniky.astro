---
/**
 * Pro brigádníky — worker-facing stránka.
 * Obsah z grason-web-develop/pages/index.vue + page_hp_* (cs.json).
 * Sdílené komponenty @piano/ui.
 */
import Base from '../layouts/Base.astro';
import Header from '@piano/ui/components/Header.astro';
import Footer from '@piano/ui/components/Footer.astro';
import Section from '@piano/ui/components/Section.astro';
import Hero from '@piano/ui/components/Hero.astro';
import Heading from '@piano/ui/components/Heading.astro';
import Text from '@piano/ui/components/Text.astro';
import Button from '@piano/ui/components/Button.astro';
import Icon from '@piano/ui/components/Icon.astro';
import { grasonNav, grasonCta } from '../config/nav';

const steps = [
  { title: 'Zaregistrujete se', text: 'Stačí vám 3 minuty, mobil a naše aplikace.' },
  { title: 'Přihlásíte se na směny', text: 'Vyberete si, kdy a kde budete pracovat.' },
  { title: 'Vše vám potvrdíme', text: 'Potvrzení směny přijde v SMS. Den předem vám ji pro jistotu připomeneme.' },
  { title: 'Pracujete', text: 'Za svou práci dostanete zaplaceno tolik, kolik jste si sami řekli.' },
];

const jobs = [
  { icon: 'lucide:concierge-bell', label: 'Hosteska' },
  { icon: 'lucide:bike', label: 'Kurýr' },
  { icon: 'lucide:calculator', label: 'Pokladní' },
  { icon: 'lucide:utensils', label: 'Číšník / Servírka' },
  { icon: 'lucide:package', label: 'Skladník' },
  { icon: 'lucide:boxes', label: 'Bedňák' },
];

const perks = [
  { icon: 'lucide:wallet', title: 'Mzdu si určujete vy', text: 'Při přihlašování uvidíte, jakou částku podnik preferuje. Je ale jen na vás, za kolik chcete pracovat.' },
  { icon: 'lucide:calendar-heart', title: 'Buďte pány svého času', text: 'Sami si naplánujete, kdy a jak často budete pracovat. Záleží jen na vás, kolik směn si vezmete.' },
  { icon: 'lucide:banknote', title: 'Výplata ihned po směně', text: 'Žádné čekání na výplatní termín — peníze máte hned, jak odpracujete.' },
];

const testimonials = [
  { initials: 'MD', quote: 'Grason je skvělá aplikace, můžu se přihlásit, kdy chci, kam chci, peníze mám hned a mám jistotu, že vždy nějakou směnu najdu.', author: 'Maryna Dragula', role: 'Servírka' },
  { initials: 'MŽ', quote: 'Grason bych doporučil, je to cesta ke svobodě. Člověk nedělá pořád to samé — poznává různé technologie a jiné kuchaře. Super věc pro lidi, co gastronomie opravdu zajímá.', author: 'Martin Železník', role: 'Kuchař' },
  { initials: 'RH', quote: 'Skvělá aplikace, která lidem pomáhá najít brigádu nebo práci — a je vyplácená ihned po směně. Určíš si, kdy chceš pracovat, kolik hodin a za jakou hodinovku.', author: 'Richard Hodási', role: 'Číšník' },
];
---

<Base title="Pro brigádníky — Grason"
      description="Vaše řešení pro flexibilní práci. Pracujte ještě dnes — směny v čase a místě, kdy a kde zrovna můžete. Výplata ihned po směně.">
  <Header brand="Grason" logoSrc="/logos/grason-logo.svg" homeHref="/" nav={grasonNav} cta={grasonCta} />

  <!-- HERO -->
  <Hero eyebrow="Pro brigádníky" background="gradient"
        lead="Pracujte ještě dnes. Směny v čase a místě, kdy a kde zrovna můžete. Sami si určíte, co, pro koho a za kolik budete dělat.">
    <Heading slot="title" as="h1" size="display" color="on-dark">Vaše řešení pro <span class="accent">flexibilní práci</span></Heading>
    <Fragment slot="actions">
      <Button href="#stahnout">Stáhnout aplikaci</Button>
    </Fragment>
    <figure slot="media" class="hero-figure">
      <img src="/images/hp-hero.png" alt="Grason — aplikace s nabídkami směn pro brigádníky" width="720" height="560" loading="eager" />
    </figure>
  </Hero>

  <!-- JAK TO FUNGUJE -->
  <Section background="default" space="lg">
    <div class="head head--center">
      <Text size="label" color="accent" align="center">Jak to funguje</Text>
      <Heading as="h2" size="h2" align="center">Od stažení appky <span class="accent">k první výplatě</span></Heading>
    </div>
    <ol class="steps">
      {steps.map((s, i) => (
        <li class="step">
          <span class="step__num">{i + 1}</span>
          <Heading as="h3" size="h3">{s.title}</Heading>
          <Text size="small" color="muted">{s.text}</Text>
        </li>
      ))}
    </ol>
  </Section>

  <!-- OBORY -->
  <Section background="alt" space="lg">
    <div class="head head--center">
      <Text size="label" color="accent" align="center">Obory</Text>
      <Heading as="h2" size="h2" align="center">Vyberte si z řady <span class="accent">firem a oborů</span></Heading>
      <Text size="lead" color="muted" align="center" balance>
        Číšník, kuchař nebo třeba kurýr. Sami si svobodně zvolíte, co a pro koho budete dělat.
      </Text>
    </div>
    <ul class="jobs">
      {jobs.map((j) => (
        <li class="job"><span class="job__icon"><Icon name={j.icon} size="md" /></span>{j.label}</li>
      ))}
    </ul>
  </Section>

  <!-- VÝHODY -->
  <Section background="default" space="lg">
    <ul class="perks">
      {perks.map((p) => (
        <li class="perk">
          <span class="perk__icon"><Icon name={p.icon} size="md" /></span>
          <Heading as="h3" size="h3">{p.title}</Heading>
          <Text size="small" color="muted">{p.text}</Text>
        </li>
      ))}
    </ul>
  </Section>

  <!-- REFERENCE -->
  <Section background="alt" space="lg">
    <div class="head head--center">
      <Text size="label" color="accent" align="center">Co říkají grasoni</Text>
      <Heading as="h2" size="h2" align="center">Práce, <span class="accent">jak ji chcete žít</span></Heading>
    </div>
    <div class="quotes">
      {testimonials.map((t, i) => (
        <figure class={`quote quote--${i % 3}`}>
          <div class="quote__head">
            <div class="quote__id">
              <strong class="quote__name">{t.author}</strong>
              <span class="quote__role">{t.role}</span>
            </div>
            <span class="quote__avatar" aria-hidden="true">{t.initials}</span>
          </div>
          <span class="quote__mark"><Icon name="lucide:quote" size="md" /></span>
          <blockquote class="quote__text">{t.quote}</blockquote>
        </figure>
      ))}
    </div>
  </Section>

  <!-- STÁHNOUT -->
  <Section id="stahnout" background="primary" space="lg">
    <div class="head head--center">
      <Text size="label" color="on-dark-muted" align="center">Mobilní aplikace</Text>
      <Heading as="h2" size="h2" align="center" color="on-dark">Mějte Grason <span class="accent">stále po ruce</span></Heading>
      <Text size="lead" color="on-dark-muted" align="center" balance>
        Stáhněte si appku a přihlaste se na první směnu ještě dnes. iOS i Android, zdarma.
      </Text>
      <div class="store">
        <Button href="https://apps.apple.com/" variant="secondary" onDark>App Store</Button>
        <Button href="https://play.google.com/" variant="secondary" onDark>Google Play</Button>
      </div>
    </div>
  </Section>

  <Footer />
</Base>

<style>
  .hero-figure { margin: 0; width: 100%; line-height: 0; }
  .hero-figure img { width: 100%; height: auto; display: block; filter: drop-shadow(0 24px 48px rgba(7, 7, 7, 0.22)); }

  .head { max-width: 760px; margin-inline: auto; margin-bottom: var(--space-7); }
  .head--center { text-align: center; }
  .head > * + * { margin-top: var(--space-3); }

  /* Steps */
  .steps { list-style: none; display: grid; gap: var(--space-6); grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); }
  .step { position: relative; padding: var(--space-6); background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-md); box-shadow: var(--shadow-sm); }
  .step > * + * { margin-top: var(--space-3); }
  .step__num { display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px; border-radius: var(--radius-full); background: var(--color-secondary-azure); color: #07333a; font-size: var(--font-size-lead); font-weight: var(--font-weight-bold); }

  /* Jobs */
  .jobs { list-style: none; display: flex; flex-wrap: wrap; gap: var(--space-4); justify-content: center; }
  .job { display: inline-flex; align-items: center; gap: var(--space-3); padding: var(--space-3) var(--space-5); background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-full); font-weight: var(--font-weight-medium); box-shadow: var(--shadow-sm); }
  .job__icon { display: inline-flex; color: var(--color-secondary-azure); }

  /* Perks */
  .perks { list-style: none; display: grid; gap: var(--space-6); grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); }
  .perk { padding: var(--space-6); background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-lg); box-shadow: var(--shadow-sm); }
  .perk > * + * { margin-top: var(--space-3); }
  .perk__icon { display: inline-flex; width: 56px; height: 56px; align-items: center; justify-content: center; border-radius: var(--radius-full); background: color-mix(in srgb, var(--color-secondary-azure) 16%, #fff); color: var(--color-text-accent); }

  /* Store buttons */
  .store { display: flex; gap: var(--space-3); justify-content: center; flex-wrap: wrap; margin-top: var(--space-5); }

  /* Reference */
  .quotes { display: grid; gap: var(--space-6); grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); }
  .quote { margin: 0; display: flex; flex-direction: column; background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: var(--space-6); box-shadow: var(--shadow-sm); }
  .quote__head { display: flex; align-items: center; justify-content: space-between; gap: var(--space-4); margin-bottom: var(--space-4); }
  .quote__id { display: flex; flex-direction: column; gap: 2px; }
  .quote__name { font-size: var(--font-size-lead); font-weight: var(--font-weight-bold); color: var(--color-secondary); line-height: 1.15; }
  .quote__role { font-size: var(--font-size-small); color: var(--color-text-muted); }
  .quote__avatar { flex-shrink: 0; width: 56px; height: 56px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; font-size: var(--font-size-body); font-weight: var(--font-weight-bold); color: #fff; }
  .quote--0 .quote__avatar { background: linear-gradient(150deg, #3CC1C8, #343160); }
  .quote--1 .quote__avatar { background: linear-gradient(150deg, #F96797, #343160); }
  .quote--2 .quote__avatar { background: linear-gradient(150deg, #FAD531, #343160); }
  .quote__mark { color: var(--color-secondary-azure); display: block; margin-bottom: var(--space-2); }
  .quote__text { font-size: var(--font-size-body); color: var(--color-text); line-height: var(--line-height-body); }
</style>
