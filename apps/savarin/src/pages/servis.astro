---
/**
 * Savarin — Servis. Obsah z legacy stránky sluzby-servis (servisní část).
 * Ceny bez DPH, platné od 1. 1. 2026 (dle podkladu). Sdílené komponenty @piano/ui.
 */
import Base from '../layouts/Base.astro';
import Header from '@piano/ui/components/Header.astro';
import Footer from '@piano/ui/components/Footer.astro';
import Breadcrumb from '@piano/ui/components/Breadcrumb.astro';
import Section from '@piano/ui/components/Section.astro';
import Hero from '@piano/ui/components/Hero.astro';
import Heading from '@piano/ui/components/Heading.astro';
import Text from '@piano/ui/components/Text.astro';
import Button from '@piano/ui/components/Button.astro';
import Icon from '@piano/ui/components/Icon.astro';
import LeadForm from '@piano/ui/components/LeadForm.astro';
import { savarinNav, savarinCta } from '../config/nav';

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    { '@type': 'BreadcrumbList', itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Domů', item: 'https://savarin.cz/' },
      { '@type': 'ListItem', position: 2, name: 'Servis', item: 'https://savarin.cz/servis' },
    ] },
  ],
};
---

<Base title="Servis Savarin — garance zásahu do 24 h, hotline 24/7"
      description="Servisní služby k systému Savarin: garance servisního zásahu do 24 hodin, hotline 24/7 pro smluvní zákazníky, školení a nové verze. Ceník servisu se smlouvou i bez ní."
      schema={schema}>
  <Header brand="Savarin" logoSrc="/logos/savarin_logo.svg" logoHeight="36px" homeHref="/" nav={savarinNav} cta={savarinCta} />

  <main>

  <Breadcrumb items={[{ label: 'Domů', href: '/' }, { label: 'Servis' }]} />

  <Hero eyebrow="Servis" background="gradient"
        lead="Podstatnou součástí dodávky je servis. Smluvním zákazníkům garantujeme termín servisního zásahu do 24 hodin a hotline 24/7.">
    <Heading slot="title" as="h1" size="display" color="on-dark">Servis, na který se <span class="accent">spolehnete</span></Heading>
    <Fragment slot="actions">
      <Button href="#poptavka">Nezávazná poptávka</Button>
      <Button href="/cenik" variant="secondary" onDark>Ceník a pronájem</Button>
    </Fragment>
  </Hero>

  <!-- GARANCE -->
  <Section background="default" space="md">
    <ul class="garance">
      <li><span class="garance__icon"><Icon name="lucide:clock" size="md" /></span><strong>Zásah do 24 h</strong><span>garantujeme smluvním zákazníkům</span></li>
      <li><span class="garance__icon"><Icon name="lucide:headset" size="md" /></span><strong>Hotline 24/7</strong><span>nepřetržitě pro smluvní zákazníky</span></li>
      <li><span class="garance__icon"><Icon name="lucide:refresh-cw" size="md" /></span><strong>Nové verze 4× ročně</strong><span>v rámci paušálu, automaticky</span></li>
    </ul>
  </Section>

  <!-- CENÍK SERVISU -->
  <Section background="alt" space="lg">
    <div class="head head--center">
      <Text size="label" color="accent" align="center">Ceník servisu</Text>
      <Heading as="h2" size="h2" align="center">Dva přístupy <span class="accent">podle smlouvy</span></Heading>
    </div>
    <div class="pricing">
      <article class="price">
        <span class="price__tag">Bez servisní smlouvy</span>
        <Text color="muted" size="small">Zákazník hradí veškeré školení, servisní zásahy a cestovní náklady.</Text>
        <ul class="rate">
          <li><span>Do 30 minut</span><span>650 Kč</span></li>
          <li><span>Každá započatá hodina</span><span>1 200 Kč</span></li>
        </ul>
        <p class="price__note">Příplatek +50 % o sobotách, nedělích a státních svátcích; +25 % ve večerních a nočních hodinách (17:00–07:00).</p>
      </article>
      <article class="price price--featured">
        <span class="price__badge">Doporučeno</span>
        <span class="price__tag">Se servisní smlouvou</span>
        <Text color="muted" size="small">Pravidelný paušální poplatek dle smlouvy. Práce nad rámec smlouvy se slevou 10 %.</Text>
        <ul class="rate">
          <li><span>Do 15 minut</span><span>330 Kč</span></li>
          <li><span>Do 30 minut</span><span>585 Kč</span></li>
          <li><span>Každá započatá hodina</span><span>1 080 Kč</span></li>
        </ul>
        <p class="price__note">Telefonické porady i volání zdarma mimo pracovní dobu a ve dnech volna. Nové verze a aktualizace v ceně paušálu.</p>
      </article>
    </div>
    <ul class="rate rate--extra">
      <li><span>Datový analytik / konzultace vazeb na účetnictví</span><span>1 470 Kč/hod</span></li>
      <li><span>Programátorské práce (dle typu)</span><span>1 550–1 990 Kč/hod</span></li>
      <li><span>Cestovní náklady</span><span>15 Kč/km</span></li>
    </ul>
    <p class="disclaimer">Všechny ceny jsou uvedeny bez DPH a jsou platné od 1. 1. 2026.</p>
  </Section>

  <!-- VZDÁLENÁ SPRÁVA + AKTUÁLNĚ -->
  <Section background="default" space="lg">
    <div class="links">
      <a class="linkcard" href="/aktualne">
        <span class="linkcard__icon"><Icon name="lucide:megaphone" size="md" /></span>
        <Heading as="h2" size="h3">Aktuální verze a novinky</Heading>
        <Text size="small" color="muted">Přehled nových verzí SW Savarin a provozních informací.</Text>
        <span class="linkcard__more">Zobrazit <Icon name="lucide:arrow-right" size="xs" /></span>
      </a>
      <div class="linkcard linkcard--static">
        <span class="linkcard__icon"><Icon name="lucide:screen-share" size="md" /></span>
        <Heading as="h2" size="h3">Vzdálená správa</Heading>
        <Text size="small" color="muted">Servis na dálku přes TeamViewer (QuickSupport pro jednorázové připojení nebo HOST pro trvalý přístup).</Text>
      </div>
    </div>
  </Section>

  <LeadForm id="poptavka" variant="full" background="alt"
            title="Potřebujete servis nebo smlouvu?"
            lead="Napište nám — domluvíme servisní smlouvu nebo vyřešíme konkrétní požadavek. Smluvním zákazníkům garantujeme zásah do 24 hodin."
            successUrl="/dekujeme" />

  </main>

  <Footer logoSrc="/logos/savarin_by_piano.svg" logoAlt="Savarin by Piano" parentNote={{ text: 'Savarin je součástí skupiny Piano', href: 'https://piano.cz' }} />
</Base>

<style>
  .head { max-width: 760px; margin-inline: auto; margin-bottom: var(--space-7); }
  .head--center { text-align: center; }
  .head > * + * { margin-top: var(--space-3); }

  .garance { list-style: none; display: grid; gap: var(--space-5); grid-template-columns: repeat(3, 1fr); }
  .garance li { display: flex; flex-direction: column; align-items: flex-start; gap: var(--space-1); padding: var(--space-5); background: var(--color-bg-alt); border-radius: var(--radius-md); border-left: 3px solid var(--color-primary); }
  .garance strong { color: var(--color-text); font-size: var(--font-size-lead); }
  .garance span:last-child { color: var(--color-text-muted); font-size: var(--font-size-small); }
  .garance__icon { display: inline-flex; color: var(--color-primary); margin-bottom: var(--space-2); }
  @media (max-width: 720px) { .garance { grid-template-columns: 1fr; } }

  .pricing { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: var(--space-6); max-width: 900px; margin-inline: auto; }
  .price { position: relative; background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: var(--space-7); box-shadow: var(--shadow-sm); display: flex; flex-direction: column; gap: var(--space-3); }
  .price--featured { border-color: var(--color-primary); box-shadow: var(--shadow-md); }
  .price__tag { font-weight: var(--font-weight-bold); font-size: var(--font-size-lead); color: var(--color-secondary); }
  .price__badge { position: absolute; top: var(--space-5); right: var(--space-5); background: var(--color-secondary-terracotta); color: #fff; font-size: var(--font-size-caption); font-weight: var(--font-weight-semibold); padding: var(--space-1) var(--space-3); border-radius: var(--radius-full); }
  .price__note { font-size: var(--font-size-small); color: var(--color-text-muted); line-height: var(--line-height-body); }

  .rate { list-style: none; display: flex; flex-direction: column; gap: var(--space-2); margin-top: var(--space-2); }
  .rate li { display: flex; justify-content: space-between; gap: var(--space-4); padding: var(--space-2) 0; border-bottom: 1px solid var(--color-border); }
  .rate li span:last-child { font-weight: var(--font-weight-bold); color: var(--color-text); white-space: nowrap; }
  .rate--extra { max-width: 900px; margin: var(--space-6) auto 0; }
  .disclaimer { text-align: center; margin-top: var(--space-5); font-size: var(--font-size-small); color: var(--color-text-muted); }

  .links { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: var(--space-6); max-width: 900px; margin-inline: auto; }
  .linkcard { background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: var(--space-6); text-decoration: none; color: inherit; display: flex; flex-direction: column; transition: var(--transition); }
  .linkcard:not(.linkcard--static):hover { border-color: var(--color-primary); box-shadow: var(--shadow-sm); }
  .linkcard > * + * { margin-top: var(--space-3); }
  .linkcard__icon { display: inline-flex; color: var(--color-text-accent); }
  .linkcard__more { margin-top: var(--space-4); color: var(--color-text-accent); font-weight: var(--font-weight-semibold); font-size: var(--font-size-small); display: inline-flex; align-items: center; gap: var(--space-1); }
</style>
