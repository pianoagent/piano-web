---
/**
 * Savarin — Recepce. Obsah z legacy stránky recepce (+ popis-programu).
 * Sdílené komponenty @piano/ui.
 */
import Base from '../layouts/Base.astro';
import Header from '@piano/ui/components/Header.astro';
import Footer from '@piano/ui/components/Footer.astro';
import Section from '@piano/ui/components/Section.astro';
import Hero from '@piano/ui/components/Hero.astro';
import Heading from '@piano/ui/components/Heading.astro';
import Text from '@piano/ui/components/Text.astro';
import Button from '@piano/ui/components/Button.astro';
import Icon from '@piano/ui/components/Icon.astro';
import USPGrid from '@piano/ui/components/USPGrid.astro';
import LeadForm from '@piano/ui/components/LeadForm.astro';
import { savarinNav, savarinCta } from '../config/nav';

const funkce = [
  { icon: 'lucide:calendar-check', title: 'Rezervace', text: 'Pro jednotlivce i skupiny, s tiskem potvrzení a evidencí záloh. Podpora přebukování, waitingu i oprav přijatých rezervací.' },
  { icon: 'lucide:layout-grid', title: 'Grafické „štafle“', text: 'Přehledná tabulka všech pokojů se stavem (volný, rezervace, obsazený), typem, jménem hosta a informací o účtu.' },
  { icon: 'lucide:bed-double', title: 'Ubytování a účty', text: 'Ubytování hostů i skupin, denní připisování ceny ubytování a služeb (garáž, pes, bazén) na účet hosta.' },
  { icon: 'lucide:receipt', title: 'Vystavení účtu', text: 'Úhrada různými druhy plateb, převod na účet jiného pokoje, společný účet za celou skupinu, jméno firmy na účtu.' },
  { icon: 'lucide:arrow-left-right', title: 'Směnárna', text: 'Pro provozy se směnárnou je součástí Recepce modul, který předepsaným způsobem vede směnárenskou agendu.' },
  { icon: 'lucide:bar-chart-3', title: 'Statistiky a výkazy', text: 'Domovní kniha, ubytovaní hosté dne, ubytovaní cizinci, přihlašovací lístky cizinců i řízení úklidu pokojů.' },
];
---

<Base title="Recepce Savarin — hotelový rezervační systém"
      description="Modul Recepce Savarin: rezervace pokojů a služeb, ubytování hostů i skupin, účty, směnárna, statistické výkazy a vazba na sklady (HRMTZ).">
  <Header brand="Savarin" logoSrc="/logos/savarin_logo.svg" logoHeight="36px" homeHref="/" nav={savarinNav} cta={savarinCta} />

  <main>

  <Hero eyebrow="Modul · Recepce" background="gradient"
        lead="SW modul RECEPCE zabezpečuje komplexní práci recepce ubytovacího zařízení — od rezervací přes ubytování hostů a skupin až po vystavení účtu a uvolnění pokoje.">
    <Heading slot="title" as="h1" size="display" color="on-dark">Celá recepce <span class="accent">pod kontrolou</span></Heading>
    <Fragment slot="actions">
      <Button href="#poptavka">Nezávazná poptávka</Button>
      <Button href="#funkce" variant="secondary" onDark>Co Recepce umí</Button>
    </Fragment>
  </Hero>

  <USPGrid id="funkce" eyebrow="Funkce modulu" title="Od rezervace po uvolnění pokoje"
           lead="Většina úkonů — rezervace, ubytování, zvýšení účtu, placení — se provádí v přehledných grafických „štaflích“."
           items={funkce} minItemWidth="300px" background="default" space="lg" />

  <!-- VAZBY -->
  <Section background="alt" space="lg">
    <div class="split">
      <div class="split__text">
        <Text size="label" color="accent">Vazby na další moduly</Text>
        <Heading as="h2" size="h2">Recepce <span class="accent">propojená</span> s pokladnou i sklady</Heading>
        <Text size="lead" color="muted" balance>
          Prodej zboží a služeb je možný i přímo „přes pult“ neubytovaným hostům. Existuje vazba do programu HRMTZ,
          který udržuje aktuální seznam prodávaného zboží a odečítá prodané zboží z příslušného skladu.
        </Text>
        <ul class="checklist">
          <li><Icon name="lucide:check" size="sm" class="hl-check" />Podklady pro zaúčtování, předávání služeb a hotovosti</li>
          <li><Icon name="lucide:check" size="sm" class="hl-check" />Modul fakturace vázaný na hotelové účty</li>
          <li><Icon name="lucide:check" size="sm" class="hl-check" />Manažerský modul s dalšími statistikami a ekonomikou</li>
          <li><Icon name="lucide:check" size="sm" class="hl-check" />Modul SledujTU — zaúčtování telefonních hovorů hostům</li>
        </ul>
        <div class="split__cta">
          <Button href="/sklady-a-kalkulace" variant="secondary">Sklady a kalkulace</Button>
        </div>
      </div>
      <ul class="flow">
        <li class="flow__node flow__node--core"><Icon name="lucide:bed-double" size="md" /><span>Recepce<small>rezervace a účty</small></span></li>
        <li class="flow__node"><Icon name="lucide:monitor" size="md" /><span>Pokladna<small>útrata na účet hosta</small></span></li>
        <li class="flow__node"><Icon name="lucide:calculator" size="md" /><span>HRMTZ<small>odpis zboží ze skladu</small></span></li>
        <li class="flow__node"><Icon name="lucide:phone" size="md" /><span>SledujTU<small>telefonní hovory</small></span></li>
      </ul>
    </div>
  </Section>

  <LeadForm id="poptavka" variant="full" background="default"
            title="Zajímá vás Recepce Savarin?"
            lead="Popište nám svůj provoz (počet pokojů, střediska, směnárna) a připravíme cenovou nabídku. Rádi zašleme i demoverzi."
            successUrl="/dekujeme" />

  </main>

  <Footer legal={[{ label: 'Ochrana osobních údajů', href: '/ochrana-udaju' }]} logoSrc="/logos/savarin_by_piano.svg" logoAlt="Savarin by Piano" parentNote={{ text: 'Savarin je součástí skupiny Piano', href: 'https://piano.cz' }} />
</Base>

<style>
  .split { display: grid; grid-template-columns: 1.2fr 1fr; gap: var(--space-8); align-items: center; }
  .split__text > * + * { margin-top: var(--space-4); }
  .split__cta { margin-top: var(--space-5); }
  @media (max-width: 880px) { .split { grid-template-columns: 1fr; gap: var(--space-6); } }

  .checklist { list-style: none; display: grid; gap: var(--space-2); }
  .checklist li { display: flex; align-items: flex-start; gap: var(--space-2); color: var(--color-text); }
  .hl-check { color: var(--color-secondary-azure); flex-shrink: 0; margin-top: 2px; }

  .flow { list-style: none; display: flex; flex-direction: column; gap: var(--space-3); }
  .flow__node {
    display: flex; align-items: center; gap: var(--space-4);
    background: var(--color-bg); border: 1px solid var(--color-border);
    border-radius: var(--radius-md); padding: var(--space-4) var(--space-5); box-shadow: var(--shadow-sm);
    color: var(--color-primary);
  }
  .flow__node span { display: flex; flex-direction: column; color: var(--color-text); font-weight: var(--font-weight-semibold); }
  .flow__node span small { font-weight: var(--font-weight-regular); font-size: var(--font-size-small); color: var(--color-text-muted); }
  .flow__node--core { background: var(--color-primary); border-color: var(--color-primary); color: #fff; }
  .flow__node--core span, .flow__node--core span small { color: #fff; }
  .flow__node--core span small { color: rgba(255,255,255,0.8); }
</style>
