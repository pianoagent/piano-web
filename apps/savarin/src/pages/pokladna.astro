---
/**
 * Savarin — Pokladna (+ sekce Mobilní pokladna #mobilni a Pokladní komponenty #komponenty).
 * Obsah z legacy stránek pokladna / mobilni-pokladna / pokladni-komponenty.
 * Sdílené komponenty @piano/ui.
 */
import Base from '../layouts/Base.astro';
import Header from '@piano/ui/components/Header.astro';
import Footer from '@piano/ui/components/Footer.astro';
import Section from '@piano/ui/components/Section.astro';
import Hero from '@piano/ui/components/Hero.astro';
import Heading from '@piano/ui/components/Heading.astro';
import Text from '@piano/ui/components/Text.astro';
import Button from '@piano/ui/components/Button.astro';
import Icon from '@piano/ui/components/Icon.astro';
import USPGrid from '@piano/ui/components/USPGrid.astro';
import LeadForm from '@piano/ui/components/LeadForm.astro';
import { savarinNav, savarinCta } from '../config/nav';

const verze = [
  { icon: 'lucide:utensils', title: 'Restaurační', text: 'Účtování na stoly a vedení otevřených účtů. Číšník otevírá a uzavírá účty hostů v průběhu celé návštěvy.' },
  { icon: 'lucide:bed-double', title: 'Hotelová', text: 'Spolupracuje s modulem Recepce — pozná, zda host bydlí na pokoji, má založený účet a „právo účtu“ pro připisování útraty.' },
  { icon: 'lucide:shopping-bag', title: 'Samoobslužná', text: 'Pro jídelny, stravovací linky, bufety a maloobchod. Po objednávce systém ihned vystaví účtenku, bez nutnosti otevírat účet.' },
];

const funkce = [
  'Ovládání přes dotykový display, PC nebo POS terminál',
  'Programovatelná restaurační klávesnice pro rychlé markování',
  'Otevřené účty, storna, převody položek mezi účty',
  'Kuchyňská tiskárna — objednávky rovnou na výdej',
  'Denní uzávěrky a odpis prodaného zboží ze skladu',
  'Certifikováno pro provoz s fiskálním modulem na Slovensku',
];

const mobilFunkce = [
  { icon: 'lucide:clipboard-list', title: 'Objednávka u stolu', text: 'Příjem objednávky na konkrétní stůl nebo židli; v dosahu sítě vidíte aktuální obsah účtu hosta.' },
  { icon: 'lucide:wifi-off', title: 'Off-line režim', text: 'Objednávejte i mimo dosah sítě — v salonku, sklepě či na zahrádce. Po připojení se data přenesou.' },
  { icon: 'lucide:undo-2', title: 'Storna a přesuny', text: 'Stornujte namarkované položky nebo je převeďte z účtu hosta na jiný účet.' },
  { icon: 'lucide:credit-card', title: 'Úhrada účtu', text: 'Zaplacení vybraných položek, volba druhu platby i převod na účet hosta ubytovaného v Recepci.' },
];

const komponenty = [
  { icon: 'lucide:monitor', title: 'PC POS a monitory', text: 'PC POS ET-700 Gladius s dotykovou obrazovkou a integrovaným UPS; dotykové monitory ELO (TouchScreen).' },
  { icon: 'lucide:smartphone', title: 'Mobilní zařízení', text: 'Mobilní číšník Android (telefon, phablet, tablet, min. Android 5.1) — komunikace přes WiFi, výdrž nad 3000 mAh.' },
  { icon: 'lucide:printer', title: 'Tiskárny', text: 'Termální EPSON TM-T20 (80 mm, rychlý tichý tisk loga) i jehličková EPSON TM-U220 (76 mm, dvoubarevný tisk).' },
  { icon: 'lucide:keyboard', title: 'Klávesnice', text: 'Programovatelné klávesnice PCU (111 kláves, čtečka magnet. karet) a Tipro (128 kláves) — cca 85 kláves pro sortiment.' },
];
---

<Base title="Pokladna Savarin — pokladní systém pro PC i POS"
      description="Pokladní systém Savarin pro restaurace, hotelové restaurace i samoobslužný provoz. Dotykové ovládání, mobilní číšník, pokladní komponenty (POS, tiskárny, klávesnice).">
  <Header brand="Savarin" logoSrc="/logos/savarin-logo.svg" homeHref="/" nav={savarinNav} cta={savarinCta} />

  <Hero eyebrow="Modul · Pokladna" background="gradient"
        lead="Software, který běží na standardním PC s programovatelnou klávesnicí i na specializovaných POS s dotykovým displejem. Certifikovaný pro provoz s fiskálním modulem na Slovensku.">
    <Heading slot="title" as="h1" size="display" color="on-dark">Pokladna Savarin pro <span class="accent">PC i POS</span></Heading>
    <Fragment slot="actions">
      <Button href="#poptavka">Nezávazná poptávka</Button>
      <Button href="#verze" variant="secondary" onDark>Verze programu</Button>
    </Fragment>
  </Hero>

  <!-- VERZE -->
  <Section id="verze" background="default" space="lg">
    <div class="head head--center">
      <Text size="label" color="accent" align="center">Možnosti nasazení</Text>
      <Heading as="h2" size="h2" align="center">Tři verze pro <span class="accent">každý typ provozu</span></Heading>
    </div>
    <div class="cards">
      {verze.map((v) => (
        <article class="card">
          <span class="card__icon"><Icon name={v.icon} size="md" /></span>
          <Heading as="h3" size="h3">{v.title}</Heading>
          <Text size="small" color="muted">{v.text}</Text>
        </article>
      ))}
    </div>
  </Section>

  <!-- FUNKCE -->
  <Section background="alt" space="lg">
    <div class="split">
      <div class="split__text">
        <Text size="label" color="accent">Výběr z možností programu</Text>
        <Heading as="h2" size="h2">Vše pro <span class="accent">rychlou obsluhu</span> a přesnou uzávěrku</Heading>
        <Text size="lead" color="muted" balance>
          Pokladna zabezpečuje veškerou agendu spojenou s prodejem až po vystavení účtu, denní uzávěrku a odpis zboží ze skladových karet.
        </Text>
      </div>
      <ul class="checklist checklist--cols">
        {funkce.map((f) => (
          <li><Icon name="lucide:check" size="sm" class="hl-check" />{f}</li>
        ))}
      </ul>
    </div>
  </Section>

  <!-- MOBILNÍ POKLADNA -->
  <USPGrid id="mobilni" eyebrow="Mobilní číšník Savarin" title="Pokladna, kterou nosíte u stolu"
           lead="Rozšíření pokladního systému o mobilní zařízení přenese objednávání i vyúčtování přímo k hostovi. Akce na terminálu se ihned zapíší do pokladny."
           items={mobilFunkce} minItemWidth="260px" background="default" space="lg" />

  <Section background="invert" space="sm">
    <ul class="signals">
      <li><Icon name="lucide:signal" size="sm" /> Signalizace síly signálu i off-line režimu</li>
      <li><Icon name="lucide:battery-medium" size="sm" /> Zobrazení kapacity baterie</li>
      <li><Icon name="lucide:list-checks" size="sm" /> Přehled odeslaných i neodeslaných požadavků</li>
    </ul>
  </Section>

  <!-- POKLADNÍ KOMPONENTY -->
  <USPGrid id="komponenty" eyebrow="Pokladní komponenty" title="Hardware prověřený v provozu"
           lead="Dodáváme a servisujeme kompletní pokladní techniku — od POS terminálů po tiskárny a klávesnice."
           items={komponenty} minItemWidth="280px" background="alt" space="lg" />

  <!-- TECHNICKÉ PŘEDPOKLADY -->
  <Section background="default" space="lg">
    <div class="head head--center">
      <Text size="label" color="accent" align="center">Technické předpoklady</Text>
      <Heading as="h2" size="h2" align="center">Co potřebujete k provozu</Heading>
    </div>
    <ul class="specs">
      <li><strong>PC / POS</strong> na bázi PC — procesor od Pentium 1.6 GHz, min. 4 GB RAM, 30 GB volného místa (doporučujeme SSD).</li>
      <li><strong>Monitor</strong> s rozlišením 1024×768 a vyšším; ideálně dotykový display nebo programovatelná klávesnice.</li>
      <li><strong>Operační systém</strong> Windows 10/11 (s výhradami WIN7).</li>
      <li><strong>Tiskárna na pásku</strong> (min. 40 znaků na řádek) se sadou českých znaků; doporučena termo a kuchyňská tiskárna.</li>
      <li><strong>Záložní zdroj UPS</strong> — cca 10 minut provozu po výpadku proudu pro dotisk otevřených účtů.</li>
    </ul>
  </Section>

  <!-- POPTÁVKA -->
  <LeadForm id="poptavka" variant="full" background="alt"
            title="Chcete vědět víc o pokladně?"
            lead="Napište nám o svém provozu — doporučíme vhodnou verzi a komponenty a připravíme cenovou nabídku. Rádi zašleme i demoverzi."
            successUrl="/dekujeme" />

  <Footer />
</Base>

<style>
  .head { max-width: 760px; margin-inline: auto; margin-bottom: var(--space-7); }
  .head--center { text-align: center; }
  .head > * + * { margin-top: var(--space-3); }

  .cards { display: grid; gap: var(--space-5); grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); }
  .card { background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: var(--space-6) var(--space-5); transition: var(--transition); }
  .card:hover { border-color: var(--color-primary); box-shadow: var(--shadow-sm); }
  .card > * + * { margin-top: var(--space-3); }
  .card__icon { display: inline-flex; color: var(--color-text-accent); }

  .split { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-8); align-items: center; }
  .split__text > * + * { margin-top: var(--space-4); }
  @media (max-width: 880px) { .split { grid-template-columns: 1fr; gap: var(--space-6); } }

  .checklist { list-style: none; display: grid; gap: var(--space-3); }
  .checklist--cols { grid-template-columns: 1fr; }
  .checklist li { display: flex; align-items: flex-start; gap: var(--space-2); color: var(--color-text); }
  .hl-check { color: var(--color-secondary-azure); flex-shrink: 0; margin-top: 2px; }

  .signals { list-style: none; display: flex; flex-wrap: wrap; gap: var(--space-6); justify-content: center; }
  .signals li { display: inline-flex; align-items: center; gap: var(--space-2); color: var(--color-text-on-dark); font-size: var(--font-size-small); }
  .signals :global(svg) { color: var(--color-secondary-gold); }

  .specs { list-style: none; max-width: 820px; margin-inline: auto; display: flex; flex-direction: column; gap: var(--space-3); }
  .specs li { padding: var(--space-4) var(--space-5); background: var(--color-bg-alt); border-left: 3px solid var(--color-primary); border-radius: var(--radius-sm); color: var(--color-text-muted); }
  .specs strong { color: var(--color-text); }
</style>
