---
/**
 * Savarin — Pokladna. Obsah z legacy stránky pokladna.
 * Mobilní pokladna, komponenty a technické předpoklady mají vlastní URL
 * (viz /mobilni-pokladna, /pokladni-komponenty, /technicke-predpoklady).
 * Sdílené komponenty @piano/ui.
 */
import Base from '../layouts/Base.astro';
import Header from '@piano/ui/components/Header.astro';
import Footer from '@piano/ui/components/Footer.astro';
import Breadcrumb from '@piano/ui/components/Breadcrumb.astro';
import Section from '@piano/ui/components/Section.astro';
import Hero from '@piano/ui/components/Hero.astro';
import Heading from '@piano/ui/components/Heading.astro';
import Text from '@piano/ui/components/Text.astro';
import Button from '@piano/ui/components/Button.astro';
import Icon from '@piano/ui/components/Icon.astro';
import LeadForm from '@piano/ui/components/LeadForm.astro';
import { savarinNav, savarinCta } from '../config/nav';

const verze = [
  { icon: 'lucide:utensils', title: 'Restaurační', text: 'Účtování na stoly a vedení otevřených účtů. Číšník otevírá a uzavírá účty hostů v průběhu celé návštěvy.' },
  { icon: 'lucide:bed-double', title: 'Hotelová', text: 'Spolupracuje s modulem Recepce — pozná, zda host bydlí na pokoji, má založený účet a „právo účtu“ pro připisování útraty.' },
  { icon: 'lucide:shopping-bag', title: 'Samoobslužná', text: 'Pro jídelny, stravovací linky, bufety a maloobchod. Po objednávce systém ihned vystaví účtenku, bez nutnosti otevírat účet.' },
];

const funkce = [
  'Ovládání přes dotykový display, PC nebo POS terminál',
  'Programovatelná restaurační klávesnice pro rychlé markování',
  'Otevřené účty, storna, převody položek mezi účty',
  'Kuchyňská tiskárna — objednávky rovnou na výdej',
  'Denní uzávěrky a odpis prodaného zboží ze skladu',
  'Certifikováno pro provoz s fiskálním modulem na Slovensku',
];

const souvisejici = [
  { href: '/mobilni-pokladna', icon: 'lucide:smartphone', title: 'Mobilní pokladna', text: 'Mobilní číšník — objednávky a úhrady přímo u stolu.' },
  { href: '/pokladni-komponenty', icon: 'lucide:keyboard', title: 'Pokladní komponenty', text: 'POS, dotykové monitory, tiskárny a klávesnice.' },
  { href: '/technicke-predpoklady', icon: 'lucide:cpu', title: 'Technické předpoklady', text: 'Jaký počítač, tiskárnu a síť pokladna potřebuje.' },
];

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'SoftwareApplication',
      name: 'Pokladna Savarin',
      applicationCategory: 'BusinessApplication',
      operatingSystem: 'Windows 10/11',
      description: 'Pokladní systém pro restaurace, hotelové restaurace i samoobslužný provoz. Ovládání přes PC, POS i dotykový display.',
      url: 'https://savarin.cz/pokladna',
      provider: { '@type': 'Organization', name: 'ComInn, s.r.o.', url: 'https://savarin.cz' },
      offers: { '@type': 'Offer', priceCurrency: 'CZK', price: '0', description: 'Cena na vyžádání podle konfigurace; k dispozici bezplatná demoverze.' },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Domů', item: 'https://savarin.cz/' },
        { '@type': 'ListItem', position: 2, name: 'Pokladna', item: 'https://savarin.cz/pokladna' },
      ],
    },
  ],
};
---

<Base title="Pokladna Savarin — pokladní systém pro PC i POS"
      description="Pokladní systém Savarin pro restaurace, hotelové restaurace i samoobslužný provoz. Dotykové ovládání, otevřené účty, denní uzávěrky a odpis zboží ze skladu."
      schema={schema}>
  <Header brand="Savarin" logoSrc="/logos/savarin_logo.svg" logoHeight="36px" homeHref="/" nav={savarinNav} cta={savarinCta} />

  <main>

  <Breadcrumb items={[{ label: 'Domů', href: '/' }, { label: 'Pokladna' }]} />

  <Hero eyebrow="Modul · Pokladna" background="gradient"
        lead="Software, který běží na standardním PC s programovatelnou klávesnicí i na specializovaných POS s dotykovým displejem. Certifikovaný pro provoz s fiskálním modulem na Slovensku.">
    <Heading slot="title" as="h1" size="display" color="on-dark">Pokladna Savarin pro <span class="accent">PC i POS</span></Heading>
    <Fragment slot="actions">
      <Button href="#poptavka">Nezávazná poptávka</Button>
      <Button href="#verze" variant="secondary" onDark>Verze programu</Button>
    </Fragment>
  </Hero>

  <!-- VERZE -->
  <Section id="verze" background="default" space="lg">
    <div class="head head--center">
      <Text size="label" color="accent" align="center">Možnosti nasazení</Text>
      <Heading as="h2" size="h2" align="center">Tři verze pro <span class="accent">každý typ provozu</span></Heading>
    </div>
    <div class="cards">
      {verze.map((v) => (
        <article class="card">
          <span class="card__icon"><Icon name={v.icon} size="md" /></span>
          <Heading as="h3" size="h3">{v.title}</Heading>
          <Text size="small" color="muted">{v.text}</Text>
        </article>
      ))}
    </div>
  </Section>

  <!-- FUNKCE -->
  <Section background="alt" space="lg">
    <div class="split">
      <div class="split__text">
        <Text size="label" color="accent">Výběr z možností programu</Text>
        <Heading as="h2" size="h2">Vše pro <span class="accent">rychlou obsluhu</span> a přesnou uzávěrku</Heading>
        <Text size="lead" color="muted" balance>
          Pokladna zabezpečuje veškerou agendu spojenou s prodejem až po vystavení účtu, denní uzávěrku a odpis zboží ze skladových karet.
        </Text>
      </div>
      <ul class="checklist checklist--cols">
        {funkce.map((f) => (
          <li><Icon name="lucide:check" size="sm" class="hl-check" />{f}</li>
        ))}
      </ul>
    </div>
  </Section>

  <!-- SOUVISEJÍCÍ -->
  <Section background="default" space="lg">
    <div class="head head--center">
      <Heading as="h2" size="h2" align="center">K pokladně patří</Heading>
    </div>
    <div class="cards">
      {souvisejici.map((s) => (
        <a class="card card--link" href={s.href}>
          <span class="card__icon"><Icon name={s.icon} size="md" /></span>
          <Heading as="h3" size="h3">{s.title}</Heading>
          <Text size="small" color="muted">{s.text}</Text>
          <span class="card__more">Zobrazit <Icon name="lucide:arrow-right" size="xs" /></span>
        </a>
      ))}
    </div>
  </Section>

  <!-- POPTÁVKA -->
  <LeadForm id="poptavka" variant="full" background="alt"
            title="Chcete vědět víc o pokladně?"
            lead="Napište nám o svém provozu — doporučíme vhodnou verzi a komponenty a připravíme cenovou nabídku. Rádi zašleme i demoverzi."
            successUrl="/dekujeme" />

  </main>

  <Footer legal={[{ label: 'Ochrana osobních údajů', href: '/ochrana-udaju' }]} logoSrc="/logos/savarin_by_piano.svg" logoAlt="Savarin by Piano" parentNote={{ text: 'Savarin je součástí skupiny Piano', href: 'https://piano.cz' }} />
</Base>

<style>
  .head { max-width: 760px; margin-inline: auto; margin-bottom: var(--space-7); }
  .head--center { text-align: center; }
  .head > * + * { margin-top: var(--space-3); }

  .cards { display: grid; gap: var(--space-5); grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); }
  .card { background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: var(--space-6) var(--space-5); transition: var(--transition); }
  .card:hover { border-color: var(--color-primary); box-shadow: var(--shadow-sm); }
  .card > * + * { margin-top: var(--space-3); }
  .card__icon { display: inline-flex; color: var(--color-text-accent); }
  .card--link { text-decoration: none; color: inherit; display: flex; flex-direction: column; }
  .card__more { margin-top: var(--space-4); color: var(--color-text-accent); font-weight: var(--font-weight-semibold); font-size: var(--font-size-small); display: inline-flex; align-items: center; gap: var(--space-1); }

  .split { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-8); align-items: center; }
  .split__text > * + * { margin-top: var(--space-4); }
  @media (max-width: 880px) { .split { grid-template-columns: 1fr; gap: var(--space-6); } }

  .checklist { list-style: none; display: grid; gap: var(--space-3); }
  .checklist--cols { grid-template-columns: 1fr; }
  .checklist li { display: flex; align-items: flex-start; gap: var(--space-2); color: var(--color-text); }
  .hl-check { color: var(--color-secondary-azure); flex-shrink: 0; margin-top: 2px; }
</style>
