---
/**
 * O nás — z grason-web-develop/pages/about.vue + page_about_* (cs.json).
 * Sdílené komponenty @piano/ui.
 */
import Base from '../layouts/Base.astro';
import Header from '@piano/ui/components/Header.astro';
import Footer from '@piano/ui/components/Footer.astro';
import Section from '@piano/ui/components/Section.astro';
import Hero from '@piano/ui/components/Hero.astro';
import Heading from '@piano/ui/components/Heading.astro';
import Text from '@piano/ui/components/Text.astro';
import Button from '@piano/ui/components/Button.astro';
import Icon from '@piano/ui/components/Icon.astro';
import { grasonNav, grasonCta, grasonFooter } from '../config/nav';

const values = ['Spolehlivost', 'Respekt', 'Slušnost', 'Důvěryhodnost', 'Férovost'];

const team = [
  { initials: 'ZK', name: 'Zuzana Kočová', position: 'Customer Success Manager', color: 'pink' },
  { initials: 'KM', name: 'Karel Mařík', position: 'CEO, Partner', color: 'green' },
  { initials: 'TJ', name: 'Tomáš Jiroušek', position: 'Partner', color: 'yellow' },
  { initials: 'KG', name: 'Kristýna Gottfrídová', position: 'Customer Success Specialist', color: 'pink' },
  { initials: 'RV', name: 'Radim Vaculík', position: 'CTO', color: 'green' },
  { initials: 'MU', name: 'Martin Urbánek', position: 'Sales Representative', color: 'yellow' },
];
---

<Base title="O nás — Grason"
      description="Tvoříme svět, kde lidé mohou pracovat, kdykoliv a kdekoliv chtějí. Měníme práci k lepšímu — pro pracovníky i podniky.">
  <Header brand="Grason" logoSrc="/logos/grason_logo.svg" logoHeight="28px" homeHref="/" nav={grasonNav} cta={grasonCta} />

  <main>

  <!-- HERO -->
  <Hero eyebrow="Měníme práci k lepšímu" background="gradient" align="center"
        lead="Grason jsme zakládali s vizí dostupné flexibilní práce pro všechny, kteří hledají v pracovním životě svobodu i jistotu. Vytvořili jsme místo, které pomáhá lidem pružně pracovat a podnikům obsazovat směny podle aktuální potřeby.">
    <Heading slot="title" as="h1" size="display" color="on-dark" align="center">Tvoříme svět, kde lidé mohou pracovat <span class="accent">kdykoliv a kdekoliv chtějí</span></Heading>
  </Hero>

  <!-- POSLÁNÍ -->
  <Section background="default" space="lg">
    <div class="mission">
      <div class="mission__item">
        <Heading as="h2" size="h2">Přizpůsobte práci svému životu, <span class="accent">ne svůj život práci</span></Heading>
        <Text size="lead" color="muted" balance>
          Každý si zaslouží práci, která mu umožní mít čas na rodinu, koníčky, studium nebo péči o blízké. My v Grasonu vám pomůžeme být pány svého času.
        </Text>
      </div>
      <div class="mission__item">
        <Heading as="h2" size="h2">Všechno je to <span class="accent">o vás</span></Heading>
        <Text size="lead" color="muted" balance>
          A o tom, abyste pracovali tak, jak chcete žít. Naším posláním je pomoci vám být pánem svého pracovního času.
        </Text>
      </div>
    </div>
  </Section>

  <!-- HODNOTY -->
  <Section background="invert" space="lg">
    <div class="head head--center">
      <Text size="label" color="accent" align="center">Naše hodnoty</Text>
      <Heading as="h2" size="h2" align="center" color="on-dark">Podporujeme komunitu a společně <span class="accent">měníme pracovní trh</span></Heading>
      <Text size="lead" color="on-dark-muted" align="center" balance>
        Slušnost a poctivost jsou pro nás samozřejmé. Dlouhé seznamy toho, co musíte a nesmíte, u nás nenajdete — sázíme na pár základních hodnot a přirozenou poctivost.
      </Text>
    </div>
    <ul class="values">
      {values.map((v) => (
        <li class="value"><Icon name="lucide:heart-handshake" size="sm" class="value__icon" />{v}</li>
      ))}
    </ul>
  </Section>

  <!-- TÝM -->
  <Section background="default" space="lg">
    <div class="head head--center">
      <Heading as="h2" size="h2" align="center">Náš tým</Heading>
      <Text size="lead" color="muted" align="center">Lidé, kteří za Grasonem stojí.</Text>
    </div>
    <ul class="team">
      {team.map((m) => (
        <li class="member">
          <span class={`member__avatar member__avatar--${m.color}`} aria-hidden="true">{m.initials}</span>
          <strong class="member__name">{m.name}</strong>
          <span class="member__role">{m.position}</span>
        </li>
      ))}
    </ul>
  </Section>

  <!-- CTA -->
  <Section background="alt" space="lg">
    <div class="head head--center">
      <Heading as="h2" size="h2" align="center">Pojďme měnit práci k lepšímu spolu</Heading>
      <Text size="lead" color="muted" align="center" balance>
        Ať už sháníte lidi do provozu, nebo hledáte flexibilní práci — Grason je tu pro vás.
      </Text>
      <div class="cta-actions">
        <Button href="/pro-firmy">Pro firmy</Button>
        <Button href="/pro-brigadniky" variant="secondary">Pro brigádníky</Button>
      </div>
    </div>
  </Section>

  </main>

  <Footer {...grasonFooter} />
</Base>

<style>
  .head { max-width: 760px; margin-inline: auto; margin-bottom: var(--space-7); }
  .head--center { text-align: center; }
  .head > * + * { margin-top: var(--space-3); }

  /* Poslání */
  .mission { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-8); max-width: 1000px; margin-inline: auto; }
  .mission__item > * + * { margin-top: var(--space-4); }
  @media (max-width: 880px) { .mission { grid-template-columns: 1fr; gap: var(--space-6); } }

  /* Hodnoty */
  .values { list-style: none; display: flex; flex-wrap: wrap; gap: var(--space-3); justify-content: center; }
  .value { display: inline-flex; align-items: center; gap: var(--space-2); padding: var(--space-3) var(--space-5); border-radius: var(--radius-full); background: rgba(255,255,255,0.06); border: 1px solid var(--color-border-on-dark); color: var(--color-text-on-dark); font-weight: var(--font-weight-medium); }
  .value__icon { color: var(--color-secondary-azure); }

  /* Tým */
  .team { list-style: none; display: grid; gap: var(--space-7) var(--space-5); grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); text-align: center; max-width: 920px; margin-inline: auto; }
  .member { display: flex; flex-direction: column; align-items: center; gap: var(--space-2); }
  .member__avatar { width: 96px; height: 96px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; font-size: var(--font-size-h3); font-weight: var(--font-weight-bold); color: #fff; box-shadow: var(--shadow-md); }
  .member__avatar--pink { background: var(--member-grad-pink); }
  .member__avatar--green { background: var(--member-grad-green); color: var(--color-text-on-azure); }
  .member__avatar--yellow { background: var(--member-grad-yellow); color: var(--color-text-on-yellow); }
  .member__name { font-size: var(--font-size-lead); font-weight: var(--font-weight-bold); color: var(--color-secondary); }
  .member__role { font-size: var(--font-size-small); color: var(--color-text-muted); }

  /* CTA */
  .cta-actions { display: flex; gap: var(--space-3); justify-content: center; flex-wrap: wrap; margin-top: var(--space-5); }
</style>
