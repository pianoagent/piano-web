---
/**
 * Grason — homepage.
 * Obsah z grason-context.md, blok #page-grason (piano-web-2026.html),
 * texty z grason-web-develop/i18n-config/locales/cs.json a bannery
 * z grason-bannery.tsv.
 * Vše ze SDÍLENÝCH komponent @piano/ui; téma řeší src/styles/theme.css.
 * Sekce bez vlastní komponenty (Stats, Pilíře, Steps, Reference, Logo wall,
 * FAQ, App split) jsou složené z primitivů — komponenty se NEFORKUJÍ.
 */
import Base from '../layouts/Base.astro';
import Header from '@piano/ui/components/Header.astro';
import Footer from '@piano/ui/components/Footer.astro';
import Section from '@piano/ui/components/Section.astro';
import Hero from '@piano/ui/components/Hero.astro';
import Heading from '@piano/ui/components/Heading.astro';
import Text from '@piano/ui/components/Text.astro';
import Button from '@piano/ui/components/Button.astro';
import Icon from '@piano/ui/components/Icon.astro';
import LogoWall from '@piano/ui/components/LogoWall.astro';
import LeadForm from '@piano/ui/components/LeadForm.astro';
import { grasonNav, grasonCta, grasonFooter } from '../config/nav';

const PHONE = '+420 739 877 799';
const PHONE_HREF = 'tel:+420739877799';

const stats = [
  { num: '3 357+', lbl: 'brigádníků v databázi' },
  { num: '82+', lbl: 'měst v ČR' },
  { num: '220 000+', lbl: 'naplánovaných směn' },
  { num: '0 Kč', lbl: 'za první měsíc' },
];

// Tři samostatné produkty Grasonu (ne jedna appka)
const products = [
  {
    img: '/images/for-companies-choose-candidates.webp',
    tag: 'GrasonFlexi',
    title: 'Brigádníci na směnu',
    text: 'Vypíšete směnu, ověření brigádníci se přihlásí a vy vyberete. Grason vyřídí smlouvu i papírování (DPP) — podklady pro výplatu máte připravené.',
    points: ['3 357+ ověřených pracovníků', 'Obsazení směny během minut', 'DPP papírování řeší Grason', 'Gastro, sklady i maloobchod'],
    href: '/grasonflexi',
  },
  {
    img: '/images/illustration-calendar.webp',
    tag: 'GrasonPlan',
    title: 'Plánování směn vlastního týmu',
    text: 'Přehledný rozvrh pro stálé zaměstnance. Zadají dostupnost, vy potvrdíte plán. Součástí je docházka (digitální píchačky), úkoly i podklady pro mzdy.',
    points: ['Plán na PC i v mobilu', 'Digitální píchačky (docházka)', 'Úkoly a checklisty', 'Podklady pro mzdy · od 990 Kč/měs'],
    href: '/grasonplan',
  },
  {
    img: '/images/for-companies-choose-favourite-workers.webp',
    tag: 'GrasonJobs',
    badge: 'Novinka',
    title: 'Inzerce a nábor stálých míst',
    text: 'Hledáte stálého kolegu na HPP nebo DPČ? Vystavíte inzerát a Grason ho automaticky propaguje tisícům lidí v gastru — dokud pozici neobsadíte.',
    points: ['Inzerce stálých úvazků', 'Automatická propagace inzerátů', 'Oslovíte tisíce lidí v gastru', 'Obsazeno = konec kampaně'],
    href: '/grasonjobs',
  },
];

// „Jak to funguje" je čistě GrasonFlexi (obsazení směny brigádníkem)
const steps = [
  { title: 'Vypíšete směnu', text: 'V appce nebo webovém rozhraní zadáte kdy, kde a koho potřebujete. Trvá to 2 minuty.' },
  { title: 'Brigádníci se hlásí', text: 'Ověření pracovníci z vašeho okolí dostanou notifikaci a zájemci se přihlásí.' },
  { title: 'Potvrdíte výběr', text: 'Vyberete vhodného kandidáta. Grason zařídí smlouvu i papírování (DPP).' },
  { title: 'Odpracováno a ohodnoceno', text: 'Pracovník dorazí na směnu, vy mu připravíte výplatu z podkladů a po směně ho ohodnotíte.' },
];

const testimonials = [
  { initials: 'MS', quote: 'Ke Grasonu nás dovedla zhoršující se situace na trhu práce a jejich inovativní přístup. Velkou výhodou je praktická aplikace a možnost operativního plánování směn 24/7.', author: 'Martin Savkulič', role: 'Manažer restaurace Pizza Nuova' },
  { initials: 'DS', quote: 'Pracovníci z Grasonu u nás vykrývají nejen nárazové směny, ale stávají se i pravidelnou součástí týmu. Oceňujeme jejich spolehlivost a rychlost.', author: 'Denisa Srnková', role: 'HR Business Partner, DámeMarket' },
  { initials: 'JK', quote: 'Velkou výhodu vidím v úspoře času, protože Grason za mě řeší byrokratické papírování.', author: 'Josef Kubíček', role: 'Manažer, Likér' },
];

const refLogos = [
  'ref-field-michelin-restaurant', 'ref-cafe-savoy', 'ref-kolkovna', 'ref-sasazu',
  'ref-O2-arena', 'ref-clarion-hotel', 'ref-zatisi-group', 'ref-420-restaurant',
  'ref-pizza-coloseum', 'ref-entree', 'ref-100-chuti-brna', 'ref-sisters-bistro',
];

const faqs = [
  { q: 'Jak rychle obsadím směnu brigádníkem? (GrasonFlexi)', a: 'Brigádníky najdete na jedno kliknutí — ověření lidé, kteří se na vypsanou směnu sami přihlásí. Volnou směnu obsadíte i na poslední chvíli.' },
  { q: 'Vyřídí Grason brigádníkovi výplatu? (GrasonFlexi)', a: 'Smlouvu a papírování (DPP) vyřídí Grason. Samotnou výplatu provádíte vy — Grason vám k ní připraví podklady. Brigádník tak má peníze rychle po směně.' },
  { q: 'Umí Grason nábor stálých zaměstnanců? (GrasonJobs)', a: 'Ano — přes GrasonJobs vystavíte inzerát na stálý úvazek (HPP, DPČ) a my ho automaticky propagujeme tisícům lidí v gastru. Jakmile pozici obsadíte, kampaň skončí.' },
  { q: 'Umí Grason plánování směn vlastního týmu? (GrasonPlan)', a: 'Ano — GrasonPlan zvládne plánování směn, dovolených i záskoků, přehledně na jednom místě. První měsíc zdarma.' },
  { q: 'Jak funguje docházka / digitální píchačky? (GrasonPlan)', a: 'Zaměstnanec se odbaví v aplikaci kliknutím na tlačítko a systém přes GPS nebo WiFi ověří, že je opravdu v provozovně (okruh 30–300 m). Žádné kartičky ani papíry.' },
  { q: 'Co umí úkoly a checklisty? (GrasonPlan)', a: 'Zadáte úkol ke směně a zaměstnanec potvrdí jeho splnění — odškrtnutím, textem, číslem nebo fotkou. Máte přehled, co bylo a nebylo splněno.' },
  { q: 'Pomůže Grason se mzdami? (GrasonPlan)', a: 'Z odpracovaných směn a docházky připraví podklady pro mzdovou účetní jedním kliknutím — konec ručního přepisování. Samotné mzdy si zpracováváte sami.' },
];

const leadProofs = [
  { icon: 'lucide:users', title: '3 357+ brigádníků', text: 'Ověření pracovníci připraveni nastoupit.' },
  { icon: 'lucide:map-pin', title: '82+ měst v ČR', text: 'Gastro, sklady i maloobchod po celé republice.' },
  { icon: 'lucide:gift', title: '1. měsíc zdarma', text: 'GrasonPlan vyzkoušíte bez rizika.' },
  { icon: 'lucide:phone', title: 'Lidská podpora', text: PHONE + ' — voláte rovnou nám.' },
];
---

<Base title="Personalista pro váš podnik | Grason"
      description="Grason je ekosystém pro řízení personálu v gastru: brigádníci na poslední chvíli, plánování směn, digitální píchačky, docházka a podklady pro mzdy. Vše na jednom místě.">
  <Header brand="Grason" logoSrc="/logos/grason_logo.svg" logoHeight="28px" homeHref="/" nav={grasonNav} cta={grasonCta} />

  <main>

  <!-- HERO — split: text vlevo, appka vpravo -->
  <Hero eyebrow="Odborník na personál" background="gradient"
        lead="Grason je nejrychlejší způsob, jak nárazově či dlouhodobě zaplnit volná místa, naplánovat směny, ohlídat zaměstnance a vyřešit papírování s tím spojené."
        usp={[{ text: '3 357+ brigádníků', icon: 'lucide:users' }, { text: '82+ měst v ČR', icon: 'lucide:map-pin' }, { text: '220 000+ naplánovaných směn', icon: 'lucide:calendar-days' }]}>
    <Heading slot="title" as="h1" size="display" color="on-dark">Obsaďte volné pozice a naplánujte směny na pár kliknutí</Heading>
    <Fragment slot="actions">
      <Button href="#poptavka">Vyzkoušet 14 dní zdarma</Button>
      <Button href="#funkce" variant="secondary" onDark>Všechny funkce</Button>
    </Fragment>
    <figure slot="media" class="hero-figure">
      <img src="/images/hp-hero.webp" alt="Grason — mobilní aplikace s nabídkami volných směn" width="720" height="560" loading="eager" />
    </figure>
  </Hero>

  <!-- LOGA KLIENTŮ -->
  <LogoWall id="zakaznici" background="default" label="Důvěřují nám restaurace, hotely i sklady po celé ČR" logos={refLogos} />

  <!-- TŘI PRODUKTY -->
  <Section id="funkce" background="default" space="lg">
    <div class="head head--center">
      <Text size="label" color="accent" align="center">Tři produkty, jeden personalista</Text>
      <Heading as="h2" size="h2" align="center">Tři řešení pro <span class="accent">celý personál</span></Heading>
      <Text size="lead" color="muted" align="center" balance>
        Grason není jedna appka. Jsou to tři samostatné nástroje — vyberete si jeden, dva, nebo všechny tři podle toho, co váš provoz zrovna potřebuje.
      </Text>
    </div>
    <div class="pillars">
      {products.map((p) => (
        <article class="pillar">
          <div class="pillar__media">
            <img src={p.img} alt="" loading="lazy" />
            {p.badge && <span class="pillar__badge">{p.badge}</span>}
          </div>
          <div class="pillar__body">
            <span class="pillar__tag">{p.tag}</span>
            <Heading as="h3" size="h3">{p.title}</Heading>
            <Text size="small" color="muted">{p.text}</Text>
            <ul class="pillar__points">
              {p.points.map((pt) => (
                <li><Icon name="lucide:check" size="sm" class="pillar__check" />{pt}</li>
              ))}
            </ul>
            <a href={p.href} class="pillar__link">Prozkoumat <Icon name="lucide:arrow-right" size="sm" /></a>
          </div>
        </article>
      ))}
    </div>
  </Section>

  <!-- MOBILNÍ APLIKACE (split) -->
  <Section background="default" space="lg">
    <div class="app">
      <div class="app__text">
        <Text size="label" color="accent">Mobilní aplikace</Text>
        <Heading as="h2" size="h2">Mějte Grason <span class="accent">stále po ruce</span></Heading>
        <Text size="lead" color="muted" balance>
          S našimi technologiemi plánujete směny, sháníte brigádníky a hlídáte docházku odkudkoliv — od baru, z kanceláře i z gauče. GrasonFlexi a GrasonPlan mají vlastní appku pro iOS i Android.
        </Text>
        <ul class="app__points">
          <li><Icon name="lucide:smartphone" size="sm" class="pillar__check" />iOS i Android, zdarma ke stažení</li>
          <li><Icon name="lucide:bell-ring" size="sm" class="pillar__check" />Notifikace o přihlášených i nástupech</li>
          <li><Icon name="lucide:refresh-cw" size="sm" class="pillar__check" />Vše synchronizováno v reálném čase</li>
        </ul>
        <div class="app__cta">
          <Button href="#poptavka">Vyzkoušet 14 dní zdarma</Button>
        </div>
      </div>
      <figure class="app__media">
        <img src="/images/for-companies-hero.webp" alt="Grason — plánování směn a docházka v mobilní aplikaci" loading="lazy" />
      </figure>
    </div>
  </Section>

  <!-- JAK TO FUNGUJE -->
  <Section background="invert" space="lg">
    <div class="head head--center">
      <Text size="label" color="accent" align="center">Jak to funguje</Text>
      <Heading as="h2" size="h2" align="center" color="on-dark">Od potřeby k obsazené <span class="accent">směně za minuty</span></Heading>
    </div>
    <ol class="steps steps--dark">
      {steps.map((s, i) => (
        <li class="step step--dark">
          <span class="step__num">{i + 1}</span>
          <Heading as="h3" size="h3" color="on-dark">{s.title}</Heading>
          <Text size="small" color="on-dark-muted">{s.text}</Text>
        </li>
      ))}
    </ol>
  </Section>

  <!-- REFERENCE -->
  <Section background="alt" space="lg">
    <div class="head head--center">
      <Text size="label" color="accent" align="center">Reference</Text>
      <Heading as="h2" size="h2" align="center">Co říkají <span class="accent">manažeři provozů</span></Heading>
    </div>
    <div class="quotes">
      {testimonials.map((t, i) => (
        <figure class={`quote quote--${i}`}>
          <div class="quote__head">
            <div class="quote__id">
              <strong class="quote__name">{t.author}</strong>
              <span class="quote__role">{t.role}</span>
            </div>
            <span class="quote__avatar" aria-hidden="true">{t.initials}</span>
          </div>
          <span class="quote__mark"><Icon name="lucide:quote" size="md" /></span>
          <blockquote class="quote__text">{t.quote}</blockquote>
        </figure>
      ))}
    </div>
  </Section>

  <!-- CTA -->
  <Section background="primary" space="lg">
    <div class="head head--center">
      <Text size="label" color="on-dark-muted" align="center">Začít s Grasonem</Text>
      <Heading as="h2" size="h2" align="center" color="on-dark">Personál bez starostí?</Heading>
      <Text size="lead" color="on-dark-muted" align="center" balance>
        Ať řešíte brigádníky, plánování vlastního týmu, nebo nábor stálých lidí — poradíme, které z našich řešení vám sedne. Konzultace je zdarma a nezávazná.
      </Text>
      <div class="cta-actions">
        <Button href="#poptavka">Vyzkoušet zdarma</Button>
        <Button href={PHONE_HREF} variant="secondary" onDark>{PHONE}</Button>
      </div>
    </div>
  </Section>

  <!-- FAQ -->
  <Section background="default" space="lg">
    <div class="head head--center">
      <Heading as="h2" size="h2" align="center">Často kladené dotazy</Heading>
      <Text size="lead" color="muted" align="center">Nenašli jste odpověď? Ozvěte se nám, rádi vám poradíme.</Text>
    </div>
    <div class="faq">
      {faqs.map((f) => (
        <details class="faq__item">
          <summary>{f.q}<Icon name="lucide:chevron-down" size="sm" class="faq__chev" /></summary>
          <div class="faq__a"><Text color="muted">{f.a}</Text></div>
        </details>
      ))}
    </div>
  </Section>

  <!-- POPTÁVKA -->
  <LeadForm id="poptavka" variant="full" background="alt"
            title="Nezávazná konzultace zdarma"
            lead="Nechte nám kontakt — projdeme váš provoz a doporučíme, které řešení se vám hodí: GrasonFlexi (brigádníci), GrasonPlan (plánování) nebo GrasonJobs (nábor)."
            proofs={leadProofs} successUrl="/dekujeme" />

  </main>

  <Footer {...grasonFooter} />
</Base>

<style>
  /* Hero obrázek (appka) — transparentní ilustrace, jemný stín */
  .hero-figure { margin: 0; width: 100%; line-height: 0; }
  .hero-figure img { width: 100%; height: auto; display: block; filter: drop-shadow(0 24px 48px rgba(7, 7, 7, 0.22)); }

  /* Sdílená hlavička sekce */
  .head { max-width: 760px; margin-inline: auto; margin-bottom: var(--space-7); }
  .head--center { text-align: center; }
  .head > * + * { margin-top: var(--space-3); }

  /* Logo wall — marquee */
  .logos__label { margin-bottom: var(--space-5); }
  .logos { overflow: hidden; -webkit-mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent); mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent); }
  .logos__track { display: flex; align-items: center; gap: var(--space-8); width: max-content; animation: logos-scroll 48s linear infinite; }
  .logos__track img { height: 34px; width: auto; opacity: 0.62; filter: grayscale(1); flex-shrink: 0; }
  @keyframes logos-scroll { from { transform: translateX(0); } to { transform: translateX(-50%); } }
  @media (prefers-reduced-motion: reduce) { .logos__track { animation: none; flex-wrap: wrap; justify-content: center; } }

  /* Stats band */
  .stats { list-style: none; display: grid; gap: var(--space-5); grid-template-columns: repeat(4, 1fr); text-align: center; }
  .stats__item { display: flex; flex-direction: column; gap: var(--space-1); }
  .stats__num { font-size: var(--font-size-h1); font-weight: var(--font-weight-bold); line-height: 1; color: var(--color-secondary); }
  .stats__lbl { font-size: var(--font-size-small); color: var(--color-text-muted); }
  @media (max-width: 720px) { .stats { grid-template-columns: repeat(2, 1fr); gap: var(--space-6); } }

  /* Pilíře */
  .pillars { display: grid; gap: var(--space-6); grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); }
  .pillar {
    display: flex; flex-direction: column;
    background: var(--color-bg); border: 1px solid var(--color-border);
    border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-sm);
    transition: var(--transition);
  }
  .pillar:hover { border-color: var(--color-primary); box-shadow: var(--shadow-md); }
  .pillar__media { position: relative; background: var(--color-bg-alt); line-height: 0; }
  .pillar__media img { width: 100%; height: 200px; object-fit: contain; display: block; padding: var(--space-5); }
  .pillar__badge {
    position: absolute; top: var(--space-4); right: var(--space-4);
    background: var(--color-secondary-terracotta); color: #fff;
    font-size: var(--font-size-caption); font-weight: var(--font-weight-semibold);
    text-transform: uppercase; letter-spacing: var(--letter-spacing-wide);
    padding: var(--space-1) var(--space-3); border-radius: var(--radius-full);
  }
  .pillar__body { flex: 1; padding: var(--space-6); display: flex; flex-direction: column; gap: var(--space-3); }
  .pillar__tag {
    align-self: flex-start; font-size: var(--font-size-caption); font-weight: var(--font-weight-semibold);
    text-transform: uppercase; letter-spacing: var(--letter-spacing-wide);
    color: var(--color-text-accent); background: color-mix(in srgb, var(--color-secondary-azure) 14%, #fff);
    padding: var(--space-1) var(--space-3); border-radius: var(--radius-full);
  }
  .pillar__points { list-style: none; display: flex; flex-direction: column; gap: var(--space-2); margin-top: var(--space-2); }
  .pillar__points li { display: flex; align-items: flex-start; gap: var(--space-2); font-size: var(--font-size-small); color: var(--color-text); }
  .pillar__check { color: var(--color-secondary-azure); flex-shrink: 0; margin-top: 2px; }
  .pillar__link { display: inline-flex; align-items: center; gap: var(--space-1); margin-top: auto; padding-top: var(--space-4); color: var(--color-text-accent); font-weight: var(--font-weight-semibold); font-size: var(--font-size-small); text-decoration: none; }
  .pillar__link:hover { gap: var(--space-2); }

  /* App split */
  .app { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-8); align-items: center; }
  .app__text > * + * { margin-top: var(--space-4); }
  .app__points { list-style: none; display: flex; flex-direction: column; gap: var(--space-3); }
  .app__points li { display: flex; align-items: flex-start; gap: var(--space-2); color: var(--color-text); }
  .app__cta { margin-top: var(--space-6); }
  .app__media { margin: 0; line-height: 0; }
  .app__media img { width: 100%; height: auto; display: block; }
  @media (max-width: 880px) { .app { grid-template-columns: 1fr; gap: var(--space-6); } .app__media { order: -1; } }

  /* Steps */
  .steps { list-style: none; display: grid; gap: var(--space-6); grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); }
  .step { position: relative; padding: var(--space-6); background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-md); box-shadow: var(--shadow-sm); }
  .step > * + * { margin-top: var(--space-3); }
  .step--dark { background: rgba(255,255,255,0.04); border-color: var(--color-border-on-dark); box-shadow: none; }
  .step__num {
    display: inline-flex; align-items: center; justify-content: center;
    width: 40px; height: 40px; border-radius: var(--radius-full);
    background: var(--color-secondary-azure); color: #07333a;
    font-size: var(--font-size-lead); font-weight: var(--font-weight-bold); line-height: 1;
  }

  /* Reference */
  .quotes { display: grid; gap: var(--space-6); grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); }
  .quote { margin: 0; display: flex; flex-direction: column; background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: var(--space-6); box-shadow: var(--shadow-sm); }
  .quote__head { display: flex; align-items: center; justify-content: space-between; gap: var(--space-4); margin-bottom: var(--space-4); }
  .quote__id { display: flex; flex-direction: column; gap: 2px; }
  .quote__name { font-size: var(--font-size-lead); font-weight: var(--font-weight-bold); color: var(--color-secondary); line-height: 1.15; }
  .quote__role { font-size: var(--font-size-small); color: var(--color-text-muted); }
  .quote__avatar {
    flex-shrink: 0; width: 60px; height: 60px; border-radius: 50%;
    display: inline-flex; align-items: center; justify-content: center;
    font-size: var(--font-size-lead); font-weight: var(--font-weight-bold);
    color: #fff; letter-spacing: 0.02em; box-shadow: var(--shadow-sm);
  }
