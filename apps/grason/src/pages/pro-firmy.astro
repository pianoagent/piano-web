---
/**
 * Pro firmy — rozcestník tří produktů + společný ceník.
 * Detaily žijí na dedikovaných stránkách: /grasonflexi, /grasonplan, /grasonjobs.
 */
import Base from '../layouts/Base.astro';
import Header from '@piano/ui/components/Header.astro';
import Footer from '@piano/ui/components/Footer.astro';
import Section from '@piano/ui/components/Section.astro';
import Hero from '@piano/ui/components/Hero.astro';
import Heading from '@piano/ui/components/Heading.astro';
import Text from '@piano/ui/components/Text.astro';
import Button from '@piano/ui/components/Button.astro';
import Icon from '@piano/ui/components/Icon.astro';
import LeadForm from '@piano/ui/components/LeadForm.astro';
import { grasonNav, grasonCta, grasonFooter } from '../config/nav';

const products = [
  {
    img: '/images/for-companies-choose-candidates.webp',
    tag: 'GrasonFlexi',
    title: 'Brigádníci na směnu',
    text: 'Vypíšete směnu, ověření brigádníci se přihlásí a vy vyberete. Grason vyřídí smlouvu i papírování (DPP).',
    points: ['3 357+ ověřených pracovníků', 'Obsazení směny během minut', 'DPP papírování řeší Grason'],
    href: '/grasonflexi',
  },
  {
    img: '/images/illustration-calendar.webp',
    tag: 'GrasonPlan',
    title: 'Plánování směn vlastního týmu',
    text: 'Přehledný rozvrh pro stálé zaměstnance. Součástí je docházka (digitální píchačky), úkoly i podklady pro mzdy.',
    points: ['Plán na PC i v mobilu', 'Docházka přes GPS / WiFi', 'Podklady pro mzdy · od 990 Kč/měs'],
    href: '/grasonplan',
  },
  {
    img: '/images/for-companies-choose-favourite-workers.webp',
    tag: 'GrasonJobs',
    badge: 'Novinka',
    title: 'Inzerce a nábor stálých míst',
    text: 'Vystavíte inzerát na stálou pozici a Grason ho automaticky propaguje tisícům lidí v gastru — dokud ji neobsadíte.',
    points: ['Inzerce stálých úvazků', 'Automatická propagace', 'Obsazeno = konec kampaně'],
    href: '/grasonjobs',
  },
];

const testimonials = [
  { initials: 'MS', quote: 'Ke Grasonu nás dovedla zhoršující se situace na trhu práce a jejich inovativní přístup. Velkou výhodou je praktická aplikace a možnost operativního plánování směn 24/7.', author: 'Martin Savkulič', role: 'Manažer restaurace Pizza Nuova' },
  { initials: 'DS', quote: 'Pracovníci z Grasonu u nás vykrývají nejen nárazové směny, ale stávají se i pravidelnou součástí týmu. Spolupráce funguje na výbornou.', author: 'Denisa Srnková', role: 'HR Business Partner, DámeMarket' },
  { initials: 'JK', quote: 'Velkou výhodu vidím v úspoře času, protože Grason za mě řeší byrokratické papírování.', author: 'Josef Kubíček', role: 'Manažer, Likér' },
];

const leadProofs = [
  { icon: 'lucide:gift', title: '14 dní zdarma', text: 'Bez platební karty, nezávazně.' },
  { icon: 'lucide:users', title: '3 357+ brigádníků', text: 'Ověření pracovníci po celé ČR.' },
  { icon: 'lucide:calendar-days', title: '220 000+ směn', text: 'Naplánováno přes GrasonPlan.' },
  { icon: 'lucide:phone', title: 'Anna Pánková', text: 'anna.pankova@grason.cz' },
];
---

<Base title="Pro firmy — Grason"
      description="Tři řešení pro celý personál: GrasonFlexi (brigádníci na směnu), GrasonPlan (plánování vlastního týmu, docházka, mzdové podklady) a GrasonJobs (inzerce a nábor stálých zaměstnanců).">
  <Header brand="Grason" logoSrc="/logos/grason_logo.svg" logoHeight="28px" homeHref="/" nav={grasonNav} cta={grasonCta} />

  <main>
  <Hero eyebrow="Pro firmy" background="gradient"
        lead="Tři samostatná řešení pro celý váš personál — brigádníci na směnu, plánování vlastního týmu i nábor stálých lidí. Vyberete si, co zrovna potřebujete.">
    <Heading slot="title" as="h1" size="display" color="on-dark">Chybí vám lidi? <span class="accent">S námi je máte</span> zítra na směně</Heading>
    <Fragment slot="actions">
      <Button href="#poptavka">Konzultace zdarma</Button>
      <Button href="#cenik" variant="secondary" onDark>Ukázat ceník</Button>
    </Fragment>
    <figure slot="media" class="hero-figure">
      <img src="/images/for-companies-hero.webp" alt="Grason pro firmy — výběr kandidátů na směnu" width="720" height="560" loading="eager" />
    </figure>
  </Hero>

  <!-- TŘI PRODUKTY -->
  <Section background="default" space="lg">
    <div class="head head--center">
      <Text size="label" color="accent" align="center">Tři produkty, jeden personalista</Text>
      <Heading as="h2" size="h2" align="center">Vyberte si <span class="accent">řešení pro váš provoz</span></Heading>
      <Text size="lead" color="muted" align="center" balance>
        Grason není jedna appka. Jsou to tři samostatné nástroje — každý má vlastní stránku s detaily.
      </Text>
    </div>
    <div class="pillars">
      {products.map((p) => (
        <article class="pillar">
          <div class="pillar__media">
            <img src={p.img} alt="" loading="lazy" />
            {p.badge && <span class="pillar__badge">{p.badge}</span>}
          </div>
          <div class="pillar__body">
            <span class="pillar__tag">{p.tag}</span>
            <Heading as="h3" size="h3">{p.title}</Heading>
            <Text size="small" color="muted">{p.text}</Text>
            <ul class="pillar__points">
              {p.points.map((pt) => (<li><Icon name="lucide:check" size="sm" class="pillar__check" />{pt}</li>))}
            </ul>
            <a href={p.href} class="pillar__link">Prozkoumat <Icon name="lucide:arrow-right" size="sm" /></a>
          </div>
        </article>
      ))}
    </div>
  </Section>

  <!-- CENÍK -->
  <Section id="cenik" background="alt" space="lg">
    <div class="head head--center">
      <Text size="label" color="accent" align="center">Ceník</Text>
      <Heading as="h2" size="h2" align="center">Předplatné <span class="accent">bez poplatků ze mzdy</span></Heading>
      <Text size="lead" color="muted" align="center" balance>
        Žádné poplatky odvozené ze mzdy pracovníka. Díky předplatnému předem přesně víte, kolik a za co měsíčně platíte.
      </Text>
    </div>
    <div class="pricing pricing--3">
      <article class="price">
        <span class="price__tag">GrasonFlexi</span>
        <Heading as="h3" size="h3">Balíčky na míru</Heading>
        <Text color="muted" size="small">Podle počtu směn, poboček a funkcí. Závazek na 3, 6 nebo 12 měsíců.</Text>
        <ul class="checklist">
          <li><Icon name="lucide:check" size="sm" class="hl-check" />Bez poplatků ze mzdy brigádníka</li>
          <li><Icon name="lucide:check" size="sm" class="hl-check" />Od základního po prémiový tarif</li>
          <li><Icon name="lucide:check" size="sm" class="hl-check" />Enterprise: neomezené směny + account manager</li>
        </ul>
        <div class="price__cta"><Button href="/grasonflexi">Více o GrasonFlexi</Button></div>
      </article>
      <article class="price price--featured">
        <span class="price__badge">1. měsíc zdarma</span>
        <span class="price__tag">GrasonPlan</span>
        <p class="price__amount">990 Kč<span>/měsíc bez DPH</span></p>
        <Text color="muted" size="small">1 podnik, do 25 uživatelů. Každý další uživatel +50 Kč/měsíc.</Text>
        <ul class="checklist">
          <li><Icon name="lucide:check" size="sm" class="hl-check" />Plánování směn, dovolených i záskoků</li>
          <li><Icon name="lucide:check" size="sm" class="hl-check" />Docházka (píchačky) a podklady pro mzdy</li>
          <li><Icon name="lucide:check" size="sm" class="hl-check" />Úkoly, checklisty, notifikace</li>
        </ul>
        <div class="price__cta"><Button href="/grasonplan">Více o GrasonPlanu</Button></div>
      </article>
      <article class="price">
        <span class="price__tag">GrasonJobs</span>
        <Heading as="h3" size="h3">Nábor na míru</Heading>
        <Text color="muted" size="small">Inzerce stálých úvazků s automatickou propagací. Cena podle rozsahu kampaně.</Text>
        <ul class="checklist">
          <li><Icon name="lucide:check" size="sm" class="hl-check" />Inzerce stálých úvazků (HPP, DPČ)</li>
          <li><Icon name="lucide:check" size="sm" class="hl-check" />Automatická propagace inzerátů</li>
          <li><Icon name="lucide:check" size="sm" class="hl-check" />Platíte jen za běžící kampaň</li>
        </ul>
        <div class="price__cta"><Button href="/grasonjobs">Více o GrasonJobs</Button></div>
      </article>
    </div>
  </Section>

  <!-- REFERENCE -->
  <Section background="default" space="lg">
    <div class="head head--center">
      <Text size="label" color="accent" align="center">Reference</Text>
      <Heading as="h2" size="h2" align="center">Co říkají <span class="accent">naši klienti</span></Heading>
    </div>
    <div class="quotes">
      {testimonials.map((t, i) => (
        <figure class={`quote quote--${i % 3}`}>
          <div class="quote__head">
            <div class="quote__id">
              <strong class="quote__name">{t.author}</strong>
              <span class="quote__role">{t.role}</span>
            </div>
            <span class="quote__avatar" aria-hidden="true">{t.initials}</span>
          </div>
          <span class="quote__mark"><Icon name="lucide:quote" size="md" /></span>
          <blockquote class="quote__text">{t.quote}</blockquote>
        </figure>
      ))}
    </div>
  </Section>

  <LeadForm id="poptavka" variant="full" background="alt"
            title="Chcete vědět více?"
            lead="Nevíte, které řešení se vám hodí? Nechte nám kontakt — projdeme váš provoz a naše kolegyně Anna doporučí GrasonFlexi, GrasonPlan, nebo GrasonJobs."
            proofs={leadProofs} successUrl="/dekujeme" />
  </main>

  <Footer {...grasonFooter} />
</Base>

<style>
  .hero-figure { margin: 0; width: 100%; line-height: 0; }
  .hero-figure img { width: 100%; height: auto; display: block; filter: drop-shadow(0 24px 48px rgba(7, 7, 7, 0.22)); }
  .head { max-width: 760px; margin-inline: auto; margin-bottom: var(--space-7); }
  .head--center { text-align: center; }
  .head > * + * { margin-top: var(--space-3); }
  .hl-check { color: var(--color-secondary-azure); flex-shrink: 0; }

  /* Produktové karty */
  .pillars { display: grid; gap: var(--space-6); grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); }
  .pillar { display: flex; flex-direction: column; background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-sm); transition: var(--transition); }
  .pillar:hover { border-color: var(--color-primary); box-shadow: var(--shadow-md); }
  .pillar__media { position: relative; background: var(--color-bg-alt); line-height: 0; }
  .pillar__media img { width: 100%; height: 200px; object-fit: contain; display: block; padding: var(--space-5); }
  .pillar__badge { position: absolute; top: var(--space-4); right: var(--space-4); background: var(--color-secondary-terracotta); color: #fff; font-size: var(--font-size-caption); font-weight: var(--font-weight-semibold); text-transform: uppercase; letter-spacing: var(--letter-spacing-wide); padding: var(--space-1) var(--space-3); border-radius: var(--radius-full); }
  .pillar__body { flex: 1; padding: var(--space-6); display: flex; flex-direction: column; gap: var(--space-3); }
  .pillar__tag { align-self: flex-start; font-size: var(--font-size-caption); font-weight: var(--font-weight-semibold); text-transform: uppercase; letter-spacing: var(--letter-spacing-wide); color: var(--color-text-accent); background: color-mix(in srgb, var(--color-secondary-azure) 14%, #fff); padding: var(--space-1) var(--space-3); border-radius: var(--radius-full); }
  .pillar__points { list-style: none; display: flex; flex-direction: column; gap: var(--space-2); margin-top: var(--space-2); }
  .pillar__points li { display: flex; align-items: flex-start; gap: var(--space-2); font-size: var(--font-size-small); color: var(--color-text); }
  .pillar__check { color: var(--color-secondary-azure); flex-shrink: 0; margin-top: 2px; }
  .pillar__link { display: inline-flex; align-items: center; gap: var(--space-1); margin-top: auto; padding-top: var(--space-4); color: var(--color-text-accent); font-weight: var(--font-weight-semibold); font-size: var(--font-size-small); text-decoration: none; }
  .pillar__link:hover { gap: var(--space-2); }

  /* Pricing */
  .checklist { list-style: none; display: grid; gap: var(--space-2); }
  .checklist li { display: flex; align-items: flex-start; gap: var(--space-2); color: var(--color-text); }
  .pricing { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: var(--space-6); max-width: 1100px; margin-inline: auto; }
  .price { position: relative; background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: var(--space-7); box-shadow: var(--shadow-sm); display: flex; flex-direction: column; gap: var(--space-3); }
  .price--featured { border-color: var(--color-primary); box-shadow: var(--shadow-md); }
  .price__tag { font-size: var(--font-size-caption); font-weight: var(--font-weight-semibold); text-transform: uppercase; letter-spacing: var(--letter-spacing-wide); color: var(--color-text-accent); }
  .price__amount { font-size: var(--font-size-h1); font-weight: var(--font-weight-bold); color: var(--color-secondary); line-height: 1; }
  .price__amount span { display: inline-block; font-size: var(--font-size-small); font-weight: var(--font-weight-regular); color: var(--color-text-muted); margin-left: var(--space-2); }
  .price__badge { position: absolute; top: var(--space-5); right: var(--space-5); background: var(--color-secondary-terracotta); color: #fff; font-size: var(--font-size-caption); font-weight: var(--font-weight-semibold); padding: var(--space-1) var(--space-3); border-radius: var(--radius-full); }
  .price .checklist { margin-top: var(--space-2); }
  .price__cta { margin-top: auto; padding-top: var(--space-4); }

  /* Reference */
  .quotes { display: grid; gap: var(--space-6); grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); }
  .quote { margin: 0; display: flex; flex-direction: column; background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: var(--space-6); box-shadow: var(--shadow-sm); }
  .quote__head { display: flex; align-items: center; justify-content: space-between; gap: var(--space-4); margin-bottom: var(--space-4); }
  .quote__id { display: flex; flex-direction: column; gap: 2px; }
  .quote__name { font-size: var(--font-size-lead); font-weight: var(--font-weight-bold); color: var(--color-secondary); line-height: 1.15; }
  .quote__role { font-size: var(--font-size-small); color: var(--color-text-muted); }
  .quote__avatar { flex-shrink: 0; width: 56px; height: 56px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; font-size: var(--font-size-body); font-weight: var(--font-weight-bold); color: #fff; }
  .quote--0 .quote__avatar { background: linear-gradient(150deg, #3CC1C8, #343160); }
  .quote--1 .quote__avatar { background: linear-gradient(150deg, #F96797, #343160); }
  .quote--2 .quote__avatar { background: linear-gradient(150deg, #FAD531, #343160); }
  .quote__mark { color: var(--color-secondary-azure); display: block; margin-bottom: var(--space-2); }
  .quote__text { font-size: var(--font-size-body); color: var(--color-text); line-height: var(--line-height-body); }
</style>
