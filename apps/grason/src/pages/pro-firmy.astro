---
/**
 * Pro firmy — detailní B2B stránka.
 * Obsah z grason-web-develop/pages/for-companies.vue + page_for-companies_*
 * (cs.json) + grason-context.md. Sdílené komponenty @piano/ui.
 */
import Base from '../layouts/Base.astro';
import Header from '@piano/ui/components/Header.astro';
import Footer from '@piano/ui/components/Footer.astro';
import Section from '@piano/ui/components/Section.astro';
import Hero from '@piano/ui/components/Hero.astro';
import Heading from '@piano/ui/components/Heading.astro';
import Text from '@piano/ui/components/Text.astro';
import Button from '@piano/ui/components/Button.astro';
import Icon from '@piano/ui/components/Icon.astro';
import LeadForm from '@piano/ui/components/LeadForm.astro';
import { grasonNav, grasonCta } from '../config/nav';

// Střídavé feature řádky — sekce „Brigádníci"
const rows = [
  { img: '/images/for-companies-choose-candidates.webp', title: 'Vybírejte si podle zkušeností a hodnocení', text: 'Vždycky víte, kdo k vám přijde pracovat. Pracovníky vybíráte podle jejich profilů, zkušeností a hodnocení od jiných firem.' },
  { img: '/images/for-companies-choose-favourite-workers.webp', title: 'Vytvořte si tým oblíbených pracovníků', text: 'Vaši oblíbení pracovníci přehledně na jednom místě. Dejte jim jednoduše vědět o nové směně dřív než ostatním.' },
  { img: '/images/for-companies-hire-people.webp', title: 'Spolupracujte se stejnými lidmi dlouhodobě', text: 'Nikdo nechce pokaždé zaškolovat nového člověka. Když budete spokojeni, pozvěte své oblíbence na další směny.' },
  { img: '/images/for-companies-feedback.webp', title: 'Zpětná vazba po každé směně', text: 'Dejte vědět, jak jste byli spokojeni. Napište pracovníkům hodnocení a získejte zpětnou vazbu i vy.' },
];

const planPoints = [
  'Plánování směn na počítači i v mobilu',
  'Zaměstnanci si sami zadají, kdy nemohou',
  'Chytré notifikace — připomenou směnu, najdou náhradníka',
  'Úkolování s potvrzením (foto, text, odkliknutí)',
  'Reporty pro mzdovou účetní na jedno kliknutí',
  'Přehled mzdových nákladů v reálném čase',
  'Sdílení personálu mezi více podniky',
  'Šablony směn a hlídání kolizí',
];

const pichackyPoints = [
  { icon: 'lucide:map-pin', title: 'GPS okruh 30 m', text: 'Systém ověří, že zaměstnanec opravdu dorazil na provozovnu.' },
  { icon: 'lucide:wifi', title: 'Ověření přes WiFi', text: 'Příchod lze potvrdit i připojením k síti provozovny.' },
  { icon: 'lucide:smartphone', title: 'Bez kartiček a papírů', text: 'Příchod i odchod jednoduše přes mobil zaměstnance.' },
  { icon: 'lucide:banknote', title: 'Podklad pro mzdy', text: 'Odpracované hodiny rovnou do reportu pro účetní.' },
];

const testimonials = [
  { initials: 'MS', quote: 'Ke Grasonu nás dovedla zhoršující se situace na trhu práce a jejich inovativní přístup. Velkou výhodou je praktická aplikace a možnost operativního plánování směn 24/7. Odpadá nám i starost s prvotním výběrem kandidátů.', author: 'Martin Savkulič', role: 'Manažer restaurace Pizza Nuova' },
  { initials: 'DS', quote: 'Pracovníci z Grasonu u nás vykrývají nejen nárazové směny na skladech, ale stávají se i pravidelnou součástí týmu. Aplikace je user-friendly, spolupráce funguje na výbornou.', author: 'Denisa Srnková', role: 'HR Business Partner, DámeMarket' },
  { initials: 'MP', quote: 'Pracovníci nalezení přes Grason byli sice dražší, ale mnohem motivovanější a ochotní makat než lidé z jiných kanálů.', author: 'Ing. Michal Prádl', role: 'Vedoucí skladu DATART Jirny' },
  { initials: 'JK', quote: 'Velkou výhodu vidím v úspoře času, protože Grason za mě řeší byrokratické papírování.', author: 'Josef Kubíček', role: 'Manažer, Likér' },
];

const leadProofs = [
  { icon: 'lucide:gift', title: '14 dní zdarma', text: 'Bez platební karty, nezávazně.' },
  { icon: 'lucide:zap', title: 'Směna za pár minut', text: 'Pozici obsadíte dřív než konkurence.' },
  { icon: 'lucide:users', title: '3 357+ brigádníků', text: 'Ověření pracovníci po celé ČR.' },
  { icon: 'lucide:phone', title: 'Anna Pánková', text: 'anna.pankova@grason.cz' },
];
---

<Base title="Pro firmy — Grason"
      description="Grason je nejrychlejší cesta k pracovníkům: brigádníci na směnu, plánování vlastního týmu (GrasonPlan) i digitální píchačky. Pozici obsadíte do několika minut.">
  <Header brand="Grason" logoSrc="/logos/grason_logo.svg" logoHeight="28px" homeHref="/" nav={grasonNav} cta={grasonCta} />

  <main>

  <!-- HERO -->
  <Hero eyebrow="Pro firmy" background="gradient"
        lead="Grason je nejrychlejší cesta k pracovníkům. Pozici obsadíte do několika minut a získáte náskok před ostatními zaměstnavateli.">
    <Heading slot="title" as="h1" size="display" color="on-dark">Chybí vám lidi? <span class="accent">S námi je máte</span> zítra na směně</Heading>
    <Fragment slot="actions">
      <Button href="#poptavka">Vyzkoušet 14 dní zdarma</Button>
      <Button href="#cenik" variant="secondary" onDark>Ukázat ceník</Button>
    </Fragment>
    <figure slot="media" class="hero-figure">
      <img src="/images/for-companies-hero.webp" alt="Grason pro firmy — výběr kandidátů na směnu" width="720" height="560" loading="eager" />
    </figure>
  </Hero>

  <Section background="alt" space="sm">
    <ul class="hero-list">
      <li><Icon name="lucide:check" size="sm" class="hl-check" />Nepotřebujete platební kartu</li>
      <li><Icon name="lucide:check" size="sm" class="hl-check" />Za pár minut máte vypsanou směnu</li>
      <li><Icon name="lucide:check" size="sm" class="hl-check" />Žádné poplatky odvozené ze mzdy</li>
    </ul>
  </Section>

  <!-- BRIGÁDNÍCI -->
  <Section id="brigadnici" background="default" space="lg">
    <div class="head head--center">
      <Text size="label" color="accent" align="center">Brigádníci</Text>
      <Heading as="h2" size="h2" align="center">Flexibilní pracovníci <span class="accent">na jedno kliknutí</span></Heading>
      <Text size="lead" color="muted" align="center" balance>
        Vypíšete směnu, ověření brigádníci se přihlásí, vy vyberete. Grason vyřídí smlouvu i výplatu.
      </Text>
    </div>
    <div class="rows">
      {rows.map((r, i) => (
        <div class={`row ${i % 2 === 1 ? 'row--reverse' : ''}`}>
          <figure class="row__media"><img src={r.img} alt="" loading="lazy" /></figure>
          <div class="row__text">
            <Heading as="h3" size="h3">{r.title}</Heading>
            <Text color="muted">{r.text}</Text>
          </div>
        </div>
      ))}
    </div>
  </Section>

  <!-- GRASONPLAN -->
  <Section id="grasonplan" background="alt" space="lg">
    <div class="split">
      <figure class="split__media"><img src="/images/illustration-calendar.webp" alt="GrasonPlan — plánování směn" loading="lazy" /></figure>
      <div class="split__text">
        <Text size="label" color="accent">GrasonPlan</Text>
        <Heading as="h2" size="h2">Plánování směn <span class="accent">vlastního týmu</span></Heading>
        <Text size="lead" color="muted" balance>
          Rozvrh bez Excelu a skupinových chatů. Zaměstnanci zadají dostupnost, vy potvrdíte plán — a náhradník za nemocného se najde sám.
        </Text>
        <ul class="checklist">
          {planPoints.map((p) => (
            <li><Icon name="lucide:check" size="sm" class="hl-check" />{p}</li>
          ))}
        </ul>
        <div class="split__cta"><Button href="#poptavka">Vyzkoušet zdarma</Button></div>
      </div>
    </div>
  </Section>

  <!-- DIGITÁLNÍ PÍCHAČKY -->
  <Section id="pichacky" background="invert" space="lg">
    <div class="head head--center">
      <Text size="label" color="accent" align="center">Digitální píchačky · Nová funkce</Text>
      <Heading as="h2" size="h2" align="center" color="on-dark">Přesně víte, <span class="accent">kdo přišel a kdy</span></Heading>
      <Text size="lead" color="on-dark-muted" align="center" balance>
        Zaměstnanec otevře appku — systém přes GPS nebo WiFi ověří, že je v provozovně, a zaznamená docházku. Žádné dohady, jen fakta.
      </Text>
    </div>
    <ul class="cards cards--dark">
      {pichackyPoints.map((p) => (
        <li class="mini">
          <span class="mini__icon"><Icon name={p.icon} size="md" /></span>
          <Heading as="h3" size="h3" color="on-dark">{p.title}</Heading>
          <Text size="small" color="on-dark-muted">{p.text}</Text>
        </li>
      ))}
    </ul>
  </Section>

  <!-- CENÍK -->
  <Section id="cenik" background="default" space="lg">
    <div class="head head--center">
      <Text size="label" color="accent" align="center">Ceník</Text>
      <Heading as="h2" size="h2" align="center">Předplatné <span class="accent">bez poplatků ze mzdy</span></Heading>
      <Text size="lead" color="muted" align="center" balance>
        Žádné poplatky odvozené ze mzdy pracovníka. Díky předplatnému předem přesně víte, kolik a za co měsíčně platíte.
      </Text>
    </div>
    <div class="pricing">
      <article class="price">
        <span class="price__tag">Brigádníci (GrasonFlexi)</span>
        <Heading as="h3" size="h3">Balíčky na míru</Heading>
        <Text color="muted" size="small">Podle počtu směn, poboček a funkcí. Závazek na 3, 6 nebo 12 měsíců.</Text>
        <ul class="checklist">
          <li><Icon name="lucide:check" size="sm" class="hl-check" />Bez poplatků ze mzdy brigádníka</li>
          <li><Icon name="lucide:check" size="sm" class="hl-check" />Od základního po prémiový tarif</li>
          <li><Icon name="lucide:check" size="sm" class="hl-check" />Enterprise: neomezené směny + account manager</li>
          <li><Icon name="lucide:check" size="sm" class="hl-check" />Automatizace dokumentů a vyplácení mezd</li>
        </ul>
        <div class="price__cta"><Button href="#poptavka">Chci nabídku</Button></div>
      </article>
      <article class="price price--featured">
        <span class="price__badge">1. měsíc zdarma</span>
        <span class="price__tag">GrasonPlan</span>
        <p class="price__amount">990 Kč<span>/měsíc bez DPH</span></p>
        <Text color="muted" size="small">1 podnik, do 25 uživatelů. Každý další uživatel +50 Kč/měsíc.</Text>
        <ul class="checklist">
          <li><Icon name="lucide:check" size="sm" class="hl-check" />Plánování směn, dovolených i záskoků</li>
          <li><Icon name="lucide:check" size="sm" class="hl-check" />Docházka a podklady pro mzdy</li>
          <li><Icon name="lucide:check" size="sm" class="hl-check" />Úkoly, checklisty, notifikace</li>
          <li><Icon name="lucide:check" size="sm" class="hl-check" />První měsíc zdarma, bez závazku</li>
        </ul>
        <div class="price__cta"><Button href="#poptavka">Vyzkoušet zdarma</Button></div>
      </article>
    </div>
  </Section>

  <!-- REFERENCE -->
  <Section background="alt" space="lg">
    <div class="head head--center">
      <Text size="label" color="accent" align="center">Reference</Text>
      <Heading as="h2" size="h2" align="center">Co říkají <span class="accent">naši klienti</span></Heading>
    </div>
    <div class="quotes">
      {testimonials.map((t, i) => (
        <figure class={`quote quote--${i % 3}`}>
          <div class="quote__head">
            <div class="quote__id">
              <strong class="quote__name">{t.author}</strong>
              <span class="quote__role">{t.role}</span>
            </div>
            <span class="quote__avatar" aria-hidden="true">{t.initials}</span>
          </div>
          <span class="quote__mark"><Icon name="lucide:quote" size="md" /></span>
          <blockquote class="quote__text">{t.quote}</blockquote>
        </figure>
      ))}
    </div>
  </Section>

  <!-- POPTÁVKA -->
  <LeadForm id="poptavka" variant="full" background="default"
            title="Chcete vědět více?"
            lead="Máte zájem o prémiovou nabídku nebo jste nenašli vše, co jste hledali? Nechte nám kontakt a naše kolegyně Anna se vám ozve."
            proofs={leadProofs} successUrl="/dekujeme" />

  </main>

  <Footer logoSrc="/logos/grason_by_piano.svg" logoAlt="Grason by Piano" />
</Base>

<style>
  .hero-figure { margin: 0; width: 100%; line-height: 0; }
  .hero-figure img { width: 100%; height: auto; display: block; filter: drop-shadow(0 24px 48px rgba(7, 7, 7, 0.22)); }

  .head { max-width: 760px; margin-inline: auto; margin-bottom: var(--space-7); }
  .head--center { text-align: center; }
  .head > * + * { margin-top: var(--space-3); }

  /* Hero list */
  .hero-list { list-style: none; display: flex; flex-wrap: wrap; gap: var(--space-5); justify-content: center; }
  .hero-list li { display: inline-flex; align-items: center; gap: var(--space-2); font-size: var(--font-size-small); color: var(--color-text); }
  .hl-check { color: var(--color-secondary-azure); flex-shrink: 0; }

  /* Střídavé řádky */
  .rows { display: flex; flex-direction: column; gap: var(--space-8); }
  .row { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-8); align-items: center; }
  .row--reverse .row__media { order: 2; }
  .row__media { margin: 0; line-height: 0; background: var(--color-bg-alt); border-radius: var(--radius-lg); padding: var(--space-6); }
  .row__media img { width: 100%; height: auto; display: block; }
  .row__text > * + * { margin-top: var(--space-3); }
  @media (max-width: 880px) { .row { grid-template-columns: 1fr; gap: var(--space-5); } .row--reverse .row__media { order: 0; } }

  /* Split */
  .split { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-8); align-items: center; }
  .split__media { margin: 0; line-height: 0; }
  .split__media img { width: 100%; height: auto; display: block; }
  .split__text > * + * { margin-top: var(--space-4); }
  .split__cta { margin-top: var(--space-5); }
  @media (max-width: 880px) { .split { grid-template-columns: 1fr; gap: var(--space-6); } .split__media { order: -1; } }

  /* Checklist */
  .checklist { list-style: none; display: grid; gap: var(--space-2); }
  .checklist li { display: flex; align-items: flex-start; gap: var(--space-2); color: var(--color-text); }

  /* Mini cards (píchačky) */
  .cards { list-style: none; display: grid; gap: var(--space-5); grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); }
  .mini { padding: var(--space-6); border-radius: var(--radius-md); }
  .cards--dark .mini { background: rgba(255,255,255,0.04); border: 1px solid var(--color-border-on-dark); }
  .mini > * + * { margin-top: var(--space-3); }
  .mini__icon { display: inline-flex; color: var(--color-secondary-azure); }

  /* Pricing */
  .pricing { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: var(--space-6); max-width: 880px; margin-inline: auto; }
  .price { position: relative; background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: var(--space-7); box-shadow: var(--shadow-sm); display: flex; flex-direction: column; gap: var(--space-3); }
  .price--featured { border-color: var(--color-primary); box-shadow: var(--shadow-md); }
  .price__tag { font-size: var(--font-size-caption); font-weight: var(--font-weight-semibold); text-transform: uppercase; letter-spacing: var(--letter-spacing-wide); color: var(--color-text-accent); }
  .price__amount { font-size: var(--font-size-h1); font-weight: var(--font-weight-bold); color: var(--color-secondary); line-height: 1; }
  .price__amount span { display: inline-block; font-size: var(--font-size-small); font-weight: var(--font-weight-regular); color: var(--color-text-muted); margin-left: var(--space-2); }
  .price__badge { position: absolute; top: var(--space-5); right: var(--space-5); background: var(--color-secondary-terracotta); color: #fff; font-size: var(--font-size-caption); font-weight: var(--font-weight-semibold); padding: var(--space-1) var(--space-3); border-radius: var(--radius-full); }
  .price .checklist { margin-top: var(--space-2); }
  .price__cta { margin-top: auto; padding-top: var(--space-4); }

  /* Reference */
  .quotes { display: grid; gap: var(--space-6); grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); }
  .quote { margin: 0; display: flex; flex-direction: column; background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: var(--space-6); box-shadow: var(--shadow-sm); }
  .quote__head { display: flex; align-items: center; justify-content: space-between; gap: var(--space-4); margin-bottom: var(--space-4); }
  .quote__id { display: flex; flex-direction: column; gap: 2px; }
  .quote__name { font-size: var(--font-size-lead); font-weight: var(--font-weight-bold); color: var(--color-secondary); line-height: 1.15; }
  .quote__role { font-size: var(--font-size-small); color: var(--color-text-muted); }
  .quote__avatar { flex-shrink: 0; width: 56px; height: 56px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; font-size: var(--font-size-body); font-weight: var(--font-weight-bold); color: #fff; }
  .quote--0 .quote__avatar { background: linear-gradient(150deg, #3CC1C8, #343160); }
  .quote--1 .quote__avatar { background: linear-gradient(150deg, #F96797, #343160); }
  .quote--2 .quote__avatar { background: linear-gradient(150deg, #FAD531, #343160); }
  .quote__mark { color: var(--color-secondary-azure); display: block; margin-bottom: var(--space-2); }
  .quote__text { font-size: var(--font-size-body); color: var(--color-text); line-height: var(--line-height-body); }
</style>
