---
/** Pecosta — Služba: Autset (automatické naskladnění). Obsah: autset-context.md. */
import Base from '../../layouts/Base.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import Section from '@piano/ui/components/Section.astro';
import Hero from '@piano/ui/components/Hero.astro';
import Heading from '@piano/ui/components/Heading.astro';
import Text from '@piano/ui/components/Text.astro';
import Button from '@piano/ui/components/Button.astro';
import Icon from '@piano/ui/components/Icon.astro';
import USPGrid from '@piano/ui/components/USPGrid.astro';
import LeadForm from '@piano/ui/components/LeadForm.astro';
import StatsBand from '../../components/StatsBand.astro';
import Faq from '../../components/Faq.astro';

const steps = [
  { icon: 'lucide:phone-call', title: 'Kontaktování dodavatele', text: 'Autset s dodavatelem domluví zasílání dodacích listů v elektronické podobě.' },
  { icon: 'lucide:scan-line', title: 'Zpracování', text: 'Dodací list je zvalidován, strojově zpracován a uložen — bez ručního přepisování.' },
  { icon: 'lucide:settings-2', title: 'Příprava dat', text: 'Data jsou transformována a připravena pro váš cílový skladový systém.' },
  { icon: 'lucide:send', title: 'Odeslání dat', text: 'Naskladnění dorazí do vašeho systému. Vše funguje dál jako dosud — jen samo.' },
];
const benefits = [
  { icon: 'lucide:clock', title: 'Úspora až 1 hodiny denně', text: 'Konec ručního přepisování dodacích listů. Čas navíc pro manažery i provozní.' },
  { icon: 'lucide:shield-check', title: 'Žádné chyby z přepisu', text: 'Validační mechanismy hlídají chyby. Podklady jsou přesnější a nemusíte je kontrolovat položkově.' },
  { icon: 'lucide:plug', title: '400+ dodavatelů', text: 'Napojení na většinu běžných skladových a účetních systémů v gastru, vč. Septimu.' },
  { icon: 'lucide:wand-2', title: 'Individuální přístup', text: 'Formát každého dodavatele přizpůsobíme — i EDI doklady přes univerzální rozhraní.' },
];
const faqs = [
  { q: 'Co je automatické naskladnění?', a: 'Dodací listy od dodavatelů se zpracují strojově a naskladní automaticky do vašeho skladového systému — bez ručního přepisování položek.' },
  { q: 'S jakými systémy se Autset propojí?', a: 'S většinou běžných skladových a účetních systémů používaných v gastru, včetně Septimu. Napojení řešíme přes univerzální rozhraní a zvládáme i EDI doklady.' },
  { q: 'Kolik času ušetřím?', a: 'Provozy s Autsetem šetří až 1 hodinu práce denně. CPI Hotels uvádí minimálně hodinu denně v každém ze svých hotelů.' },
  { q: 'Musím měnit dodavatele nebo systém?', a: 'Ne. Autset se napojí na vaše stávající dodavatele i cílový systém. Vše funguje dál jako dosud, jen bez ruční práce.' },
];
const autsetStats = [
  { num: '1 hod.', lbl: 'ušetřená práce denně' },
  { num: '400+', lbl: 'napojených dodavatelů' },
  { num: '0', lbl: 'ručně přepsaných dokladů' },
  { num: '24', lbl: 'hotelů CPI v ČR využívá Autset' },
];
---
<Base title="Autset – automatické naskladnění dodacích listů | Pecosta"
      description="Autset automaticky naskladní dodací listy do vašeho skladového systému. Bez ručního přepisování, bez chyb, úspora až 1 hodiny denně. 400+ napojených dodavatelů.">
  <SiteHeader />
  <main>
    <Hero eyebrow="Služba Pecosta" background="alt"
          lead="Nepřepisujte, AUTSETUJTE. Dodací listy od 400+ dodavatelů se zpracují strojově a naskladní automaticky do vašeho skladového systému — bez chyb a bez hodin administrativy.">
      <Heading slot="title" as="h1" size="display"><em>Autset</em> — naskladnění bez práce</Heading>
      <Fragment slot="actions">
        <Button href="#poptavka">Chci analýzu zdarma</Button>
        <Button href="/sluzby/aukcni-nakupy" variant="secondary">Aukční nákupy</Button>
      </Fragment>
    </Hero>

    <Section background="default" space="lg">
      <div class="prose">
        <Heading as="h2" size="h2">Konec ručního přepisování dodacích listů</Heading>
        <Text size="lead" color="muted">
          Naskladnění zboží z dodacích listů zabere denně hodiny — a každý ruční přepis je riziko chyby.
          Autset celý proces zautomatizuje: dodací list zvaliduje, zpracuje a odešle data přímo
          do vašeho skladového systému.
        </Text>
        <Text color="muted">
          Skladové účetní tak mají přesnější podklady a nemusí je kontrolovat položku po položce.
          Autset je součástí rodiny Pecosta a propojuje se i se Septimem.
        </Text>
      </div>
    </Section>

    <Section background="alt" space="lg">
      <div class="head head--center">
        <Text size="label" color="accent" align="center">Jak to funguje</Text>
        <Heading as="h2" size="h2" align="center">Ve čtyřech krocích</Heading>
      </div>
      <ol class="steps">
        {steps.map((s, i) => (
          <li class="step">
            <span class="step__num">{i + 1}</span>
            <span class="step__icon"><Icon name={s.icon} size="lg" /></span>
            <Heading as="h3" size="h3">{s.title}</Heading>
            <Text size="small" color="muted">{s.text}</Text>
          </li>
        ))}
      </ol>
    </Section>

    <USPGrid eyebrow="Výhody" title="Proč Autset" items={benefits} background="default" space="lg" minItemWidth="240px" />
    <StatsBand items={autsetStats} background="alt" />
    <Faq items={faqs} title="Časté otázky k Autsetu" background="default" />
    <LeadForm id="poptavka" variant="full" background="alt"
              title="Ukážeme vám naskladnění bez práce"
              lead="Nechte nám kontakt — předvedeme Autset na vašich dodavatelích a systému. Zdarma a bez závazků."
              submitLabel="Chci analýzu zdarma" />
  </main>
  <SiteFooter />
</Base>

<style>
  .prose { max-width: 760px; }
  .prose > * + * { margin-top: var(--space-4); }
  .head { max-width: 760px; margin-inline: auto; margin-bottom: var(--space-7); text-align: center; }
  .head > * + * { margin-top: var(--space-3); }
  .steps { list-style: none; display: grid; gap: var(--space-6); grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); }
  .step { position: relative; padding: var(--space-6); background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-md); box-shadow: var(--shadow-sm); }
  .step > * + * { margin-top: var(--space-3); }
  .step__num { position: absolute; top: var(--space-4); right: var(--space-5); font-size: var(--font-size-h2); font-weight: var(--font-weight-bold); color: var(--color-neutral-200); line-height: 1; }
  .step__icon { display: inline-flex; align-items: center; justify-content: center; width: 56px; height: 56px; border-radius: var(--radius-md); background: color-mix(in srgb, var(--color-primary) 10%, #fff); color: var(--color-primary); }
</style>
