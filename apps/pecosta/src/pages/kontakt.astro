---
/** Pecosta — Kontakt. Obsah: pecosta-context.md. */
import Base from '../layouts/Base.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import Section from '@piano/ui/components/Section.astro';
import Hero from '@piano/ui/components/Hero.astro';
import Heading from '@piano/ui/components/Heading.astro';
import Text from '@piano/ui/components/Text.astro';
import Icon from '@piano/ui/components/Icon.astro';
import LeadForm from '@piano/ui/components/LeadForm.astro';

const contacts = [
  { icon: 'lucide:mail', label: 'E-mail', value: 'pecosta@pecosta.cz', href: 'mailto:pecosta@pecosta.cz' },
  { icon: 'lucide:phone', label: 'Telefon', value: '+420 734 442 683', href: 'tel:+420734442683' },
  { icon: 'lucide:map-pin', label: 'Sídlo', value: 'Kořenského 1262/40, 703 00 Ostrava-Vítkovice', href: null },
  { icon: 'lucide:building-2', label: 'Společnost', value: 'PECOSTA, a.s. · IČO 09708464', href: null },
];
---
<Base title="Kontakt | Pecosta"
      description="Spojte se s Pecostou. E-mail pecosta@pecosta.cz, telefon +420 734 442 683. PECOSTA, a.s., Ostrava-Vítkovice. Nezávazná analýza úspor zdarma.">
  <SiteHeader />
  <main>
    <Hero eyebrow="Kontakt" background="alt"
          lead="Ozvěte se nám — nebo nechte kontakt a spojíme se s vámi. Začínáme vždy nezávaznou analýzou úspor zdarma.">
      <Heading slot="title" as="h1" size="display">Pojďme <em>počítat úspory</em></Heading>
    </Hero>

    <Section background="default" space="lg">
      <ul class="contacts">
        {contacts.map((c) => (
          <li class="contact">
            <span class="contact__icon"><Icon name={c.icon} size="md" /></span>
            <div>
              <Text size="label" color="muted">{c.label}</Text>
              {c.href
                ? <a class="contact__value" href={c.href}>{c.value}</a>
                : <span class="contact__value">{c.value}</span>}
            </div>
          </li>
        ))}
      </ul>
    </Section>

    <LeadForm id="poptavka" variant="full" background="alt"
              title="Nechte nám kontakt"
              lead="Připravíme cenové porovnání a kalkulaci úspor pro váš provoz. Zdarma a bez závazků."
              submitLabel="Chci analýzu zdarma" />
  </main>
  <SiteFooter />
</Base>

<style>
  .contacts { list-style: none; display: grid; gap: var(--space-5); grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); max-width: 960px; margin-inline: auto; }
  .contact { display: flex; align-items: flex-start; gap: var(--space-4); padding: var(--space-6); background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-md); box-shadow: var(--shadow-sm); }
  .contact__icon { flex-shrink: 0; display: inline-flex; align-items: center; justify-content: center; width: 48px; height: 48px; border-radius: var(--radius-md); background: color-mix(in srgb, var(--color-primary) 10%, #fff); color: var(--color-primary); }
  .contact__value { display: block; margin-top: 2px; font-weight: var(--font-weight-semibold); color: var(--color-text); text-decoration: none; }
  a.contact__value:hover { color: var(--color-primary); }
</style>
