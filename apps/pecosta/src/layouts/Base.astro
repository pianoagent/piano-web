---
/**
 * Base — layout webu Pecosta.
 * Načte téma Pecosta + sdílenou SEO hlavičku. Definuje Organization schema.
 */
import '../styles/theme.css';
import BaseHead from '@piano/ui/layouts/BaseHead.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  schema?: object;
}

const SITE_NAME = 'Pecosta';
const SITE_URL = 'https://pecosta.cz';

const {
  title,
  description = 'Pecosta — chytrý nákup surovin a energií pro gastro. Aukční nákupy, úspora až 16 % a automatické naskladňování.',
  image = '/og-default.jpg',
  type = 'website',
  noindex = false,
  schema,
} = Astro.props;

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Pecosta',
  legalName: 'PECOSTA, a.s.',
  url: SITE_URL,
  logo: `${SITE_URL}/logos/pecosta_color.svg`,
  email: 'pecosta@pecosta.cz',
  telephone: '+420 734 442 683',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Kořenského 1262/40',
    addressLocality: 'Ostrava-Vítkovice',
    postalCode: '703 00',
    addressCountry: 'CZ',
  },
  parentOrganization: { '@type': 'Organization', name: 'Piano Solutions', url: 'https://piano.cz' },
};

const schemas = [organizationSchema, ...(schema ? [schema] : [])];
---

<!doctype html>
<html lang="cs">
  <head>
    <BaseHead
      title={title}
      description={description}
      image={image}
      type={type}
      noindex={noindex}
      siteName={SITE_NAME}
      siteUrl={SITE_URL}
      schemas={schemas}
    />
  </head>
  <body>
    <slot />
  </body>
</html>
