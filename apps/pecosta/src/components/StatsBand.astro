---
/**
 * StatsBand — tenký wrapper nad @piano/ui/StatsBand.
 * Jen dodává výchozí pecostí čísla; lze přepsat props `items`.
 * Vzhled a markup řeší sdílená komponenta — NEFORKOVAT.
 */
import UiStatsBand from '@piano/ui/components/StatsBand.astro';

interface Stat { num: string; lbl: string; }
interface Props { items?: Stat[]; background?: 'default' | 'alt'; }

const defaults: Stat[] = [
  { num: '16 %', lbl: 'průměrná úspora na surovinách' },
  { num: '960+', lbl: 'provozů nakupuje s Pecostou' },
  { num: '400+', lbl: 'napojených dodavatelů' },
  { num: '2,5 mld.', lbl: 'Kč nákupní objem ročně' },
];
const { items = defaults, background = 'alt' } = Astro.props;
---

<UiStatsBand items={items} background={background} />
