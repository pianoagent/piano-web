---
/** Qerko — Kontakt. Obsah ze staré stránky qerko.com/kontakt (telefon, e-mail). */
import Base from '../layouts/Base.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import Section from '@piano/ui/components/Section.astro';
import Hero from '@piano/ui/components/Hero.astro';
import Heading from '@piano/ui/components/Heading.astro';
import Text from '@piano/ui/components/Text.astro';
import Icon from '@piano/ui/components/Icon.astro';
import LeadForm from '@piano/ui/components/LeadForm.astro';

const support = [
  { title: 'Mám zájem o Qerko', icon: 'lucide:shopping-bag', phone: '+420 277 277 945', tel: 'tel:+420277277945', mail: 'info@qerko.com' },
  { title: 'Podpora podniků', icon: 'lucide:headset', phone: '+420 277 277 945', tel: 'tel:+420277277945', mail: 'podpora@qerko.com' },
  { title: 'Pro média', icon: 'lucide:newspaper', mail: 'pr@qerko.com' },
];
---
<Base title="Kontakt | Qerko"
      description="Kontakt na Qerko: obchod a podpora pro podniky. Napište nám nebo zavolejte — ukážeme vám, jak Qerko otočí víc stolů a zvedne dýška.">
  <SiteHeader />
  <main>
    <Hero eyebrow="Kontakt" background="alt"
          lead="Zajímá vás Qerko pro váš podnik, nebo už Qerko používáte? Rádi pomůžeme — jsme tu pro vás.">
      <Heading slot="title" as="h1" size="display">Ozvěte se <em>nám</em></Heading>
    </Hero>

    <Section background="default" space="lg">
      <div class="grid">
        {support.map((s) => (
          <div class="ccard">
            <span class="ccard__icon"><Icon name={s.icon} size="md" /></span>
            <Heading as="h2" size="h3">{s.title}</Heading>
            {s.phone && <a class="ccard__phone" href={s.tel}>{s.phone}</a>}
            {s.mail && <a class="ccard__mail" href={`mailto:${s.mail}`}>{s.mail}</a>}
          </div>
        ))}
      </div>
      <Text size="small" color="muted" align="center" class="legal">
        Qerko s.r.o., IČO 06678815, DIČ CZ06678815 · Praha · Držitel licence České národní banky (platební instituce).
      </Text>
    </Section>

    <LeadForm id="poptavka" variant="full" background="alt"
              title="Napište nám"
              lead="Nechte nám kontakt a krátkou zprávu — ozveme se co nejdříve." />
  </main>
  <SiteFooter />
</Base>

<style>
  .grid { display: grid; gap: var(--space-5); grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); }
  .ccard { background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-md); box-shadow: var(--shadow-sm); padding: var(--space-6); text-align: center; }
  .ccard__icon { display: inline-flex; align-items: center; justify-content: center; width: 48px; height: 48px; border-radius: var(--radius-md); background: color-mix(in srgb, var(--color-primary) 12%, #fff); color: var(--color-primary); margin-bottom: var(--space-3); }
  .ccard__phone { display: block; font-size: var(--font-size-h3); font-weight: var(--font-weight-bold); color: var(--color-secondary); text-decoration: none; margin-top: var(--space-2); }
  .ccard__mail { display: block; font-size: var(--font-size-small); color: var(--color-text-accent); text-decoration: none; margin-top: var(--space-1); }
  .legal { margin-top: var(--space-7); }
</style>
