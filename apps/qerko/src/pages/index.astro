---
/**
 * Qerko — homepage (první verze).
 * Obsah vytěžen ze starých stránek qerko.com (index, qr-platba, objednavani,
 * vernostni-program, hodnoceni, q-point, rezervace) + qerko-context.md.
 * Vše ze SDÍLENÝCH komponent @piano/ui; téma řeší src/styles/theme.css.
 * Sekce bez vlastní komponenty (Stats, Steps, Feature rows, Awards, Reference,
 * FAQ) jsou složené z primitivů (Section/Heading/Text/Button/Icon) —
 * komponenty se NEFORKUJÍ.
 */
import Base from '../layouts/Base.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import Section from '@piano/ui/components/Section.astro';
import Hero from '@piano/ui/components/Hero.astro';
import Heading from '@piano/ui/components/Heading.astro';
import Text from '@piano/ui/components/Text.astro';
import Button from '@piano/ui/components/Button.astro';
import Icon from '@piano/ui/components/Icon.astro';
import USPGrid from '@piano/ui/components/USPGrid.astro';
import LeadForm from '@piano/ui/components/LeadForm.astro';
import LogoWall from '@piano/ui/components/LogoWall.astro';

const stats = [
  { num: '+20 %', lbl: 'více otočených stolů' },
  { num: '+40 %', lbl: 'vyšší dýška pro obsluhu' },
  { num: '4 min', lbl: 'ušetřené na každý stůl' },
  { num: '1,5 mil.+', lbl: 'obsloužených hostů' },
];

const steps = [
  { icon: 'lucide:qr-code', title: 'Host naskenuje QR', text: 'Na stole je QR kód nebo NFC. Host ho naskenuje telefonem — žádná aplikace navíc není potřeba.' },
  { icon: 'lucide:utensils', title: 'Vidí menu a objednává', text: 'Digitální menu se načte z vaší pokladny. Host si může rovnou objednat další jídlo i pití.' },
  { icon: 'lucide:smartphone', title: 'Zaplatí z mobilu', text: 'Rozdělí účet, přidá spropitné a zaplatí kartou, Apple Pay nebo stravenkou — kdykoliv chce.' },
  { icon: 'lucide:monitor-check', title: 'Obsluha vše vidí v POS', text: 'Platba i objednávka se okamžitě propíší do pokladny. Číšník má čas na nově příchozí.' },
  { icon: 'lucide:receipt', title: 'Účtenka e-mailem', text: 'Host dostane digitální účtenku automaticky. Žádné čekání, žádný papír navíc.' },
  { icon: 'lucide:star', title: 'Qerko požádá o recenzi', text: 'Po platbě se Qerko zeptá na hodnocení a vybídne k recenzi na Googlu i follow na Instagramu.' },
];

const features = [
  { icon: 'lucide:qr-code', title: 'Platba QR kódem od stolu', text: 'Host zaplatí sám z telefonu, kdykoliv chce. Obsluha nemusí kasírovat jednotlivé stoly.' },
  { icon: 'lucide:split', title: 'Rozdělení účtu', text: 'Každý host zaplatí jen za své. Žádné počítání u stolu, žádné čekání na drobné.' },
  { icon: 'lucide:hand-coins', title: 'Vyšší spropitné', text: 'Host přidá dýško jedním klikem. Provozy s Qerkem mají v průměru o 40 % vyšší tipy.' },
  { icon: 'lucide:utensils', title: 'Digitální menu a objednávání', text: 'Menu s fotkami se načte z pokladny. Objednávky jdou rovnou do POS a kuchyně.' },
  { icon: 'lucide:award', title: 'Věrnostní program', text: 'Hosté se stávají followery podniku. Personalizované nabídky je přivedou zpět.' },
  { icon: 'lucide:star', title: 'Hodnocení a Google recenze', text: 'Qerko automaticky sbírá recenze od spokojených hostů. Buďte číslo 1 ve městě.' },
];

// Detailní bloky produktu — kotvy odpovídají navigaci a patičce
const blocks = [
  {
    id: 'qr-platba', bg: 'default', icon: 'lucide:qr-code', eyebrow: 'Qerko platba',
    title: 'Zaplatí sami. Vy markujete dál.',
    text: '„Zaplatím!" je fráze, která běžně stojí obsluhu i hosty desítky minut. S Qerkem si hosté sami rozpočítají účet a zaplatí z mobilu — platba se propíše do pokladny a obsluha o všem ví.',
    bullets: ['Bezkontaktní platba bez PIN', 'Visa, Mastercard, Apple Pay, stravenky', 'Rozdělení účtu mezi hosty'],
  },
  {
    id: 'objednavani', bg: 'alt', icon: 'lucide:utensils', eyebrow: 'Digitální menu a objednávka',
    title: 'Co takhle kávu nebo dezert?',
    text: 'Na tuhle otázku je někdy zoufale málo času. Vaše menu si automaticky stáhneme z pokladny, ukážeme ho hostům a doporučíme položky na míru. Objednávky z telefonu jdou přímo do POS a kuchyně — tržby rostou až o 10 %.',
    bullets: ['Menu s fotkami, vždy aktuální', 'Objednávky rovnou do POS a kuchyně', 'Předobjednávky i takeaway'],
  },
  {
    id: 'rezervace', bg: 'default', icon: 'lucide:calendar-check', eyebrow: 'Rezervace',
    title: 'Rezervace z mobilu i webu',
    text: 'Hosté si rezervují stůl přímo z aplikace nebo z webového formuláře. Vy máte přehled o obsazenosti a méně práce s telefonáty.',
    bullets: ['Rezervace přímo z appky Qerko', 'Webový rezervační formulář', 'Přehled obsazenosti na jednom místě'],
  },
  {
    id: 'vernost', bg: 'alt', icon: 'lucide:heart-handshake', eyebrow: 'Věrnostní program',
    title: 'Aby se k vám hosté vraceli',
    text: 'Pomocí chytrých nástrojů přivedeme vaše hosty zpět a přimějeme je chodit častěji. Po platbě jim pošlete poděkování, voucher nebo pozvánku na nové menu — bez práce navíc.',
    bullets: ['Personalizované zprávy po platbě', 'Vouchery a chytré nabídky', 'Hosté jako followeři podniku'],
  },
  {
    id: 'hodnoceni', bg: 'default', icon: 'lucide:star', eyebrow: 'Hodnocení a reputace',
    title: 'Staňte se podnikem číslo jedna',
    text: 'Bylo vše v pořádku? Ve šrumci špičky někdy nezbyde čas se zeptat. Qerko se zákazníka zeptá hned po platbě — a vy na hodnocení reagujete poděkováním nebo omluvou. Spokojené hosty pak vybídneme k recenzi na Google Maps a follow na Instagramu.',
    bullets: ['Soukromá zpětná vazba hned po platbě', 'Automatické Google recenze', 'Více sledujících na Instagramu'],
  },
  {
    id: 'qpoint', bg: 'alt', icon: 'lucide:tablet-smartphone', eyebrow: 'Qpoint',
    title: 'Rozvoz i e-shop v jednom tabletu',
    text: 'Qpoint agreguje objednávky z rozvozu a vlastního online shopu přehledně na jednom tabletu. Žádné přepínání mezi platformami — vše na jednom místě.',
    bullets: ['Objednávky z rozvozu i e-shopu', 'Vše přehledně na jednom tabletu', 'Vlastní online shop podniku'],
  },
];

const awards = [
  { title: 'Vítěz Startup Awards', note: 'Cena veřejnosti' },
  { title: '2× Křišťálová Lupa', note: 'E-commerce inspirace' },
  { title: 'Licence ČNB', note: 'Evropská platební instituce' },
  { title: 'Banka roku — 2. místo', note: 'Kategorie Fintech' },
  { title: 'Top 10 App Store', note: 'Jídlo a pití' },
  { title: '1,5 mil.+ uživatelů', note: 've 3 evropských zemích' },
];

const testimonials = [
  { initials: 'TH', headline: 'Super funkční Qerko', quote: 'Byl jsem několikrát a pokaždé skvělá návštěva. Super funkční Qerko — to se mi tam líbilo nejvíc.', author: 'Tomáš Hofmann', role: '199 recenzí · Google Maps' },
  { initials: 'NL', headline: 'Platba přes Qerko je plus', quote: 'Moc milá obsluha, skvělé jídlo, fajn polední nabídky. Další plus je platba přes Qerko.', author: 'Nikola Lešková', role: '19 recenzí · Google Maps' },
  { initials: 'JK', headline: 'Bonusové body za podporu', quote: 'Dobré pivo, dobré jídlo, bonusové body za podporu Qerka a velmi milí číšníci.', author: 'Jiří Kučera', role: '110 recenzí · Google Maps' },
];

const faqs = [
  { q: 'Kolik Qerko stojí?', a: 'Žádný měsíční paušál. Platíte jen transakční poplatek 2,90 Kč + 1,35 % z částky a jednorázový starter pack podle počtu stolů (od 2 890 Kč). Platby, objednávání, věrnostní program i rezervace jsou v ceně.' },
  { q: 'Musíme měnit pokladnu?', a: 'Ne. Qerko je napojené na 30+ POS systémů včetně Septimu. Menu i platby se propisují do vaší stávající pokladny.' },
  { q: 'Co když host nechce platit přes telefon?', a: 'Qerko nic nenahrazuje násilím — funguje vedle běžné obsluhy. Host zaplatí přes Qerko, jen když chce. Obsluha má díky tomu víc času na ostatní stoly.' },
  { q: 'Jaké platební metody hosté využijí?', a: 'Visa, Mastercard, Apple Pay, uložené karty, stravenky (Edenred, Sodexo, Benefit Plus, Naše Stravenka, UP) i Bitcoin.' },
  { q: 'Jak dlouho trvá instalace?', a: 'Profesionální instalace zabere do 3 hodin (4 900 Kč), nebo si Qerko nasadíte sami zdarma. Stačí vytisknout QR kódy na stoly a napojit pokladnu.' },
];

const leadProofs = [
  { icon: 'lucide:repeat', title: '+20 % otočených stolů', text: 'Hosté platí sami, obsluha stíhá víc.' },
  { icon: 'lucide:hand-coins', title: '+40 % vyšší dýška', text: 'Spropitné jedním klikem v telefonu.' },
  { icon: 'lucide:store', title: '1,5 mil.+ hostů', text: 'Qerko zná hosté po celé ČR.' },
  { icon: 'lucide:badge-check', title: 'Bez měsíčního paušálu', text: 'Platíte jen za reálné platby.' },
];
---

<Base title="Vyšší tržby, vyšší dýška a lepší recenze pro váš podnik | Qerko"
      description="Qerko je pomocník na place, se kterým otočíte více stolů, získáte vyšší dýška a lepší hodnocení na Google i Instagramu.">
  <SiteHeader />

  <main>

  <!-- HERO -->
  <Hero eyebrow="Pomocník na place" background="gradient"
        lead="Qerko pomáhá číšníkům připravit pro hosty bezchybný zážitek. Hosté platí a objednávají z mobilu, dávají vyšší dýško a lepší recenze. Obsluha má čas na to podstatné."
        usp={['+20 % otočených stolů', '+40 % vyšší dýško', '4 min ušetřené na stůl', '1,5 mil.+ hostů']}>
    <Heading slot="title" as="h1" size="display" color="on-dark">Skvělé podniky ví, jak vytěžit ze špiček maximum</Heading>
    <Fragment slot="actions">
      <Button href="#poptavka">Chci Qerko</Button>
      <Button href="#jak-to-funguje" variant="secondary" onDark>Jak to funguje</Button>
    </Fragment>
    <figure slot="media" class="hero-figure" aria-label="Qerko — platba a objednávka z mobilu přímo od stolu">
      <svg class="hero-phone" viewBox="0 0 460 540" xmlns="http://www.w3.org/2000/svg" role="img">
        <defs>
          <filter id="qp-shadow" x="-30%" y="-30%" width="160%" height="160%">
            <feDropShadow dx="0" dy="14" stdDeviation="20" flood-color="#06352A" flood-opacity="0.28"/>
          </filter>
          <filter id="qp-shadow-sm" x="-40%" y="-40%" width="180%" height="180%">
            <feDropShadow dx="0" dy="6" stdDeviation="9" flood-color="#06352A" flood-opacity="0.22"/>
          </filter>
        </defs>

        <!-- Telefon -->
        <g filter="url(#qp-shadow)">
          <rect x="124" y="22" width="212" height="496" rx="34" fill="#FFFFFF"/>
          <rect x="136" y="36" width="188" height="468" rx="24" fill="#F5F9F7"/>
          <rect x="202" y="48" width="56" height="10" rx="5" fill="#DCE7E1"/>
        </g>

        <!-- Hlavička účtu -->
        <text x="154" y="92" font-size="17" font-weight="700" fill="#1A241F">Stůl 12</text>
        <text x="154" y="110" font-size="10" font-weight="500" fill="#5E6E66">Restaurace Masaryčka</text>
        <!-- QR značka -->
        <g transform="translate(276,74)" fill="#06352A">
          <rect x="0" y="0" width="11" height="11" rx="2"/><rect x="15" y="0" width="11" height="11" rx="2"/>
          <rect x="0" y="15" width="11" height="11" rx="2"/><rect x="15" y="15" width="6" height="6" rx="1"/>
          <rect x="24" y="19" width="6" height="6" rx="1"/><rect x="24" y="0" width="6" height="6" rx="1"/>
        </g>

        <!-- Položky účtu -->
        <g font-size="12" font-weight="600" fill="#1A241F">
          <text x="154" y="148">2× Pivo</text>           <text x="318" y="148" text-anchor="end" fill="#5E6E66">120 Kč</text>
          <text x="154" y="176">1× Svíčková</text>      <text x="318" y="176" text-anchor="end" fill="#5E6E66">245 Kč</text>
          <text x="154" y="204">1× Káva</text>           <text x="318" y="204" text-anchor="end" fill="#5E6E66">65 Kč</text>
        </g>
        <line x1="154" y1="222" x2="318" y2="222" stroke="#DCE7E1" stroke-width="1.5"/>

        <!-- Rozdělit účet -->
        <text x="154" y="250" font-size="11" font-weight="600" fill="#1A241F">Rozdělit účet</text>
        <g transform="translate(286,240)">
          <rect x="0" y="0" width="32" height="18" rx="9" fill="#008556"/>
          <circle cx="23" cy="9" r="6.5" fill="#FFFFFF"/>
        </g>

        <!-- Spropitné -->
        <text x="154" y="286" font-size="10" font-weight="600" fill="#5E6E66">Spropitné</text>
        <g transform="translate(154,294)">
          <rect x="0" y="0" width="48" height="26" rx="13" fill="none" stroke="#C2D2C9" stroke-width="1.5"/>
          <text x="24" y="17" font-size="11" font-weight="600" fill="#1A241F" text-anchor="middle">10 %</text>
          <rect x="58" y="0" width="48" height="26" rx="13" fill="#008556"/>
          <text x="82" y="17" font-size="11" font-weight="700" fill="#FFFFFF" text-anchor="middle">15 %</text>
          <rect x="116" y="0" width="48" height="26" rx="13" fill="none" stroke="#C2D2C9" stroke-width="1.5"/>
          <text x="140" y="17" font-size="11" font-weight="600" fill="#1A241F" text-anchor="middle">20 %</text>
        </g>

        <!-- Celkem -->
        <text x="154" y="362" font-size="11" font-weight="500" fill="#5E6E66">Celkem se spropitným</text>
        <text x="318" y="364" text-anchor="end" font-size="18" font-weight="700" fill="#008556">494 Kč</text>

        <!-- Tlačítko Zaplatit -->
        <g transform="translate(154,380)">
          <rect x="0" y="0" width="164" height="42" rx="21" fill="#008556"/>
          <text x="82" y="27" font-size="14" font-weight="700" fill="#FFFFFF" text-anchor="middle">Zaplatit</text>
        </g>
        <text x="236" y="448" font-size="9" font-weight="500" fill="#97A89F" text-anchor="middle">Apple Pay · karta · stravenky</text>

        <!-- Plovoucí odznak: hodnocení -->
        <g filter="url(#qp-shadow-sm)" transform="translate(24,150)">
          <rect x="0" y="0" width="132" height="46" rx="23" fill="#FFFFFF"/>
          <g transform="translate(16,15)" fill="#00B579">
            <path d="M8 0l2.2 4.6 5 .7-3.6 3.5.9 5L8 11.4 3.5 13.8l.9-5L.8 5.3l5-.7z"/>
            <g transform="translate(17,0)"><path d="M8 0l2.2 4.6 5 .7-3.6 3.5.9 5L8 11.4 3.5 13.8l.9-5L.8 5.3l5-.7z"/></g>
            <g transform="translate(34,0)"><path d="M8 0l2.2 4.6 5 .7-3.6 3.5.9 5L8 11.4 3.5 13.8l.9-5L.8 5.3l5-.7z"/></g>
          </g>
          <text x="74" y="30" font-size="11" font-weight="700" fill="#1A241F">Google 4,9</text>
        </g>

        <!-- Plovoucí odznak: dýško -->
        <g filter="url(#qp-shadow-sm)" transform="translate(300,400)">
          <rect x="0" y="0" width="138" height="46" rx="23" fill="#00B579"/>
          <text x="22" y="29" font-size="15" font-weight="700" fill="#FFFFFF">＋40 %</text>
          <text x="84" y="29" font-size="12" font-weight="600" fill="#FFFFFF">dýško</text>
        </g>
      </svg>
    </figure>
  </Hero>

  <!-- LOGA KLIENTŮ -->
  <LogoWall background="default" ext="png" label="Platí u nás hosté ve špičkových podnicích"
    logos={['ambiente', 'kolkovna', 'masarycka', 'potrefena-husa', 'pivovar-narodni', 'bruxx', 'spojka-karlin', 'vnitroblock', 'pizza-coloseum-nova-karolina', 'restaurace-vinohradsky-parlament', 'grain-bistro', 'manga-cowboy', 'restaurace-hybernska', 'rebelbean-pole', 'pivovar-revnice']} />

  <!-- JAK TO FUNGUJE -->
  <Section id="jak-to-funguje" background="default" space="lg">
    <div class="head head--center">
      <Text size="label" color="accent" align="center">Jak to funguje</Text>
      <Heading as="h2" size="h2" align="center">Od QR kódu po <em>recenzi</em> — bez práce navíc</Heading>
      <Text size="lead" color="muted" align="center" balance>
        Kde zrovna není číšník, tam pomůže Qerko. Šest kroků, které otočí víc stolů a zvednou dýška.
      </Text>
    </div>
    <ol class="steps">
      {steps.map((s, i) => (
        <li class="step">
          <span class="step__num">{i + 1}</span>
          <span class="step__icon"><Icon name={s.icon} size="lg" /></span>
          <Heading as="h3" size="h3">{s.title}</Heading>
          <Text size="small" color="muted">{s.text}</Text>
        </li>
      ))}
    </ol>
  </Section>

  <!-- FUNKCE -->
  <div id="funkce">
    <USPGrid eyebrow="Co Qerko umí" title="Všechny nástroje pro pohostinství pod jednou střechou"
             lead="Platba, objednávání, věrnost i reputace — v jednom řešení napojeném na vaši pokladnu."
             items={features} minItemWidth="280px" background="alt" space="lg" />
  </div>

  <!-- DETAILNÍ BLOKY PRODUKTU -->
  {blocks.map((b, i) => (
    <Section id={b.id} background={b.bg} space="lg">
      <div class:list={['feature', i % 2 === 1 && 'feature--rev']}>
        <div class="feature__media" aria-hidden="true">
          <span class="feature__icon"><Icon name={b.icon} size="xl" /></span>
        </div>
        <div class="feature__body">
          <Text size="label" color="accent">{b.eyebrow}</Text>
          <Heading as="h2" size="h2">{b.title}</Heading>
          <Text size="lead" color="muted">{b.text}</Text>
          <ul class="ticks">
            {b.bullets.map((t) => (
              <li><Icon name="lucide:check" size="sm" class="ticks__ico" />{t}</li>
            ))}
          </ul>
        </div>
      </div>
    </Section>
  ))}

  <!-- OCENĚNÍ -->
  <Section background="invert" space="lg">
    <div class="head head--center">
      <Text size="label" color="accent" align="center">Nechceme se chlubit, ale…</Text>
      <Heading as="h2" size="h2" align="center" color="on-dark">Qerku <em>věří</em> hosté i porotci</Heading>
    </div>
    <ul class="awards">
      {awards.map((a) => (
        <li class="award">
          <span class="award__title">{a.title}</span>
          <span class="award__note">{a.note}</span>
        </li>
      ))}
    </ul>
  </Section>

  <!-- REFERENCE -->
  <Section id="komunita" background="default" space="lg">
    <div class="head head--center">
      <Text size="label" color="accent" align="center">Říkají hosté</Text>
      <Heading as="h2" size="h2" align="center">Nejlépe hodnocené podniky <em>mají Qerko</em></Heading>
      <Text size="lead" color="muted" align="center" balance>
        Qerko obsloužilo přes 1 500 000 hostů. Tady je, co o podnicích s Qerkem píšou.
      </Text>
    </div>
    <div class="quotes">
      {testimonials.map((t, i) => (
        <figure class={`quote quote--${i}`}>
          <div class="quote__head">
            <div class="quote__id">
              <strong class="quote__name">{t.author}</strong>
              <span class="quote__role">{t.role}</span>
            </div>
            <span class="quote__avatar" aria-hidden="true">{t.initials}</span>
          </div>
          <span class="quote__mark"><Icon name="lucide:quote" size="md" /></span>
          <p class="quote__headline">{t.headline}</p>
          <blockquote class="quote__text">{t.quote}</blockquote>
        </figure>
      ))}
    </div>
  </Section>

  <!-- CTA -->
  <Section background="primary" space="lg">
    <div class="head head--center">
      <Text size="label" color="on-dark-muted" align="center">Máte skvělý podnik?</Text>
      <Heading as="h2" size="h2" align="center" color="on-dark">Víme, jak ho udělat ještě lepší</Heading>
      <Text size="lead" color="on-dark-muted" align="center" balance>
        Pojďme se na to spolu v rychlosti mrknout. Nezávazně a bez měsíčního paušálu.
      </Text>
      <div class="cta-actions">
        <Button href="#poptavka">Chci vyzkoušet Qerko</Button>
        <Button href="tel:+420277277945" variant="secondary" onDark>+420 277 277 945</Button>
      </div>
    </div>
  </Section>

  <!-- FAQ -->
  <Section background="alt" space="lg">
    <div class="head head--center">
      <Heading as="h2" size="h2" align="center">Často kladené dotazy</Heading>
      <Text size="lead" color="muted" align="center">Nenašli jste odpověď? Ozvěte se nám, rádi poradíme.</Text>
    </div>
    <div class="faq">
      {faqs.map((f) => (
        <details class="faq__item">
