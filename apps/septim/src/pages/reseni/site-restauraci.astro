---
import SegmentPage from '../../components/SegmentPage.astro';
const benefits = [
  { icon: 'lucide:network', title: 'Řízení z jednoho místa', text: 'Sdílené receptury, sklady i finanční řízení napříč všemi pobočkami.' },
  { icon: 'lucide:database', title: 'Jednotná data', text: 'Databanka receptur a centrální CRM — stejná nabídka i věrnostní program všude.' },
  { icon: 'lucide:trending-up', title: 'Roste s vámi', text: 'Přidání další provozovny bez bolestivé výměny systému. Ověřeno největšími řetězci v ČR.' },
  { icon: 'lucide:bar-chart-3', title: 'Srovnatelné reporty', text: 'Výsledky poboček vedle sebe — kde se daří a kde ne, hned vidíte.' },
];
const modules = [
  { title: 'Manažer', href: '/funkce/manazer' },
  { title: 'Reporty a přehledy', href: '/funkce/reporty-prehledy' },
  { title: 'Skladové hospodářství', href: '/funkce/skladove-hospodarstvi' },
  { title: 'Věrnostní systém', href: '/funkce/vernostni-system' },
  { title: 'Pokladna', href: '/funkce/pokladna' },
];
const faqs = [
  { q: 'Jak Septim zvládá více provozoven?', a: 'Můžete sdílet receptury i sklady a řídit finance všech restaurací dohromady, nebo je vést zvlášť a finance vidět celkově. Pod tím jsou desítky let vývoje — většina systémů selhává právě při růstu.' },
  { q: 'Udržíme jednotnou nabídku napříč pobočkami?', a: 'Ano. Databanka receptur a centrální správa drží jednotnost evidence i nabídky a garantují srovnatelnost reportů napříč celou sítí.' },
  { q: 'Pro koho je řešení vhodné?', a: 'Pro sítě restaurací, sportovní haly i zábavní areály — všude, kde je potřeba propojit více provozních oblastí a řídit je centrálně.' },
];
---
<SegmentPage
  title="Pokladní a provozní systém pro síť restaurací | Septim"
  description="Septim řídí celou síť restaurací z jednoho místa: sdílené receptury a sklady, centrální CRM a srovnatelné finanční reporty napříč pobočkami. Ověřeno největšími řetězci v ČR."
  eyebrow="Řešení pro sítě restaurací"
  titleHtml="Provozní systém pro <em>síť restaurací</em>"
  lead="Řízení sítě vyžaduje specifický přístup. Septim propojí všechny pobočky — sdílíte receptury, sklady i finanční řízení a máte srovnatelné výsledky napříč celým řetězcem."
  logoLabel="Sítě restaurací, které používají Septim"
  benefitsTitle="Proč Septim pro síť restaurací"
  benefits={benefits}
  edition={{ name: 'Septim.4', href: '/produkty/septim-4', text: 'Plná edice pro restaurace a sítě — pokladna, sklady, manažer i centrální řízení poboček.' }}
  modules={modules}
  faqs={faqs}
  heroImage="/images/reseni-site-restauraci.jpg"
  heroImageAlt="Síť restaurací využívající Septim"
/>
