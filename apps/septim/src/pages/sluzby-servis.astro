---
/** Septim — Služby a servis. Obsah: septim-obsah/sluzby-servis.md. SEO meta nově. */
import Base from '../layouts/Base.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import Section from '@piano/ui/components/Section.astro';
import Hero from '@piano/ui/components/Hero.astro';
import Heading from '@piano/ui/components/Heading.astro';
import Text from '@piano/ui/components/Text.astro';
import Button from '@piano/ui/components/Button.astro';
import Icon from '@piano/ui/components/Icon.astro';
import USPGrid from '@piano/ui/components/USPGrid.astro';
import LeadForm from '@piano/ui/components/LeadForm.astro';

const services = [
  { icon: 'lucide:headset', title: 'Helpdesk a Hotline', text: 'Pomoc v pracovní době i NON-STOP hotline mimo ni — na dálku i výjezdem technika.', href: '/sluzby-servis/helpdesk-hotline' },
  { icon: 'lucide:graduation-cap', title: 'Konzultace a školení', text: 'Konzultanti s praxí z gastra nastaví systém na míru a zaškolí personál.', href: '/sluzby-servis/konzultace-skoleni' },
  { icon: 'lucide:wrench', title: 'Instalace systému', text: 'Příprava na testovacím serveru a spuštění do ostrého provozu v domluvený termín.', href: '/sluzby-servis/instalace-systemu-septim' },
  { icon: 'lucide:activity', title: 'Monitoring HW & SW', text: 'Hlídáme správný chod hardwaru i softwaru vašeho provozu.', href: '/sluzby-servis/monitoring-hardware-software' },
  { icon: 'lucide:shield-check', title: 'Záruční a pozáruční servis', text: 'Dostupné náhradní díly a rychlý servisní zásah.', href: '/sluzby-servis/zarucni-pozarucni-servis' },
  { icon: 'lucide:file-text', title: 'Servisní smlouva', text: 'Jasné podmínky podpory a zvýhodněné sazby — varianty Standard a Plus.', href: '/sluzby-servis/podminky-servisni-smlouvy' },
  { icon: 'lucide:cable', title: 'Slaboproudé instalace', text: 'Kompletní kabeláž a infrastruktura pro váš provoz.', href: '/sluzby-servis/slaboproude-instalace' },
  { icon: 'lucide:code', title: 'Vývoj na míru', text: 'Úpravy a integrace podle specifických potřeb vašeho provozu.', href: '/sluzby-servis/vyvoj-na-miru' },
];
---
<Base title="Služby a servis Septim – podpora 24/7 pro váš provoz"
      description="Komplexní servis a služby pro systém Septim: helpdesk a hotline 24/7, konzultace a školení, instalace, monitoring, záruční servis i vývoj na míru. Důvěřují nám 30 let.">
  <SiteHeader />
  <main>
    <Hero eyebrow="Služby a servis" background="alt"
          lead="Pro systém Septim poskytujeme komplexní servis a služby. Pro zákazníky je klíčová kvalita a rychlost servisu pro chod provozu — proto nám důvěřují už 30 let.">
      <Heading slot="title" as="h1" size="display">Podpora <em>produktů Septim</em></Heading>
    </Hero>

    <Section background="primary" space="md">
      <div class="support">
        <div class="support__item">
          <span class="support__label">Helpdesk</span>
          <a class="support__phone" href="tel:+420257011101">+420 257 011 101</a>
          <span class="support__hours">Po–Pá 8:30–17:00</span>
        </div>
        <div class="support__divider" aria-hidden="true"></div>
        <div class="support__item">
          <span class="support__label">Hotline 24/7</span>
          <a class="support__phone" href="tel:+420777737846">+420 777 737 846</a>
          <span class="support__hours">Mimo pracovní dobu</span>
        </div>
        <div class="support__divider" aria-hidden="true"></div>
        <div class="support__item">
          <span class="support__label">E-mail</span>
          <a class="support__phone support__phone--sm" href="mailto:servis@septim.cz">servis@septim.cz</a>
          <span class="support__hours">Odpovídáme co nejdříve</span>
        </div>
      </div>
    </Section>

    <USPGrid eyebrow="Co nabízíme" title="Služby pro váš klid" items={services} background="default" space="lg" minItemWidth="260px" />

    <Section background="alt" space="md">
      <div class="faq-cta">
        <Heading as="h2" size="h3">Hledáte rychlou odpověď?</Heading>
        <Text color="muted">Projděte si technické rady a nejčastější otázky k systému Septim — pro personál na place i pro management.</Text>
        <Button href="/technicke-rady-faq" variant="secondary">Technické rady a FAQ</Button>
      </div>
    </Section>

    <LeadForm id="poptavka" variant="callback" background="default"
              title="Potřebujete pomoc nebo konzultaci?"
              lead="Nechte nám telefon — ozve se vám naše podpora." />
  </main>
  <SiteFooter />
</Base>

<style>
  .support { display: flex; align-items: center; justify-content: center; gap: var(--space-6); flex-wrap: wrap; }
  .support__item { display: flex; flex-direction: column; align-items: center; gap: 2px; text-align: center; }
  .support__label { font-size: var(--font-size-label); text-transform: uppercase; letter-spacing: var(--letter-spacing-wide); color: var(--color-text-on-dark-muted); }
  .support__phone { font-size: var(--font-size-h3); font-weight: var(--font-weight-bold); color: var(--color-text-on-dark); text-decoration: none; }
  .support__phone--sm { font-size: var(--font-size-lead); }
  .support__hours { font-size: var(--font-size-small); color: var(--color-text-on-dark-muted); }
  .support__divider { width: 1px; height: 48px; background: var(--color-border-on-dark); }
  @media (max-width: 640px) { .support__divider { display: none; } }
  .faq-cta { max-width: 760px; }
  .faq-cta > * + * { margin-top: var(--space-3); }
</style>
