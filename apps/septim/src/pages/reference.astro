---
/** Septim — Reference / Naši zákazníci. Obsah: septim-obsah/nasi-zakaznici.md. SEO meta nově. */
import Base from '../layouts/Base.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import Section from '@piano/ui/components/Section.astro';
import Hero from '@piano/ui/components/Hero.astro';
import Heading from '@piano/ui/components/Heading.astro';
import Text from '@piano/ui/components/Text.astro';
import Button from '@piano/ui/components/Button.astro';
import LeadForm from '@piano/ui/components/LeadForm.astro';
import StatsBand from '../components/StatsBand.astro';
import LogoWall from '../components/LogoWall.astro';
import Testimonials from '../components/Testimonials.astro';
---
<Base title="Reference – koho řídí Septim | michelinské restaurace i sítě"
      description="Septim používají Ambiente, FIELD, Entrée, Kolkovna, SaSaZu, Zátiší Group i Pizza Coloseum. Michelinské restaurace, přední sítě a známí šéfkuchaři. Jednička na trhu už 30 let.">
  <SiteHeader />
  <main>
    <Hero eyebrow="Reference" background="gradient"
          lead="Komplexní provozní systém Septim je nejrespektovanější software pro restaurace v ČR. Michelinské restaurace, přední sítě i známí šéfkuchaři — většina používá právě Septim.">
      <Heading slot="title" as="h1" size="display" color="on-dark">Důvěřují nám <em>ti nejlepší</em></Heading>
      <Fragment slot="actions">
        <Button href="#poptavka">Chci Septim</Button>
      </Fragment>
    </Hero>

    <LogoWall label="Více než 1 500 spokojených provozů po celé ČR" background="default" />
    <StatsBand />
    <Testimonials background="alt" lead="Od michelinských restaurací po kavárny za rohem — Septim řídí provoz těch nejnáročnějších." />

    <Section background="default" space="lg">
      <div class="cta">
        <Text size="label" color="accent">Případová studie</Text>
        <Heading as="h2" size="h2">Kolkovna &amp; Septim — 23 let spolu</Heading>
        <Text color="muted" class="cta__text">
          2 bistra, 10 restaurací a 1 jídelna pod jednou skupinou — celé řízené Septimem. Podívejte se,
          jak vypadá spolupráce, která trvá přes dvě dekády.
        </Text>
        <Button href="/kolkovna/10x-restaurant" variant="secondary">Přečíst případovou studii</Button>
      </div>
    </Section>

    <LeadForm id="poptavka" variant="full" background="alt"
              title="Přidejte se k nejlepším"
              lead="Nechte nám kontakt — ukážeme vám Septim přímo na vašem typu provozu." />
  </main>
  <SiteFooter />
</Base>

<style>
  .cta { max-width: 760px; margin-inline: auto; text-align: center; }
  .cta > * + * { margin-top: var(--space-3); }
  .cta__text { max-width: 620px; margin-inline: auto; }
</style>
