---
import IntegracePage from '../../components/IntegracePage.astro';
const benefits = [
  { icon: 'lucide:bell', title: 'Objednávky rovnou v Septimu', text: 'Nové objednávky z Foodora i Wolt se okamžitě zobrazí v pokladním systému.' },
  { icon: 'lucide:receipt', title: 'Automatické účtenky a sklad', text: 'Účtenky se vytvoří samy a skladové zásoby se aktualizují bez ručního přepisování.' },
  { icon: 'lucide:layout-dashboard', title: 'Vše z jednoho místa', text: 'Rozvozové i běžné objednávky v jednom přehledném rozhraní.' },
  { icon: 'lucide:bike', title: 'Ověřené služby', text: 'Přímé napojení na populární rozvážkové služby Foodora a Wolt.' },
];
const faqs = [
  { q: 'Jak se objednávky z rozvozu dostanou do Septimu?', a: 'Nová objednávka z Foodora nebo Wolt se okamžitě objeví v Septimu, automaticky se vytvoří účtenka a aktualizují skladové zásoby — vše bez ručního zásahu.' },
  { q: 'Vidím rozvoz i běžné objednávky pohromadě?', a: 'Ano. Septim propojí objednávky do jednoho přehledného rozhraní, takže máte celý provoz pod kontrolou z jednoho místa.' },
];
---
<IntegracePage
  title="Integrace Foodora a Wolt do systému Septim"
  description="Přímá integrace rozvozových služeb Foodora a Wolt s pokladním systémem Septim: objednávky rovnou v systému, automatické účtenky a aktualizace skladu. Přehled z jednoho místa."
  eyebrow="Integrace a zařízení"
  titleHtml="Foodora a <em>Wolt</em>"
  lead="Rozšiřte své gastro podnikání přímou integrací rozvozových služeb Foodora a Wolt se systémem Septim — přehled a kontrola z jednoho místa."
  intro={["Připojte provoz k populárním rozvážkovým službám a získejte přehled přímo ze Septimu. Nové objednávky se okamžitě zobrazí v systému, vytvoří se účtenky a aktualizují sklady.", "Žádné ruční přepisování mezi aplikacemi — vše běží automaticky a v jednom rozhraní."]}
  introHeading="Přímá integrace Foodora a Wolt"
  benefitsTitle="Co propojení přináší"
  benefits={benefits}
  faqs={faqs}
  heroImage="/images/integrace-foodora-wolt.jpg"
  heroImageAlt="Rozvoz Foodora a Wolt napojený na Septim"
/>
