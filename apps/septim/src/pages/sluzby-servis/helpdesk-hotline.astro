---
/** Septim — Služby: Helpdesk a Hotline. Obsah: septim-obsah/sluzby-servis/helpdesk-hotline.md. SEO meta nově. */
import Base from '../../layouts/Base.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import Section from '@piano/ui/components/Section.astro';
import Hero from '@piano/ui/components/Hero.astro';
import Heading from '@piano/ui/components/Heading.astro';
import Text from '@piano/ui/components/Text.astro';
import Button from '@piano/ui/components/Button.astro';
import USPGrid from '@piano/ui/components/USPGrid.astro';
import LeadForm from '@piano/ui/components/LeadForm.astro';
import StatsBand from '../../components/StatsBand.astro';
import LogoWall from '../../components/LogoWall.astro';
import Faq from '@piano/ui/components/Faq.astro';

const jistoty = [
  { icon: 'lucide:headset', title: 'Podpora 24/7', text: 'Vzdálená i osobní pomoc — v pracovní době i mimo ni.' },
  { icon: 'lucide:package-check', title: 'Náhradní díly', text: 'Dostupné náhradní díly a technická podpora pro hardware.' },
  { icon: 'lucide:lightbulb', title: 'Poradenství', text: 'Rady k používání softwaru Septim a jeho nastavení.' },
];
const pokryti = [
  { icon: 'lucide:badge-check', title: 'Proškolení technici', text: 'Několik desítek techniků zajišťuje bezproblémový chod systému Septim.' },
  { icon: 'lucide:map-pin', title: 'Praha, Olomouc, Tábor', text: 'Technici na třech místech republiky pro rychlejší dostupnost.' },
  { icon: 'lucide:monitor-smartphone', title: 'Na dálku i na místě', text: 'Většinu problémů vyřešíme po telefonu nebo vzdáleným připojením.' },
];
const faqs = [
  { q: 'Kde najdu svůj servisní kód?', a: 'Servisní kód byste měli mít nalepený na pokladně a na manažerském počítači. Hledejte nálepku „Septim“.' },
  { q: 'Pro koho je Helpdesk a Hotline určen?', a: 'Helpdesk a Hotline systému Septim je určen pro zákazníky Septimu s aktuálně platnou servisní smlouvou.' },
  { q: 'Zaplatil jsem faktury — je můj servisní kód platný?', a: 'V případě zaplacení zaslaných faktur je servisní kód platný. Pro ověření můžete zavolat na naše obchodní oddělení na tel. +420 257 011 100.' },
  { q: 'Nemohu najít servisní číslo nebo potřebuji urychlit aktivaci. Co mám dělat?', a: 'Kontaktujte naše obchodní oddělení ihned po zaplacení obdržených faktur pro urychlení aktivace servisních služeb. Stejně postupujte, pokud nemůžete najít vaše servisní číslo. Volejte +420 257 011 100.' },
  { q: 'V jakých termínech se podpora věnuje mým požadavkům?', a: 'Naše oddělení podpory se telefonickým i mailovým požadavkům věnuje v termínech dle vaší servisní smlouvy. Podrobný popis naleznete ve své servisní smlouvě a obecný popis na stránce Podmínky servisní smlouvy.' },
  { q: 'Řešíte problémy na dálku, nebo na místě?', a: 'Pokud je to možné, řešíme požadavky na dálku — je to rychlejší a levnější. V případě, že je potřeba fyzická přítomnost pro zajištění provozu systému, vyjíždí náš technik k vám.' },
];
---
<Base title="Helpdesk a Hotline Septim – NON-STOP pomoc pro váš provoz"
      description="Helpdesk a Hotline systému Septim: pomoc a poradenství v pracovní době, mimo ni NON-STOP hotline pro software i hardware. Technici v Praze, Olomouci a Táboře.">
  <SiteHeader />
  <main>
    <Hero eyebrow="Služby a servis" background="alt"
          lead="Septim má propracovaný systém pomoci pro své zákazníky. Zajišťujeme pomoc a poradenství v pracovní době — a mimo ni garantujeme NON-STOP pomoc s provozním softwarem i hardwarem.">
      <Heading slot="title" as="h1" size="display">Helpdesk a <em>Hotline</em></Heading>
      <Fragment slot="actions">
        <Button href="tel:+420257011101">Volat Helpdesk</Button>
        <Button href="/sluzby-servis" variant="secondary">Všechny služby</Button>
      </Fragment>
    </Hero>

    <Section background="primary" space="md">
      <div class="support">
        <div class="support__item">
          <span class="support__label">Helpdesk · Po–Pá 8:30–17:00</span>
          <a class="support__phone" href="tel:+420257011101">+420 257 011 101</a>
          <span class="support__hours">Rady s používáním, řešení aktuální situace i nastavení Septimu</span>
        </div>
        <div class="support__divider" aria-hidden="true"></div>
        <div class="support__item">
          <span class="support__label">Hotline · mimo pracovní dobu</span>
          <a class="support__phone" href="tel:+420777737846">+420 777 737 846</a>
          <span class="support__hours">Akutní problémy se systémem Septim a souvisejícím hardwarem</span>
        </div>
        <div class="support__divider" aria-hidden="true"></div>
        <div class="support__item">
          <span class="support__label">E-mail</span>
          <a class="support__phone support__phone--sm" href="mailto:servis@septim.cz">servis@septim.cz</a>
          <span class="support__hours">Písemné technické dotazy k systému Septim</span>
        </div>
      </div>
    </Section>

    <USPGrid eyebrow="Servis a podpora" title="Jistota správného fungování vašeho provozu" items={jistoty} background="default" space="lg" minItemWidth="240px" />
    <USPGrid eyebrow="Pokrytí" title="Podpora servisu po celé republice" items={pokryti} background="alt" space="lg" minItemWidth="240px" />
    <LogoWall label="Respektované provozy, které se opírají o podporu našeho servisu" background="default" />
    <StatsBand />
    <Faq items={faqs} title="Často kladené otázky k Helpdesku a Hotline" background="default" />
    <LeadForm id="poptavka" variant="callback" background="alt"
              title="Potřebujete zajistit služby Septimu?"
              lead="Nechte nám telefon — spojí se s vámi naše obchodní oddělení." />
  </main>
  <SiteFooter />
</Base>

<style>
  .support { display: flex; align-items: stretch; justify-content: center; gap: var(--space-6); flex-wrap: wrap; }
  .support__item { display: flex; flex-direction: column; align-items: center; gap: 2px; text-align: center; max-width: 300px; }
  .support__label { font-size: var(--font-size-label); text-transform: uppercase; letter-spacing: var(--letter-spacing-wide); color: var(--color-text-on-dark-muted); }
  .support__phone { font-size: var(--font-size-h3); font-weight: var(--font-weight-bold); color: var(--color-text-on-dark); text-decoration: none; }
  .support__phone--sm { font-size: var(--font-size-lead); }
  .support__hours { font-size: var(--font-size-small); color: var(--color-text-on-dark-muted); }
  .support__divider { width: 1px; background: var(--color-border-on-dark); }
  @media (max-width: 640px) { .support__divider { display: none; } }
</style>
