---
/**
 * SiteHeader — Septim wrapper nad sdíleným @piano/ui Header.
 * Drží na jednom místě brand, logo a Septim navigaci (per-web data z config/nav).
 */
import Header from '@piano/ui/components/Header.astro';
import { septimNav, septimCta } from '../config/nav';

interface Props { transparent?: boolean; }
const { transparent = false } = Astro.props;
---
<Header brand="Septim" logoSrc="/logos/septim_logo.svg" logoHeight="26px" homeHref="/"
        nav={septimNav} cta={septimCta} transparent={transparent} />
