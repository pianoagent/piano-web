---
/**
 * Testimonials — tenký wrapper nad @piano/ui/Testimonials.
 * Jen dodává výchozí septimí reference; lze přepsat props `items`.
 * Gradienty avatarů definuje theme.css (--testimonial-grad-1/2/3).
 * Vzhled a markup řeší sdílená komponenta — NEFORKOVAT.
 */
import UiTestimonials from '@piano/ui/components/Testimonials.astro';

interface Item { initials: string; headline: string; quote: string; author: string; role: string; michelin?: boolean; photo?: string; }
interface Props { items?: Item[]; title?: string; lead?: string; eyebrow?: string; background?: 'default' | 'alt'; }

const defaults: Item[] = [
  { initials: 'TK', headline: 'Výborný systém!', quote: 'Pokladní systém Septim a služba WebCare nám pomáhá být blíž našim zákazníkům.', author: 'Tomáš Karpíšek', role: 'Šéf restaurací Ambiente' },
  { initials: 'RK', headline: 'Stabilita a efektivita', quote: 'Provozní systém Septim je zásadní součástí restaurace FIELD. Díky němu mám jistotu, že celý provoz běží stabilně a efektivně.', author: 'Radek Kašpárek', role: 'Šéfkuchař a zakladatel FIELD', michelin: true, photo: '/images/ref-radek-kasparek.webp' },
  { initials: 'VV', headline: 'Naprostý přehled', quote: 'Na Septimu mi nejvíce vyhovuje, že si mohu nadefinovat jakoukoli sestavu a okamžitě dostanu vyhodnocení. Mám pak naprostý přehled.', author: 'Václav Vojíř', role: "Majitel Bugsy's baru, Praha" },
];
const { items = defaults, title = 'Důvěřují nám ti nejlepší', lead, eyebrow = 'Reference', background = 'default' } = Astro.props;
---

<UiTestimonials items={items} title={title} lead={lead} eyebrow={eyebrow} background={background} />
