---
/**
 * EET 2027 - homepage (jednostranka).
 * Samostatny informacni web k navratu elektronicke evidence trzeb od roku 2027.
 * Vse ze SDILENYCH komponent @piano/ui; tema resi src/styles/theme.css.
 * Sekce bez vlastni komponenty jsou slozene z primitivu (Section/Heading/Text/Button).
 */
import Base from '../layouts/Base.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import Section from '@piano/ui/components/Section.astro';
import Hero from '@piano/ui/components/Hero.astro';
import Heading from '@piano/ui/components/Heading.astro';
import Text from '@piano/ui/components/Text.astro';
import Button from '@piano/ui/components/Button.astro';
import Icon from '@piano/ui/components/Icon.astro';
import USPGrid from '@piano/ui/components/USPGrid.astro';
import LeadForm from '@piano/ui/components/LeadForm.astro';

// Co se meni
const zmeny = [
  { icon: 'lucide:receipt', title: 'Účtenka jen na vyžádání', text: 'Konec povinného tisku. Účtenku vydáte, jen když ji zákazník chce, klidně i digitálně.' },
  { icon: 'lucide:credit-card', title: 'Eviduje se osobní platba', text: 'Hotovost, karta, QR kód i stravenky přijaté při osobním kontaktu se zákazníkem.' },
  { icon: 'lucide:cpu', title: 'Stačí softwarový update', text: 'Moderní pokladní systém zvládne nová pravidla aktualizací. Nové vybavení obvykle není potřeba.' },
  { icon: 'lucide:file-text', title: 'Minimum údajů', text: 'Stát po vás chce méně dat než u prvního EET. Evidence je jednodušší.' },
  { icon: 'lucide:hand-coins', title: 'Výhodnější spropitné', text: 'Dobrovolné spropitné do 7 % tržeb bude osvobozeno od daní i odvodů.' },
  { icon: 'lucide:percent', title: 'Nižší DPH na nealko', text: 'Daň u nealkoholických nápojů klesá z 21 % na 12 %.' },
];

// EET vs EET 2.0
const compare = [
  { icon: 'lucide:receipt', cat: 'Účtenka', old: 'Povinný tisk', neu: 'Jen na vyžádání' },
  { icon: 'lucide:credit-card', cat: 'Co se eviduje', old: 'Hotovost i karty', neu: 'Jen osobní platby' },
  { icon: 'lucide:cpu', cat: 'Hardware', old: 'Nové vybavení', neu: 'Pokladna stačí' },
  { icon: 'lucide:file-text', cat: 'Data', old: 'Rozsáhlý výkaz', neu: 'Minimum údajů' },
  { icon: 'lucide:search', cat: 'Kontroly', old: 'Plošné kontroly', neu: 'Cílená analytika' },
];

// Harmonogram (legislativni milniky)
const timeline = [
  { date: 'Únor 2026', title: 'Zahájení připomínkového řízení', state: 'done' },
  { date: 'Květen 2026', title: 'Návrh prošel prvním čtením', state: 'done' },
  { date: 'Červen 2026', title: 'Zveřejnění technické specifikace', state: 'current' },
  { date: 'Červenec 2026', title: 'Zpřístupnění testovacího prostředí', state: 'future' },
  { date: 'Prosinec 2026', title: 'Spuštění aplikace MOJE EET', state: 'future' },
  { date: '1. ledna 2027', title: 'Zahájení běžného provozu EET 2.0', state: 'future' },
];

// Koho se to tyka
const koho = [
  { icon: 'lucide:utensils-crossed', title: 'Restaurace', text: 'Od bister po velké podniky a sítě provozoven.' },
  { icon: 'lucide:coffee', title: 'Kavárny a bary', text: 'Kavárny, vinárny, koktejlové i pivní bary.' },
  { icon: 'lucide:bed-double', title: 'Hotely a penziony', text: 'Recepce, restaurace i room service na jednom účtu.' },
  { icon: 'lucide:truck', title: 'Stánky a street food', text: 'Mobilní prodej, food trucky a sezónní provozy.' },
];

// Jak se pripravit (kroky)
const kroky = [
  { icon: 'lucide:search-check', title: 'Ověřte připravenost pokladny', text: 'Zjistěte, zda váš stávající systém EET 2.0 zvládne, nebo zda potřebujete jiné řešení.' },
  { icon: 'lucide:list-checks', title: 'Zvolte systém připravený na EET', text: 'Vyberte pokladní systém, který nová pravidla splní spolehlivě a bez improvizace.' },
  { icon: 'lucide:settings', title: 'Instalace a nastavení do konce 2026', text: 'Nechte systém nainstalovat a nastavit s dostatečnou rezervou před spuštěním.' },
  { icon: 'lucide:graduation-cap', title: 'Zaškolte obsluhu', text: 'Projděte si nové rozhraní a postupy, ať jste 1. ledna 2027 v klidu.' },
];

const reseniBody = [
  'Splní EET 2.0 spolehlivě a v souladu s pravidly',
  'Funguje online, účtenku vydá i digitálně',
  'Zvládne hotovost, kartu, QR kód i stravenky',
  'Instalaci a nastavení stihnete s rezervou před 1. 1. 2027',
];

const faqs = [
  { q: 'Kdy začne EET 2.0 platit a musím to řešit už teď?', a: 'Od 1. ledna 2027. Do té doby je potřeba mít funkční pokladní systém připravený na nová pravidla, včetně instalace, nastavení a zaškolení obsluhy. Příprava se vyplatí s předstihem, protože ke konci roku 2026 bývají kapacity dodavatelů plné.' },
  { q: 'Koho se EET 2.0 týká?', a: 'Prakticky každé restaurace, kavárny, baru nebo hotelu. Evidovat se budou všechny platby přijaté při osobním kontaktu se zákazníkem: hotovost, karta, QR kód i stravenky. Výjimku mají pouze OSVČ v prvním pásmu paušálního režimu s příjmy do 1 milionu Kč ročně.' },
  { q: 'Musím si pořizovat nový pokladní systém?', a: 'Záleží na tom, co dnes používáte. Moderní systémy zvládnou EET 2.0 softwarovým updatem. Zastaralý nebo nevhodný systém ale může přechod prodražit a času na výměnu ubývá.' },
  { q: 'Co mi hrozí, když nebudu evidovat?', a: 'Pokuta až 500 000 Kč. Finanční správa navíc bude porovnávat tržby podnikatelů ve stejném oboru a regionu, takže odchylky automaticky přitáhnou pozornost kontrolorů.' },
  { q: 'Je EET 2.0 složitější než to první?', a: 'Ne, naopak. Funguje pouze v online režimu bez výjimek a variant, účtenku vydáváte jen na vyžádání i digitálně a stát po vás chce méně dat než dřív. S vhodným systémem většinu změn nepoznáte.' },
  { q: 'Co se změní u spropitného?', a: 'Dobrovolné spropitné bude osvobozeno od daně i odvodů až do výše 7 % měsíčních tržeb. Detailní pravidla pro evidenci se zatím upřesňují.' },
];

const leadProofs = [
  { icon: 'lucide:gift', title: 'Konzultace zdarma', text: 'Nezávazně a bez rizika.' },
  { icon: 'lucide:search-check', title: 'Ověření vaší pokladny', text: 'Zjistíme, zda je systém na EET připravený.' },
  { icon: 'lucide:calendar-check', title: 'Stihnete deadline', text: 'Připraveno před 1. 1. 2027.' },
  { icon: 'lucide:shield-check', title: 'Bez stresu a pokut', text: 'Provedeme vás přechodem krok za krokem.' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<Base title="Návrat EET od roku 2027, připravte se včas"
      description="Přehledný průvodce návratem elektronické evidence tržeb od 1. ledna 2027. Co se mění, koho se to týká a jak se včas připravit. Nezávazná konzultace zdarma."
      schema={faqSchema}>
  <SiteHeader />

  <main>

  <!-- HERO -->
  <Hero background="gradient"
        eyebrow="Elektronická evidence tržeb · od 1. ledna 2027"
        lead="Evidence tržeb se vrací. Není ale důvod k panice. Stačí včas ověřit, zda je vaše pokladna připravená, a v klidu doladit, co je potřeba. Tady najdete přehledně, co se mění a jak na to."
        usp={[
          { text: 'Platí od 2027', icon: 'lucide:calendar-clock' },
          { text: 'Připravte se včas', icon: 'lucide:clock' },
          { text: 'Bez stresu a pokut', icon: 'lucide:shield-check' },
        ]}>
    <Heading slot="title" as="h1" size="display" color="on-dark">EET se vrací. Připravte se včas a <em>bez stresu</em></Heading>
    <Fragment slot="actions">
      <Button href="#konzultace">Nezávazná konzultace</Button>
      <Button href="#co-se-meni" variant="secondary" onDark>Co se mění</Button>
    </Fragment>
  </Hero>

  <!-- CO SE MENI -->
  <USPGrid id="co-se-meni" eyebrow="Co se mění" title="Nová pravidla v kostce"
           lead="EET 2.0 je jednodušší než první vlna. Tady jsou změny, které se vás dotknou nejvíc."
           items={zmeny} columns={3} background="default" space="lg" />

  <!-- EET vs EET 2.0 -->
  <Section background="alt" space="lg">
    <div class="head-center">
      <Text size="label" color="accent" align="center">5 klíčových rozdílů</Text>
      <Heading as="h2" size="h2" align="center">EET versus EET 2.0, co se opravdu <em>mění</em></Heading>
    </div>
    <div class="cmp">
      <div class="cmp__col">
        <p class="cmp__head"><strong>EET</strong><span>jak to bylo</span></p>
        {compare.map((c) => (
          <div class="cmp__row">
            <span class="cmp__ico"><Icon name={c.icon} size="sm" /></span>
            <span class="cmp__txt"><span class="cmp__cat">{c.cat}</span><span class="cmp__val">{c.old}</span></span>
          </div>
        ))}
      </div>
      <div class="cmp__col cmp__col--new">
        <p class="cmp__head"><strong>EET 2.0</strong><span>jak to bude</span></p>
        {compare.map((c) => (
          <div class="cmp__row">
            <span class="cmp__ico"><Icon name={c.icon} size="sm" /></span>
            <span class="cmp__txt"><span class="cmp__cat">{c.cat}</span><span class="cmp__val">{c.neu}</span></span>
          </div>
        ))}
      </div>
    </div>
  </Section>

  <!-- HARMONOGRAM -->
  <Section background="default" space="lg">
    <div class="head-center">
      <Text size="label" color="accent" align="center">Časová osa</Text>
      <Heading as="h2" size="h2" align="center">Harmonogram zavedení</Heading>
    </div>
    <div class="tl">
      <span class="tl__line" aria-hidden="true"></span>
      {timeline.map((m) => (
        <div class:list={['tl__item', `tl__item--${m.state}`]}>
          <span class="tl__dot" aria-hidden="true"></span>
          <div class="tl__card">
            <span class="tl__date">{m.date}</span>
            <p class="tl__title">{m.title}</p>
            {m.state === 'current' && <span class="tl__badge">Aktuálně</span>}
          </div>
        </div>
      ))}
    </div>
  </Section>

  <!-- KOHO SE TO TYKA -->
  <Section id="koho" background="alt" space="lg">
    <div class="head-center">
      <Text size="label" color="accent" align="center">Koho se to týká</Text>
      <Heading as="h2" size="h2" align="center">Týká se prakticky <em>celé gastronomie</em></Heading>
      <Text size="lead" color="muted" align="center" balance>
        Evidovat se budou všechny platby přijaté při osobním kontaktu se zákazníkem: hotovost, karta, QR kód i stravenky.
      </Text>
    </div>
    <div class="who">
      {koho.map((k) => (
        <article class="who__card">
          <span class="who__ico"><Icon name={k.icon} size="md" /></span>
          <Heading as="h3" size="h3">{k.title}</Heading>
          <Text size="small" color="muted">{k.text}</Text>
        </article>
      ))}
    </div>
    <p class="note">
      <span class="note__ico"><Icon name="lucide:info" size="sm" /></span>
      Výjimku mají pouze OSVČ v prvním pásmu paušálního režimu s příjmy do 1 milionu Kč ročně.
    </p>
  </Section>

  <!-- JAK SE PRIPRAVIT -->
  <Section id="priprava" background="default" space="lg">
    <div class="head-center">
      <Text size="label" color="accent" align="center">Jak se připravit</Text>
      <Heading as="h2" size="h2" align="center">Čtyři kroky k <em>klidnému</em> startu</Heading>
      <Text size="lead" color="muted" align="center" balance>
        Nečekejte na poslední chvíli. S předstihem je příprava otázkou několika kroků.
      </Text>
    </div>
    <ol class="steps">
      {kroky.map((s, i) => (
        <li class="step">
          <span class="step__num">{i + 1}</span>
          <span class="step__ico"><Icon name={s.icon} size="md" /></span>
          <Heading as="h3" size="h3">{s.title}</Heading>
          <Text size="small" color="muted">{s.text}</Text>
        </li>
      ))}
    </ol>
  </Section>

  <!-- POKLADNA PRIPRAVENA NA EET -->
  <Section id="reseni" background="primary" space="lg">
    <div class="reseni">
      <div class="reseni__text">
        <Text size="label" color="on-dark-muted">Řešení</Text>
        <Heading as="h2" size="h2" color="on-dark">Pokladní systém připravený na EET</Heading>
        <Text size="lead" color="on-dark-muted" class="reseni__lead">
          Nejjistější cesta je mít pokladnu, která nová pravidla zvládne sama. Pomůžeme vám ověřit, jestli je váš systém připravený, a poradíme, co případně doladit.
        </Text>
        <ul class="reseni__list">
          {reseniBody.map((b) => (
            <li class="reseni__item"><span class="reseni__check"><Icon name="lucide:check" size="sm" /></span>{b}</li>
          ))}
        </ul>
        <div class="reseni__actions">
          <Button href="#konzultace">Chci nezávaznou konzultaci</Button>
        </div>
      </div>
    </div>
  </Section>

  <!-- FAQ -->
  <Section id="faq" background="default" space="lg" container="narrow">
    <Heading as="h2" size="h2" align="center">Časté dotazy</Heading>
    <div class="faq">
      {faqs.map((f) => (
        <details class="faq__item">
          <summary class="faq__q">{f.q}</summary>
          <div class="faq__a"><Text color="muted">{f.a}</Text></div>
        </details>
      ))}
    </div>
  </Section>

  <!-- KONZULTACE -->
  <LeadForm id="konzultace" variant="full" background="alt"
            action="/api/lead"
            title="Nezávazná konzultace zdarma"
            lead="Nechte nám kontakt. Ozveme se vám, ověříme připravenost vaší pokladny a poradíme, jak EET 2.0 zvládnout v klidu."
            proofs={leadProofs} />

  </main>

  <SiteFooter />
</Base>

<style>
  .head-center { max-width: 720px; margin: 0 auto var(--space-7); text-align: center; }
  .head-center :global(h2) { margin-top: var(--space-2); }
  .head-center :global(.text) { margin-top: var(--space-3); }

  /* EET vs EET 2.0 */
  .cmp { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-5); max-width: 880px; margin: 0 auto; }
  .cmp__col { background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: var(--space-6); display: flex; flex-direction: column; gap: var(--space-4); }
  .cmp__col--new { background: var(--color-primary); border-color: var(--color-primary); color: #fff; }
  .cmp__head { margin: 0 0 var(--space-2); display: flex; flex-direction: column; }
  .cmp__head strong { font-family: var(--font-sans); font-size: var(--font-size-h3); font-weight: var(--font-weight-bold); }
  .cmp__head span { font-size: var(--font-size-small); color: var(--color-text-muted); }
  .cmp__col--new .cmp__head span { color: rgba(255,255,255,.72); }
  .cmp__row { display: flex; align-items: center; gap: var(--space-3); }
  .cmp__ico { display: inline-flex; color: var(--color-text-accent); flex-shrink: 0; }
  .cmp__col--new .cmp__ico { color: var(--color-secondary-gold); }
  .cmp__txt { display: flex; flex-direction: column; }
  .cmp__cat { font-size: var(--font-size-caption); text-transform: uppercase; letter-spacing: var(--letter-spacing-wide); color: var(--color-text-muted); }
  .cmp__col--new .cmp__cat { color: rgba(255,255,255,.68); }
  .cmp__val { font-weight: var(--font-weight-semibold); font-size: var(--font-size-body); }

  /* Harmonogram */
  .tl { position: relative; max-width: 620px; margin: 0 auto; display: flex; flex-direction: column; gap: var(--space-4); padding-left: var(--space-1); }
  .tl__line { position: absolute; left: 8px; top: 10px; bottom: 10px; width: 2px; background: var(--color-border); }
  .tl__item { position: relative; display: grid; grid-template-columns: auto 1fr; column-gap: var(--space-4); align-items: start; }
  .tl__dot { width: 18px; height: 18px; border-radius: var(--radius-full); background: var(--color-bg); border: 2px solid var(--color-border); margin-top: 2px; position: relative; z-index: 1; }
  .tl__item--done .tl__dot { background: var(--color-primary); border-color: var(--color-primary); }
  .tl__item--current .tl__dot { border-color: var(--color-primary); box-shadow: 0 0 0 4px var(--color-bg), 0 0 0 6px var(--color-primary); }
  .tl__item--current .tl__dot::after { content: ''; position: absolute; inset: 3px; border-radius: var(--radius-full); background: var(--color-primary); }
  .tl__card { padding: var(--space-4) var(--space-5); background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-md); }
  .tl__item--current .tl__card { border-color: var(--color-primary); box-shadow: 0 8px 24px rgba(26,79,139,.12); }
  .tl__item--future .tl__card { background: transparent; border-style: dashed; }
  .tl__date { font-size: var(--font-size-caption); font-weight: var(--font-weight-semibold); text-transform: uppercase; letter-spacing: var(--letter-spacing-wide); color: var(--color-text-accent); }
  .tl__item--future .tl__date { color: var(--color-text-muted); }
  .tl__title { margin: var(--space-1) 0 0; font-size: var(--font-size-body); font-weight: var(--font-weight-semibold); line-height: var(--line-height-tight); }
  .tl__badge { display: inline-block; margin-top: var(--space-2); font-size: var(--font-size-caption); font-weight: var(--font-weight-medium); text-transform: uppercase; letter-spacing: var(--letter-spacing-wide); color: #fff; background: var(--color-primary); padding: 1px var(--space-2); border-radius: var(--radius-sm); }

  /* Koho se to tyka */
  .who { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: var(--space-5); }
  .who__card { background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: var(--space-6) var(--space-5); }
  .who__card > * + * { margin-top: var(--space-3); }
  .who__ico { display: inline-flex; color: var(--color-text-accent); }
  .note { display: flex; align-items: center; justify-content: center; gap: var(--space-2); margin-top: var(--space-6); font-size: var(--font-size-small); color: var(--color-text-muted); text-align: center; }
  .note__ico { display: inline-flex; color: var(--color-text-accent); flex-shrink: 0; }
  @media (max-width: 880px) { .who { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media (max-width: 520px) { .who { grid-template-columns: 1fr; } }

  /* Kroky */
  .steps { list-style: none; display: grid; gap: var(--space-6); grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); }
  .step { position: relative; padding: var(--space-6); background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-md); box-shadow: var(--shadow-sm); }
  .step > * + * { margin-top: var(--space-3); }
  .step__num { position: absolute; top: var(--space-4); right: var(--space-5); font-size: var(--font-size-h2); font-weight: var(--font-weight-bold); color: var(--color-neutral-200); line-height: 1; }
  .step__ico { display: inline-flex; color: var(--color-text-accent); }

  /* Reseni */
  .reseni { max-width: 720px; }
  .reseni__lead { margin-top: var(--space-4); }
  .reseni :global(h2) { margin-top: var(--space-2); }
  .reseni__list { list-style: none; display: grid; gap: var(--space-3); margin-top: var(--space-6); }
  .reseni__item { display: flex; align-items: flex-start; gap: var(--space-3); color: var(--color-text-on-dark); }
  .reseni__check { display: inline-flex; color: var(--color-secondary-gold); flex-shrink: 0; margin-top: 2px; }
  .reseni__actions { margin-top: var(--space-7); }

  /* FAQ */
  .faq { margin-top: var(--space-6); display: flex; flex-direction: column; gap: var(--space-3); }
  .faq__item { background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: var(--space-4) var(--space-5); }
  .faq__q { cursor: pointer; font-family: var(--font-sans); font-weight: var(--font-weight-semibold); color: var(--color-text); list-style: none; display: flex; justify-content: space-between; align-items: center; gap: var(--space-4); }
  .faq__q::-webkit-details-marker { display: none; }
  .faq__q::after { content: "+"; color: var(--color-text-accent); font-size: 1.4em; line-height: 1; flex-shrink: 0; }
  .faq__item[open] .faq__q::after { content: "\2212"; }
  .faq__a { margin-top: var(--space-3); }
</style>
