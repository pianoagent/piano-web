---
/**
 * LegalPage — Protel app šablona pro právní stránky (úzká prose).
 * Obsah: HTML z content/legal/*.html (vytěženo ze starého webu protelsystems.cz).
 * Skládá sdílené komponenty @piano/ui — NEFORKOVAT.
 */
import Base from '../layouts/Base.astro';
import SiteHeader from './SiteHeader.astro';
import SiteFooter from './SiteFooter.astro';
import Section from '@piano/ui/components/Section.astro';
import Hero from '@piano/ui/components/Hero.astro';
import Heading from '@piano/ui/components/Heading.astro';

interface Props { title: string; description: string; heading: string; html: string; eyebrow?: string; }
const { title, description, heading, html, eyebrow = 'Právní informace' } = Astro.props;
---
<Base title={title} description={description} noindex>
  <SiteHeader />
  <main>
    <Hero eyebrow={eyebrow} background="alt" space="md">
      <Heading slot="title" as="h1" size="h1">{heading}</Heading>
    </Hero>
    <Section background="default" space="lg" container="narrow">
      <div class="legal"><Fragment set:html={html} /></div>
    </Section>
  </main>
  <SiteFooter />
</Base>

<style>
  .legal { max-width: 760px; }
  .legal :global(h2) { font-weight: var(--font-weight-medium); font-size: var(--font-size-h3); color: var(--color-secondary); margin: var(--space-7) 0 var(--space-3); }
  .legal :global(h3) { font-weight: var(--font-weight-semibold); font-size: var(--font-size-lead); margin: var(--space-5) 0 var(--space-2); }
  .legal :global(p) { color: var(--color-text-muted); line-height: var(--line-height-body); margin-bottom: var(--space-3); }
  .legal :global(ul), .legal :global(ol) { margin: 0 0 var(--space-4) var(--space-5); color: var(--color-text-muted); display: flex; flex-direction: column; gap: var(--space-1); }
  .legal :global(a) { color: var(--color-text-accent); word-break: break-word; }
  .legal :global(strong) { color: var(--color-text); }
  .legal :global(table) { border-collapse: collapse; margin-bottom: var(--space-4); }
  .legal :global(td), .legal :global(th) { border: 1px solid var(--color-border); padding: var(--space-2) var(--space-3); color: var(--color-text-muted); }
  .legal :global(h2:first-child) { margin-top: 0; }
</style>
