---
/**
 * Protel — landing „Legislativa hotelu“. Obsah vytěžen z legislativa-hotelu.html starého
 * protelsystems.cz (jazykově uhlazeno). Vše ze sdílených komponent @piano/ui.
 */
import Base from '../layouts/Base.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import Section from '@piano/ui/components/Section.astro';
import Hero from '@piano/ui/components/Hero.astro';
import Heading from '@piano/ui/components/Heading.astro';
import Text from '@piano/ui/components/Text.astro';
import Button from '@piano/ui/components/Button.astro';
import Icon from '@piano/ui/components/Icon.astro';
import Breadcrumb from '@piano/ui/components/Breadcrumb.astro';
import USPGrid from '@piano/ui/components/USPGrid.astro';
import LeadForm from '@piano/ui/components/LeadForm.astro';

const related = [
  { icon: "lucide:layout-dashboard", title: "Hotelový systém Protel", text: "PMS přizpůsobený CZ a SK legislativě.", href: "/produkty/hotelovy-system-protel" },
  { icon: "lucide:scan-line", title: "Čtečka dokladů", text: "Přesná evidence údajů hostů z dokladů.", href: "/produkty/ctecka-dokladu" },
  { icon: "lucide:line-chart", title: "Reporting", text: "Statistiky a podklady pro úřady i účetnictví.", href: "/produkty/hotelovy-system-protel#reporting" },
  { icon: "lucide:shield-check", title: "Ochrana dat a bezpečnost", text: "GDPR, PCI a tokenizace karet.", href: "/produkty/hotelovy-system-protel#ochrana-dat-a-bezpecnost" },
];
---

<Base title="Legislativa hotelu | Protel"
      description="Národnostní statistiky, městské poplatky, podklady pro účetnictví i report pro cizineckou policii — Protel legislativně splňuje vše a náš tým hlídá změny zákonů za vás.">
  <SiteHeader />

  <main>
    <Breadcrumb items={[{ label: 'Úvod', href: '/' }, { label: 'Řešení', href: '/#reseni' }, { label: "Legislativa hotelu" }]} />

    <Hero eyebrow="Řešení" background="gradient"
          lead="Národnostní statistiky? Podklad pro výpočet městského poplatku? Podklad pro účetnictví? Report pro cizineckou policii? Víme, je toho hodně…">
      <Heading slot="title" as="h1" size="display" color="on-dark">Legislativa <em>hotelu</em></Heading>
      <Fragment slot="actions">
        <Button href="#poptavka">Vyzkoušet Protel zdarma</Button>
        <Button href="/produkty" variant="secondary" onDark>Prohlédnout produkty</Button>
      </Fragment>
    </Hero>

    <Section background="default" space="lg">
      <div class="solution">
        <Text size="label" color="accent">Protel má řešení</Text>
        <Heading as="h2" size="h2">Hotelový systém Protel vše legislativně splňuje!</Heading>
        <Text size="lead" color="muted">Díky speciálně upraveným reportům a nastavením je náš hotelový systém přizpůsoben české a slovenské legislativě. A velice důležitý je také náš tým, který průběžně sleduje, jaké zákonné požadavky se změnily. Na změny vás upozorní a systémová nastavení upraví.</Text>
      </div>
    </Section>

    <Section background="primary" space="lg">
      <figure class="quoteband">
        <span class="quoteband__mark"><Icon name="lucide:quote" size="lg" /></span>
        <blockquote>
          <Heading as="p" size="h3" color="on-dark" align="center">Výhodou Protelu je splnění všech legislativních požadavků pro vedení hotelu — a aktivní sledování změn zákonných požadavků naším týmem.</Heading>
        </blockquote>
      </figure>
    </Section>

    <USPGrid eyebrow="Související" title="Související s legislativou hotelu"
             items={related} minItemWidth="260px" background="alt" space="lg" />

    <LeadForm id="poptavka" variant="full" background="default"
              title="Vyzkoušejte Protel zdarma"
              lead="Co byste u vás v hotelu rádi zlepšili? Nechte nám kontakt — ozveme se a ukážeme Protel přímo ve vašem hotelu." />
  </main>

  <SiteFooter />
</Base>

<style>
  .solution { max-width: 800px; margin-inline: auto; }
  .solution > :global(* + *) { margin-top: var(--space-4); }
  .quoteband { margin: 0; max-width: 840px; margin-inline: auto; display: flex; flex-direction: column; align-items: center; gap: var(--space-4); text-align: center; }
  .quoteband__mark { color: var(--color-text-on-dark); opacity: 0.7; }
  .quoteband blockquote { margin: 0; }
</style>
