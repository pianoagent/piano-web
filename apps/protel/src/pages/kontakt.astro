---
/**
 * Protel — Kontakt. Údaje ze starého webu protelsystems.cz / protel-context.md.
 */
import Base from '../layouts/Base.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import Section from '@piano/ui/components/Section.astro';
import Heading from '@piano/ui/components/Heading.astro';
import Text from '@piano/ui/components/Text.astro';
import Icon from '@piano/ui/components/Icon.astro';
import LeadForm from '@piano/ui/components/LeadForm.astro';

const contacts = [
  { icon: 'lucide:briefcase', label: 'Obchod', value: 'sales@protelsystems.cz', href: 'mailto:sales@protelsystems.cz' },
  { icon: 'lucide:phone', label: 'Obchod — telefon', value: '+420 257 011 107', href: 'tel:+420257011107' },
  { icon: 'lucide:life-buoy', label: 'Hotline', value: 'help@protelsystems.cz', href: 'mailto:help@protelsystems.cz' },
  { icon: 'lucide:phone-call', label: 'Hotline — telefon', value: '+420 778 776 835', href: 'tel:+420778776835' },
  { icon: 'lucide:map-pin', label: 'Sídlo', value: 'protel systems s.r.o., Thámova 166/18, 186 00 Praha 8 – Karlín' },
];
---

<Base title="Kontakt — Protel" description="Spojte se s týmem Protel. Obchod, hotline a sídlo společnosti protel systems s.r.o.">
  <SiteHeader />

  <main>
    <Section background="alt" space="lg">
      <div class="head head--center">
        <Text size="label" color="accent" align="center">Kontakt</Text>
        <Heading as="h1" size="h1" align="center">Pojďme to <em>probrat</em></Heading>
        <Text size="lead" color="muted" align="center" balance>
          Co byste u vás v hotelu rádi zlepšili? Ozvěte se nám — připravíme řešení na míru.
        </Text>
      </div>
      <ul class="cards">
        {contacts.map((c) => (
          <li class="card">
            <span class="card__icon"><Icon name={c.icon} size="md" /></span>
            <span class="card__label">{c.label}</span>
            {c.href ? <a class="card__value" href={c.href}>{c.value}</a> : <span class="card__value">{c.value}</span>}
          </li>
        ))}
      </ul>
    </Section>

    <LeadForm id="poptavka" variant="full" background="default"
              title="Napište nám"
              lead="Nechte nám kontakt — ozveme se a ukážeme Protel přímo ve vašem hotelu." />
  </main>

  <SiteFooter />
</Base>

<style>
  .head { max-width: 760px; margin-inline: auto; margin-bottom: var(--space-7); }
  .head--center { text-align: center; }
  .head > * + * { margin-top: var(--space-3); }
  .cards { list-style: none; display: grid; gap: var(--space-5); grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); }
  .card {
    display: flex; flex-direction: column; gap: var(--space-2); padding: var(--space-6);
    background: var(--color-bg); border: 1px solid var(--color-border);
    border-radius: var(--radius-md); box-shadow: var(--shadow-sm);
  }
  .card__icon {
    display: inline-flex; align-items: center; justify-content: center;
    width: 48px; height: 48px; border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--color-primary) 10%, #fff); color: var(--color-primary);
  }
  .card__label { font-size: var(--font-size-small); color: var(--color-text-muted); }
  .card__value { font-weight: var(--font-weight-semibold); color: var(--color-text); text-decoration: none; }
  a.card__value:hover { color: var(--color-text-accent); }
</style>
