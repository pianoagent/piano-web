---
/**
 * Protel — produkt „Automatický mailing“. Obsah vytěžen z produkty/automaticky-mailing.html
 * starého protelsystems.cz (jazykově uhlazeno, fakta zachována).
 * Vše ze sdílených komponent @piano/ui.
 */
import Base from '../../layouts/Base.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import Section from '@piano/ui/components/Section.astro';
import Hero from '@piano/ui/components/Hero.astro';
import Heading from '@piano/ui/components/Heading.astro';
import Text from '@piano/ui/components/Text.astro';
import Button from '@piano/ui/components/Button.astro';
import Icon from '@piano/ui/components/Icon.astro';
import Breadcrumb from '@piano/ui/components/Breadcrumb.astro';
import USPGrid from '@piano/ui/components/USPGrid.astro';
import LeadForm from '@piano/ui/components/LeadForm.astro';

const features = [
  {
    id: "potvrzeni-rezervace", icon: "lucide:mail-check", title: "Potvrzení rezervace",
    paras: [
      "Jakmile vznikne rezervace — automaticky, nebo ručně — systém hostovi okamžitě odešle potvrzení s termíny pobytu, typem pokoje, cenovými podmínkami a dalšími údaji.",
      "Hosté mají jasné a přesné informace o rezervaci a na pobyt se mohou těšit s jistotou, že je vše zajištěno.",
    ],
  },
  {
    id: "pred-prijezdova-komunikace", icon: "lucide:calendar-clock", title: "Před-příjezdová komunikace",
    paras: [
      "Nastavíte, kolik dní před příjezdem se mají e-maily zasílat a s jakou frekvencí — komunikaci přizpůsobíte potřebám a preferencím hostů.",
      "Před příjezdem tak hosty informujete o pokynech k příjezdu, možnostech dopravy, speciálních nabídkách nebo akcích během pobytu. Hosté se cítí vítáni ještě dřív, než dorazí.",
    ],
  },
  {
    id: "upselling", icon: "lucide:trending-up", title: "Upselling",
    paras: [
      "Díky filtrům a personalizovaným zprávám nabídnete hostům dodatečné služby přesně na míru — například hostům se základním typem pokoje upgrade do vyšší kategorie za příplatek.",
      "Maximalizujete tak příjem hotelu, hosté si vylepší pobyt podle svých preferencí — a hodnocení hotelu ovlivníte dřív, než host odjede.",
    ],
  },
  {
    id: "zustante-ve-spojeni", icon: "lucide:heart-handshake", title: "Zůstaňte ve spojení",
    paras: [
      "S hosty zůstanete v kontaktu i po odjezdu: automatická narozeninová přání posilují osobní vztah, pravidelné newslettery informují o novinkách, slevách, událostech v hotelu i zajímavých místech v okolí.",
      "Udržujete zájem hostů o váš hotel a motivujete je k opětovné návštěvě.",
    ],
  },
  {
    id: "interni-komunikace", icon: "lucide:messages-square", title: "Interní komunikace",
    paras: [
      "Automatický mailing usnadňuje i komunikaci uvnitř hotelu — třeba zadávání úklidu nebo hlášení závad. Systém automaticky vygeneruje upozornění a pošle je s podrobnostmi příslušnému oddělení.",
      "Úkoly se řeší rychle a bez chyb z ručního zadávání, komunikace mezi odděleními se zlepšuje a produktivita roste.",
    ],
  },
  {
    id: "filtr-rezervaci", icon: "lucide:filter", title: "Filtr rezervací",
    paras: [
      "Filtry umožňují cílit e-maily podle data příjezdu, délky pobytu, typu pokoje nebo speciálních požadavků. Novým hostům pošlete uvítací e-mail, hostům s delším pobytem speciální akce, rodinám s dětmi tipy na aktivity.",
      "Hosté dostávají relevantní a včasné informace, personál šetří čas — a spokojenost i loajalita hostů roste.",
    ],
  },
];

const related = [
  { icon: "lucide:layout-dashboard", title: "Hotelový systém", text: "Správa pokojů, rezervací, hostů a statistik — snadné používání a pokročilé funkce pro kompletní přehled o provozu.", href: "/produkty/hotelovy-system-protel" },
  { icon: "lucide:globe", title: "Webové rezervace", text: "Přímé rezervace přes web hotelu, bez provizí třetích stran.", href: "/produkty/webove-rezervace" },
  { icon: "lucide:book-open", title: "Digitální hotelová kniha", text: "Hotelová kniha elektronicky, vždy aktuální a po ruce.", href: "/produkty/digitalni-hotelova-kniha" },
  { icon: "lucide:smartphone", title: "Online check-in/out", text: "Host vyřídí check-in i check-out přes mobil, bez fronty na recepci.", href: "/produkty/online-check-in-out" },
];
---

<Base title="Automatický mailing | Protel"
      description="Důležité informace, potvrzení rezervací i upozornění odcházejí hostům včas a bez zásahu recepčního. Filtry zachovají personalizaci a přesné cílení na potřeby jednotlivých hostů.">
  <SiteHeader />

  <main>
    <Breadcrumb items={[{ label: 'Úvod', href: '/' }, { label: 'Produkty', href: '/produkty' }, { label: "Automatický mailing" }]} />

    <Hero eyebrow="Produkty" background="gradient"
          lead="Automatický mailing zajišťuje, že důležité informace, potvrzení rezervací nebo upozornění odcházejí hostům včas a bez zásahu recepčního. Díky filtrům při tvorbě zpráv si zachováte personalizaci a lépe zacílíte na potřeby jednotlivých hostů.">
      <Heading slot="title" as="h1" size="display" color="on-dark">Automatický <em>mailing</em></Heading>
      <Fragment slot="actions">
        <Button href="#poptavka">Vyzkoušet Protel zdarma</Button>
        <Button href="/produkty" variant="secondary" onDark>Všechny produkty</Button>
      </Fragment>
    </Hero>

    <Section background="default" space="lg">
      <nav class="jump" aria-label="Funkce produktu">
        {features.map((f) => (
          <a class="jump__chip" href={`#${f.id}`}>{f.title}</a>
        ))}
      </nav>
      <div class="features">
        {features.map((f) => (
          <article class="feature" id={f.id}>
            <span class="feature__icon"><Icon name={f.icon} size="lg" /></span>
            <Heading as="h2" size="h3">{f.title}</Heading>
            {f.paras.map((p) => (
              <Text color="muted">{p}</Text>
            ))}
          </article>
        ))}
      </div>
    </Section>

    <Section background="primary" space="lg">
      <figure class="quoteband">
        <span class="quoteband__mark"><Icon name="lucide:quote" size="lg" /></span>
        <blockquote>
          <Heading as="p" size="h3" color="on-dark" align="center">Automatický mailing je plně automatizovaný díky integraci s hotelovým systémem. Filtry umožňují personalizovanou komunikaci s hosty — a vám dávají možnost prodat více služeb.</Heading>
        </blockquote>
      </figure>
    </Section>

    <USPGrid eyebrow="Dále by vás mohlo zajímat" title="Související produkty"
             items={related} minItemWidth="260px" background="alt" space="lg" />

    <LeadForm id="poptavka" variant="full" background="default"
              title="Vyzkoušejte Protel zdarma"
              lead="Co byste u vás v hotelu rádi zlepšili? Nechte nám kontakt — ozveme se a ukážeme Protel přímo ve vašem hotelu." />
  </main>

  <SiteFooter />
</Base>

<style>
  .jump { display: flex; flex-wrap: wrap; gap: var(--space-2); justify-content: center; margin-bottom: var(--space-8); }
  .jump__chip {
    display: inline-flex; padding: var(--space-2) var(--space-4);
    border: 1px solid var(--color-border); border-radius: var(--radius-full);
    background: var(--color-bg-alt); color: var(--color-text);
    font-size: var(--font-size-small); font-weight: var(--font-weight-semibold);
    text-decoration: none; transition: border-color var(--duration-base) var(--easing);
  }
  .jump__chip:hover { border-color: var(--color-primary); color: var(--color-text-accent); }
  .features { max-width: 800px; margin-inline: auto; display: flex; flex-direction: column; gap: var(--space-9); }
  .feature { scroll-margin-top: var(--space-9); }
  .feature > :global(* + *) { margin-top: var(--space-3); }
  .feature__icon {
    display: inline-flex; align-items: center; justify-content: center;
    width: 56px; height: 56px; border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--color-primary) 10%, #fff); color: var(--color-primary);
  }
  .quoteband { margin: 0; max-width: 840px; margin-inline: auto; display: flex; flex-direction: column; align-items: center; gap: var(--space-4); text-align: center; }
  .quoteband__mark { color: var(--color-text-on-dark); opacity: 0.7; }
  .quoteband blockquote { margin: 0; }
</style>
