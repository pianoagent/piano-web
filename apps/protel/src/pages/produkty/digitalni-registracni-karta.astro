---
/**
 * Protel — produkt „Digitální registrační karta“. Obsah vytěžen z produkty/digitalni-registracni-karta.html
 * starého protelsystems.cz (jazykově uhlazeno, fakta zachována).
 * Vše ze sdílených komponent @piano/ui.
 */
import Base from '../../layouts/Base.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import Section from '@piano/ui/components/Section.astro';
import Hero from '@piano/ui/components/Hero.astro';
import Heading from '@piano/ui/components/Heading.astro';
import Text from '@piano/ui/components/Text.astro';
import Button from '@piano/ui/components/Button.astro';
import Icon from '@piano/ui/components/Icon.astro';
import Breadcrumb from '@piano/ui/components/Breadcrumb.astro';
import USPGrid from '@piano/ui/components/USPGrid.astro';
import LeadForm from '@piano/ui/components/LeadForm.astro';

const features = [
  {
    id: "vyplneni-udaju", icon: "lucide:pencil-line", title: "Vyplnění údajů",
    paras: [
      "Host vyplní všechny potřebné údaje k pobytu přímo na svém mobilním zařízení — kdekoli a kdykoli. Získáte navíc skutečnou e-mailovou adresu hosta, což usnadňuje budoucí komunikaci mezi hotelem a hostem.",
    ],
  },
  {
    id: "podpis", icon: "lucide:pen-tool", title: "Podpis",
    paras: [
      "Registrační formulář host podepíše prstem přímo na obrazovce svého zařízení; na kiosku lze použít digitální pero a tablet. Podpis se integruje do formuláře a uloží v PDF.",
      "Digitalizace registrace výrazně snižuje spotřebu papíru a usnadňuje archivaci i správu dokumentů.",
    ],
  },
  {
    id: "nahled-na-ucet", icon: "lucide:receipt", title: "Náhled na účet",
    paras: [
      "Při vyplňování registrační karty si host zobrazí i náhled svého účtu — plánovaný pobyt, cenu za ubytování, služby a další položky. Vše zkontroluje a případně upraví ještě před dokončením registrace.",
    ],
  },
  {
    id: "upselling", icon: "lucide:trending-up", title: "Upselling",
    paras: [
      "Během check-inu nabídnete hostům doplňkové služby — snídaně, wellness procedury nebo pokojový servis — přímo v jejich mobilu. Host si službu pohodlně vybere a okamžitě zakoupí; transakce se zaznamenávají v reálném čase.",
    ],
  },
  {
    id: "bezpecnost", icon: "lucide:shield-check", title: "Bezpečnost",
    paras: [
      "S Protelem je vše bezpečné. Při ztrátě nebo odcizení lze digitální registrační kartu rychle deaktivovat — uživatel nebo správce ji okamžitě zablokuje a zamezí neoprávněnému přístupu.",
    ],
  },
  {
    id: "automaticke-archivovani", icon: "lucide:archive", title: "Automatické archivování",
    paras: [
      "Každý záznam se po vyplnění formuláře automaticky uloží do bezpečného úložiště. Data jsou kdykoli dostupná — pro kontrolu cizinecké policie, reporting i další administrativní účely. Žádné ruční ukládání ani třídění.",
    ],
  },
];

const related = [
  { icon: "lucide:smartphone", title: "Online check-in/out", text: "Host vyřídí check-in i check-out přes mobil, bez fronty na recepci.", href: "/produkty/online-check-in-out" },
  { icon: "lucide:monitor-smartphone", title: "Kiosek", text: "Samoobslužný check-in/out terminál přímo v hotelu.", href: "/produkty/kiosek" },
  { icon: "lucide:scan-line", title: "Čtečka dokladů", text: "Rychlé načtení údajů z dokladů i platebních karet.", href: "/produkty/ctecka-dokladu" },
  { icon: "lucide:mail", title: "Automatický mailing", text: "Personalizované e-maily hostům bez zásahu recepčního.", href: "/produkty/automaticky-mailing" },
];
---

<Base title="Digitální registrační karta | Protel"
      description="Digitální registrační karta umožní hostům vyplnit údaje pohodlně přes mobilní telefon a strávit u recepčního pultu minimum času.">
  <SiteHeader />

  <main>
    <Breadcrumb items={[{ label: 'Úvod', href: '/' }, { label: 'Produkty', href: '/produkty' }, { label: "Digitální registrační karta" }]} />

    <Hero eyebrow="Produkty" background="gradient"
          lead="Digitální registrační karta je elegantní způsob, jak umožnit hostům vyplnit své údaje pohodlně a u recepčního pultu strávit minimum času. Vše jednoduše přes mobilní telefon hosta.">
      <Heading slot="title" as="h1" size="display" color="on-dark">Digitální <em>registrační karta</em></Heading>
      <Fragment slot="actions">
        <Button href="#poptavka">Vyzkoušet Protel zdarma</Button>
        <Button href="/produkty" variant="secondary" onDark>Všechny produkty</Button>
      </Fragment>
    </Hero>

    <Section background="default" space="lg">
      <nav class="jump" aria-label="Funkce produktu">
        {features.map((f) => (
          <a class="jump__chip" href={`#${f.id}`}>{f.title}</a>
        ))}
      </nav>
      <div class="features">
        {features.map((f) => (
          <article class="feature" id={f.id}>
            <span class="feature__icon"><Icon name={f.icon} size="lg" /></span>
            <Heading as="h2" size="h3">{f.title}</Heading>
            {f.paras.map((p) => (
              <Text color="muted">{p}</Text>
            ))}
          </article>
        ))}
      </div>
    </Section>

    <Section background="primary" space="lg">
      <figure class="quoteband">
        <span class="quoteband__mark"><Icon name="lucide:quote" size="lg" /></span>
        <blockquote>
          <Heading as="p" size="h3" color="on-dark" align="center">Digitální registrační karta usnadňuje hostům registraci a zkracuje čekání u recepce. Host může kdykoli nahlédnout na svůj účet a vy mu jednoduše nabídnete další služby. Zefektivněte své hotelové podnikání!</Heading>
        </blockquote>
      </figure>
    </Section>

    <USPGrid eyebrow="Dále by vás mohlo zajímat" title="Související produkty"
             items={related} minItemWidth="260px" background="alt" space="lg" />

    <LeadForm id="poptavka" variant="full" background="default"
              title="Vyzkoušejte Protel zdarma"
              lead="Co byste u vás v hotelu rádi zlepšili? Nechte nám kontakt — ozveme se a ukážeme Protel přímo ve vašem hotelu." />
  </main>

  <SiteFooter />
</Base>

<style>
  .jump { display: flex; flex-wrap: wrap; gap: var(--space-2); justify-content: center; margin-bottom: var(--space-8); }
  .jump__chip {
    display: inline-flex; padding: var(--space-2) var(--space-4);
    border: 1px solid var(--color-border); border-radius: var(--radius-full);
    background: var(--color-bg-alt); color: var(--color-text);
    font-size: var(--font-size-small); font-weight: var(--font-weight-semibold);
    text-decoration: none; transition: border-color var(--duration-base) var(--easing);
  }
  .jump__chip:hover { border-color: var(--color-primary); color: var(--color-text-accent); }
  .features { max-width: 800px; margin-inline: auto; display: flex; flex-direction: column; gap: var(--space-9); }
  .feature { scroll-margin-top: var(--space-9); }
  .feature > :global(* + *) { margin-top: var(--space-3); }
  .feature__icon {
    display: inline-flex; align-items: center; justify-content: center;
    width: 56px; height: 56px; border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--color-primary) 10%, #fff); color: var(--color-primary);
  }
  .quoteband { margin: 0; max-width: 840px; margin-inline: auto; display: flex; flex-direction: column; align-items: center; gap: var(--space-4); text-align: center; }
  .quoteband__mark { color: var(--color-text-on-dark); opacity: 0.7; }
  .quoteband blockquote { margin: 0; }
</style>
