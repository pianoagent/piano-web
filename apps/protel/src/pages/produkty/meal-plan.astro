---
/**
 * Protel — produkt „MealPlan“. Obsah vytěžen z produkty/meal-plan.html
 * starého protelsystems.cz (jazykově uhlazeno, fakta zachována).
 * Vše ze sdílených komponent @piano/ui.
 */
import Base from '../../layouts/Base.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import Section from '@piano/ui/components/Section.astro';
import Hero from '@piano/ui/components/Hero.astro';
import Heading from '@piano/ui/components/Heading.astro';
import Text from '@piano/ui/components/Text.astro';
import Button from '@piano/ui/components/Button.astro';
import Icon from '@piano/ui/components/Icon.astro';
import Breadcrumb from '@piano/ui/components/Breadcrumb.astro';
import USPGrid from '@piano/ui/components/USPGrid.astro';
import LeadForm from '@piano/ui/components/LeadForm.astro';

const features = [
  {
    id: "digitalni-odbaveni-stravniku", icon: "lucide:utensils", title: "Digitální odbavení strávníků",
    paras: [
      "MealPlan digitalizuje hotelové stravování bez papírových seznamů a bez Excelu. Obsluha má přehled na mobilu nebo tabletu a hosta odbaví jedním kliknutím — u snídaní, obědů i večeří.",
      "Pořádek udržíte i ve špičce, uděláte méně chyb a máte jistotu, že pracujete se správnými informacemi přímo z PMS.",
    ],
  },
  {
    id: "prehled-v-realnem-case", icon: "lucide:activity", title: "Přehled v reálném čase",
    paras: [
      "MealPlan automaticky zobrazuje aktuální seznam strávníků a průběžně počítá, kolik hostů už přišlo a kolik jich zbývá. Personál okamžitě vidí nápor v restauraci, na koho se čeká a kdy posílit obsluhu či doplnit bufet.",
      "Živý přehled ocení hlavně hotely s vyšší obsazeností, kde stravování jede ve špičce a každá minuta rozhoduje. Manažer i obsluha pracují se stejnými daty a provoz probíhá plynule.",
    ],
  },
  {
    id: "vse-dulezite-ihned-na-ocich", icon: "lucide:eye", title: "Vše důležité ihned na očích",
    paras: [
      "U každého hosta máte okamžitě klíčové informace pro rychlou a bezpečnou obsluhu. MealPlan zobrazí poznámky k dietám a alergenům — třeba alergii na lepek, bezlaktózovou stravu nebo další individuální požadavky.",
      "Personál nemusí nic dohledávat a reaguje rovnou na místě. Výsledkem je méně chyb, profesionálnější servis a spokojenější hosté.",
    ],
  },
];

const related = [
  { icon: "lucide:layout-dashboard", title: "Hotelový systém", text: "Správa pokojů, rezervací, hostů a statistik — snadné používání a pokročilé funkce pro kompletní přehled o provozu.", href: "/produkty/hotelovy-system-protel" },
  { icon: "lucide:concierge-bell", title: "Room Service", text: "Host načte QR kód a objednávka jde přímo do Septimu v kuchyni či baru. Plně automatizované.", href: "/produkty/room-service" },
  { icon: "lucide:bed-double", title: "Housekeeping", text: "Digitální správa úklidu a údržby pokojů — vše v reálném čase.", href: "/produkty/housekeeping" },
  { icon: "lucide:mail", title: "Automatický mailing", text: "Personalizované e-maily hostům bez zásahu recepčního.", href: "/produkty/automaticky-mailing" },
];
---

<Base title="MealPlan — digitální evidence stravování | Protel"
      description="MealPlan kompletně digitalizuje evidenci snídaní, obědů a večeří. Obsluha má vše v mobilu nebo na tabletu — žádné papírové seznamy, Excel tabulky ani ruční sčítání.">
  <SiteHeader />

  <main>
    <Breadcrumb items={[{ label: 'Úvod', href: '/' }, { label: 'Produkty', href: '/produkty' }, { label: "MealPlan" }]} />

    <Hero eyebrow="Produkty" background="gradient"
          lead="MealPlan je chytrý nástroj pro hotely, který kompletně digitalizuje evidenci snídaní, obědů, večeří a stravování hostů. Obsluha má vše v mobilu nebo na tabletu — žádné papírové seznamy, žádné Excel tabulky ani ruční sčítání. V reálném čase vidíte, kdo už přišel, na koho ještě čekáte a kolik hostů zbývá odbavit.">
      <Heading slot="title" as="h1" size="display" color="on-dark">Meal<em>Plan</em></Heading>
      <Fragment slot="actions">
        <Button href="#poptavka">Vyzkoušet Protel zdarma</Button>
        <Button href="/produkty" variant="secondary" onDark>Všechny produkty</Button>
      </Fragment>
    </Hero>

    <Section background="default" space="lg">
      <nav class="jump" aria-label="Funkce produktu">
        {features.map((f) => (
          <a class="jump__chip" href={`#${f.id}`}>{f.title}</a>
        ))}
      </nav>
      <div class="features">
        {features.map((f) => (
          <article class="feature" id={f.id}>
            <span class="feature__icon"><Icon name={f.icon} size="lg" /></span>
            <Heading as="h2" size="h3">{f.title}</Heading>
            {f.paras.map((p) => (
              <Text color="muted">{p}</Text>
            ))}
          </article>
        ))}
      </div>
    </Section>

    <Section background="primary" space="lg">
      <figure class="quoteband">
        <span class="quoteband__mark"><Icon name="lucide:quote" size="lg" /></span>
        <blockquote>
          <Heading as="p" size="h3" color="on-dark" align="center">Bez papírů, bez Excelu a bez ručního sčítání! Plně digitální odbavení hotelových strávníků a přehled o stravování hostů v reálném čase. To je MealPlan.</Heading>
        </blockquote>
      </figure>
    </Section>

    <USPGrid eyebrow="Dále by vás mohlo zajímat" title="Související produkty"
             items={related} minItemWidth="260px" background="alt" space="lg" />

    <LeadForm id="poptavka" variant="full" background="default"
              title="Vyzkoušejte Protel zdarma"
              lead="Co byste u vás v hotelu rádi zlepšili? Nechte nám kontakt — ozveme se a ukážeme Protel přímo ve vašem hotelu." />
  </main>

  <SiteFooter />
</Base>

<style>
  .jump { display: flex; flex-wrap: wrap; gap: var(--space-2); justify-content: center; margin-bottom: var(--space-8); }
  .jump__chip {
    display: inline-flex; padding: var(--space-2) var(--space-4);
    border: 1px solid var(--color-border); border-radius: var(--radius-full);
    background: var(--color-bg-alt); color: var(--color-text);
    font-size: var(--font-size-small); font-weight: var(--font-weight-semibold);
    text-decoration: none; transition: border-color var(--duration-base) var(--easing);
  }
  .jump__chip:hover { border-color: var(--color-primary); color: var(--color-text-accent); }
  .features { max-width: 800px; margin-inline: auto; display: flex; flex-direction: column; gap: var(--space-9); }
  .feature { scroll-margin-top: var(--space-9); }
  .feature > :global(* + *) { margin-top: var(--space-3); }
  .feature__icon {
    display: inline-flex; align-items: center; justify-content: center;
    width: 56px; height: 56px; border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--color-primary) 10%, #fff); color: var(--color-primary);
  }
  .quoteband { margin: 0; max-width: 840px; margin-inline: auto; display: flex; flex-direction: column; align-items: center; gap: var(--space-4); text-align: center; }
  .quoteband__mark { color: var(--color-text-on-dark); opacity: 0.7; }
  .quoteband blockquote { margin: 0; }
</style>
