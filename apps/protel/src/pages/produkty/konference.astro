---
/**
 * Protel — produkt „Konference“. Obsah vytěžen z produkty/konference.html
 * starého protelsystems.cz (jazykově uhlazeno, fakta zachována).
 * Vše ze sdílených komponent @piano/ui.
 */
import Base from '../../layouts/Base.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import Section from '@piano/ui/components/Section.astro';
import Hero from '@piano/ui/components/Hero.astro';
import Heading from '@piano/ui/components/Heading.astro';
import Text from '@piano/ui/components/Text.astro';
import Button from '@piano/ui/components/Button.astro';
import Icon from '@piano/ui/components/Icon.astro';
import Breadcrumb from '@piano/ui/components/Breadcrumb.astro';
import USPGrid from '@piano/ui/components/USPGrid.astro';
import LeadForm from '@piano/ui/components/LeadForm.astro';

const features = [
  {
    id: "rezervace-mistnosti", icon: "lucide:calendar-days", title: "Rezervace místností",
    paras: [
      "Konferenční modul je automatickou součástí hotelového systému. Konferenční místnosti rezervujete přímo z přehledného plánu, který zobrazuje dostupnost jednotlivých prostor i jejich kombinací.",
      "Systém automaticky sleduje obsazenost a dostupnost místností, takže využití prostor snadno optimalizujete a konferenční rezervace řídíte efektivně.",
    ],
  },
  {
    id: "evidence-detailu-akce", icon: "lucide:clipboard-list", title: "Evidence detailů akce",
    paras: [
      "Všechny dohodnuté detaily akce — požadavky na stravování, technické vybavení nebo uspořádání prostor — evidujete na jednom místě. Smlouvu nebo function sheet pak vygenerujete jediným kliknutím, vždy s aktuálními údaji.",
    ],
  },
  {
    id: "navaznost-na-rezervace-ubytovani", icon: "lucide:bed-double", title: "Návaznost na rezervace ubytování",
    paras: [
      "Konference se úzce propojují s rezervacemi ubytování. Organizátoři banketů snadno synchronizují skupinové rezervace s ubytováním účastníků — celý pobyt včetně účasti na konferenci proběhne hladce a z jednoho systému.",
    ],
  },
];

const related = [
  { icon: "lucide:layout-dashboard", title: "Hotelový systém", text: "Správa pokojů, rezervací, hostů a statistik — snadné používání a pokročilé funkce pro kompletní přehled o provozu.", href: "/produkty/hotelovy-system-protel" },
  { icon: "lucide:soup", title: "MealPlan", text: "Digitální evidence snídaní, obědů a večeří bez papírů a Excelu.", href: "/produkty/meal-plan" },
  { icon: "lucide:mail", title: "Automatický mailing", text: "Personalizované e-maily hostům bez zásahu recepčního.", href: "/produkty/automaticky-mailing" },
  { icon: "lucide:network", title: "Hotelové řetězce", text: "Centrální správa více hotelů z jednoho místa.", href: "/produkty/hotelove-retezce" },
];
---

<Base title="Konference | Protel"
      description="Konferenční modul je automatickou součástí hotelového systému Protel: rezervace konferenčních místností, sledování dostupnosti a vybavení, správa stravování, fakturace za pronájem i správa účastníků.">
  <SiteHeader />

  <main>
    <Breadcrumb items={[{ label: 'Úvod', href: '/' }, { label: 'Produkty', href: '/produkty' }, { label: "Konference" }]} />

    <Hero eyebrow="Produkty" background="gradient"
          lead="Konferenční modul, který je automatickou součástí hotelového systému Protel, nabízí rezervace konferenčních místností, sledování dostupnosti a vybavení, správu stravování a občerstvení, fakturaci za pronájem, správu účastníků, generování reportů a další úkony spojené s pořádáním událostí ve vašem hotelu.">
      <Heading slot="title" as="h1" size="display" color="on-dark">Konference <em>bez starostí</em></Heading>
      <Fragment slot="actions">
        <Button href="#poptavka">Vyzkoušet Protel zdarma</Button>
        <Button href="/produkty" variant="secondary" onDark>Všechny produkty</Button>
      </Fragment>
    </Hero>

    <Section background="default" space="lg">
      <nav class="jump" aria-label="Funkce produktu">
        {features.map((f) => (
          <a class="jump__chip" href={`#${f.id}`}>{f.title}</a>
        ))}
      </nav>
      <div class="features">
        {features.map((f) => (
          <article class="feature" id={f.id}>
            <span class="feature__icon"><Icon name={f.icon} size="lg" /></span>
            <Heading as="h2" size="h3">{f.title}</Heading>
            {f.paras.map((p) => (
              <Text color="muted">{p}</Text>
            ))}
          </article>
        ))}
      </div>
    </Section>

    <Section background="primary" space="lg">
      <figure class="quoteband">
        <span class="quoteband__mark"><Icon name="lucide:quote" size="lg" /></span>
        <blockquote>
          <Heading as="p" size="h3" color="on-dark" align="center">Efektivní organizace a propojení konferenčních akcí s banketními rezervacemi a ubytováním zlepšuje servis hostům — a vašemu hotelu přináší ohromnou úsporu času a financí!</Heading>
        </blockquote>
      </figure>
    </Section>

    <USPGrid eyebrow="Dále by vás mohlo zajímat" title="Související produkty"
             items={related} minItemWidth="260px" background="alt" space="lg" />

    <LeadForm id="poptavka" variant="full" background="default"
              title="Vyzkoušejte Protel zdarma"
              lead="Co byste u vás v hotelu rádi zlepšili? Nechte nám kontakt — ozveme se a ukážeme Protel přímo ve vašem hotelu." />
  </main>

  <SiteFooter />
</Base>

<style>
  .jump { display: flex; flex-wrap: wrap; gap: var(--space-2); justify-content: center; margin-bottom: var(--space-8); }
  .jump__chip {
    display: inline-flex; padding: var(--space-2) var(--space-4);
    border: 1px solid var(--color-border); border-radius: var(--radius-full);
    background: var(--color-bg-alt); color: var(--color-text);
    font-size: var(--font-size-small); font-weight: var(--font-weight-semibold);
    text-decoration: none; transition: border-color var(--duration-base) var(--easing);
  }
  .jump__chip:hover { border-color: var(--color-primary); color: var(--color-text-accent); }
  .features { max-width: 800px; margin-inline: auto; display: flex; flex-direction: column; gap: var(--space-9); }
  .feature { scroll-margin-top: var(--space-9); }
  .feature > :global(* + *) { margin-top: var(--space-3); }
  .feature__icon {
    display: inline-flex; align-items: center; justify-content: center;
    width: 56px; height: 56px; border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--color-primary) 10%, #fff); color: var(--color-primary);
  }
  .quoteband { margin: 0; max-width: 840px; margin-inline: auto; display: flex; flex-direction: column; align-items: center; gap: var(--space-4); text-align: center; }
  .quoteband__mark { color: var(--color-text-on-dark); opacity: 0.7; }
  .quoteband blockquote { margin: 0; }
</style>
