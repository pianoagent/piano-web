---
/**
 * Protel — produkt „Webové rezervace“. Obsah vytěžen z produkty/webove-rezervace.html
 * starého protelsystems.cz (jazykově uhlazeno, fakta zachována).
 * Vše ze sdílených komponent @piano/ui.
 */
import Base from '../../layouts/Base.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import Section from '@piano/ui/components/Section.astro';
import Hero from '@piano/ui/components/Hero.astro';
import Heading from '@piano/ui/components/Heading.astro';
import Text from '@piano/ui/components/Text.astro';
import Button from '@piano/ui/components/Button.astro';
import Icon from '@piano/ui/components/Icon.astro';
import Breadcrumb from '@piano/ui/components/Breadcrumb.astro';
import USPGrid from '@piano/ui/components/USPGrid.astro';
import LeadForm from '@piano/ui/components/LeadForm.astro';

const features = [
  {
    id: "aktualizace-dostupnosti-pokoju", icon: "lucide:calendar-sync", title: "Aktualizace dostupnosti pokojů",
    paras: [
      "Hosté si přes formulář na vašem webu rezervují pobyt kdykoli a odkudkoli — jednoduše si vyberou termín a typ pokoje podle svých preferencí.",
      "Online aktualizace dostupnosti zabraňuje přebookování a zajišťuje správné plánování kapacity. Nepřijdete o příležitost prodat volné pokoje a maximalizujete příjmy.",
    ],
  },
  {
    id: "dynamicke-ceny", icon: "lucide:tags", title: "Dynamické ceny",
    paras: [
      "Cenovou politiku nastavíte jednou správně v PMS a ceny se v reálném čase automaticky synchronizují s webovým rezervačním formulářem. Prodejní ceny jsou tak vždy aktuální.",
      "Dynamický přístup umožňuje reagovat na změny na trhu, optimalizovat výnosy z ubytování a zůstat konkurenceschopní.",
    ],
  },
  {
    id: "garance", icon: "lucide:shield-check", title: "Garance",
    paras: [
      "Pro dokončení rezervace můžete vyžadovat platbu přes napojenou platební bránu, nebo zadání platebních údajů jako záruky. Údaje se do hotelového systému přenášejí v bezpečné formě chráněné proti zneužití.",
      "Rezervace je potvrzena a chráněna proti nečekaným zrušením — jistota pro vás i vaše hosty.",
    ],
  },
  {
    id: "evidence-rezervace", icon: "lucide:clipboard-list", title: "Evidence rezervace",
    paras: [
      "Veškeré rezervace i jejich změny se okamžitě zaznamenávají do hotelového systému Protel. Recepce má vždy aktuální přehled o dostupnosti pokojů a stavu rezervací — provoz je efektivnější.",
    ],
  },
  {
    id: "potvrzeni-rezervace", icon: "lucide:mail-check", title: "Potvrzení rezervace",
    paras: [
      "Po dokončení rezervace se hostovi automaticky odešle potvrzení s termínem pobytu, typem pokoje a dalšími podrobnostmi. Host má jistotu, že je vše zajištěno.",
      "Přes potvrzení host svou rezervaci také snadno spravuje — zkontroluje detaily, provede změny nebo rezervaci zruší.",
    ],
  },
  {
    id: "pobytove-balicky", icon: "lucide:gift", title: "Pobytové balíčky",
    paras: [
      "Hosté vybírají z balíčků kombinujících ubytování s doplňkovými službami a zážitky — wellness procedurami, kulturními aktivitami nebo romantickou večeří.",
      "Pro hotel jsou balíčky ve webových rezervacích efektivní cestou, jak zvýšit obsazenost, optimalizovat tržby a nabídnout hostům osobnější zážitek.",
    ],
  },
];

const related = [
  { icon: "lucide:layout-dashboard", title: "Hotelový systém", text: "Správa pokojů, rezervací, hostů a statistik — snadné používání a pokročilé funkce pro kompletní přehled o provozu.", href: "/produkty/hotelovy-system-protel" },
  { icon: "lucide:credit-card", title: "Platební řešení hotelu", text: "Plně integrované platby přímo v Protelu. Méně chyb a nižší riziko vracení transakcí.", href: "/produkty/platebni-reseni-hotelu" },
  { icon: "lucide:mail", title: "Automatický mailing", text: "Personalizované e-maily hostům bez zásahu recepčního.", href: "/produkty/automaticky-mailing" },
  { icon: "lucide:smartphone", title: "Online check-in/out", text: "Host vyřídí check-in i check-out přes mobil, bez fronty na recepci.", href: "/produkty/online-check-in-out" },
];
---

<Base title="Webové rezervace | Protel"
      description="Online rezervační formulář na vašich stránkách umožní hostům kdykoli si rezervovat pobyt přímo u vás — s aktuální dostupností, dynamickými cenami a garancí platby.">
  <SiteHeader />

  <main>
    <Breadcrumb items={[{ label: 'Úvod', href: '/' }, { label: 'Produkty', href: '/produkty' }, { label: "Webové rezervace" }]} />

    <Hero eyebrow="Produkty" background="gradient"
          lead="Online webový formulář na vašich stránkách umožní hostům, aby si u vás kdykoli rezervovali svůj pobyt — s aktuální dostupností pokojů a cenami přímo z hotelového systému.">
      <Heading slot="title" as="h1" size="display" color="on-dark">Webové <em>rezervace</em></Heading>
      <Fragment slot="actions">
        <Button href="#poptavka">Vyzkoušet Protel zdarma</Button>
        <Button href="/produkty" variant="secondary" onDark>Všechny produkty</Button>
      </Fragment>
    </Hero>

    <Section background="default" space="lg">
      <nav class="jump" aria-label="Funkce produktu">
        {features.map((f) => (
          <a class="jump__chip" href={`#${f.id}`}>{f.title}</a>
        ))}
      </nav>
      <div class="features">
        {features.map((f) => (
          <article class="feature" id={f.id}>
            <span class="feature__icon"><Icon name={f.icon} size="lg" /></span>
            <Heading as="h2" size="h3">{f.title}</Heading>
            {f.paras.map((p) => (
              <Text color="muted">{p}</Text>
            ))}
          </article>
        ))}
      </div>
    </Section>

    <Section background="primary" space="lg">
      <figure class="quoteband">
        <span class="quoteband__mark"><Icon name="lucide:quote" size="lg" /></span>
        <blockquote>
          <Heading as="p" size="h3" color="on-dark" align="center">Webová rezervace je klíčovou součástí každého moderního hotelového provozu. Protel je garancí dokončení úspěšné rezervace a bezpečnou ochranou pro váš hotel i hosta.</Heading>
        </blockquote>
      </figure>
    </Section>

    <USPGrid eyebrow="Dále by vás mohlo zajímat" title="Související produkty"
             items={related} minItemWidth="260px" background="alt" space="lg" />

    <LeadForm id="poptavka" variant="full" background="default"
              title="Vyzkoušejte Protel zdarma"
              lead="Co byste u vás v hotelu rádi zlepšili? Nechte nám kontakt — ozveme se a ukážeme Protel přímo ve vašem hotelu." />
  </main>

  <SiteFooter />
</Base>

<style>
  .jump { display: flex; flex-wrap: wrap; gap: var(--space-2); justify-content: center; margin-bottom: var(--space-8); }
  .jump__chip {
    display: inline-flex; padding: var(--space-2) var(--space-4);
    border: 1px solid var(--color-border); border-radius: var(--radius-full);
    background: var(--color-bg-alt); color: var(--color-text);
    font-size: var(--font-size-small); font-weight: var(--font-weight-semibold);
    text-decoration: none; transition: border-color var(--duration-base) var(--easing);
  }
  .jump__chip:hover { border-color: var(--color-primary); color: var(--color-text-accent); }
  .features { max-width: 800px; margin-inline: auto; display: flex; flex-direction: column; gap: var(--space-9); }
  .feature { scroll-margin-top: var(--space-9); }
  .feature > :global(* + *) { margin-top: var(--space-3); }
  .feature__icon {
    display: inline-flex; align-items: center; justify-content: center;
    width: 56px; height: 56px; border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--color-primary) 10%, #fff); color: var(--color-primary);
  }
  .quoteband { margin: 0; max-width: 840px; margin-inline: auto; display: flex; flex-direction: column; align-items: center; gap: var(--space-4); text-align: center; }
  .quoteband__mark { color: var(--color-text-on-dark); opacity: 0.7; }
  .quoteband blockquote { margin: 0; }
</style>
