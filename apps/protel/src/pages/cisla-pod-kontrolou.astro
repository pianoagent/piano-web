---
/**
 * Protel — landing „Čísla pod kontrolou“. Obsah vytěžen z cisla-pod-kontrolou.html starého
 * protelsystems.cz (jazykově uhlazeno). Vše ze sdílených komponent @piano/ui.
 */
import Base from '../layouts/Base.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import Section from '@piano/ui/components/Section.astro';
import Hero from '@piano/ui/components/Hero.astro';
import Heading from '@piano/ui/components/Heading.astro';
import Text from '@piano/ui/components/Text.astro';
import Button from '@piano/ui/components/Button.astro';
import Icon from '@piano/ui/components/Icon.astro';
import Breadcrumb from '@piano/ui/components/Breadcrumb.astro';
import USPGrid from '@piano/ui/components/USPGrid.astro';
import LeadForm from '@piano/ui/components/LeadForm.astro';

const related = [
  { icon: "lucide:layout-dashboard", title: "Hotelový systém Protel", text: "Data o provozu na jednom místě.", href: "/produkty/hotelovy-system-protel" },
  { icon: "lucide:tags", title: "Cenotvorba", text: "Flexibilní ceny plně pod kontrolou.", href: "/produkty/hotelovy-system-protel#cenotvorba" },
  { icon: "lucide:receipt", title: "Fakturace", text: "Automatické účtování s historií změn.", href: "/produkty/hotelovy-system-protel#fakturace" },
  { icon: "lucide:line-chart", title: "Reporting", text: "Dashboardy a sestavy podle vaší segmentace.", href: "/produkty/hotelovy-system-protel#reporting" },
];
---

<Base title="Čísla pod kontrolou | Protel"
      description="Kdy máte nejlepší obsazenost? Kdo jsou vaši hosté? Co nejvíce vydělává? Protel hlídá obsazenost, výnosy i segmentaci hostů — přehledně a bez práce navíc.">
  <SiteHeader />

  <main>
    <Breadcrumb items={[{ label: 'Úvod', href: '/' }, { label: 'Řešení', href: '/#reseni' }, { label: "Čísla pod kontrolou" }]} />

    <Hero eyebrow="Řešení" background="gradient"
          lead="Kdy mám nejlepší obsazenost? Kdo jsou moji hosté? Co mi nejvíce vydělává? Plním rozpočet podle očekávání? A jak jsem na tom do budoucna? Máte vůbec ve svém nabitém pracovním tempu čas na zodpovězení všech těchto otázek?">
      <Heading slot="title" as="h1" size="display" color="on-dark">Čísla <em>pod kontrolou</em></Heading>
      <Fragment slot="actions">
        <Button href="#poptavka">Vyzkoušet Protel zdarma</Button>
        <Button href="/produkty" variant="secondary" onDark>Prohlédnout produkty</Button>
      </Fragment>
    </Hero>

    <Section background="default" space="lg">
      <div class="solution">
        <Text size="label" color="accent">Protel má řešení</Text>
        <Heading as="h2" size="h2">Protel vám pomůže vyznat se ve složitých číslech</Heading>
        <Text size="lead" color="muted">Už jen tím, že vznikne rezervace, se v hotelovém systému ukládá mnoho cenných dat. Ta nejzásadnější se týkají obsazenosti, sledování výnosů ve správných kategoriích a segmentace hostů. V PMS Protel si sami nastavíte segmenty tak, aby byly u každé rezervace vždy správně alokovány. Zvolíte si i vlastní kategorie produktů, které pro lepší reporting zařadíte do správných skupin. Pak už stačí nastavit rozpočet a cenovou politiku — a hotel vám funguje skoro sám.</Text>
      </div>
    </Section>

    <Section background="primary" space="lg">
      <figure class="quoteband">
        <span class="quoteband__mark"><Icon name="lucide:quote" size="lg" /></span>
        <blockquote>
          <Heading as="p" size="h3" color="on-dark" align="center">Cenná data o obsazenosti, výnosech a segmentaci hostů umožňují snadné nastavení rozpočtu a cenové politiky pro efektivní vedení hotelu.</Heading>
        </blockquote>
      </figure>
    </Section>

    <USPGrid eyebrow="Související" title="Související s čísly pod kontrolou"
             items={related} minItemWidth="260px" background="alt" space="lg" />

    <LeadForm id="poptavka" variant="full" background="default"
              title="Vyzkoušejte Protel zdarma"
              lead="Co byste u vás v hotelu rádi zlepšili? Nechte nám kontakt — ozveme se a ukážeme Protel přímo ve vašem hotelu." />
  </main>

  <SiteFooter />
</Base>

<style>
  .solution { max-width: 800px; margin-inline: auto; }
  .solution > :global(* + *) { margin-top: var(--space-4); }
  .quoteband { margin: 0; max-width: 840px; margin-inline: auto; display: flex; flex-direction: column; align-items: center; gap: var(--space-4); text-align: center; }
  .quoteband__mark { color: var(--color-text-on-dark); opacity: 0.7; }
  .quoteband blockquote { margin: 0; }
</style>
