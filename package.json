{
  "name": "piano-web",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:piano": "npm run dev -w @piano/app-piano",
    "build:piano": "npm run build -w @piano/app-piano",
    "preview:piano": "npm run preview -w @piano/app-piano",
    "dev:septim": "npm run dev -w @piano/app-septim",
    "build:septim": "npm run build -w @piano/app-septim",
    "preview:septim": "npm run preview -w @piano/app-septim",
    "dev:grason": "npm run dev -w @piano/app-grason",
    "build:grason": "npm run build -w @piano/app-grason",
    "preview:grason": "npm run preview -w @piano/app-grason",
    "dev:savarin": "npm run dev -w @piano/app-savarin",
    "build:savarin": "npm run build -w @piano/app-savarin",
    "preview:savarin": "npm run preview -w @piano/app-savarin",
    "dev:harsys": "npm run dev -w @piano/app-harsys",
    "build:harsys": "npm run build -w @piano/app-harsys",
    "preview:harsys": "npm run preview -w @piano/app-harsys"
  }
}
