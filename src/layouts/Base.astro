---
import '../styles/tokens.css';

interface Props {
  title: string;
  description?: string;
  image?: string;          // OG image URL (absolutní)
  type?: 'website' | 'article';
  noindex?: boolean;
  schema?: object;         // JSON-LD per stránka (přidá se ke globálnímu Organization)
}

const {
  title,
  description = 'Piano — technologie pro restaurace a hotely. Pokladní systémy, rezervace, online platby a analytika na jednom místě.',
  image = 'https://piano.cz/og-default.jpg',
  type = 'website',
  noindex = false,
  schema,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, 'https://piano.cz').href;
const fullTitle = title.includes('Piano') ? title : `${title} | Piano`;

// Schema.org — Organization (globální, na každé stránce)
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Piano Solutions',
  url: 'https://piano.cz',
  logo: 'https://piano.cz/logo.svg',
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'sales',
    areaServed: 'CZ',
    availableLanguage: ['Czech', 'English'],
  },
  sameAs: [
    'https://www.linkedin.com/company/piano-solutions',
  ],
};

const schemas = [organizationSchema, ...(schema ? [schema] : [])];
---

<!doctype html>
<html lang="cs">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- SEO base -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={image} />
    <meta property="og:site_name" content="Piano" />
    <meta property="og:locale" content="cs_CZ" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Schema.org JSON-LD -->
    {schemas.map(s => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}

    <!-- Favicon (doplnit) -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font: var(--text-body);
    font-family: var(--font-sans);
    color: var(--color-text);
    background: var(--color-bg);
  }
</style>
