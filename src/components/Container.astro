---
/**
 * Container — Piano layout primitiv (omezení šířky obsahu)
 *
 *   size: "default" (1200) | "narrow" (760) | "wide" (1360) | "full"
 *   as:   HTML tag (default "div")
 *
 * Centruje obsah a drží jednotné horizontální odsazení (--container-pad).
 * Šířky se řídí tokeny v tokens.css — Header, Footer i sekce sdílí stejnou hodnotu.
 */
interface Props {
  size?: 'default' | 'narrow' | 'wide' | 'full';
  as?: string;
  class?: string;
  [key: string]: any;
}

const { size = 'default', as = 'div', class: className, ...rest } = Astro.props;
const Tag = as;
const classes = ['container', `container--${size}`, className].filter(Boolean).join(' ');
---

<Tag class={classes} {...rest}><slot /></Tag>

<style>
  .container {
    width: 100%;
    margin-inline: auto;
    padding-inline: var(--container-pad);
  }
  .container--default { max-width: var(--container-max); }
  .container--narrow  { max-width: var(--container-max-narrow); }
  .container--wide    { max-width: var(--container-max-wide); }
  .container--full    { max-width: none; }
</style>
