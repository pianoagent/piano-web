---
/**
 * Card — Piano primitiv (kontejner)
 *
 *   variant: "default" | "elevated" | "bordered" | "filled"   (default "default")
 *   padding: "none" | "sm" | "md" | "lg"                       (default "md")
 *   chamfer: boolean → signature seříznutý levý horní roh      (default false)
 *   href:    string  → renderuje jako <a> (klikací karta s hoverem)
 *   as:      "div" | "article" | "li"                          (default "div")
 *
 * Sloty: výchozí (tělo) + volitelný "media" (obrázek/grafika nahoře, bez paddingu).
 */
type Tag = 'div' | 'article' | 'li';

interface Props {
  variant?: 'default' | 'elevated' | 'bordered' | 'filled';
  padding?: 'none' | 'sm' | 'md' | 'lg';
  chamfer?: boolean;
  href?: string;
  as?: Tag;
  class?: string;
  [key: string]: any;
}

const {
  variant = 'default',
  padding = 'md',
  chamfer = false,
  href,
  as = 'div',
  class: className,
  ...rest
} = Astro.props;

const Tag = href ? 'a' : as;
const hasMedia = Astro.slots.has('media');

const classes = [
  'card',
  `card--${variant}`,
  `card--pad-${padding}`,
  chamfer && 'card--chamfer',
  href && 'card--link',
  hasMedia && 'card--has-media',
  className,
]
  .filter(Boolean)
  .join(' ');
---

<Tag class={classes} href={href} {...rest}>
  {hasMedia && (
    <div class="card__media"><slot name="media" /></div>
  )}
  <div class="card__body"><slot /></div>
</Tag>

<style>
  .card {
    display: block;
    position: relative;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: inherit;
    text-decoration: none;
    overflow: hidden;
  }

  /* Varianty */
  .card--elevated { border-color: transparent; box-shadow: var(--shadow-md); }
  .card--bordered { border-color: var(--color-border-strong); }
  .card--filled   { background: var(--color-bg-alt); border-color: transparent; }

  /* Signature chamfer */
  .card--chamfer {
    border-radius: 0;
    clip-path: var(--chamfer-clip);
  }

  /* Media (obrázek nahoře — bez paddingu) */
  .card__media { display: block; }
  .card__media :global(img) { display: block; width: 100%; height: auto; }

  /* Padding (na tělo; media zůstává na hraně) */
  .card--pad-none .card__body { padding: 0; }
  .card--pad-sm   .card__body { padding: var(--space-4); }
  .card--pad-md   .card__body { padding: var(--space-5); }
  .card--pad-lg   .card__body { padding: var(--space-7); }

  /* Klikací karta */
  .card--link { transition: var(--transition); cursor: pointer; }
  .card--link:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }
  .card--link:focus-visible {
    outline: none;
    box-shadow: var(--shadow-focus);
  }
</style>
