---
/**
 * Footer — Piano (tmavý, vícesloupcový)
 *
 * Data z src/config/nav.ts (produkty, firma, kontakt, sociální sítě, právní odkazy).
 * Logo je prozatím textový wordmark — výměna za reálné SVG na jednom místě.
 */
import Icon from './Icon.astro';
import { products, companyNav, legalNav, socialLinks, contact } from '../config/nav';

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__inner">
    <div class="footer__top">
      <!-- Brand -->
      <div class="footer__brand">
        <a href="/" class="footer__logo" aria-label="Piano — domů">
          <Icon name="piano-mark" size="md" />
          <span class="footer__wordmark">Piano</span>
        </a>
        <p class="footer__tagline">
          Technologie pro restaurace a hotely — pokladny, rezervace, platby a analytika na jednom místě.
        </p>
        <ul class="footer__social" aria-label="Sociální sítě">
          {socialLinks.map((s) => (
            <li>
              <a href={s.href} class="footer__social-link" aria-label={s.label} target="_blank" rel="noopener">
                <Icon name={s.icon} size="sm" />
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Produkty -->
      <nav class="footer__col" aria-label="Produkty">
        <h2 class="footer__heading">Produkty</h2>
        <ul class="footer__list">
          {products.map((p) => (
            <li><a href={p.href} class="footer__link">{p.label}</a></li>
          ))}
        </ul>
      </nav>

      <!-- Společnost -->
      <nav class="footer__col" aria-label="Společnost">
        <h2 class="footer__heading">Společnost</h2>
        <ul class="footer__list">
          {companyNav.map((c) => (
            <li><a href={c.href} class="footer__link">{c.label}</a></li>
          ))}
        </ul>
      </nav>

      <!-- Kontakt -->
      <div class="footer__col">
        <h2 class="footer__heading">Kontakt</h2>
        <ul class="footer__list">
          <li><a href={`mailto:${contact.email}`} class="footer__link">{contact.email}</a></li>
          <li><a href={`tel:${contact.phone.replace(/\s/g, '')}`} class="footer__link">{contact.phone}</a></li>
          <li><span class="footer__muted">{contact.address}</span></li>
        </ul>
      </div>
    </div>

    <!-- Spodní lišta -->
    <div class="footer__bottom">
      <p class="footer__copy">© {year} Piano Solutions s.r.o.</p>
      <ul class="footer__legal">
        {legalNav.map((l) => (
          <li><a href={l.href} class="footer__link footer__link--small">{l.label}</a></li>
        ))}
      </ul>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-neutral-900);
    color: var(--color-text-on-dark);
  }
  .footer__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--space-8) var(--space-5) var(--space-5);
  }

  .footer__top {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1.2fr;
    gap: var(--space-7);
    padding-bottom: var(--space-7);
    border-bottom: 1px solid var(--color-border-on-dark);
  }

  /* Brand */
  .footer__logo {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-text-on-dark);
    text-decoration: none;
  }
  .footer__wordmark {
    font-family: var(--font-sans);
    font-weight: var(--font-weight-semibold);
    font-size: 22px;
    letter-spacing: var(--letter-spacing-tight);
  }
  .footer__tagline {
    margin-top: var(--space-3);
    max-width: 320px;
    font-size: var(--font-size-small);
    line-height: var(--line-height-body);
    color: var(--color-text-on-dark-muted);
  }
  .footer__social {
    display: flex;
    gap: var(--space-2);
    list-style: none;
    margin-top: var(--space-5);
  }
  .footer__social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    color: var(--color-text-on-dark);
    border: 1px solid var(--color-border-on-dark);
    border-radius: var(--radius-sm);
    transition: var(--transition);
  }
  .footer__social-link:hover {
    background: var(--color-primary);
    border-color: var(--color-primary);
  }

  /* Sloupce */
  .footer__heading {
    font-family: var(--font-sans);
    font-size: var(--font-size-label);
    font-weight: var(--font-weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wide);
    color: var(--color-text-on-dark-muted);
    margin-bottom: var(--space-4);
  }
  .footer__list { list-style: none; display: flex; flex-direction: column; gap: var(--space-3); }
  .footer__link {
    color: var(--color-text-on-dark);
    text-decoration: none;
    font-size: var(--font-size-body);
    transition: var(--transition);
  }
  .footer__link:hover { color: var(--color-secondary-gold); }
  .footer__link--small { font-size: var(--font-size-small); }
  .footer__muted { color: var(--color-text-on-dark-muted); font-size: var(--font-size-body); }

  /* Spodní lišta */
  .footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding-top: var(--space-5);
    flex-wrap: wrap;
  }
  .footer__copy { font-size: var(--font-size-small); color: var(--color-text-on-dark-muted); }
  .footer__legal { display: flex; gap: var(--space-5); list-style: none; flex-wrap: wrap; }

  /* Responsive */
  @media (max-width: 880px) {
    .footer__top { grid-template-columns: 1fr 1fr; gap: var(--space-6); }
    .footer__brand { grid-column: 1 / -1; }
  }
  @media (max-width: 520px) {
    .footer__top { grid-template-columns: 1fr; }
    .footer__bottom { flex-direction: column; align-items: flex-start; }
  }
</style>
