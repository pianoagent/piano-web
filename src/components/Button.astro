---
/**
 * Button — Piano primitivní komponenta
 *
 * Varianty:
 *   variant: "primary" | "secondary" | "ghost"
 *   size:    "sm" | "md" | "lg"
 *   href:    string  → renderuje jako <a>, jinak <button>
 *   full:    boolean → 100% šířka
 */

interface Props {
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  full?: boolean;
  type?: 'button' | 'submit' | 'reset';
  class?: string;
  [key: string]: any;
}

const {
  variant = 'primary',
  size = 'md',
  href,
  full = false,
  type = 'button',
  class: className,
  ...rest
} = Astro.props;

const tag = href ? 'a' : 'button';
const classes = ['btn', `btn--${variant}`, `btn--${size}`, full && 'btn--full', className]
  .filter(Boolean)
  .join(' ');
---

{tag === 'a' ? (
  <a href={href} class={classes} {...rest}>
    <slot />
  </a>
) : (
  <button type={type} class={classes} {...rest}>
    <slot />
  </button>
)}

<style>
  .btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    font: var(--text-label);
    font-family: var(--font-sans);
    letter-spacing: var(--letter-spacing-wide);
    text-transform: uppercase;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: var(--transition);
    white-space: nowrap;
    clip-path: var(--chamfer-clip-sm);
  }

  /* Vnitřní výplň jako samostatná vrstva (inset 1px) → vznikne 1px rámeček
     vč. obtažené diagonální hrany zkosení. Barva .btn = rámeček, ::before = výplň. */
  .btn::before {
    content: "";
    position: absolute;
    inset: 1px;
    clip-path: var(--chamfer-clip-sm);
    background: transparent;
    transition: var(--transition);
    pointer-events: none;
  }
  /* Obsah (text/ikona) nad vrstvou výplně */
  .btn > :global(*),
  .btn { z-index: 0; }

  .btn:focus-visible {
    outline: none;
    box-shadow: var(--shadow-focus);
  }

  /* Sizes */
  .btn--sm {
    padding: var(--space-2) var(--space-4);
    font-size: 12px;
  }

  .btn--md {
    padding: var(--space-3) var(--space-5);
  }

  .btn--lg {
    padding: var(--space-4) var(--space-7);
    font-size: 14px;
  }

  /* Full width */
  .btn--full {
    width: 100%;
  }

  /* Primary — karmínová CTA (plná výplň) */
  .btn--primary { background: var(--color-primary); color: var(--color-text-on-dark); }
  .btn--primary::before { background: var(--color-primary); }
  .btn--primary:hover { background: var(--color-primary-hover); }
  .btn--primary:hover::before { background: var(--color-primary-hover); }
  .btn--primary:active { background: var(--color-primary-active); }
  .btn--primary:active::before { background: var(--color-primary-active); }

  /* Secondary — outlined (rámeček = .btn, výplň = ::before) */
  .btn--secondary { background: var(--color-border-strong); color: var(--color-text); }
  .btn--secondary::before { background: var(--color-bg); }
  .btn--secondary:hover { background: var(--color-neutral-900); color: var(--color-neutral-900); }
  .btn--secondary:active::before { background: var(--color-neutral-50); }

  /* Ghost — jen text, bez zkosení */
  .btn--ghost {
    background: transparent;
    color: var(--color-text-accent);
    clip-path: none;
    padding-left: 0;
    padding-right: 0;
  }
  .btn--ghost::before { display: none; }
  .btn--ghost:hover { color: var(--color-primary-hover); }
</style>
