---
import Base from '../layouts/Base.astro';
import Button from '../components/Button.astro';
---

<Base title="Piano — komponenty">
  <main style="padding: 48px; display: flex; flex-direction: column; gap: 48px; max-width: 800px;">

    <section>
      <h2 style="font: var(--text-h3); font-family: var(--font-sans); margin-bottom: 24px; color: var(--color-text-muted);">Button</h2>

      <div style="display: flex; flex-wrap: wrap; gap: 16px; align-items: center; margin-bottom: 16px;">
        <Button variant="primary" size="sm">Primární SM</Button>
        <Button variant="primary" size="md">Primární MD</Button>
        <Button variant="primary" size="lg">Primární LG</Button>
      </div>

      <div style="display: flex; flex-wrap: wrap; gap: 16px; align-items: center; margin-bottom: 16px;">
        <Button variant="secondary" size="sm">Sekundární SM</Button>
        <Button variant="secondary" size="md">Sekundární MD</Button>
        <Button variant="secondary" size="lg">Sekundární LG</Button>
      </div>

      <div style="display: flex; flex-wrap: wrap; gap: 16px; align-items: center;">
        <Button variant="ghost" size="sm">Ghost →</Button>
        <Button variant="ghost" size="md">Ghost →</Button>
        <Button href="/o-nas" variant="primary">Odkaz jako button</Button>
      </div>
    </section>

    <section style="background: var(--color-bg-invert); padding: 32px;">
      <div style="display: flex; flex-wrap: wrap; gap: 16px; align-items: center;">
        <Button variant="primary">CTA na tmavém pozadí</Button>
        <Button variant="secondary" style="border-color: var(--color-border-on-dark); color: var(--color-text-on-dark);">Outline on dark</Button>
      </div>
    </section>

  </main>
</Base>
