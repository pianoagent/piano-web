---
import Base from '../layouts/Base.astro';
import Button from '../components/Button.astro';
import Heading from '../components/Heading.astro';
import Text from '../components/Text.astro';
import Icon from '../components/Icon.astro';
import Badge from '../components/Badge.astro';
import Card from '../components/Card.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Base title="Piano — komponenty">
  <Header />

  <main style="padding: 48px 24px; display: flex; flex-direction: column; gap: 48px; max-width: 1200px; margin: 0 auto;">

    <section>
      <h2 style="font: var(--text-h3); font-family: var(--font-sans); margin-bottom: 24px; color: var(--color-text-muted);">Heading</h2>

      <div style="display: flex; flex-direction: column; gap: 16px; margin-bottom: 24px;">
        <Heading as="h1" size="display">Display nadpis</Heading>
        <Heading as="h1">Nadpis úrovně H1</Heading>
        <Heading as="h2">Nadpis úrovně H2</Heading>
        <Heading as="h3">Nadpis úrovně H3</Heading>
      </div>

      <div style="margin-bottom: 24px;">
        <Heading as="h2" size="h1">Pomocná síla, se kterou <em>otočíte</em> více stolů</Heading>
        <Text size="caption" color="muted" style="margin-top: 8px;">↑ akcent jedním slovem přes &lt;em&gt; (PP Eiko)</Text>
      </div>

      <div style="display: flex; flex-direction: column; gap: 8px;">
        <Heading as="h3" color="accent">Akcentní barva</Heading>
        <Heading as="h3" color="muted">Tlumená barva</Heading>
        <Heading as="h3" align="center">Zarovnání na střed</Heading>
      </div>
    </section>

    <section>
      <h2 style="font: var(--text-h3); font-family: var(--font-sans); margin-bottom: 24px; color: var(--color-text-muted);">Text</h2>

      <div style="display: flex; flex-direction: column; gap: 16px;">
        <Text size="lead">Lead — perex sekce, větší řádek pro úvodní odstavec pod nadpisem.</Text>
        <Text size="body">Body — výchozí text odstavce. Lorem ipsum dolor sit amet, <strong>zvýraznění</strong> a <a href="#">odkaz</a> v textu.</Text>
        <Text size="small" color="muted">Small — drobnější doplňkový text, často tlumený.</Text>
        <Text size="caption">Caption — popisek pod obrázkem nebo metadaty.</Text>
        <Text size="label">Label — verzálkový štítek</Text>
      </div>
    </section>

    <section>
      <h2 style="font: var(--text-h3); font-family: var(--font-sans); margin-bottom: 24px; color: var(--color-text-muted);">Button</h2>

      <div style="display: flex; flex-wrap: wrap; gap: 16px; align-items: center; margin-bottom: 16px;">
        <Button variant="primary" size="sm">Primární SM</Button>
        <Button variant="primary" size="md">Primární MD</Button>
        <Button variant="primary" size="lg">Primární LG</Button>
      </div>

      <div style="display: flex; flex-wrap: wrap; gap: 16px; align-items: center; margin-bottom: 16px;">
        <Button variant="secondary" size="sm">Sekundární SM</Button>
        <Button variant="secondary" size="md">Sekundární MD</Button>
        <Button variant="secondary" size="lg">Sekundární LG</Button>
      </div>

      <div style="display: flex; flex-wrap: wrap; gap: 16px; align-items: center; margin-bottom: 16px;">
        <Button variant="ghost" size="sm">Ghost →</Button>
        <Button variant="ghost" size="md">Ghost →</Button>
        <Button href="/o-nas" variant="primary">Odkaz jako button</Button>
      </div>

      <!-- CTA pár — obě tlačítka musí mít shodné zkosení -->
      <div style="display: flex; flex-wrap: wrap; gap: 16px; align-items: center;">
        <Button variant="primary">Domluvit demo</Button>
        <Button variant="secondary">Více informací</Button>
      </div>
    </section>

    <section>
      <h2 style="font: var(--text-h3); font-family: var(--font-sans); margin-bottom: 24px; color: var(--color-text-muted);">Icon</h2>

      <div style="display: flex; flex-wrap: wrap; gap: 24px; align-items: center; margin-bottom: 16px;">
        <Icon name="piano-mark" size="xs" />
        <Icon name="piano-mark" size="sm" />
        <Icon name="piano-mark" size="md" />
        <Icon name="piano-mark" size="lg" />
        <Icon name="piano-mark" size="xl" color="accent" />
      </div>

      <div style="display: flex; flex-wrap: wrap; gap: 24px; align-items: center;">
        <Icon name="lucide:check" color="accent" />
        <Icon name="lucide:credit-card" color="default" />
        <Icon name="lucide:calendar-check" color="muted" />
        <Icon name="lucide:bar-chart-3" color="accent" />
        <Icon name="lucide:arrow-right" />
      </div>
    </section>

    <section>
      <h2 style="font: var(--text-h3); font-family: var(--font-sans); margin-bottom: 24px; color: var(--color-text-muted);">Badge</h2>

      <div style="display: flex; flex-wrap: wrap; gap: 12px; align-items: center; margin-bottom: 16px;">
        <Badge variant="neutral">Neutral</Badge>
        <Badge variant="primary">Primary</Badge>
        <Badge variant="success">Success</Badge>
        <Badge variant="warning">Warning</Badge>
        <Badge variant="info">Info</Badge>
      </div>

      <div style="display: flex; flex-wrap: wrap; gap: 12px; align-items: center; margin-bottom: 16px;">
        <Badge variant="neutral" tone="solid">Neutral</Badge>
        <Badge variant="primary" tone="solid">Primary</Badge>
        <Badge variant="success" tone="solid">Success</Badge>
        <Badge variant="warning" tone="solid">Warning</Badge>
        <Badge variant="info" tone="solid">Info</Badge>
      </div>

      <div style="display: flex; flex-wrap: wrap; gap: 12px; align-items: center;">
        <Badge variant="success" icon="lucide:check">Aktivní</Badge>
        <Badge variant="primary" icon="lucide:sparkles">Novinka</Badge>
        <Badge variant="neutral" size="sm">SM</Badge>
      </div>
    </section>

    <section>
      <h2 style="font: var(--text-h3); font-family: var(--font-sans); margin-bottom: 24px; color: var(--color-text-muted);">Card</h2>

      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 24px;">
        <Card variant="default">
          <Badge variant="primary" style="margin-bottom: 12px;">Default</Badge>
          <Heading as="h3">Základní karta</Heading>
          <Text size="small" color="muted" style="margin-top: 8px;">Jemný rámeček, výchozí varianta.</Text>
        </Card>

        <Card variant="elevated">
          <Badge variant="info" style="margin-bottom: 12px;">Elevated</Badge>
          <Heading as="h3">Se stínem</Heading>
          <Text size="small" color="muted" style="margin-top: 8px;">Zdvižená karta se stínem.</Text>
        </Card>

        <Card variant="filled" chamfer>
          <Badge variant="success" style="margin-bottom: 12px;">Filled + chamfer</Badge>
          <Heading as="h3">Signature roh</Heading>
          <Text size="small" color="muted" style="margin-top: 8px;">Tónované pozadí se seříznutým rohem.</Text>
        </Card>

        <Card href="#" variant="bordered">
          <Heading as="h3">Klikací karta</Heading>
          <Text size="small" color="muted" style="margin-top: 8px;">Hover zdvih + odkaz.</Text>
          <Text size="label" color="accent" style="margin-top: 16px; display: inline-flex; align-items: center; gap: 6px;">Více <Icon name="lucide:arrow-right" size="xs" /></Text>
        </Card>
      </div>
    </section>

    <section style="background: var(--color-bg-invert); padding: 32px; display: flex; flex-direction: column; gap: 24px;">
      <div>
        <Heading as="h2" color="on-dark">Nadpis na tmavém pozadí</Heading>
        <Text size="lead" color="on-dark-muted" style="margin-top: 8px;">Perex v tlumené světlé barvě pro tmavé sekce.</Text>
      </div>
      <div style="display: flex; flex-wrap: wrap; gap: 16px; align-items: center;">
        <Button variant="primary">CTA na tmavém pozadí</Button>
        <Button variant="ghost" style="color: var(--color-text-on-dark);">Ghost na tmavém →</Button>
      </div>
    </section>

  </main>

  <Footer />
</Base>
